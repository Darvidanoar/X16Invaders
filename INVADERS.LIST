00159F  1                  ; --- sprite 44 (Type A, crab/green): attr $1FC00+44*8=$1FD60 ---
00159F  1                  ; addr[12:5] = VRAM_INV_A_F0>>5 = $00100>>5 = $08
00159F  1  A9 11           lda #$11
0015A1  1  8D 22 9F        sta VERA_addr_bank
0015A4  1  A9 FD           lda #$FD               ; high byte of $1FD60
0015A6  1  8D 21 9F        sta VERA_addr_high
0015A9  1  A9 60           lda #$60               ; low byte of $1FD60
0015AB  1  8D 20 9F        sta VERA_addr_low
0015AE  1  A9 08           lda #$08               ; byte 0: addr[12:5]
0015B0  1  8D 23 9F        sta VERA_data0
0015B3  1  A9 00           lda #$00
0015B5  1  8D 23 9F        sta VERA_data0
0015B8  1  A9 60           lda #96                ; X
0015BA  1  8D 23 9F        sta VERA_data0
0015BD  1  A9 00           lda #0
0015BF  1  8D 23 9F        sta VERA_data0
0015C2  1  A9 D0           lda #208               ; Y (row 13: 13*16=208)
0015C4  1  8D 23 9F        sta VERA_data0
0015C7  1  A9 00           lda #0
0015C9  1  8D 23 9F        sta VERA_data0
0015CC  1  A9 0C           lda #SPR_Z_FRONT
