001C4B  1  11 11 11 10  
001C4F  1                  ; row 9
001C4F  1  11 11 11 11     .byte $11,$11,$11,$11,$11,$11,$11,$11
001C53  1  11 11 11 11  
001C57  1                  ; row 10
001C57  1  11 11 11 11     .byte $11,$11,$11,$11,$11,$11,$11,$11
001C5B  1  11 11 11 11  
001C5F  1                  ; row 11
001C5F  1  11 11 11 11     .byte $11,$11,$11,$11,$11,$11,$11,$11
001C63  1  11 11 11 11  
001C67  1                  ; row 12  (engine notches: cols 2-3 and 12-13 transparent)
001C67  1  11 00 11 11     .byte $11,$00,$11,$11,$11,$11,$00,$11
001C6B  1  11 11 00 11  
