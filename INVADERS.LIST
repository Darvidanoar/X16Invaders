001576  1  A9 A0           lda #160               ; Y (row 10: 10*16=160)
001578  1  8D 23 9F        sta VERA_data0
00157B  1  A9 00           lda #0
00157D  1  8D 23 9F        sta VERA_data0
001580  1  A9 0C           lda #SPR_Z_FRONT
001582  1  8D 23 9F        sta VERA_data0
001585  1  A9 50           lda #SPR_16x16_PAL0
001587  1  8D 23 9F        sta VERA_data0
00158A  1               
00158A  1  A2 15           ldx #21
00158C  1  A0 0F           ldy #15
00158E  1  18              clc
00158F  1  20 F0 FF        jsr PLOT
001592  1  A2 00           ldx #0
001594  1  BD 85 1D     @lp_b: lda str_score_b, x
001597  1  F0 06           beq @lp_b_done
