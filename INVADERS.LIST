0011F4  1  A5 rr           lda score_lo
0011F6  1  20 88 1C        jsr print_hex_byte
0011F9  1               
0011F9  1                  ; (Plot: Set X to Row, Set Y to Col)
0011F9  1  A2 0C           ldx #12
0011FB  1  A0 20           ldy #32
0011FD  1  18              clc
0011FE  1  20 F0 FF        jsr PLOT
001201  1  A2 00           ldx #0
001203  1  BD 15 1D     @go3: lda str_hi_score_go, x
001206  1  F0 06           beq @go3d
001208  1  20 D2 FF        jsr CHROUT
00120B  1  E8              inx
