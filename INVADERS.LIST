00163F  1                  ; --- write sprite attributes for 4 shields (sequential VERA write) ---
00163F  1                  ; Slots 66–69: $1FE10, $1FE18, $1FE20, $1FE28  (high=$FE, bank=1)
00163F  1  A9 11           lda #$11               ; stride=1, bank=1
001641  1  8D 22 9F        sta VERA_addr_bank
001644  1  A9 FE           lda #$FE
001646  1  8D 21 9F        sta VERA_addr_high
001649  1  A9 10           lda #$10               ; low byte of $1FE10
00164B  1  8D 20 9F        sta VERA_addr_low
00164E  1               
00164E  1  A2 00           ldx #0
001650  1               @spr_init:
001650  1  A9 28           lda #$28               ; byte 0: addr[12:5] = VRAM_SHIELD_FULL>>5 = $00500>>5 = $28
001652  1  8D 23 9F        sta VERA_data0
001655  1  A9 00           lda #$00               ; byte 1: 4bpp, addr[16:13]=0
001657  1  8D 23 9F        sta VERA_data0
00165A  1  BD A6 1B        lda shield_x_lo, x     ; byte 2: X lo
00165D  1  8D 23 9F        sta VERA_data0
001660  1  BD AA 1B        lda shield_x_hi, x     ; byte 3: X hi
001663  1  8D 23 9F        sta VERA_data0
001666  1  A9 60           lda #<SHIELD_Y         ; byte 4: Y lo
001668  1  8D 23 9F        sta VERA_data0
00166B  1  A9 01           lda #>SHIELD_Y         ; byte 5: Y hi
00166D  1  8D 23 9F        sta VERA_data0
001670  1  A9 0C           lda #SPR_Z_FRONT       ; byte 6: z-depth=3 (in front of all layers)
001672  1  8D 23 9F        sta VERA_data0
001675  1  A9 A0           lda #SPR_32x32_PAL0    ; byte 7: 32x32, palette 0
001677  1  8D 23 9F        sta VERA_data0
00167A  1  E8              inx
00167B  1  E0 04           cpx #4
00167D  1  D0 D1           bne @spr_init
00167F  1               
00167F  1  60              rts
001680  1               
001680  1               ;******************************************************************
001680  1               ; update_shield_sprite — write new data-addr byte to shield sprite N
001680  1               ;   Input:  X = shield index (0–3)
001680  1               ;           shield_damage[X] = current damage level (1–7)
001680  1               ;   Writes sprite byte 0 (addr[12:5]) using shield_addr_b0 lookup.
001680  1               ;   VERA addr for byte 0 of sprite N: $1FE10 + N*8
001680  1               ;******************************************************************
001680  1               update_shield_sprite:
001680  1  9C 25 9F        stz VERA_ctrl
001683  1  A9 11           lda #$11               ; stride=1, bank=1
001685  1  8D 22 9F        sta VERA_addr_bank
001688  1  A9 FE           lda #$FE
00168A  1  8D 21 9F        sta VERA_addr_high
00168D  1  8A              txa                    ; A = shield index
00168E  1  0A              asl                    ; ×2
00168F  1  0A              asl                    ; ×4
001690  1  0A              asl                    ; ×8
001691  1  18              clc
001692  1  69 10           adc #$10               ; + low byte of $1FE10
001694  1  8D 20 9F        sta VERA_addr_low
001697  1  B4 rr           ldy shield_damage, x   ; Y = damage level (1-3)
001699  1  B9 AE 1B        lda shield_addr_b0, y  ; addr[12:5] for this tile
00169C  1  8D 23 9F        sta VERA_data0
00169F  1  60              rts
0016A0  1               
0016A0  1               ;******************************************************************
0016A0  1               ; hide_shield_sprite — disable sprite for shield N (z-depth=0)
0016A0  1               ;   Input: X = shield index (0–3)
0016A0  1               ;   Writes sprite byte 6 at $1FE10 + N*8 + 6 = $1FE16 + N*8
0016A0  1               ;******************************************************************
0016A0  1               hide_shield_sprite:
0016A0  1  9C 25 9F        stz VERA_ctrl
0016A3  1  A9 11           lda #$11
0016A5  1  8D 22 9F        sta VERA_addr_bank
0016A8  1  A9 FE           lda #$FE
0016AA  1  8D 21 9F        sta VERA_addr_high
0016AD  1  8A              txa
0016AE  1  0A              asl
0016AF  1  0A              asl
0016B0  1  0A              asl
0016B1  1  18              clc
0016B2  1  69 16           adc #$16               ; low($1FE10) + 6 = $16, + N*8
0016B4  1  8D 20 9F        sta VERA_addr_low
0016B7  1  A9 00           lda #0                 ; z-depth=0 → sprite disabled
0016B9  1  8D 23 9F        sta VERA_data0
0016BC  1  60              rts
0016BD  1               
0016BD  1               ;******************************************************************
0016BD  1               ; damage_shield — increment damage counter for shield X and update
0016BD  1               ;   sprite (or disable it when counter reaches 8 = destroyed).
0016BD  1               ;   Input:  X = shield index (0–3)
0016BD  1               ;   Clobbers: A, Y, VERA registers.  Preserves X.
0016BD  1               ;******************************************************************
0016BD  1               damage_shield:
0016BD  1  F6 rr           inc shield_damage, x
0016BF  1  B5 rr           lda shield_damage, x
0016C1  1  C9 08           cmp #8
0016C3  1  F0 06           beq @destroy
0016C5  1  B0 07           bcs @done              ; already at 8 (safety guard)
0016C7  1  20 80 16        jsr update_shield_sprite
0016CA  1  60              rts
0016CB  1               @destroy:
0016CB  1  20 A0 16        jsr hide_shield_sprite
0016CE  1               @done:
0016CE  1  60              rts
0016CF  1               
0016CF  1               ;******************************************************************
0016CF  1               ; check_bullet_shields — test active player bullet vs all 4 shields
0016CF  1               ;
0016CF  1               ;   Overlap condition (AABB, all values VERA 16-bit):
0016CF  1               ;     X: bullet_x+8 > shield_x  AND  bullet_x < shield_x+16
0016CF  1               ;     Y: bullet_y+8 > SHIELD_Y  AND  bullet_y < SHIELD_Y+16
0016CF  1               ;
0016CF  1               ;   On hit: calls damage_shield, deactivates bullet, returns.
0016CF  1               ;   Scratch used: zp_scratch_lo/hi.  Preserves nothing.
0016CF  1               ;******************************************************************
0016CF  1               check_bullet_shields:
0016CF  1  A5 rr           lda bullet_active
0016D1  1  F0 6D           beq @done
0016D3  1               
0016D3  1                  ; --- Y quick check (same band for all shields) ---
0016D3  1                  ; (1) bullet_y+8 > SHIELD_Y
0016D3  1  A5 rr           lda bullet_y_lo
0016D5  1  18              clc
0016D6  1  69 08           adc #8
0016D8  1  85 rr           sta zp_scratch_lo
0016DA  1  A5 rr           lda bullet_y_hi
0016DC  1  69 00           adc #0
0016DE  1  85 rr           sta zp_scratch_hi
0016E0  1  A5 rr           lda zp_scratch_lo
0016E2  1  38              sec
0016E3  1  E9 60           sbc #<SHIELD_Y
0016E5  1  A5 rr           lda zp_scratch_hi
0016E7  1  E9 01           sbc #>SHIELD_Y
0016E9  1  30 55           bmi @done              ; bullet bottom above shield top
0016EB  1               
0016EB  1                  ; (2) bullet_y < SHIELD_Y+32
0016EB  1  A5 rr           lda bullet_y_lo
0016ED  1  38              sec
0016EE  1  E9 80           sbc #<(SHIELD_Y + 32)
0016F0  1  A5 rr           lda bullet_y_hi
0016F2  1  E9 01           sbc #>(SHIELD_Y + 32)
0016F4  1  10 4A           bpl @done              ; bullet top at or below shield bottom
0016F6  1               
0016F6  1                  ; --- Y overlaps: scan each shield ---
0016F6  1  A2 00           ldx #0
0016F8  1               @sld_loop:
0016F8  1  B5 rr           lda shield_damage, x
0016FA  1  C9 08           cmp #8
0016FC  1  B0 3D           bcs @next_sld          ; destroyed, skip
0016FE  1               
0016FE  1                  ; X check (1): bullet_x+8 > shield_x[x]
0016FE  1  A5 rr           lda bullet_x_lo
001700  1  18              clc
001701  1  69 08           adc #8
001703  1  85 rr           sta zp_scratch_lo
001705  1  A5 rr           lda bullet_x_hi
001707  1  69 00           adc #0
001709  1  85 rr           sta zp_scratch_hi
00170B  1  A5 rr           lda zp_scratch_lo
00170D  1  38              sec
00170E  1  FD A6 1B        sbc shield_x_lo, x
001711  1  A5 rr           lda zp_scratch_hi
001713  1  FD AA 1B        sbc shield_x_hi, x
001716  1  30 23           bmi @next_sld
001718  1               
001718  1                  ; X check (2): bullet_x < shield_x[x]+32
001718  1  BD A6 1B        lda shield_x_lo, x
00171B  1  18              clc
00171C  1  69 20           adc #32
00171E  1  85 rr           sta zp_scratch_lo
001720  1  BD AA 1B        lda shield_x_hi, x
001723  1  69 00           adc #0
001725  1  85 rr           sta zp_scratch_hi
001727  1  A5 rr           lda bullet_x_lo
001729  1  38              sec
00172A  1  E5 rr           sbc zp_scratch_lo
00172C  1  A5 rr           lda bullet_x_hi
00172E  1  E5 rr           sbc zp_scratch_hi
001730  1  10 09           bpl @next_sld
001732  1               
001732  1                  ; --- HIT ---
001732  1  20 BD 16        jsr damage_shield      ; X = shield index
001735  1  64 rr           stz bullet_active
001737  1  20 2B 0E        jsr update_bullet_sprite
00173A  1  60              rts
00173B  1               
00173B  1               @next_sld:
00173B  1  E8              inx
00173C  1  E0 04           cpx #4
00173E  1  D0 B8           bne @sld_loop
001740  1               @done:
001740  1  60              rts
001741  1               
001741  1               ;******************************************************************
001741  1               ; check_invbullet_shields — test each active invader bullet vs all
001741  1               ;   4 shields.  Same AABB logic as check_bullet_shields but loops
001741  1               ;   over 3 bullet slots (ibul_active / ibul_x / ibul_y arrays).
001741  1               ;
001741  1               ;   Scratch: zp_scratch_lo/hi, zp_row (bullet slot index),
001741  1               ;            zp_col (shield index during inner scan).
001741  1               ;******************************************************************
001741  1               check_invbullet_shields:
001741  1  A2 00           ldx #0                 ; outer loop: invader bullet slot
001743  1               @ibul_loop:
001743  1  86 rr           stx zp_row             ; save slot before any branch
001745  1  B5 rr           lda ibul_active, x
001747  1  F0 7B           beq @next_ibul
001749  1               
001749  1                  ; --- Y quick check ---
001749  1                  ; (1) ibul_y+8 > SHIELD_Y
001749  1  B5 rr           lda ibul_y_lo, x
00174B  1  18              clc
00174C  1  69 08           adc #8
00174E  1  85 rr           sta zp_scratch_lo
001750  1  B5 rr           lda ibul_y_hi, x
001752  1  69 00           adc #0
001754  1  85 rr           sta zp_scratch_hi
001756  1  A5 rr           lda zp_scratch_lo
001758  1  38              sec
001759  1  E9 60           sbc #<SHIELD_Y
00175B  1  A5 rr           lda zp_scratch_hi
00175D  1  E9 01           sbc #>SHIELD_Y
00175F  1  30 63           bmi @next_ibul
001761  1               
001761  1                  ; (2) ibul_y < SHIELD_Y+32
001761  1  A6 rr           ldx zp_row
001763  1  B5 rr           lda ibul_y_lo, x
001765  1  38              sec
001766  1  E9 80           sbc #<(SHIELD_Y + 32)
001768  1  B5 rr           lda ibul_y_hi, x
00176A  1  E9 01           sbc #>(SHIELD_Y + 32)
00176C  1  10 56           bpl @next_ibul
00176E  1               
00176E  1                  ; --- Y overlaps: scan shields with Y register ---
00176E  1  A0 00           ldy #0
001770  1               @sld_scan:
001770  1  B9 rr rr        lda shield_damage, y
001773  1  C9 08           cmp #8
001775  1  B0 48           bcs @next_sld_y        ; destroyed
001777  1               
001777  1                  ; X check (1): ibul_x+8 > shield_x[y]
001777  1  A6 rr           ldx zp_row
001779  1  B5 rr           lda ibul_x_lo, x
00177B  1  18              clc
00177C  1  69 08           adc #8
00177E  1  85 rr           sta zp_scratch_lo
001780  1  B5 rr           lda ibul_x_hi, x
001782  1  69 00           adc #0
001784  1  85 rr           sta zp_scratch_hi
001786  1  A5 rr           lda zp_scratch_lo
001788  1  38              sec
001789  1  F9 A6 1B        sbc shield_x_lo, y
00178C  1  A5 rr           lda zp_scratch_hi
00178E  1  F9 AA 1B        sbc shield_x_hi, y
001791  1  30 2C           bmi @next_sld_y
001793  1               
001793  1                  ; X check (2): ibul_x < shield_x[y]+32
001793  1  B9 A6 1B        lda shield_x_lo, y
001796  1  18              clc
001797  1  69 20           adc #32
001799  1  85 rr           sta zp_scratch_lo
00179B  1  B9 AA 1B        lda shield_x_hi, y
00179E  1  69 00           adc #0
0017A0  1  85 rr           sta zp_scratch_hi
0017A2  1  A6 rr           ldx zp_row
0017A4  1  B5 rr           lda ibul_x_lo, x
0017A6  1  38              sec
0017A7  1  E5 rr           sbc zp_scratch_lo
0017A9  1  B5 rr           lda ibul_x_hi, x
0017AB  1  E5 rr           sbc zp_scratch_hi
0017AD  1  10 10           bpl @next_sld_y
0017AF  1               
0017AF  1                  ; --- HIT ---
0017AF  1  98              tya                    ; shield index → A → X for damage_shield
0017B0  1  AA              tax
0017B1  1  20 BD 16        jsr damage_shield
0017B4  1  A6 rr           ldx zp_row             ; restore bullet slot
0017B6  1  74 rr           stz ibul_active, x
0017B8  1  20 1C 10        jsr update_inv_bullet_sprite
0017BB  1  A6 rr           ldx zp_row
0017BD  1  80 05           bra @next_ibul         ; done with this bullet
0017BF  1               
0017BF  1               @next_sld_y:
0017BF  1  C8              iny
0017C0  1  C0 04           cpy #4
0017C2  1  D0 AC           bne @sld_scan
0017C4  1               
0017C4  1               @next_ibul:
0017C4  1  A6 rr           ldx zp_row
0017C6  1  E8              inx
0017C7  1  E0 03           cpx #3
0017C9  1  F0 03           beq @cis_done
0017CB  1  4C 43 17        jmp @ibul_loop
0017CE  1               @cis_done:
0017CE  1  60              rts
0017CF  1               
0017CF  1               ;******************************************************************
0017CF  1               ; add_score_bcd — add a 2-byte BCD pair to the score
0017CF  1               ;   A = BCD low byte (units/tens), Y = BCD mid byte (hundreds/thousands)
0017CF  1               ;******************************************************************
0017CF  1               add_score_bcd:
0017CF  1  F8              sed
0017D0  1  18              clc
0017D1  1  65 rr           adc score_lo
0017D3  1  85 rr           sta score_lo
0017D5  1  98              tya
0017D6  1  65 rr           adc score_mid
0017D8  1  85 rr           sta score_mid
0017DA  1  A5 rr           lda score_hi
0017DC  1  69 00           adc #0
0017DE  1  85 rr           sta score_hi
0017E0  1  D8              cld
0017E1  1  60              rts
0017E2  1               
0017E2  1               ;******************************************************************
0017E2  1               ; update_ufo — per-frame UFO logic: spawn timer + movement
0017E2  1               ;
0017E2  1               ;   Inactive: 16-bit ufo_timer counts down each frame.
0017E2  1               ;   On zero: UFO spawns at left edge (X=0), timer reset to
0017E2  1               ;             UFO_TIMER_INIT + (prng() & $7F) for next cycle.
0017E2  1               ;   Active: move right UFO_SPEED VERA pixels/frame.
0017E2  1               ;           Deactivate when X >= 640 (off right edge).
0017E2  1               ;   Updates VERA sprite 3 after any state change.
0017E2  1               ;******************************************************************
0017E2  1               update_ufo:
0017E2  1  A5 rr           lda ufo_active
0017E4  1  D0 36           bne @move_ufo
0017E6  1               
0017E6  1                  ; --- timer countdown (16-bit decrement) ---
0017E6  1  A5 rr           lda ufo_timer_lo
0017E8  1  D0 0B           bne @dec_lo
0017EA  1  A5 rr           lda ufo_timer_hi
0017EC  1  F0 0F           beq @spawn                   ; both zero → spawn (guard against stuck state)
0017EE  1  C6 rr           dec ufo_timer_hi
0017F0  1  A9 FF           lda #$FF
0017F2  1  85 rr           sta ufo_timer_lo
0017F4  1  60              rts
0017F5  1               @dec_lo:
0017F5  1  C6 rr           dec ufo_timer_lo
0017F7  1  A5 rr           lda ufo_timer_lo
0017F9  1  05 rr           ora ufo_timer_hi
0017FB  1  D0 47           bne @ufo_done                ; timer not yet zero
0017FD  1               
0017FD  1               @spawn:
0017FD  1  A9 01           lda #1
0017FF  1  85 rr           sta ufo_active
001801  1  64 rr           stz ufo_x_lo
001803  1  64 rr           stz ufo_x_hi
001805  1                  ; next timer = UFO_TIMER_INIT + (prng() & $7F) so interval varies by 0-127 frames
001805  1  20 D2 0F        jsr prng
001808  1  29 7F           and #$7F
00180A  1  18              clc
00180B  1  69 58           adc #<UFO_TIMER_INIT
00180D  1  85 rr           sta ufo_timer_lo
00180F  1  A9 02           lda #>UFO_TIMER_INIT
001811  1  69 00           adc #0
001813  1  85 rr           sta ufo_timer_hi
001815  1  20 45 18        jsr update_ufo_sprite
001818  1  20 07 19        jsr snd_start_ufo_drone
00181B  1  60              rts
00181C  1               
00181C  1                  ; --- move UFO right ---
00181C  1               @move_ufo:
00181C  1  A5 rr           lda ufo_x_lo
00181E  1  18              clc
00181F  1  69 02           adc #UFO_SPEED
001821  1  85 rr           sta ufo_x_lo
001823  1  A5 rr           lda ufo_x_hi
001825  1  69 00           adc #0
001827  1  85 rr           sta ufo_x_hi
001829  1                  ; deactivate if X high byte >= 3 (≥ 768, safely off the 640-wide screen)
001829  1                  ; simpler guard: X hi > 0 means X >= 256; combined with lo check
001829  1  C9 02           cmp #>640                    ; A = new hi; >640 = 2
00182B  1  90 11           bcc @ufo_on_screen           ; hi < 2 → still visible
00182D  1  D0 06           bne @ufo_off_screen          ; hi > 2 → gone
00182F  1  A5 rr           lda ufo_x_lo
001831  1  C9 80           cmp #<640
001833  1  90 09           bcc @ufo_on_screen           ; hi=2, lo < 128 → past edge but close; still off
001835  1               @ufo_off_screen:
001835  1  64 rr           stz ufo_active
001837  1  20 45 18        jsr update_ufo_sprite
00183A  1  20 2E 19        jsr snd_stop_ufo_drone
00183D  1  60              rts
00183E  1               @ufo_on_screen:
00183E  1  20 45 18        jsr update_ufo_sprite
001841  1  20 46 19        jsr snd_update_ufo_drone
001844  1               @ufo_done:
001844  1  60              rts
001845  1               
001845  1               ;******************************************************************
001845  1               ; update_ufo_sprite — write sprite 3 (UFO) position + enable/disable
001845  1               ;   addr[12:5] = VRAM_UFO>>5 = $01500>>5 = $A8
001845  1               ;   Writes bytes 2-6; bytes 0-1 and 7 set once at init.
001845  1               ;******************************************************************
001845  1               update_ufo_sprite:
001845  1  9C 25 9F        stz VERA_ctrl
001848  1  A9 11 8D 22     VERA_SET_ADDR (UFO_SPRITE_ATTR + 2), 1
00184C  1  9F A9 FC 8D  
001850  1  21 9F A9 1A  
001857  1  A5 rr           lda ufo_x_lo
001859  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
00185C  1  A5 rr           lda ufo_x_hi
00185E  1  29 03           and #$03
001860  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
001863  1  A9 20           lda #<UFO_Y
001865  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
001868  1  A9 00           lda #>UFO_Y
00186A  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
00186D  1  A5 rr           lda ufo_active
00186F  1  F0 04           beq @z_off
001871  1  A9 0C           lda #SPR_Z_FRONT
001873  1  80 02           bra @write_z
001875  1               @z_off:
001875  1  A9 00           lda #0
001877  1               @write_z:
001877  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
00187A  1  60              rts
00187B  1               
00187B  1               ;******************************************************************
00187B  1               ; check_bullet_ufo — AABB test: player bullet vs. UFO sprite (16x16)
00187B  1               ;   Bullet rect: (bullet_x, bullet_y)+(7,7);  UFO rect: (ufo_x, UFO_Y)+(15,15)
00187B  1               ;   On hit: bullet deactivated, UFO killed, score added, explosion started.
00187B  1               ;   Scratch: zp_scratch_lo/hi, zp_x_lo/hi, zp_row_y_lo/hi
00187B  1               ;******************************************************************
00187B  1               check_bullet_ufo:
00187B  1  A5 rr           lda bullet_active
00187D  1  D0 01           bne :+
00187F  1  60              rts
001880  1  A5 rr        :  lda ufo_active
001882  1  D0 01           bne :+
001884  1  60              rts
001885  1               :
001885  1               
001885  1                  ; --- Y check 1: bullet_y+8 > UFO_Y ---
001885  1  A5 rr           lda bullet_y_lo
001887  1  18              clc
001888  1  69 08           adc #8
00188A  1  85 rr           sta zp_scratch_lo
00188C  1  A5 rr           lda bullet_y_hi
00188E  1  69 00           adc #0
001890  1  85 rr           sta zp_scratch_hi
001892  1  A5 rr           lda zp_scratch_lo
001894  1  38              sec
001895  1  E9 20           sbc #<UFO_Y
001897  1  A5 rr           lda zp_scratch_hi
001899  1  E9 00           sbc #>UFO_Y
00189B  1  30 69           bmi @done                    ; bullet bottom above UFO top → no hit
00189D  1               
00189D  1                  ; --- Y check 2: bullet_y < UFO_Y+16 ---
00189D  1  A5 rr           lda bullet_y_lo
00189F  1  38              sec
0018A0  1  E9 30           sbc #<(UFO_Y + 16)
0018A2  1  A5 rr           lda bullet_y_hi
0018A4  1  E9 00           sbc #>(UFO_Y + 16)
0018A6  1  10 5E           bpl @done                    ; bullet top at or below UFO bottom → no hit
0018A8  1               
0018A8  1                  ; --- X check 1: bullet_x+8 > ufo_x ---
0018A8  1  A5 rr           lda bullet_x_lo
0018AA  1  18              clc
0018AB  1  69 08           adc #8
0018AD  1  85 rr           sta zp_scratch_lo
0018AF  1  A5 rr           lda bullet_x_hi
0018B1  1  69 00           adc #0
0018B3  1  85 rr           sta zp_scratch_hi
0018B5  1  A5 rr           lda zp_scratch_lo
0018B7  1  38              sec
0018B8  1  E5 rr           sbc ufo_x_lo
0018BA  1  A5 rr           lda zp_scratch_hi
0018BC  1  E5 rr           sbc ufo_x_hi
0018BE  1  30 46           bmi @done                    ; bullet right edge left of UFO left edge → no hit
0018C0  1               
0018C0  1                  ; --- X check 2: bullet_x < ufo_x+16 ---
0018C0  1  A5 rr           lda ufo_x_lo
0018C2  1  18              clc
0018C3  1  69 10           adc #16
0018C5  1  85 rr           sta zp_scratch_lo
0018C7  1  A5 rr           lda ufo_x_hi
0018C9  1  69 00           adc #0
0018CB  1  85 rr           sta zp_scratch_hi
0018CD  1  A5 rr           lda bullet_x_lo
0018CF  1  38              sec
0018D0  1  E5 rr           sbc zp_scratch_lo
0018D2  1  A5 rr           lda bullet_x_hi
0018D4  1  E5 rr           sbc zp_scratch_hi
0018D6  1  10 2E           bpl @done                    ; bullet left edge at or right of UFO right edge → no hit
0018D8  1               
0018D8  1                  ; --- HIT ---
0018D8  1  A5 rr           lda ufo_x_lo
0018DA  1  85 rr           sta zp_x_lo
0018DC  1  A5 rr           lda ufo_x_hi
0018DE  1  85 rr           sta zp_x_hi
0018E0  1  A9 20           lda #<UFO_Y
0018E2  1  85 rr           sta zp_row_y_lo
0018E4  1  A9 00           lda #>UFO_Y
0018E6  1  85 rr           sta zp_row_y_hi
0018E8  1  20 7E 0F        jsr start_explosion
0018EB  1               
0018EB  1  64 rr           stz bullet_active
0018ED  1  20 2B 0E        jsr update_bullet_sprite
0018F0  1               
0018F0  1  64 rr           stz ufo_active
0018F2  1  20 45 18        jsr update_ufo_sprite
0018F5  1  20 2E 19        jsr snd_stop_ufo_drone
0018F8  1               
0018F8  1                  ; score: ufo_score table indexed by shot_count & 7
0018F8  1  A5 rr           lda shot_count
0018FA  1  29 07           and #$07
0018FC  1  AA              tax
0018FD  1  BD 96 1B        lda ufo_score_lo, x
001900  1  BC 9E 1B        ldy ufo_score_hi, x
001903  1  20 CF 17        jsr add_score_bcd
001906  1               
001906  1               @done:
001906  1  60              rts
001907  1               
001907  1               ;******************************************************************
001907  1               ; snd_start_ufo_drone — enable VERA PSG voice 3 (sawtooth, full vol, freq1)
001907  1               ;   Called once when UFO spawns.
001907  1               ;******************************************************************
001907  1               snd_start_ufo_drone:
001907  1  9C 25 9F        stz VERA_ctrl
00190A  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
00190E  1  9F A9 F9 8D  
001912  1  21 9F A9 CC  
001919  1  A9 32           lda #<UFO_DRONE_FREQ1
00191B  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L
00191E  1  A9 04           lda #>UFO_DRONE_FREQ1
001920  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
001923  1  A9 FF           lda #PSG_VOL_FULL
001925  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001928  1  A9 40           lda #PSG_WAVE_SAW
00192A  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
00192D  1  60              rts
00192E  1               
00192E  1               ;******************************************************************
00192E  1               ; snd_stop_ufo_drone — silence VERA PSG voice 3
00192E  1               ;   Called when UFO leaves screen or is destroyed.
00192E  1               ;******************************************************************
00192E  1               snd_stop_ufo_drone:
00192E  1  9C 25 9F        stz VERA_ctrl
001931  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE3 + 2), 1   ; byte 2 = volume/enable
001935  1  9F A9 F9 8D  
001939  1  21 9F A9 CE  
001940  1  A9 00           lda #$00
001942  1  8D 23 9F        sta VERA_data0               ; zero volume → silent
001945  1  60              rts
001946  1               
001946  1               ;******************************************************************
001946  1               ; snd_update_ufo_drone — warble between freq1/freq2 using frame_count
001946  1               ;   bit 3 (flips every 8 frames ≈ 3.75 Hz wobble rate).
001946  1               ;   Call every frame while UFO is active.
001946  1               ;   Rewrites all 4 voice bytes (keeps volume/waveform stable).
001946  1               ;******************************************************************
001946  1               snd_update_ufo_drone:
001946  1  9C 25 9F        stz VERA_ctrl
001949  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
00194D  1  9F A9 F9 8D  
001951  1  21 9F A9 CC  
001958  1  A5 rr           lda frame_count
00195A  1  29 08           and #$08                     ; bit 3: 0 for 8 frames, 1 for 8 frames
00195C  1  D0 09           bne @freq2
00195E  1  A9 32           lda #<UFO_DRONE_FREQ1
001960  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L (freq1)
001963  1  A9 04           lda #>UFO_DRONE_FREQ1
001965  1  80 07           bra @rest
001967  1               @freq2:
001967  1  A9 4B           lda #<UFO_DRONE_FREQ2
001969  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L (freq2)
00196C  1  A9 06           lda #>UFO_DRONE_FREQ2
00196E  1               @rest:
00196E  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
001971  1  A9 FF           lda #PSG_VOL_FULL
001973  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001976  1  A9 40           lda #PSG_WAVE_SAW
001978  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
00197B  1  60              rts
00197C  1               
00197C  1               ;******************************************************************
00197C  1               ; update_hud — rewrite dynamic values each frame
00197C  1               ;   Overwrites fixed screen positions; no full redraw needed
00197C  1               ;******************************************************************
00197C  1               update_hud:
00197C  1                  ; Frame counter at row 19, col 2
00197C  1  A9 13           lda #19
00197E  1  A0 02           ldy #2
001980  1  18              clc
001981  1  20 F0 FF        jsr PLOT
001984  1  A2 00           ldx #0
001986  1  BD 6C 1A     @fc_lbl: lda str_frame_lbl,x
001989  1  F0 06           beq @fc_val
00198B  1  20 D2 FF        jsr CHROUT
00198E  1  E8              inx
00198F  1  80 F5           bra @fc_lbl
001991  1               @fc_val:
001991  1  A5 rr           lda frame_count
001993  1  20 B6 19        jsr print_hex_byte
001996  1               
001996  1                  ; Last key at row 21, col 2
001996  1  A9 15           lda #21
001998  1  A0 02           ldy #2
00199A  1  18              clc
00199B  1  20 F0 FF        jsr PLOT
00199E  1  A2 00           ldx #0
0019A0  1  BD 78 1A     @kl_lbl: lda str_key_lbl,x
0019A3  1  F0 06           beq @kl_val
0019A5  1  20 D2 FF        jsr CHROUT
0019A8  1  E8              inx
0019A9  1  80 F5           bra @kl_lbl
0019AB  1               @kl_val:
0019AB  1  A5 rr           lda key_last
0019AD  1  20 B6 19        jsr print_hex_byte
0019B0  1  A9 20           lda #' '
0019B2  1  20 D2 FF        jsr CHROUT                    ; erase stale digit if value shrank
0019B5  1               
0019B5  1  60              rts
0019B6  1               
0019B6  1               ;******************************************************************
0019B6  1               ; print_hex_byte — print .A as two uppercase hex digits via CHROUT
0019B6  1               ;******************************************************************
0019B6  1               print_hex_byte:
0019B6  1  48              pha
0019B7  1  4A              lsr                           ; shift high nibble down
0019B8  1  4A              lsr
0019B9  1  4A              lsr
0019BA  1  4A              lsr
0019BB  1  20 C5 19        jsr print_hex_nybble
0019BE  1  68              pla
0019BF  1  29 0F           and #$0F                      ; isolate low nibble
0019C1  1  20 C5 19        jsr print_hex_nybble
0019C4  1  60              rts
0019C5  1               
0019C5  1               ; print_hex_nybble — print lower 4 bits of .A as one hex digit
0019C5  1               ;   Relies on carry state from CMP to select digit vs. letter range
0019C5  1               print_hex_nybble:
0019C5  1  C9 0A           cmp #10
0019C7  1  90 06           bcc @digit                    ; carry clear → 0-9
0019C9  1  69 36           adc #($41 - 10 - 1)          ; A-F: 'A'=65; carry set adds 1
0019CB  1  20 D2 FF        jsr CHROUT
0019CE  1  60              rts
0019CF  1               @digit:
0019CF  1  69 30           adc #$30                      ; 0-9: '0'=48; carry clear adds 0
0019D1  1  20 D2 FF        jsr CHROUT
0019D4  1  60              rts
0019D5  1               
0019D5  1               ;******************************************************************
