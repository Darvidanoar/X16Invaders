0012FC  1               ;******************************************************************
0012FC  1               ; wave_clear_screen — display wave-clear message; SPACE or 3-sec
0012FC  1               ;   timer advances to next_wave; RUN/STOP exits to BASIC.
0012FC  1               ;   Keeps player X, lives, score, and shield state intact.
0012FC  1               ;
0012FC  1               ;   Layout:
0012FC  1               ;     Row  9, col 15: "WAVE CLEAR"
0012FC  1               ;     Row 11, col 15: "WAVE: N"    (N = wave just completed)
0012FC  1               ;     Row 14, col  8: "PRESS SPACE TO CONTINUE"
0012FC  1               ;******************************************************************
0012FC  1               wave_clear_screen:
0012FC  1  20 71 1A        jsr snd_stop_ufo_drone    ; silence drone (UFO already gone but guard)
0012FF  1  20 15 1B        jsr snd_stop_march        ; silence march beat
001302  1  64 rr           stz ufo_active
001304  1  20 88 19        jsr update_ufo_sprite
001307  1               
001307  1  A9 93           lda #PETSCII_CLR
001309  1  20 D2 FF        jsr CHROUT
00130C  1               
00130C  1  A9 09           lda #9
00130E  1  A0 0F           ldy #15
001310  1  18              clc
001311  1  20 F0 FF        jsr PLOT
001314  1  A2 00           ldx #0
001316  1  BD 46 1C     @wc1: lda str_wave_clear, x
001319  1  F0 06           beq @wc1d
00131B  1  20 D2 FF        jsr CHROUT
00131E  1  E8              inx
00131F  1  80 F5           bra @wc1
001321  1               @wc1d:
001321  1               
001321  1  A9 0B           lda #11
001323  1  A0 0F           ldy #15
001325  1  18              clc
001326  1  20 F0 FF        jsr PLOT
001329  1  A2 00           ldx #0
00132B  1  BD 51 1C     @wc2: lda str_wave_lbl, x
00132E  1  F0 06           beq @wc2d
001330  1  20 D2 FF        jsr CHROUT
001333  1  E8              inx
001334  1  80 F5           bra @wc2
001336  1               @wc2d:
001336  1  A5 rr           lda wave
001338  1  20 CC 13        jsr print_dec_byte
00133B  1               
00133B  1  A9 0E           lda #14
00133D  1  A0 08           ldy #8
00133F  1  18              clc
001340  1  20 F0 FF        jsr PLOT
001343  1  A2 00           ldx #0
001345  1  BD 58 1C     @wc3: lda str_wave_continue, x
001348  1  F0 06           beq @wc3d
