0013CF  1  E8              inx
0013D0  1  E0 03           cpx #3
0013D2  1  D0 F8           bne @nw_ibul
0013D4  1  A9 5A           lda #INV_FIRE_TIMER_INIT
0013D6  1  85 rr           sta inv_fire_timer
0013D8  1               
0013D8  1                  ; reset UFO timer (UFO already inactive from wave_clear_screen)
0013D8  1  A9 58           lda #<UFO_TIMER_INIT
0013DA  1  85 rr           sta ufo_timer_lo
0013DC  1  A9 02           lda #>UFO_TIMER_INIT
0013DE  1  85 rr           sta ufo_timer_hi
0013E0  1               
0013E0  1                  ; reset invader grid to full, using new wave_init_speed
0013E0  1  20 9A 0B        jsr init_invaders
0013E3  1               
0013E3  1  A9 93           lda #PETSCII_CLR
