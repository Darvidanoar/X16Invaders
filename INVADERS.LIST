001182  1               ;******************************************************************
001182  1               ; player_hit — handle a bullet-player collision:
001182  1               ;   explosion at player position, decrement lives, respawn, invincibility
001182  1               ;******************************************************************
001182  1               player_hit:
001182  1                  ; start explosion at player position
001182  1  A5 rr           lda player_x_lo
001184  1  85 rr           sta zp_x_lo
001186  1  A5 rr           lda player_x_hi
001188  1  85 rr           sta zp_x_hi
00118A  1  A9 A4           lda #<PLAYER_Y
00118C  1  85 rr           sta zp_row_y_lo
00118E  1  A9 01           lda #>PLAYER_Y
001190  1  85 rr           sta zp_row_y_hi
001192  1  20 A7 0F        jsr start_explosion
001195  1               
001195  1                  ; decrement lives
001195  1  C6 rr           dec lives
001197  1  F0 0D           beq @game_over            ; lives hit 0 → end game (Phase 6 will handle this properly)
001199  1               
001199  1                  ; grant invincibility and re-centre the ship
001199  1  A9 78           lda #INV_HIT_FRAMES
00119B  1  85 rr           sta inv_hit_timer
