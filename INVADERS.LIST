001318  1               ;******************************************************************
001318  1               ; wave_clear_screen — display wave-clear message; SPACE or 3-sec
001318  1               ;   timer advances to next_wave; RUN/STOP exits to BASIC.
001318  1               ;   Keeps player X, lives, score, and shield state intact.
001318  1               ;
001318  1               ;   Layout:
001318  1               ;     Row  9, col 15: "WAVE CLEAR"
001318  1               ;     Row 11, col 15: "WAVE: N"    (N = wave just completed)
001318  1               ;     Row 14, col  8: "PRESS SPACE TO CONTINUE"
001318  1               ;******************************************************************
001318  1               wave_clear_screen:
001318  1  20 93 1A        jsr snd_stop_ufo_drone    ; silence drone (UFO already gone but guard)
00131B  1  20 37 1B        jsr snd_stop_march        ; silence march beat
00131E  1  20 9C 1B        jsr snd_stop_fire         ; silence fire tone
001321  1  20 01 1C        jsr snd_stop_exp          ; silence explosion noise
001324  1  64 rr           stz ufo_active
001326  1  20 AA 19        jsr update_ufo_sprite
001329  1               
001329  1  A9 93           lda #PETSCII_CLR
00132B  1  20 D2 FF        jsr CHROUT
00132E  1               
00132E  1  A9 09           lda #9
001330  1  A0 0F           ldy #15
001332  1  18              clc
001333  1  20 F0 FF        jsr PLOT
001336  1  A2 00           ldx #0
001338  1  BD 32 1D     @wc1: lda str_wave_clear, x
00133B  1  F0 06           beq @wc1d
00133D  1  20 D2 FF        jsr CHROUT
001340  1  E8              inx
