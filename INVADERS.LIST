0014F9  1  8D 20 9F        sta VERA_addr_low
0014FC  1               
0014FC  1  A2 00           ldx #0
0014FE  1               @spr_init:
0014FE  1  A9 28           lda #$28               ; byte 0: addr[12:5] = VRAM_SHIELD_FULL>>5 = $00500>>5 = $28
001500  1  8D 23 9F        sta VERA_data0
001503  1  A9 00           lda #$00               ; byte 1: 4bpp, addr[16:13]=0
001505  1  8D 23 9F        sta VERA_data0
001508  1  BD 24 1A        lda shield_x_lo, x     ; byte 2: X lo
00150B  1  8D 23 9F        sta VERA_data0
00150E  1  BD 28 1A        lda shield_x_hi, x     ; byte 3: X hi
001511  1  8D 23 9F        sta VERA_data0
001514  1  A9 60           lda #<SHIELD_Y         ; byte 4: Y lo
001516  1  8D 23 9F        sta VERA_data0
001519  1  A9 01           lda #>SHIELD_Y         ; byte 5: Y hi
00151B  1  8D 23 9F        sta VERA_data0
00151E  1  A9 0C           lda #SPR_Z_FRONT       ; byte 6: z-depth=3 (in front of all layers)
001520  1  8D 23 9F        sta VERA_data0
001523  1  A9 A0           lda #SPR_32x32_PAL0    ; byte 7: 32x32, palette 0
001525  1  8D 23 9F        sta VERA_data0
001528  1  E8              inx
001529  1  E0 04           cpx #4
00152B  1  D0 D1           bne @spr_init
00152D  1               
00152D  1  60              rts
00152E  1               
00152E  1               ;******************************************************************
00152E  1               ; update_shield_sprite — write new data-addr byte to shield sprite N
00152E  1               ;   Input:  X = shield index (0–3)
00152E  1               ;           shield_damage[X] = current damage level (1–7)
00152E  1               ;   Writes sprite byte 0 (addr[12:5]) using shield_addr_b0 lookup.
00152E  1               ;   VERA addr for byte 0 of sprite N: $1FE10 + N*8
00152E  1               ;******************************************************************
00152E  1               update_shield_sprite:
00152E  1  9C 25 9F        stz VERA_ctrl
001531  1  A9 11           lda #$11               ; stride=1, bank=1
001533  1  8D 22 9F        sta VERA_addr_bank
001536  1  A9 FE           lda #$FE
001538  1  8D 21 9F        sta VERA_addr_high
00153B  1  8A              txa                    ; A = shield index
00153C  1  0A              asl                    ; ×2
00153D  1  0A              asl                    ; ×4
00153E  1  0A              asl                    ; ×8
00153F  1  18              clc
001540  1  69 10           adc #$10               ; + low byte of $1FE10
001542  1  8D 20 9F        sta VERA_addr_low
001545  1  B4 rr           ldy shield_damage, x   ; Y = damage level (1-3)
001547  1  B9 2C 1A        lda shield_addr_b0, y  ; addr[12:5] for this tile
00154A  1  8D 23 9F        sta VERA_data0
00154D  1  60              rts
00154E  1               
00154E  1               ;******************************************************************
00154E  1               ; hide_shield_sprite — disable sprite for shield N (z-depth=0)
00154E  1               ;   Input: X = shield index (0–3)
00154E  1               ;   Writes sprite byte 6 at $1FE10 + N*8 + 6 = $1FE16 + N*8
00154E  1               ;******************************************************************
00154E  1               hide_shield_sprite:
00154E  1  9C 25 9F        stz VERA_ctrl
001551  1  A9 11           lda #$11
001553  1  8D 22 9F        sta VERA_addr_bank
001556  1  A9 FE           lda #$FE
001558  1  8D 21 9F        sta VERA_addr_high
00155B  1  8A              txa
00155C  1  0A              asl
00155D  1  0A              asl
00155E  1  0A              asl
00155F  1  18              clc
001560  1  69 16           adc #$16               ; low($1FE10) + 6 = $16, + N*8
001562  1  8D 20 9F        sta VERA_addr_low
001565  1  A9 00           lda #0                 ; z-depth=0 → sprite disabled
001567  1  8D 23 9F        sta VERA_data0
00156A  1  60              rts
00156B  1               
00156B  1               ;******************************************************************
00156B  1               ; damage_shield — increment damage counter for shield X and update
00156B  1               ;   sprite (or disable it when counter reaches 8 = destroyed).
00156B  1               ;   Input:  X = shield index (0–3)
00156B  1               ;   Clobbers: A, Y, VERA registers.  Preserves X.
00156B  1               ;******************************************************************
00156B  1               damage_shield:
00156B  1  F6 rr           inc shield_damage, x
00156D  1  B5 rr           lda shield_damage, x
00156F  1  C9 08           cmp #8
001571  1  F0 06           beq @destroy
001573  1  B0 07           bcs @done              ; already at 8 (safety guard)
001575  1  20 2E 15        jsr update_shield_sprite
001578  1  60              rts
001579  1               @destroy:
001579  1  20 4E 15        jsr hide_shield_sprite
00157C  1               @done:
00157C  1  60              rts
00157D  1               
00157D  1               ;******************************************************************
00157D  1               ; check_bullet_shields — test active player bullet vs all 4 shields
00157D  1               ;
00157D  1               ;   Overlap condition (AABB, all values VERA 16-bit):
00157D  1               ;     X: bullet_x+8 > shield_x  AND  bullet_x < shield_x+16
00157D  1               ;     Y: bullet_y+8 > SHIELD_Y  AND  bullet_y < SHIELD_Y+16
00157D  1               ;
00157D  1               ;   On hit: calls damage_shield, deactivates bullet, returns.
00157D  1               ;   Scratch used: zp_scratch_lo/hi.  Preserves nothing.
00157D  1               ;******************************************************************
00157D  1               check_bullet_shields:
00157D  1  A5 rr           lda bullet_active
00157F  1  F0 6D           beq @done
001581  1               
001581  1                  ; --- Y quick check (same band for all shields) ---
001581  1                  ; (1) bullet_y+8 > SHIELD_Y
001581  1  A5 rr           lda bullet_y_lo
001583  1  18              clc
001584  1  69 08           adc #8
001586  1  85 rr           sta zp_scratch_lo
001588  1  A5 rr           lda bullet_y_hi
00158A  1  69 00           adc #0
00158C  1  85 rr           sta zp_scratch_hi
00158E  1  A5 rr           lda zp_scratch_lo
001590  1  38              sec
001591  1  E9 60           sbc #<SHIELD_Y
001593  1  A5 rr           lda zp_scratch_hi
001595  1  E9 01           sbc #>SHIELD_Y
001597  1  30 55           bmi @done              ; bullet bottom above shield top
001599  1               
001599  1                  ; (2) bullet_y < SHIELD_Y+32
001599  1  A5 rr           lda bullet_y_lo
00159B  1  38              sec
00159C  1  E9 80           sbc #<(SHIELD_Y + 32)
00159E  1  A5 rr           lda bullet_y_hi
0015A0  1  E9 01           sbc #>(SHIELD_Y + 32)
0015A2  1  10 4A           bpl @done              ; bullet top at or below shield bottom
0015A4  1               
0015A4  1                  ; --- Y overlaps: scan each shield ---
0015A4  1  A2 00           ldx #0
0015A6  1               @sld_loop:
0015A6  1  B5 rr           lda shield_damage, x
0015A8  1  C9 08           cmp #8
0015AA  1  B0 3D           bcs @next_sld          ; destroyed, skip
0015AC  1               
0015AC  1                  ; X check (1): bullet_x+8 > shield_x[x]
0015AC  1  A5 rr           lda bullet_x_lo
0015AE  1  18              clc
0015AF  1  69 08           adc #8
0015B1  1  85 rr           sta zp_scratch_lo
0015B3  1  A5 rr           lda bullet_x_hi
0015B5  1  69 00           adc #0
0015B7  1  85 rr           sta zp_scratch_hi
0015B9  1  A5 rr           lda zp_scratch_lo
0015BB  1  38              sec
0015BC  1  FD 24 1A        sbc shield_x_lo, x
0015BF  1  A5 rr           lda zp_scratch_hi
0015C1  1  FD 28 1A        sbc shield_x_hi, x
0015C4  1  30 23           bmi @next_sld
0015C6  1               
0015C6  1                  ; X check (2): bullet_x < shield_x[x]+32
0015C6  1  BD 24 1A        lda shield_x_lo, x
0015C9  1  18              clc
0015CA  1  69 20           adc #32
0015CC  1  85 rr           sta zp_scratch_lo
0015CE  1  BD 28 1A        lda shield_x_hi, x
0015D1  1  69 00           adc #0
0015D3  1  85 rr           sta zp_scratch_hi
0015D5  1  A5 rr           lda bullet_x_lo
0015D7  1  38              sec
0015D8  1  E5 rr           sbc zp_scratch_lo
0015DA  1  A5 rr           lda bullet_x_hi
0015DC  1  E5 rr           sbc zp_scratch_hi
0015DE  1  10 09           bpl @next_sld
0015E0  1               
0015E0  1                  ; --- HIT ---
0015E0  1  20 6B 15        jsr damage_shield      ; X = shield index
0015E3  1  64 rr           stz bullet_active
0015E5  1  20 2B 0E        jsr update_bullet_sprite
0015E8  1  60              rts
0015E9  1               
0015E9  1               @next_sld:
0015E9  1  E8              inx
0015EA  1  E0 04           cpx #4
0015EC  1  D0 B8           bne @sld_loop
0015EE  1               @done:
0015EE  1  60              rts
0015EF  1               
0015EF  1               ;******************************************************************
0015EF  1               ; check_invbullet_shields — test each active invader bullet vs all
0015EF  1               ;   4 shields.  Same AABB logic as check_bullet_shields but loops
0015EF  1               ;   over 3 bullet slots (ibul_active / ibul_x / ibul_y arrays).
0015EF  1               ;
0015EF  1               ;   Scratch: zp_scratch_lo/hi, zp_row (bullet slot index),
0015EF  1               ;            zp_col (shield index during inner scan).
0015EF  1               ;******************************************************************
0015EF  1               check_invbullet_shields:
0015EF  1  A2 00           ldx #0                 ; outer loop: invader bullet slot
0015F1  1               @ibul_loop:
0015F1  1  86 rr           stx zp_row             ; save slot before any branch
0015F3  1  B5 rr           lda ibul_active, x
0015F5  1  F0 7B           beq @next_ibul
0015F7  1               
0015F7  1                  ; --- Y quick check ---
0015F7  1                  ; (1) ibul_y+8 > SHIELD_Y
0015F7  1  B5 rr           lda ibul_y_lo, x
0015F9  1  18              clc
0015FA  1  69 08           adc #8
0015FC  1  85 rr           sta zp_scratch_lo
0015FE  1  B5 rr           lda ibul_y_hi, x
001600  1  69 00           adc #0
001602  1  85 rr           sta zp_scratch_hi
001604  1  A5 rr           lda zp_scratch_lo
001606  1  38              sec
001607  1  E9 60           sbc #<SHIELD_Y
001609  1  A5 rr           lda zp_scratch_hi
00160B  1  E9 01           sbc #>SHIELD_Y
00160D  1  30 63           bmi @next_ibul
00160F  1               
00160F  1                  ; (2) ibul_y < SHIELD_Y+32
00160F  1  A6 rr           ldx zp_row
001611  1  B5 rr           lda ibul_y_lo, x
001613  1  38              sec
001614  1  E9 80           sbc #<(SHIELD_Y + 32)
001616  1  B5 rr           lda ibul_y_hi, x
001618  1  E9 01           sbc #>(SHIELD_Y + 32)
00161A  1  10 56           bpl @next_ibul
00161C  1               
00161C  1                  ; --- Y overlaps: scan shields with Y register ---
00161C  1  A0 00           ldy #0
00161E  1               @sld_scan:
00161E  1  B9 rr rr        lda shield_damage, y
001621  1  C9 08           cmp #8
001623  1  B0 48           bcs @next_sld_y        ; destroyed
001625  1               
001625  1                  ; X check (1): ibul_x+8 > shield_x[y]
001625  1  A6 rr           ldx zp_row
001627  1  B5 rr           lda ibul_x_lo, x
001629  1  18              clc
00162A  1  69 08           adc #8
00162C  1  85 rr           sta zp_scratch_lo
00162E  1  B5 rr           lda ibul_x_hi, x
001630  1  69 00           adc #0
001632  1  85 rr           sta zp_scratch_hi
001634  1  A5 rr           lda zp_scratch_lo
001636  1  38              sec
001637  1  F9 24 1A        sbc shield_x_lo, y
00163A  1  A5 rr           lda zp_scratch_hi
00163C  1  F9 28 1A        sbc shield_x_hi, y
00163F  1  30 2C           bmi @next_sld_y
001641  1               
001641  1                  ; X check (2): ibul_x < shield_x[y]+32
001641  1  B9 24 1A        lda shield_x_lo, y
001644  1  18              clc
001645  1  69 20           adc #32
001647  1  85 rr           sta zp_scratch_lo
001649  1  B9 28 1A        lda shield_x_hi, y
00164C  1  69 00           adc #0
00164E  1  85 rr           sta zp_scratch_hi
001650  1  A6 rr           ldx zp_row
001652  1  B5 rr           lda ibul_x_lo, x
001654  1  38              sec
001655  1  E5 rr           sbc zp_scratch_lo
001657  1  B5 rr           lda ibul_x_hi, x
001659  1  E5 rr           sbc zp_scratch_hi
00165B  1  10 10           bpl @next_sld_y
00165D  1               
00165D  1                  ; --- HIT ---
00165D  1  98              tya                    ; shield index → A → X for damage_shield
00165E  1  AA              tax
00165F  1  20 6B 15        jsr damage_shield
001662  1  A6 rr           ldx zp_row             ; restore bullet slot
001664  1  74 rr           stz ibul_active, x
001666  1  20 1C 10        jsr update_inv_bullet_sprite
001669  1  A6 rr           ldx zp_row
00166B  1  80 05           bra @next_ibul         ; done with this bullet
00166D  1               
00166D  1               @next_sld_y:
00166D  1  C8              iny
00166E  1  C0 04           cpy #4
001670  1  D0 AC           bne @sld_scan
001672  1               
001672  1               @next_ibul:
001672  1  A6 rr           ldx zp_row
001674  1  E8              inx
001675  1  E0 03           cpx #3
001677  1  F0 03           beq @cis_done
001679  1  4C F1 15        jmp @ibul_loop
00167C  1               @cis_done:
00167C  1  60              rts
00167D  1               
00167D  1               ;******************************************************************
00167D  1               ; add_score_bcd — add a 2-byte BCD pair to the score
00167D  1               ;   A = BCD low byte (units/tens), Y = BCD mid byte (hundreds/thousands)
00167D  1               ;******************************************************************
00167D  1               add_score_bcd:
00167D  1  F8              sed
00167E  1  18              clc
00167F  1  65 rr           adc score_lo
001681  1  85 rr           sta score_lo
001683  1  98              tya
001684  1  65 rr           adc score_mid
001686  1  85 rr           sta score_mid
001688  1  A5 rr           lda score_hi
00168A  1  69 00           adc #0
00168C  1  85 rr           sta score_hi
00168E  1  D8              cld
00168F  1  60              rts
001690  1               
001690  1               ;******************************************************************
001690  1               ; update_ufo — per-frame UFO logic: spawn timer + movement
001690  1               ;
001690  1               ;   Inactive: 16-bit ufo_timer counts down each frame.
001690  1               ;   On zero: UFO spawns at left edge (X=0), timer reset to
001690  1               ;             UFO_TIMER_INIT + (prng() & $7F) for next cycle.
001690  1               ;   Active: move right UFO_SPEED VERA pixels/frame.
001690  1               ;           Deactivate when X >= 640 (off right edge).
001690  1               ;   Updates VERA sprite 3 after any state change.
001690  1               ;******************************************************************
001690  1               update_ufo:
001690  1  A5 rr           lda ufo_active
001692  1  D0 36           bne @move_ufo
001694  1               
001694  1                  ; --- timer countdown (16-bit decrement) ---
001694  1  A5 rr           lda ufo_timer_lo
001696  1  D0 0B           bne @dec_lo
001698  1  A5 rr           lda ufo_timer_hi
00169A  1  F0 0F           beq @spawn                   ; both zero → spawn (guard against stuck state)
00169C  1  C6 rr           dec ufo_timer_hi
00169E  1  A9 FF           lda #$FF
0016A0  1  85 rr           sta ufo_timer_lo
0016A2  1  60              rts
0016A3  1               @dec_lo:
0016A3  1  C6 rr           dec ufo_timer_lo
0016A5  1  A5 rr           lda ufo_timer_lo
0016A7  1  05 rr           ora ufo_timer_hi
0016A9  1  D0 47           bne @ufo_done                ; timer not yet zero
0016AB  1               
0016AB  1               @spawn:
0016AB  1  A9 01           lda #1
0016AD  1  85 rr           sta ufo_active
0016AF  1  64 rr           stz ufo_x_lo
0016B1  1  64 rr           stz ufo_x_hi
0016B3  1                  ; next timer = UFO_TIMER_INIT + (prng() & $7F) so interval varies by 0-127 frames
0016B3  1  20 D2 0F        jsr prng
0016B6  1  29 7F           and #$7F
0016B8  1  18              clc
0016B9  1  69 58           adc #<UFO_TIMER_INIT
0016BB  1  85 rr           sta ufo_timer_lo
0016BD  1  A9 02           lda #>UFO_TIMER_INIT
0016BF  1  69 00           adc #0
0016C1  1  85 rr           sta ufo_timer_hi
0016C3  1  20 F3 16        jsr update_ufo_sprite
0016C6  1  20 B5 17        jsr snd_start_ufo_drone
0016C9  1  60              rts
0016CA  1               
0016CA  1                  ; --- move UFO right ---
0016CA  1               @move_ufo:
0016CA  1  A5 rr           lda ufo_x_lo
0016CC  1  18              clc
0016CD  1  69 02           adc #UFO_SPEED
0016CF  1  85 rr           sta ufo_x_lo
0016D1  1  A5 rr           lda ufo_x_hi
0016D3  1  69 00           adc #0
0016D5  1  85 rr           sta ufo_x_hi
0016D7  1                  ; deactivate if X high byte >= 3 (≥ 768, safely off the 640-wide screen)
0016D7  1                  ; simpler guard: X hi > 0 means X >= 256; combined with lo check
0016D7  1  C9 02           cmp #>640                    ; A = new hi; >640 = 2
0016D9  1  90 11           bcc @ufo_on_screen           ; hi < 2 → still visible
0016DB  1  D0 06           bne @ufo_off_screen          ; hi > 2 → gone
0016DD  1  A5 rr           lda ufo_x_lo
0016DF  1  C9 80           cmp #<640
0016E1  1  90 09           bcc @ufo_on_screen           ; hi=2, lo < 128 → past edge but close; still off
0016E3  1               @ufo_off_screen:
0016E3  1  64 rr           stz ufo_active
0016E5  1  20 F3 16        jsr update_ufo_sprite
0016E8  1  20 DC 17        jsr snd_stop_ufo_drone
0016EB  1  60              rts
0016EC  1               @ufo_on_screen:
0016EC  1  20 F3 16        jsr update_ufo_sprite
0016EF  1  20 F4 17        jsr snd_update_ufo_drone
0016F2  1               @ufo_done:
0016F2  1  60              rts
0016F3  1               
0016F3  1               ;******************************************************************
0016F3  1               ; update_ufo_sprite — write sprite 3 (UFO) position + enable/disable
0016F3  1               ;   addr[12:5] = VRAM_UFO>>5 = $01500>>5 = $A8
0016F3  1               ;   Writes bytes 2-6; bytes 0-1 and 7 set once at init.
0016F3  1               ;******************************************************************
0016F3  1               update_ufo_sprite:
0016F3  1  9C 25 9F        stz VERA_ctrl
0016F6  1  A9 11 8D 22     VERA_SET_ADDR (UFO_SPRITE_ATTR + 2), 1
0016FA  1  9F A9 FC 8D  
0016FE  1  21 9F A9 1A  
001705  1  A5 rr           lda ufo_x_lo
001707  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
00170A  1  A5 rr           lda ufo_x_hi
00170C  1  29 03           and #$03
00170E  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
001711  1  A9 20           lda #<UFO_Y
001713  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
001716  1  A9 00           lda #>UFO_Y
001718  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
00171B  1  A5 rr           lda ufo_active
00171D  1  F0 04           beq @z_off
00171F  1  A9 0C           lda #SPR_Z_FRONT
001721  1  80 02           bra @write_z
001723  1               @z_off:
001723  1  A9 00           lda #0
001725  1               @write_z:
001725  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
001728  1  60              rts
001729  1               
001729  1               ;******************************************************************
001729  1               ; check_bullet_ufo — AABB test: player bullet vs. UFO sprite (16x16)
001729  1               ;   Bullet rect: (bullet_x, bullet_y)+(7,7);  UFO rect: (ufo_x, UFO_Y)+(15,15)
001729  1               ;   On hit: bullet deactivated, UFO killed, score added, explosion started.
001729  1               ;   Scratch: zp_scratch_lo/hi, zp_x_lo/hi, zp_row_y_lo/hi
001729  1               ;******************************************************************
001729  1               check_bullet_ufo:
001729  1  A5 rr           lda bullet_active
00172B  1  D0 01           bne :+
00172D  1  60              rts
00172E  1  A5 rr        :  lda ufo_active
001730  1  D0 01           bne :+
001732  1  60              rts
001733  1               :
001733  1               
001733  1                  ; --- Y check 1: bullet_y+8 > UFO_Y ---
001733  1  A5 rr           lda bullet_y_lo
001735  1  18              clc
001736  1  69 08           adc #8
001738  1  85 rr           sta zp_scratch_lo
00173A  1  A5 rr           lda bullet_y_hi
00173C  1  69 00           adc #0
00173E  1  85 rr           sta zp_scratch_hi
001740  1  A5 rr           lda zp_scratch_lo
001742  1  38              sec
001743  1  E9 20           sbc #<UFO_Y
001745  1  A5 rr           lda zp_scratch_hi
001747  1  E9 00           sbc #>UFO_Y
001749  1  30 69           bmi @done                    ; bullet bottom above UFO top → no hit
00174B  1               
00174B  1                  ; --- Y check 2: bullet_y < UFO_Y+16 ---
00174B  1  A5 rr           lda bullet_y_lo
00174D  1  38              sec
00174E  1  E9 30           sbc #<(UFO_Y + 16)
001750  1  A5 rr           lda bullet_y_hi
001752  1  E9 00           sbc #>(UFO_Y + 16)
001754  1  10 5E           bpl @done                    ; bullet top at or below UFO bottom → no hit
001756  1               
001756  1                  ; --- X check 1: bullet_x+8 > ufo_x ---
001756  1  A5 rr           lda bullet_x_lo
001758  1  18              clc
001759  1  69 08           adc #8
00175B  1  85 rr           sta zp_scratch_lo
00175D  1  A5 rr           lda bullet_x_hi
00175F  1  69 00           adc #0
001761  1  85 rr           sta zp_scratch_hi
001763  1  A5 rr           lda zp_scratch_lo
001765  1  38              sec
001766  1  E5 rr           sbc ufo_x_lo
001768  1  A5 rr           lda zp_scratch_hi
00176A  1  E5 rr           sbc ufo_x_hi
00176C  1  30 46           bmi @done                    ; bullet right edge left of UFO left edge → no hit
00176E  1               
00176E  1                  ; --- X check 2: bullet_x < ufo_x+16 ---
00176E  1  A5 rr           lda ufo_x_lo
001770  1  18              clc
001771  1  69 10           adc #16
001773  1  85 rr           sta zp_scratch_lo
001775  1  A5 rr           lda ufo_x_hi
001777  1  69 00           adc #0
001779  1  85 rr           sta zp_scratch_hi
00177B  1  A5 rr           lda bullet_x_lo
00177D  1  38              sec
00177E  1  E5 rr           sbc zp_scratch_lo
001780  1  A5 rr           lda bullet_x_hi
001782  1  E5 rr           sbc zp_scratch_hi
001784  1  10 2E           bpl @done                    ; bullet left edge at or right of UFO right edge → no hit
001786  1               
