001925  1               ;******************************************************************
001925  1               ; check_invbullet_shields — test each active invader bullet vs all
001925  1               ;   4 shields.  Same AABB logic as check_bullet_shields but loops
001925  1               ;   over 3 bullet slots (ibul_active / ibul_x / ibul_y arrays).
001925  1               ;
001925  1               ;   Scratch: zp_scratch_lo/hi, zp_row (bullet slot index),
001925  1               ;            zp_col (shield index during inner scan).
001925  1               ;******************************************************************
001925  1               check_invbullet_shields:
001925  1  A2 00           ldx #0                 ; outer loop: invader bullet slot
001927  1               @ibul_loop:
001927  1  86 rr           stx zp_row             ; save slot before any branch
001929  1  B5 rr           lda ibul_active, x
00192B  1  F0 7B           beq @next_ibul
00192D  1               
00192D  1                  ; --- Y quick check ---
00192D  1                  ; (1) ibul_y+8 > SHIELD_Y
00192D  1  B5 rr           lda ibul_y_lo, x
00192F  1  18              clc
001930  1  69 08           adc #8
001932  1  85 rr           sta zp_scratch_lo
001934  1  B5 rr           lda ibul_y_hi, x
001936  1  69 00           adc #0
001938  1  85 rr           sta zp_scratch_hi
00193A  1  A5 rr           lda zp_scratch_lo
00193C  1  38              sec
00193D  1  E9 60           sbc #<SHIELD_Y
00193F  1  A5 rr           lda zp_scratch_hi
001941  1  E9 01           sbc #>SHIELD_Y
001943  1  30 63           bmi @next_ibul
001945  1               
001945  1                  ; (2) ibul_y < SHIELD_Y+32
001945  1  A6 rr           ldx zp_row
001947  1  B5 rr           lda ibul_y_lo, x
001949  1  38              sec
00194A  1  E9 80           sbc #<(SHIELD_Y + 32)
00194C  1  B5 rr           lda ibul_y_hi, x
00194E  1  E9 01           sbc #>(SHIELD_Y + 32)
001950  1  10 56           bpl @next_ibul
001952  1               
001952  1                  ; --- Y overlaps: scan shields with Y register ---
001952  1  A0 00           ldy #0
001954  1               @sld_scan:
001954  1  B9 rr rr        lda shield_damage, y
001957  1  C9 08           cmp #8
001959  1  B0 48           bcs @next_sld_y        ; destroyed
00195B  1               
00195B  1                  ; X check (1): ibul_x+8 > shield_x[y]
