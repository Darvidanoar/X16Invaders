0016A7  1  8D 23 9F        sta VERA_data0
0016AA  1  E8              inx
0016AB  1  D0 F7           bne @up_s1c
0016AD  1  A2 80           ldx #128
0016AF  1  BD 71 26     @up_s1d: lda shield_tile_dmg1 + 256, x
0016B2  1  8D 23 9F        sta VERA_data0
0016B5  1  E8              inx
0016B6  1  D0 F7           bne @up_s1d
