001465  1               ; Called once after screen clear, before main_loop.
001465  1               ;******************************************************************
001465  1               draw_score_labels:
001465  1  A2 01           ldx #1
001467  1  A0 01           ldy #1
001469  1  18              clc
00146A  1  20 F0 FF        jsr PLOT
00146D  1  A2 00           ldx #0
