001793  1  A9 28           lda #$28               ; byte 0: addr[12:5] = VRAM_SHIELD_FULL>>5 = $00500>>5 = $28
001795  1  8D 23 9F        sta VERA_data0
001798  1  A9 00           lda #$00               ; byte 1: 4bpp, addr[16:13]=0
00179A  1  8D 23 9F        sta VERA_data0
00179D  1  BD B3 1D        lda shield_x_lo, x     ; byte 2: X lo
0017A0  1  8D 23 9F        sta VERA_data0
0017A3  1  BD B7 1D        lda shield_x_hi, x     ; byte 3: X hi
0017A6  1  8D 23 9F        sta VERA_data0
0017A9  1  A9 60           lda #<SHIELD_Y         ; byte 4: Y lo
0017AB  1  8D 23 9F        sta VERA_data0
0017AE  1  A9 01           lda #>SHIELD_Y         ; byte 5: Y hi
0017B0  1  8D 23 9F        sta VERA_data0
0017B3  1  A9 0C           lda #SPR_Z_FRONT       ; byte 6: z-depth=3 (in front of all layers)
0017B5  1  8D 23 9F        sta VERA_data0
0017B8  1  A9 A0           lda #SPR_32x32_PAL0    ; byte 7: 32x32, palette 0
0017BA  1  8D 23 9F        sta VERA_data0
0017BD  1  E8              inx
0017BE  1  E0 04           cpx #4
0017C0  1  D0 D1           bne @spr_init
0017C2  1               
0017C2  1  60              rts
0017C3  1               
0017C3  1               ;******************************************************************
0017C3  1               ; update_shield_sprite — write new data-addr byte to shield sprite N
0017C3  1               ;   Input:  X = shield index (0–3)
0017C3  1               ;           shield_damage[X] = current damage level (1–7)
0017C3  1               ;   Writes sprite byte 0 (addr[12:5]) using shield_addr_b0 lookup.
0017C3  1               ;   VERA addr for byte 0 of sprite N: $1FE10 + N*8
0017C3  1               ;******************************************************************
0017C3  1               update_shield_sprite:
0017C3  1  9C 25 9F        stz VERA_ctrl
0017C6  1  A9 11           lda #$11               ; stride=1, bank=1
0017C8  1  8D 22 9F        sta VERA_addr_bank
0017CB  1  A9 FE           lda #$FE
0017CD  1  8D 21 9F        sta VERA_addr_high
0017D0  1  8A              txa                    ; A = shield index
0017D1  1  0A              asl                    ; ×2
0017D2  1  0A              asl                    ; ×4
0017D3  1  0A              asl                    ; ×8
0017D4  1  18              clc
0017D5  1  69 10           adc #$10               ; + low byte of $1FE10
0017D7  1  8D 20 9F        sta VERA_addr_low
0017DA  1  B4 rr           ldy shield_damage, x   ; Y = damage level (1-3)
0017DC  1  B9 BB 1D        lda shield_addr_b0, y  ; addr[12:5] for this tile
0017DF  1  8D 23 9F        sta VERA_data0
0017E2  1  60              rts
0017E3  1               
0017E3  1               ;******************************************************************
0017E3  1               ; hide_shield_sprite — disable sprite for shield N (z-depth=0)
0017E3  1               ;   Input: X = shield index (0–3)
0017E3  1               ;   Writes sprite byte 6 at $1FE10 + N*8 + 6 = $1FE16 + N*8
0017E3  1               ;******************************************************************
0017E3  1               hide_shield_sprite:
0017E3  1  9C 25 9F        stz VERA_ctrl
0017E6  1  A9 11           lda #$11
0017E8  1  8D 22 9F        sta VERA_addr_bank
0017EB  1  A9 FE           lda #$FE
0017ED  1  8D 21 9F        sta VERA_addr_high
0017F0  1  8A              txa
0017F1  1  0A              asl
0017F2  1  0A              asl
0017F3  1  0A              asl
0017F4  1  18              clc
0017F5  1  69 16           adc #$16               ; low($1FE10) + 6 = $16, + N*8
0017F7  1  8D 20 9F        sta VERA_addr_low
0017FA  1  A9 00           lda #0                 ; z-depth=0 → sprite disabled
0017FC  1  8D 23 9F        sta VERA_data0
0017FF  1  60              rts
001800  1               
001800  1               ;******************************************************************
001800  1               ; damage_shield — increment damage counter for shield X and update
001800  1               ;   sprite (or disable it when counter reaches 8 = destroyed).
001800  1               ;   Input:  X = shield index (0–3)
001800  1               ;   Clobbers: A, Y, VERA registers.  Preserves X.
001800  1               ;******************************************************************
001800  1               damage_shield:
001800  1  F6 rr           inc shield_damage, x
001802  1  B5 rr           lda shield_damage, x
001804  1  C9 08           cmp #8
001806  1  F0 06           beq @destroy
001808  1  B0 07           bcs @done              ; already at 8 (safety guard)
00180A  1  20 C3 17        jsr update_shield_sprite
00180D  1  60              rts
00180E  1               @destroy:
00180E  1  20 E3 17        jsr hide_shield_sprite
001811  1               @done:
001811  1  60              rts
001812  1               
001812  1               ;******************************************************************
001812  1               ; check_bullet_shields — test active player bullet vs all 4 shields
001812  1               ;
001812  1               ;   Overlap condition (AABB, all values VERA 16-bit):
001812  1               ;     X: bullet_x+8 > shield_x  AND  bullet_x < shield_x+16
001812  1               ;     Y: bullet_y+8 > SHIELD_Y  AND  bullet_y < SHIELD_Y+16
001812  1               ;
001812  1               ;   On hit: calls damage_shield, deactivates bullet, returns.
001812  1               ;   Scratch used: zp_scratch_lo/hi.  Preserves nothing.
001812  1               ;******************************************************************
001812  1               check_bullet_shields:
001812  1  A5 rr           lda bullet_active
001814  1  F0 6D           beq @done
001816  1               
001816  1                  ; --- Y quick check (same band for all shields) ---
001816  1                  ; (1) bullet_y+8 > SHIELD_Y
001816  1  A5 rr           lda bullet_y_lo
001818  1  18              clc
001819  1  69 08           adc #8
00181B  1  85 rr           sta zp_scratch_lo
00181D  1  A5 rr           lda bullet_y_hi
00181F  1  69 00           adc #0
001821  1  85 rr           sta zp_scratch_hi
001823  1  A5 rr           lda zp_scratch_lo
001825  1  38              sec
001826  1  E9 60           sbc #<SHIELD_Y
001828  1  A5 rr           lda zp_scratch_hi
00182A  1  E9 01           sbc #>SHIELD_Y
00182C  1  30 55           bmi @done              ; bullet bottom above shield top
00182E  1               
00182E  1                  ; (2) bullet_y < SHIELD_Y+32
00182E  1  A5 rr           lda bullet_y_lo
001830  1  38              sec
001831  1  E9 80           sbc #<(SHIELD_Y + 32)
001833  1  A5 rr           lda bullet_y_hi
001835  1  E9 01           sbc #>(SHIELD_Y + 32)
001837  1  10 4A           bpl @done              ; bullet top at or below shield bottom
001839  1               
001839  1                  ; --- Y overlaps: scan each shield ---
001839  1  A2 00           ldx #0
00183B  1               @sld_loop:
00183B  1  B5 rr           lda shield_damage, x
00183D  1  C9 08           cmp #8
00183F  1  B0 3D           bcs @next_sld          ; destroyed, skip
001841  1               
001841  1                  ; X check (1): bullet_x+8 > shield_x[x]
001841  1  A5 rr           lda bullet_x_lo
001843  1  18              clc
001844  1  69 08           adc #8
001846  1  85 rr           sta zp_scratch_lo
001848  1  A5 rr           lda bullet_x_hi
00184A  1  69 00           adc #0
00184C  1  85 rr           sta zp_scratch_hi
00184E  1  A5 rr           lda zp_scratch_lo
001850  1  38              sec
001851  1  FD B3 1D        sbc shield_x_lo, x
001854  1  A5 rr           lda zp_scratch_hi
001856  1  FD B7 1D        sbc shield_x_hi, x
001859  1  30 23           bmi @next_sld
00185B  1               
00185B  1                  ; X check (2): bullet_x < shield_x[x]+32
00185B  1  BD B3 1D        lda shield_x_lo, x
00185E  1  18              clc
00185F  1  69 20           adc #32
001861  1  85 rr           sta zp_scratch_lo
001863  1  BD B7 1D        lda shield_x_hi, x
001866  1  69 00           adc #0
001868  1  85 rr           sta zp_scratch_hi
00186A  1  A5 rr           lda bullet_x_lo
00186C  1  38              sec
00186D  1  E5 rr           sbc zp_scratch_lo
00186F  1  A5 rr           lda bullet_x_hi
001871  1  E5 rr           sbc zp_scratch_hi
001873  1  10 09           bpl @next_sld
001875  1               
001875  1                  ; --- HIT ---
001875  1  20 00 18        jsr damage_shield      ; X = shield index
001878  1  64 rr           stz bullet_active
00187A  1  20 47 0E        jsr update_bullet_sprite
00187D  1  60              rts
00187E  1               
00187E  1               @next_sld:
00187E  1  E8              inx
00187F  1  E0 04           cpx #4
001881  1  D0 B8           bne @sld_loop
001883  1               @done:
001883  1  60              rts
001884  1               
001884  1               ;******************************************************************
001884  1               ; check_invbullet_shields — test each active invader bullet vs all
001884  1               ;   4 shields.  Same AABB logic as check_bullet_shields but loops
001884  1               ;   over 3 bullet slots (ibul_active / ibul_x / ibul_y arrays).
001884  1               ;
001884  1               ;   Scratch: zp_scratch_lo/hi, zp_row (bullet slot index),
001884  1               ;            zp_col (shield index during inner scan).
001884  1               ;******************************************************************
001884  1               check_invbullet_shields:
001884  1  A2 00           ldx #0                 ; outer loop: invader bullet slot
001886  1               @ibul_loop:
001886  1  86 rr           stx zp_row             ; save slot before any branch
001888  1  B5 rr           lda ibul_active, x
00188A  1  F0 7B           beq @next_ibul
00188C  1               
00188C  1                  ; --- Y quick check ---
00188C  1                  ; (1) ibul_y+8 > SHIELD_Y
00188C  1  B5 rr           lda ibul_y_lo, x
00188E  1  18              clc
00188F  1  69 08           adc #8
001891  1  85 rr           sta zp_scratch_lo
001893  1  B5 rr           lda ibul_y_hi, x
001895  1  69 00           adc #0
001897  1  85 rr           sta zp_scratch_hi
001899  1  A5 rr           lda zp_scratch_lo
00189B  1  38              sec
00189C  1  E9 60           sbc #<SHIELD_Y
00189E  1  A5 rr           lda zp_scratch_hi
0018A0  1  E9 01           sbc #>SHIELD_Y
0018A2  1  30 63           bmi @next_ibul
0018A4  1               
0018A4  1                  ; (2) ibul_y < SHIELD_Y+32
0018A4  1  A6 rr           ldx zp_row
0018A6  1  B5 rr           lda ibul_y_lo, x
0018A8  1  38              sec
0018A9  1  E9 80           sbc #<(SHIELD_Y + 32)
0018AB  1  B5 rr           lda ibul_y_hi, x
0018AD  1  E9 01           sbc #>(SHIELD_Y + 32)
0018AF  1  10 56           bpl @next_ibul
0018B1  1               
0018B1  1                  ; --- Y overlaps: scan shields with Y register ---
0018B1  1  A0 00           ldy #0
0018B3  1               @sld_scan:
0018B3  1  B9 rr rr        lda shield_damage, y
0018B6  1  C9 08           cmp #8
0018B8  1  B0 48           bcs @next_sld_y        ; destroyed
0018BA  1               
0018BA  1                  ; X check (1): ibul_x+8 > shield_x[y]
0018BA  1  A6 rr           ldx zp_row
0018BC  1  B5 rr           lda ibul_x_lo, x
0018BE  1  18              clc
0018BF  1  69 08           adc #8
0018C1  1  85 rr           sta zp_scratch_lo
0018C3  1  B5 rr           lda ibul_x_hi, x
0018C5  1  69 00           adc #0
0018C7  1  85 rr           sta zp_scratch_hi
0018C9  1  A5 rr           lda zp_scratch_lo
0018CB  1  38              sec
0018CC  1  F9 B3 1D        sbc shield_x_lo, y
0018CF  1  A5 rr           lda zp_scratch_hi
0018D1  1  F9 B7 1D        sbc shield_x_hi, y
0018D4  1  30 2C           bmi @next_sld_y
0018D6  1               
0018D6  1                  ; X check (2): ibul_x < shield_x[y]+32
0018D6  1  B9 B3 1D        lda shield_x_lo, y
0018D9  1  18              clc
0018DA  1  69 20           adc #32
0018DC  1  85 rr           sta zp_scratch_lo
0018DE  1  B9 B7 1D        lda shield_x_hi, y
0018E1  1  69 00           adc #0
0018E3  1  85 rr           sta zp_scratch_hi
0018E5  1  A6 rr           ldx zp_row
0018E7  1  B5 rr           lda ibul_x_lo, x
0018E9  1  38              sec
0018EA  1  E5 rr           sbc zp_scratch_lo
0018EC  1  B5 rr           lda ibul_x_hi, x
0018EE  1  E5 rr           sbc zp_scratch_hi
0018F0  1  10 10           bpl @next_sld_y
0018F2  1               
0018F2  1                  ; --- HIT ---
0018F2  1  98              tya                    ; shield index → A → X for damage_shield
0018F3  1  AA              tax
0018F4  1  20 00 18        jsr damage_shield
0018F7  1  A6 rr           ldx zp_row             ; restore bullet slot
0018F9  1  74 rr           stz ibul_active, x
0018FB  1  20 38 10        jsr update_inv_bullet_sprite
0018FE  1  A6 rr           ldx zp_row
001900  1  80 05           bra @next_ibul         ; done with this bullet
001902  1               
001902  1               @next_sld_y:
001902  1  C8              iny
001903  1  C0 04           cpy #4
001905  1  D0 AC           bne @sld_scan
001907  1               
001907  1               @next_ibul:
001907  1  A6 rr           ldx zp_row
001909  1  E8              inx
00190A  1  E0 03           cpx #3
00190C  1  F0 03           beq @cis_done
00190E  1  4C 86 18        jmp @ibul_loop
001911  1               @cis_done:
001911  1  60              rts
