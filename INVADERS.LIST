002371  1               
002371  1               ;******************************************************************
002371  1               ; Shield sprite pixel data — 16x16 4bpp, 128 bytes each
002371  1               ;
002371  1               ;   Color 0 = transparent, Color 7 = dark green (palette entry 7,
002371  1               ;   set to dark green by init_shields).
002371  1               ;   Each byte encodes 2 pixels: high nibble = left, low nibble = right.
002371  1               ;
002371  1               ;   Damage progression: each level erodes 4 more rows from the top,
002371  1               ;   replacing solid color-7 pixels with a 2-pixel checkerboard of
002371  1               ;   color 7 and transparent.  Rows not yet eroded remain solid.
002371  1               ;
002371  1               ;   Checker A (odd bits lit):  $70 $07 $70 $07 $70 $07 $70 $07
002371  1               ;   Checker B (even bits lit): $07 $70 $07 $70 $07 $70 $07 $70
002371  1               ;   Solid row:                 $77 $77 $77 $77 $77 $77 $77 $77
002371  1               ;
002371  1               ;   Classic Space Invaders arch/bunker shape (32x32, 4bpp, color index 7)
002371  1               ;   Dome narrows upward (rows 0-1); solid body (rows 2-19); arch cut
002371  1               ;   from rows 20-27 with 8px legs; solid base rows 28-31 (32px wide).
002371  1               ;   Damage progression: dome erodes first, then body, then arch/base.
002371  1               ;   Each row = 16 bytes (32 pixels × 4bpp).  32 rows × 16 bytes = 512 bytes per tile.
002371  1               ;
002371  1               ;   shield_tile_full:  dome 24/28px, 18 solid body rows, 8 arch rows, 4 base rows
002371  1               ;   shield_tile_dmg1:  2 holes in dome top row
002371  1               ;   shield_tile_dmg2:  dome top 20px, dome row 1 holed
002371  1               ;   shield_tile_dmg3:  dome 16px, dome row 1 holed, 1 body hole
002371  1               ;   shield_tile_dmg4:  dome 8/16px, 3 body holes, arch narrows to 6px
002371  1               ;   shield_tile_dmg5:  dome gone/4px, 4 body holes, arch 4px, base hole
002371  1               ;   shield_tile_dmg6:  body fragmenting, arch 2px legs, 2 base holes
002371  1               ;   shield_tile_dmg7:  ruins — pillar stubs, arch dots, base crumbling
002371  1               ;******************************************************************
002371  1               
002371  1               shield_tile_full:
002371  1  00 00 00 00     .byte $00,$00,$00,$00,$77,$77,$77,$77,$77,$77,$77,$77,$00,$00,$00,$00  ; r0  dome 24px
002375  1  77 77 77 77  
002379  1  77 77 77 77  
002381  1  00 00 00 77     .byte $00,$00,$00,$77,$77,$77,$77,$77,$77,$77,$77,$77,$77,$00,$00,$00  ; r1  dome 28px
002385  1  77 77 77 77  
002389  1  77 77 77 77  
002391  1  00 00 77 77     .byte $00,$00,$77,$77,$77,$77,$77,$77,$77,$77,$77,$77,$77,$77,$00,$00  ; r2  solid body
