001850  1  8D 23 9F        sta VERA_data0
001853  1  A9 0C           lda #SPR_Z_FRONT       ; byte 6: z-depth=3 (in front of all layers)
001855  1  8D 23 9F        sta VERA_data0
001858  1  A9 A0           lda #SPR_32x32_PAL0    ; byte 7: 32x32, palette 0
00185A  1  8D 23 9F        sta VERA_data0
