001569  1               ; hide_all_inv_sprites — set z-depth=0 for all 55 invader sprites
001569  1               ;   Uses VERA stride=8 to write only byte 6 (z-depth) of each block.
001569  1               ;   First invader sprite byte 6: $1FC00 + 11*8 + 6 = $1FC5E
001569  1               ;******************************************************************
001569  1               hide_all_inv_sprites:
001569  1  9C 25 9F        stz VERA_ctrl
00156C  1  A9 41           lda #$41               ; stride=8 (code $4 in high nibble), bank=1
00156E  1  8D 22 9F        sta VERA_addr_bank
001571  1  A9 FC           lda #$FC
001573  1  8D 21 9F        sta VERA_addr_high
001576  1  A9 5E           lda #$5E               ; low byte of $1FC5E  ($1FC58+6)
001578  1  8D 20 9F        sta VERA_addr_low
00157B  1  A9 00           lda #0                 ; z-depth=0 → disabled
00157D  1  A2 37           ldx #55
00157F  1               @loop:
00157F  1  8D 23 9F        sta VERA_data0         ; writes byte 6; addr auto-advances by 8
001582  1  CA              dex
001583  1  D0 FA           bne @loop
001585  1  60              rts
