001838  1               ;******************************************************************
001838  1               ; update_shield_sprite — write new data-addr byte to shield sprite N
001838  1               ;   Input:  X = shield index (0–3)
001838  1               ;           shield_damage[X] = current damage level (1–7)
001838  1               ;   Writes sprite byte 0 (addr[12:5]) using shield_addr_b0 lookup.
001838  1               ;   VERA addr for byte 0 of sprite N: $1FE10 + N*8
001838  1               ;******************************************************************
001838  1               update_shield_sprite:
001838  1  9C 25 9F        stz VERA_ctrl
00183B  1  A9 11           lda #$11               ; stride=1, bank=1
00183D  1  8D 22 9F        sta VERA_addr_bank
001840  1  A9 FE           lda #$FE
001842  1  8D 21 9F        sta VERA_addr_high
001845  1  8A              txa                    ; A = shield index
001846  1  0A              asl                    ; ×2
001847  1  0A              asl                    ; ×4
001848  1  0A              asl                    ; ×8
001849  1  18              clc
00184A  1  69 10           adc #$10               ; + low byte of $1FE10
00184C  1  8D 20 9F        sta VERA_addr_low
00184F  1  B4 rr           ldy shield_damage, x   ; Y = damage level (1-3)
001851  1  B9 1E 1F        lda shield_addr_b0, y  ; addr[12:5] for this tile
001854  1  8D 23 9F        sta VERA_data0
001857  1  60              rts
001858  1               
001858  1               ;******************************************************************
001858  1               ; hide_shield_sprite — disable sprite for shield N (z-depth=0)
001858  1               ;   Input: X = shield index (0–3)
001858  1               ;   Writes sprite byte 6 at $1FE10 + N*8 + 6 = $1FE16 + N*8
001858  1               ;******************************************************************
001858  1               hide_shield_sprite:
001858  1  9C 25 9F        stz VERA_ctrl
00185B  1  A9 11           lda #$11
00185D  1  8D 22 9F        sta VERA_addr_bank
001860  1  A9 FE           lda #$FE
001862  1  8D 21 9F        sta VERA_addr_high
001865  1  8A              txa
001866  1  0A              asl
001867  1  0A              asl
001868  1  0A              asl
001869  1  18              clc
00186A  1  69 16           adc #$16               ; low($1FE10) + 6 = $16, + N*8
00186C  1  8D 20 9F        sta VERA_addr_low
00186F  1  A9 00           lda #0                 ; z-depth=0 → sprite disabled
001871  1  8D 23 9F        sta VERA_data0
001874  1  60              rts
001875  1               
001875  1               ;******************************************************************
001875  1               ; damage_shield — increment damage counter for shield X and update
001875  1               ;   sprite (or disable it when counter reaches 8 = destroyed).
001875  1               ;   Input:  X = shield index (0–3)
001875  1               ;   Clobbers: A, Y, VERA registers.  Preserves X.
001875  1               ;******************************************************************
001875  1               damage_shield:
001875  1  F6 rr           inc shield_damage, x
001877  1  B5 rr           lda shield_damage, x
001879  1  C9 08           cmp #8
00187B  1  F0 06           beq @destroy
00187D  1  B0 07           bcs @done              ; already at 8 (safety guard)
00187F  1  20 38 18        jsr update_shield_sprite
001882  1  60              rts
001883  1               @destroy:
001883  1  20 58 18        jsr hide_shield_sprite
001886  1               @done:
001886  1  60              rts
001887  1               
001887  1               ;******************************************************************
001887  1               ; check_bullet_shields — test active player bullet vs all 4 shields
001887  1               ;
001887  1               ;   Overlap condition (AABB, all values VERA 16-bit):
001887  1               ;     X: bullet_x+8 > shield_x  AND  bullet_x < shield_x+16
001887  1               ;     Y: bullet_y+8 > SHIELD_Y  AND  bullet_y < SHIELD_Y+16
001887  1               ;
001887  1               ;   On hit: calls damage_shield, deactivates bullet, returns.
001887  1               ;   Scratch used: zp_scratch_lo/hi.  Preserves nothing.
001887  1               ;******************************************************************
001887  1               check_bullet_shields:
001887  1  A5 rr           lda bullet_active
001889  1  F0 6D           beq @done
00188B  1               
00188B  1                  ; --- Y quick check (same band for all shields) ---
00188B  1                  ; (1) bullet_y+8 > SHIELD_Y
00188B  1  A5 rr           lda bullet_y_lo
00188D  1  18              clc
00188E  1  69 08           adc #8
001890  1  85 rr           sta zp_scratch_lo
001892  1  A5 rr           lda bullet_y_hi
001894  1  69 00           adc #0
001896  1  85 rr           sta zp_scratch_hi
001898  1  A5 rr           lda zp_scratch_lo
00189A  1  38              sec
00189B  1  E9 60           sbc #<SHIELD_Y
00189D  1  A5 rr           lda zp_scratch_hi
00189F  1  E9 01           sbc #>SHIELD_Y
0018A1  1  30 55           bmi @done              ; bullet bottom above shield top
0018A3  1               
0018A3  1                  ; (2) bullet_y < SHIELD_Y+32
0018A3  1  A5 rr           lda bullet_y_lo
0018A5  1  38              sec
0018A6  1  E9 80           sbc #<(SHIELD_Y + 32)
0018A8  1  A5 rr           lda bullet_y_hi
0018AA  1  E9 01           sbc #>(SHIELD_Y + 32)
0018AC  1  10 4A           bpl @done              ; bullet top at or below shield bottom
0018AE  1               
0018AE  1                  ; --- Y overlaps: scan each shield ---
0018AE  1  A2 00           ldx #0
0018B0  1               @sld_loop:
0018B0  1  B5 rr           lda shield_damage, x
0018B2  1  C9 08           cmp #8
0018B4  1  B0 3D           bcs @next_sld          ; destroyed, skip
0018B6  1               
0018B6  1                  ; X check (1): bullet_x+8 > shield_x[x]
0018B6  1  A5 rr           lda bullet_x_lo
0018B8  1  18              clc
0018B9  1  69 08           adc #8
0018BB  1  85 rr           sta zp_scratch_lo
0018BD  1  A5 rr           lda bullet_x_hi
0018BF  1  69 00           adc #0
0018C1  1  85 rr           sta zp_scratch_hi
0018C3  1  A5 rr           lda zp_scratch_lo
0018C5  1  38              sec
0018C6  1  FD 16 1F        sbc shield_x_lo, x
0018C9  1  A5 rr           lda zp_scratch_hi
0018CB  1  FD 1A 1F        sbc shield_x_hi, x
0018CE  1  30 23           bmi @next_sld
0018D0  1               
0018D0  1                  ; X check (2): bullet_x < shield_x[x]+32
0018D0  1  BD 16 1F        lda shield_x_lo, x
0018D3  1  18              clc
0018D4  1  69 20           adc #32
0018D6  1  85 rr           sta zp_scratch_lo
0018D8  1  BD 1A 1F        lda shield_x_hi, x
0018DB  1  69 00           adc #0
0018DD  1  85 rr           sta zp_scratch_hi
0018DF  1  A5 rr           lda bullet_x_lo
0018E1  1  38              sec
0018E2  1  E5 rr           sbc zp_scratch_lo
0018E4  1  A5 rr           lda bullet_x_hi
0018E6  1  E5 rr           sbc zp_scratch_hi
0018E8  1  10 09           bpl @next_sld
0018EA  1               
0018EA  1                  ; --- HIT ---
0018EA  1  20 75 18        jsr damage_shield      ; X = shield index
0018ED  1  64 rr           stz bullet_active
0018EF  1  20 63 0E        jsr update_bullet_sprite
0018F2  1  60              rts
0018F3  1               
0018F3  1               @next_sld:
0018F3  1  E8              inx
0018F4  1  E0 04           cpx #4
0018F6  1  D0 B8           bne @sld_loop
0018F8  1               @done:
0018F8  1  60              rts
