0011D1  1  F0 06           beq @go_ctr_done
0011D3  1  20 D2 FF        jsr CHROUT
0011D6  1  E8              inx
0011D7  1  80 F5           bra @go_ctr_lp
0011D9  1               @go_ctr_done:
0011D9  1               
0011D9  1                  ; wait 300 frames (≈ 5 seconds at 60 Hz) using 16-bit countdown in scratch
0011D9  1  A9 2C           lda #<300
0011DB  1  85 rr           sta zp_scratch_lo
0011DD  1  A9 01           lda #>300
0011DF  1  85 rr           sta zp_scratch_hi
