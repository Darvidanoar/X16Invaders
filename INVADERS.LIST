001761  1  A9 10 8D 22     VERA_SET_ADDR VRAM_SHIELD_DMG7, 1
001765  1  9F A9 13 8D  
001769  1  21 9F A9 00  
001770  1  A2 80           ldx #128
001772  1  BD 4F 30     @up_s7a: lda shield_tile_dmg7 - 128, x
001775  1  8D 23 9F        sta VERA_data0
001778  1  E8              inx
001779  1  D0 F7           bne @up_s7a
00177B  1  A2 80           ldx #128
00177D  1  BD CF 30     @up_s7b: lda shield_tile_dmg7, x
001780  1  8D 23 9F        sta VERA_data0
001783  1  E8              inx
001784  1  D0 F7           bne @up_s7b
001786  1  A2 80           ldx #128
001788  1  BD 4F 31     @up_s7c: lda shield_tile_dmg7 + 128, x
00178B  1  8D 23 9F        sta VERA_data0
00178E  1  E8              inx
00178F  1  D0 F7           bne @up_s7c
001791  1  A2 80           ldx #128
001793  1  BD CF 31     @up_s7d: lda shield_tile_dmg7 + 256, x
001796  1  8D 23 9F        sta VERA_data0
001799  1  E8              inx
00179A  1  D0 F7           bne @up_s7d
00179C  1               
00179C  1                  ; --- reset damage counters ---
00179C  1  64 rr           stz shield_damage+0
00179E  1  64 rr           stz shield_damage+1
0017A0  1  64 rr           stz shield_damage+2
0017A2  1  64 rr           stz shield_damage+3
