000810  1               ;******************************************************************
000810  1               ; Constants
000810  1               ;******************************************************************
000810  1               
000810  1               ; VERA display control
000810  1               VERA_SPRITE_EN  = %01000000      ; VERA_dc_video bit 6: enable sprites
000810  1               
000810  1               ; PETSCII control codes
000810  1               PETSCII_WHITE   = $05            ; set text color to white
000810  1               PETSCII_CLR     = $93            ; clear screen and home cursor
000810  1               PETSCII_HOME    = $13            ; home cursor (no clear)
000810  1               PETSCII_RETURN  = $0D            ; carriage return
000810  1               
000810  1               ; SCREEN_SET_CHARSET font numbers (call address $FF62)
000810  1               CHARSET_UPPER   = 1              ; Commodore upper/graphics: $41-$5A = A-Z
000810  1               CHARSET_LOWER   = 2              ; Commodore lower/upper:    $41-$5A = a-z (lowercase)
000810  1               
000810  1               ; Key codes (PETSCII)
000810  1               KEY_RUN_STOP    = $03            ; RUN/STOP — exit game
000810  1               
000810  1               ; Input flag bits (key_flags)
000810  1               KEY_LEFT        = %00000001
000810  1               KEY_RIGHT       = %00000010
000810  1               KEY_FIRE        = %00000100
000810  1               
000810  1               ; JOYSTICK_GET .A return: {B,Y,Sel,Sta,Up,Dn,Left,Right} active low
000810  1               JOY_RIGHT       = %00000001     ; bit 0
000810  1               JOY_LEFT        = %00000010     ; bit 1
000810  1               
000810  1               ; Player ship — all positions in VERA 640x480 coordinate space
000810  1               PLAYER_Y        = 420            ; fixed Y, near bottom (479 = bottom edge)
000810  1               PLAYER_X_INIT   = 312            ; starting X, centred  ((640-16)/2)
000810  1               PLAYER_X_MIN    = 8              ; left  boundary (sprite left edge)
000810  1               PLAYER_X_MAX    = 616            ; right boundary (640 - 16px sprite - 8px margin)
000810  1               PLAYER_SPEED    = 4              ; pixels per frame
000810  1               
000810  1               ; Sprite attribute encoding helpers
000810  1               SPRITE1_ATTR    = $1FC08 ; sprite 1 attribute base ($1FC00=sprite 0, reserved for KERNAL mouse)
000810  1               SPR_Z_FRONT     = %00001100     ; byte 6: z-depth = %11 in bits 3-2 (in front of all layers)
000810  1               SPR_16x16_PAL0  = %01010000     ; byte 7: width=1(16px), height=1(16px), palette_off=0
000810  1               SPR_32x16_PAL0  = %10010000     ; byte 7: width=2(32px), height=1(16px), palette_off=0
000810  1               SPR_32x32_PAL0  = %10100000     ; byte 7: width=2(32px), height=2(32px), palette_off=0
000810  1               SPR_8x8_PAL0    = %00000000     ; byte 7: width=0(8px),  height=0(8px),  palette_off=0
000810  1               
000810  1               ; Explosion sprite (slot 4)
000810  1               VRAM_EXPLOSION     = $00440     ; explosion pixel data (128 bytes, 16x16 4bpp)
000810  1               EXPLODE_SPRITE_ATTR = $1FC20    ; sprite 4 attribute base (explosion)
000810  1               EXPLODE_FRAMES     = 30         ; display duration in frames (~0.5 sec at 60 Hz)
000810  1               
000810  1               ; Invader bullets (sprite slots 5-7)
000810  1               VRAM_INV_BULLET    = $00420     ; invader bullet pixel data (32 bytes, 8x8 4bpp)
000810  1               INV_BULLET_SPR_BASE = $1FC28    ; sprite 5 attribute base (first invader bullet)
000810  1               INV_BULLET_SPEED   = 6          ; VERA pixels per frame downward (=3 game pixels)
000810  1               INV_FIRE_TIMER_MIN = 10         ; minimum frames between fire attempts
000810  1               INV_FIRE_TIMER_INIT = 90        ; frames before first shot
000810  1               
000810  1               ; Player lives
000810  1               LIVES_INIT         = 3          ; starting lives
000810  1               INV_HIT_FRAMES     = 120        ; invincibility duration after being hit (2 sec at 60 Hz)
000810  1               
000810  1               ; UFO saucer (sprite slot 3)
000810  1               UFO_SPRITE_ATTR    = $1FC18      ; sprite 3 attribute base ($1FC00 + 3*8)
000810  1               VRAM_UFO           = $01500      ; UFO pixel data (128 bytes, 16x16 4bpp, after shield tiles)
000810  1               UFO_Y              = 32          ; VERA Y coord (= display pixel 16, top of play field)
000810  1               UFO_SPEED          = 2           ; VERA pixels per frame rightward (1 display pixel/frame)
000810  1               UFO_TIMER_INIT     = 600         ; frames between UFO appearances (≈10 sec at 60 Hz)
000810  1               
000810  1               ; Wave progression
000810  1               WAVE_CLEAR_FRAMES  = 180         ; auto-advance delay after wave clear (≈3 sec at 60 Hz)
000810  1               WAVE_SPEED_STEP    = 5           ; inv_move_speed decreases by this each wave
000810  1               
000810  1               ; VERA PSG voice 3 — UFO drone (base addr $1F9C0 + 3*4 = $1F9CC)
000810  1               ; PSG byte layout: 0=FREQ_L, 1=FREQ_H, 2=volume([7]=R,[6]=L,[5:0]=vol 0-63), 3=waveform([7:6])
000810  1               ; Waveform codes: 00=pulse, 01=sawtooth, 10=triangle, 11=noise
000810  1               ; freq_hz ≈ freq_reg * 25000000 / (512 * 131072)  →  freq_reg ≈ freq_hz * 2.684
000810  1               VRAM_PSG_VOICE3    = VRAM_psg + 12   ; $1F9CC — voice 3 registers
000810  1               PSG_VOL_FULL       = $FF             ; R enable + L enable + volume 63
000810  1               PSG_WAVE_SAW       = %01000000       ; sawtooth waveform (bits 7:6 = 01)
000810  1               UFO_DRONE_FREQ1    = 1074            ; ≈400 Hz  ($0432)
000810  1               UFO_DRONE_FREQ2    = 1611            ; ≈600 Hz  ($064B)
000810  1               
000810  1               ; Shields
000810  1               SHIELD_Y           = 352        ; VERA Y coordinate for all 4 shields (176 display pixels)
000810  1               SHIELD_SPR_BASE    = $1FE10     ; sprite slot 66 attr ($1FC00 + 66*8); slots 8-65 in use
000810  1               VRAM_SHIELD_FULL   = $00500     ; 512-byte 32x32 4bpp tile: intact
000810  1               VRAM_SHIELD_DMG1   = $00700     ; 12% damaged
000810  1               VRAM_SHIELD_DMG2   = $00900     ; 25% damaged
000810  1               VRAM_SHIELD_DMG3   = $00B00     ; 37% damaged
000810  1               VRAM_SHIELD_DMG4   = $00D00     ; 50% damaged
000810  1               VRAM_SHIELD_DMG5   = $00F00     ; 62% damaged
000810  1               VRAM_SHIELD_DMG6   = $01100     ; 75% damaged
000810  1               VRAM_SHIELD_DMG7   = $01300     ; nearly destroyed
000810  1               
000810  1               ; Player bullet
000810  1               BULLET_SPRITE_ATTR = $1FC10     ; sprite 2 attribute base (player bullet)
000810  1               VRAM_BULLET     = $00400        ; player bullet pixel data (32 bytes, 8x8 4bpp)
000810  1               BULLET_SPEED    = 12            ; VERA pixels per frame upward (= 6 game pixels)
000810  1               BULLET_Y_INIT   = PLAYER_Y - 8 ; bullet starts just above player ship top
000810  1               
000810  1               ; Invader grid geometry (VERA 640x480 coordinate space)
000810  1               INV_GRID_X_INIT   = 112         ; left-column X at start (centered: (640 - 10*40 - 16) / 2 = 112)
000810  1               INV_GRID_Y_BASE   = 80          ; top-row Y, fixed base (drops added via inv_offset_y)
000810  1               INV_SPACING_X     = 40          ; VERA pixels between invader column origins
000810  1               INV_SPACING_Y     = 48          ; VERA pixels between invader row origins
000810  1               INV_STEP_X        = 4           ; VERA pixels per march step
000810  1               INV_DROP_Y        = 16          ; VERA pixels per grid drop
000810  1               INV_MOVE_SPEED_INIT = 50        ; frames between march steps (initial)
000810  1               INV_COUNT_INIT    = 55
000810  1               INV_MOVE_SPEED_MIN = 5           ; minimum frames per march step
000810  1               
000810  1               ; Grid boundary: when grid_x reaches these values, reverse and drop
000810  1               ; Rightmost invader base X = grid_x + 10*INV_SPACING_X (=400). Right wall = 624 (640-16px).
000810  1               ; So right limit = 624 - 400 - 16 = 208
000810  1               INV_X_RIGHT_LIM   = 208
000810  1               INV_X_LEFT_LIM    = 16          ; leftmost sprite at x=grid_x must stay >= 16
000810  1               
000810  1               ; VRAM addresses for invader sprite pixel data (128 bytes each, 16x16 4bpp)
000810  1               VRAM_INV_A_F0   = $00100        ; Type A (crab,   bottom rows 3-4), frame 0
000810  1               VRAM_INV_A_F1   = $00180        ; Type A frame 1
000810  1               VRAM_INV_B_F0   = $00200        ; Type B (octopus, middle rows 1-2), frame 0
000810  1               VRAM_INV_B_F1   = $00280        ; Type B frame 1
000810  1               VRAM_INV_C_F0   = $00300        ; Type C (squid,   top row 0), frame 0
000810  1               VRAM_INV_C_F1   = $00380        ; Type C frame 1
000810  1               
000810  1               ; Sprite addr[12:5] byte values for each type/frame (= VRAM_addr >> 5)
000810  1               ;   VRAM $00100>>5=$08  $00180>>5=$0C  $00200>>5=$10  $00280>>5=$14  $00300>>5=$18  $00380>>5=$1C
000810  1               INV_ATTR_BASE   = $1FC58        ; sprite slot 11 = first invader ($1FC00 + 11*8)
000810  1               INV_SPRITE_SLOT = 11            ; first invader sprite slot index
000810  1               
000810  1               ;******************************************************************
000810  1               ; start — main program entry point
000810  1               ;******************************************************************
000810  1               start:
000810  1  78              sei                           ; disable interrupts during init
000811  1               
000811  1                  ; Switch to 40-column text mode (mode 0)
000811  1                  ; Carry clear = SET mode (carry set = READ mode)
000811  1  18              clc
000812  1  A9 00           lda #$00
000814  1  20 5F FF        jsr SCREEN_MODE
000817  1               
000817  1                  ; Seed PRNG with hardware entropy
000817  1  20 CF FE        jsr ENTROPY_GET
00081A  1  85 rr           sta rand_seed_lo
00081C  1  86 rr           stx rand_seed_hi
00081E  1               
00081E  1                  ; Enable sprites in VERA display controller
00081E  1  9C 25 9F        stz VERA_ctrl                 ; DCSEL=0, ADDRSEL=0
000821  1  AD 29 9F        lda VERA_dc_video
000824  1  09 40           ora #VERA_SPRITE_EN
000826  1  8D 29 9F        sta VERA_dc_video
000829  1               
000829  1               
000829  1                  ; Clear game variables
000829  1  64 rr           stz key_last
00082B  1  64 rr           stz key_flags
00082D  1  64 rr           stz frame_count
00082F  1  64 rr           stz bullet_active
000831  1  64 rr           stz score_lo
000833  1  64 rr           stz score_mid
000835  1  64 rr           stz score_hi
000837  1  64 rr           stz hi_score_lo
000839  1  64 rr           stz hi_score_mid
00083B  1  64 rr           stz hi_score_hi
00083D  1  64 rr           stz ufo_active
00083F  1  A9 58           lda #<UFO_TIMER_INIT
000841  1  85 rr           sta ufo_timer_lo
000843  1  A9 02           lda #>UFO_TIMER_INIT
000845  1  85 rr           sta ufo_timer_hi
000847  1  64 rr           stz shot_count
000849  1  A9 01           lda #1
00084B  1  85 rr           sta wave
00084D  1  A9 32           lda #INV_MOVE_SPEED_INIT
00084F  1  85 rr           sta wave_init_speed
000851  1               
000851  1                  ; Set initial player position before sprite init reads it
000851  1  20 78 09        jsr init_player
000854  1               
000854  1  58              cli                           ; re-enable interrupts
000855  1               
000855  1                  ; Switch to Commodore uppercase/graphics charset: $41-$5A = A-Z
000855  1                  ; Must be called AFTER SCREEN_MODE (which resets to lowercase by default)
000855  1  A9 01           lda #CHARSET_UPPER
000857  1  20 62 FF        jsr SCREEN_SET_CHARSET
00085A  1               
00085A  1                  ; Clear screen and set text color
00085A  1  A9 05           lda #PETSCII_WHITE
00085C  1  20 D2 FF        jsr CHROUT
00085F  1  A9 93           lda #PETSCII_CLR
000861  1  20 D2 FF        jsr CHROUT
000864  1               
000864  1                  ; Upload sprite pixel data and configure sprite 1 attributes
000864  1  20 87 09        jsr init_sprites
000867  1               
000867  1                  ; Upload invader sprite data, set palette, init grid state, place sprites
000867  1  20 86 0B        jsr init_invaders
00086A  1  20 22 15        jsr hide_all_inv_sprites     ; hide all 55 during title screen
00086D  1               
00086D  1  20 CB 13        jsr draw_title_screen
000870  1               
000870  1               ;------------------------------------------------------------------
000870  1               ; title_loop — wait for SPACE; blink "PRESS SPACE TO START"
000870  1               ;------------------------------------------------------------------
000870  1               title_loop:
000870  1  20 2B 09        jsr wait_vsync
000873  1  E6 rr           inc frame_count
000875  1  20 2D 09        jsr update_input
000878  1               
000878  1  A5 rr           lda key_last
00087A  1  C9 03           cmp #KEY_RUN_STOP
00087C  1  D0 03           bne @tl_no_exit
00087E  1  4C 23 09        jmp exit_game
000881  1               @tl_no_exit:
000881  1               
000881  1  A5 rr           lda key_flags
000883  1  29 04           and #KEY_FIRE
000885  1  D0 33           bne start_game
000887  1               
000887  1                  ; blink using frame_count bit 5 (~2 Hz)
000887  1  A5 rr           lda frame_count
000889  1  29 20           and #$20
00088B  1  D0 15           bne @tl_on
00088D  1               @tl_off:
00088D  1  A9 11           lda #17
00088F  1  A0 0A           ldy #10
000891  1  18              clc
000892  1  20 F0 FF        jsr PLOT
000895  1  A2 14           ldx #20                      ; erase 20 chars of "PRESS SPACE TO START"
000897  1  A9 20        @tl_erase: lda #' '
000899  1  20 D2 FF        jsr CHROUT
00089C  1  CA              dex
00089D  1  D0 F8           bne @tl_erase
00089F  1  4C 70 08        jmp title_loop
0008A2  1               @tl_on:
0008A2  1  A9 11           lda #17
0008A4  1  A0 0A           ldy #10
0008A6  1  18              clc
0008A7  1  20 F0 FF        jsr PLOT
0008AA  1  A2 00           ldx #0
0008AC  1  BD 17 1B     @tl_print: lda str_press_space, x
0008AF  1  F0 06           beq @tl_print_done
0008B1  1  20 D2 FF        jsr CHROUT
0008B4  1  E8              inx
0008B5  1  80 F5           bra @tl_print
0008B7  1               @tl_print_done:
0008B7  1  4C 70 08        jmp title_loop
0008BA  1               
0008BA  1               start_game:
0008BA  1  20 BA 0C        jsr update_invader_sprites   ; re-enable all 55 invaders at grid positions
0008BD  1  20 3F 15        jsr init_shields             ; upload shield tiles, init damage counters, place sprites
0008C0  1  A9 93           lda #PETSCII_CLR
0008C2  1  20 D2 FF        jsr CHROUT                   ; clear title text, leave sprites visible
0008C5  1               
0008C5  1               ;******************************************************************
0008C5  1               ; main_loop — one iteration per video frame (60 Hz)
0008C5  1               ;******************************************************************
0008C5  1               main_loop:
0008C5  1  20 2B 09        jsr wait_vsync
0008C8  1               
0008C8  1  E6 rr           inc frame_count
0008CA  1               
0008CA  1  20 2D 09        jsr update_input              ; fills key_flags (joystick) + key_last (GETIN)
0008CD  1               
0008CD  1  A5 rr           lda key_last
0008CF  1  C9 03           cmp #KEY_RUN_STOP
0008D1  1  F0 50           beq exit_game
0008D3  1               
0008D3  1                  ; --- invincibility timer ---
0008D3  1  A5 rr           lda inv_hit_timer
0008D5  1  F0 02           beq @no_inv_dec
0008D7  1  C6 rr           dec inv_hit_timer
0008D9  1               @no_inv_dec:
0008D9  1               
0008D9  1  20 70 0D        jsr move_player               ; apply movement, clamp to boundaries
0008DC  1  20 BF 0D        jsr update_player_sprite      ; write new X to VERA sprite 1
0008DF  1               
0008DF  1                  ; --- fire player bullet (SPACE pressed and bullet not already active) ---
0008DF  1  A5 rr           lda key_flags
0008E1  1  29 04           and #KEY_FIRE
0008E3  1  F0 07           beq @skip_fire
0008E5  1  A5 rr           lda bullet_active
0008E7  1  D0 03           bne @skip_fire
0008E9  1  20 02 0E        jsr fire_bullet
0008EC  1               @skip_fire:
0008EC  1               
0008EC  1                  ; --- move bullet if active ---
0008EC  1  A5 rr           lda bullet_active
0008EE  1  F0 03           beq @skip_bullet_move
0008F0  1  20 21 0E        jsr move_bullet
0008F3  1               @skip_bullet_move:
0008F3  1               
0008F3  1                  ; --- check player bullet vs invader collision ---
0008F3  1  20 72 0E        jsr check_bullet_invader
0008F6  1               
0008F6  1                  ; --- check player bullet vs shield collision ---
0008F6  1  20 CB 17        jsr check_bullet_shields
0008F9  1               
0008F9  1                  ; --- explosion timer ---
0008F9  1  20 C1 0F        jsr update_explosion
0008FC  1               
0008FC  1                  ; --- invader bullets: move, spawn, boundary check ---
0008FC  1  20 F0 0F        jsr update_inv_bullets
0008FF  1               
0008FF  1                  ; --- invader bullet vs player collision ---
0008FF  1  20 FE 10        jsr check_inv_bullet_player
000902  1               
000902  1                  ; --- invader bullet vs shield collision ---
000902  1  20 3D 18        jsr check_invbullet_shields
000905  1               
000905  1                  ; --- UFO spawn/move and player bullet collision ---
000905  1  20 DE 18        jsr update_ufo
000908  1  20 77 19        jsr check_bullet_ufo
00090B  1               
00090B  1                  ; --- Invader march timer ---
00090B  1  C6 rr           dec inv_move_timer
00090D  1  D0 07           bne @skip_inv_step
00090F  1  20 55 0C        jsr step_invaders             ; move grid, check bounds, update sprites
000912  1  A5 rr           lda inv_move_speed
000914  1  85 rr           sta inv_move_timer
000916  1               @skip_inv_step:
000916  1               
000916  1                  ; --- check wave clear (all 55 invaders dead) ---
000916  1  A5 rr           lda inv_count
000918  1  D0 03           bne @no_wave_clear
00091A  1  4C E6 12        jmp wave_clear_screen
00091D  1               @no_wave_clear:
00091D  1               
00091D  1  20 78 1A        jsr update_hud                ; refresh text readouts
000920  1               
000920  1  4C C5 08        jmp main_loop
000923  1               
000923  1               ;------------------------------------------------------------------
000923  1               exit_game:
000923  1  A9 93           lda #PETSCII_CLR
000925  1  20 D2 FF        jsr CHROUT
000928  1  4C 47 FF        jmp ENTER_BASIC
00092B  1               
00092B  1               ;******************************************************************
00092B  1               ; wait_vsync — busy-poll VERA_isr until VSYNC, then clear flag
00092B  1               ;******************************************************************
00092B  1               wait_vsync:
00092B  1                  ; WAI sleeps the CPU until any IRQ fires.  The KERNAL's VSYNC IRQ
00092B  1                  ; handler (60 Hz) wakes us up and has already cleared VERA_isr bit 0
00092B  1                  ; by the time execution returns here, so polling VERA_isr would loop
00092B  1                  ; forever.  Just return — one WAI ≈ one frame.
00092B  1  CB              wai
00092C  1  60              rts
00092D  1               
00092D  1               ;******************************************************************
00092D  1               ; update_input — joystick + GETIN keyboard input each frame
00092D  1               ;
00092D  1               ;   key_flags bits set this frame:
00092D  1               ;     KEY_LEFT  — left arrow held
00092D  1               ;     KEY_RIGHT — right arrow held
00092D  1               ;     KEY_FIRE  — space bar pressed
00092D  1               ;   key_last   — raw PETSCII from GETIN (RUN/STOP etc.)
00092D  1               ;
00092D  1               ;   JOYSTICK_GET(0) = keyboard-as-joystick; gives smooth held-key
00092D  1               ;   movement with no repeat delay.  GETIN handles space and RUN/STOP.
00092D  1               ;******************************************************************
00092D  1               update_input:
00092D  1  64 rr           stz key_flags
00092F  1  64 rr           stz key_last
000931  1               
000931  1                  ; --- joystick 0 = keyboard d-pad (active low: 0 = pressed) ---
000931  1                  ; Byte returned: {B,Y,Sel,Sta,Up,Dn,Left,Right} bits 7–0
000931  1  A9 00           lda #0
000933  1  20 56 FF        jsr JOYSTICK_GET
000936  1  48              pha                           ; save — AND destroys .A
000937  1               
000937  1  29 01           and #JOY_RIGHT                ; bit 0: right arrow
000939  1  D0 06           bne @not_right
00093B  1  A5 rr           lda key_flags
00093D  1  09 02           ora #KEY_RIGHT
00093F  1  85 rr           sta key_flags
000941  1               @not_right:
000941  1  68              pla
000942  1  29 02           and #JOY_LEFT                 ; bit 1: left arrow
000944  1  D0 06           bne @not_left
000946  1  A5 rr           lda key_flags
000948  1  09 01           ora #KEY_LEFT
00094A  1  85 rr           sta key_flags
00094C  1               @not_left:
00094C  1               
00094C  1                  ; --- GETIN — discrete events: fire, RUN/STOP, arrow fallback ---
00094C  1               @getin_drain:
00094C  1  20 E4 FF        jsr GETIN
00094F  1  F0 26           beq @getin_done               ; buffer empty
000951  1  85 rr           sta key_last
000953  1  C9 9D           cmp #$9D                      ; cursor left (PETSCII)
000955  1  D0 08           bne @chk_right_getin
000957  1  A5 rr           lda key_flags
000959  1  09 01           ora #KEY_LEFT
00095B  1  85 rr           sta key_flags
00095D  1  80 ED           bra @getin_drain
00095F  1               @chk_right_getin:
00095F  1  C9 1D           cmp #$1D                      ; cursor right (PETSCII)
000961  1  D0 08           bne @chk_fire_getin
000963  1  A5 rr           lda key_flags
000965  1  09 02           ora #KEY_RIGHT
000967  1  85 rr           sta key_flags
000969  1  80 E1           bra @getin_drain
00096B  1               @chk_fire_getin:
00096B  1  C9 20           cmp #$20                      ; space = fire
00096D  1  D0 DD           bne @getin_drain
00096F  1  A5 rr           lda key_flags
000971  1  09 04           ora #KEY_FIRE
000973  1  85 rr           sta key_flags
000975  1  80 D5           bra @getin_drain
000977  1               @getin_done:
000977  1  60              rts
000978  1               
000978  1               ;******************************************************************
000978  1               ; init_player — set player_x to starting position
000978  1               ;******************************************************************
000978  1               init_player:
000978  1  A9 38           lda #<PLAYER_X_INIT
00097A  1  85 rr           sta player_x_lo
00097C  1  A9 01           lda #>PLAYER_X_INIT
00097E  1  85 rr           sta player_x_hi
000980  1  A9 03           lda #LIVES_INIT
000982  1  85 rr           sta lives
000984  1  64 rr           stz inv_hit_timer
000986  1  60              rts
000987  1               
000987  1               ;******************************************************************
000987  1               ; init_sprites — upload pixel data + write sprite 1 attributes
000987  1               ;
000987  1               ;   Sprite 0 ($1FC00) is reserved by the KERNAL mouse cursor —
000987  1               ;   we disable it and keep clear of $1FC00.
000987  1               ;
000987  1               ;   Sprite 1 ($1FC08) = player ship
000987  1               ;   Pixel data at VRAM $00080 (128 bytes, 16x16 4bpp)
000987  1               ;   Address encoding:  addr[12:5] = $00080>>5 = $04  → byte 0 = $04
000987  1               ;                      4bpp, addr[16:13] = 0          → byte 1 = $00
000987  1               ;******************************************************************
000987  1               init_sprites:
000987  1  9C 25 9F        stz VERA_ctrl
00098A  1               
00098A  1                  ; --- set palette entries 1-4 ---
00098A  1                  ; VERA palette entry N is 2 bytes at VRAM_palette + N*2
00098A  1                  ; Byte 0: [7:4]=Green [3:0]=Blue   Byte 1: [3:0]=Red (bits 7-4 unused)
00098A  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_palette + 2), 1   ; entry 1 (player white); stride=1 auto-advances
00098E  1  9F A9 FA 8D  
000992  1  21 9F A9 02  
000999  1  A9 FF           lda #$FF                               ; G=$F, B=$F
00099B  1  8D 23 9F        sta VERA_data0
00099E  1  A9 0F           lda #$0F                               ; R=$F  → white
0009A0  1  8D 23 9F        sta VERA_data0
0009A3  1                  ; entry 2 = cyan  (R=0, G=$F, B=$F)
0009A3  1  A9 FF           lda #$FF                               ; G=$F, B=$F
0009A5  1  8D 23 9F        sta VERA_data0
0009A8  1  A9 00           lda #$00                               ; R=$0
0009AA  1  8D 23 9F        sta VERA_data0
0009AD  1                  ; entry 3 = magenta (R=$F, G=0, B=$F)
0009AD  1  A9 0F           lda #$0F                               ; G=$0, B=$F
0009AF  1  8D 23 9F        sta VERA_data0
0009B2  1  A9 0F           lda #$0F                               ; R=$F
0009B4  1  8D 23 9F        sta VERA_data0
0009B7  1                  ; entry 4 = green  (R=0, G=$F, B=0)
0009B7  1  A9 F0           lda #$F0                               ; G=$F, B=$0
0009B9  1  8D 23 9F        sta VERA_data0
0009BC  1  A9 00           lda #$00                               ; R=$0
0009BE  1  8D 23 9F        sta VERA_data0
0009C1  1                  ; entry 5 = red    (R=$F, G=0, B=0)
0009C1  1  A9 00           lda #$00                               ; G=$0, B=$0
0009C3  1  8D 23 9F        sta VERA_data0
0009C6  1  A9 0F           lda #$0F                               ; R=$F
0009C8  1  8D 23 9F        sta VERA_data0
0009CB  1                  ; --- disable sprite 0 (KERNAL mouse cursor) ---
0009CB  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_sprattr + 6), 1   ; sprite 0 byte 6 = z-depth
0009CF  1  9F A9 FC 8D  
0009D3  1  21 9F A9 06  
0009DA  1  A9 00           lda #$00                               ; z-depth=0 → disabled
0009DC  1  8D 23 9F        sta VERA_data0
0009DF  1               
0009DF  1                  ; --- upload player sprite pixel data to VRAM $00080 ---
0009DF  1  A9 10 8D 22     VERA_SET_ADDR $00080, 1
0009E3  1  9F A9 00 8D  
0009E7  1  21 9F A9 80  
0009EE  1  A2 00           ldx #0
0009F0  1               @upload:
0009F0  1  BD 9F 1B        lda player_spr_data,x
0009F3  1  8D 23 9F        sta VERA_data0
0009F6  1  E8              inx
0009F7  1  E0 80           cpx #128
0009F9  1  D0 F5           bne @upload
0009FB  1               
0009FB  1                  ; --- write sprite 1 attribute bytes ---
0009FB  1  A9 11 8D 22     VERA_SET_ADDR SPRITE1_ATTR, 1
0009FF  1  9F A9 FC 8D  
000A03  1  21 9F A9 08  
000A0A  1  A9 04           lda #$04
000A0C  1  8D 23 9F        sta VERA_data0               ; byte 0: addr[12:5] = $00080>>5 = $04
000A0F  1  A9 00           lda #$00
000A11  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, addr[16:13] = 0
000A14  1  A5 rr           lda player_x_lo
000A16  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000A19  1  A5 rr           lda player_x_hi
000A1B  1  29 03           and #$03
000A1D  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000A20  1  A9 A4           lda #<PLAYER_Y
000A22  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000A25  1  A9 01           lda #>PLAYER_Y
000A27  1  29 03           and #$03
000A29  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000A2C  1  A9 0C           lda #SPR_Z_FRONT
000A2E  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3, no collision, no flip
000A31  1  A9 50           lda #SPR_16x16_PAL0
000A33  1  8D 23 9F        sta VERA_data0               ; byte 7: palette 0, 16x16
000A36  1               
000A36  1                  ; --- upload player bullet pixel data to VRAM $00400 ---
000A36  1  A9 10 8D 22     VERA_SET_ADDR VRAM_BULLET, 1
000A3A  1  9F A9 04 8D  
000A3E  1  21 9F A9 00  
000A45  1  A2 00           ldx #0
000A47  1               @up_bullet:
000A47  1  BD 1F 1C        lda bullet_spr_data,x
000A4A  1  8D 23 9F        sta VERA_data0
000A4D  1  E8              inx
000A4E  1  E0 20           cpx #32
000A50  1  D0 F5           bne @up_bullet
000A52  1               
000A52  1                  ; --- write sprite 2 attributes (initially disabled, z-depth=0) ---
000A52  1  A9 11 8D 22     VERA_SET_ADDR BULLET_SPRITE_ATTR, 1
000A56  1  9F A9 FC 8D  
000A5A  1  21 9F A9 10  
000A61  1  A9 20           lda #$20                     ; byte 0: addr[12:5] = $00400>>5 = $20
000A63  1  8D 23 9F        sta VERA_data0
000A66  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000A68  1  8D 23 9F        sta VERA_data0
000A6B  1  A9 00           lda #$00                     ; byte 2: X lo (arbitrary; sprite disabled)
000A6D  1  8D 23 9F        sta VERA_data0
000A70  1  A9 00           lda #$00                     ; byte 3: X hi
000A72  1  8D 23 9F        sta VERA_data0
000A75  1  A9 00           lda #$00                     ; byte 4: Y lo
000A77  1  8D 23 9F        sta VERA_data0
000A7A  1  A9 00           lda #$00                     ; byte 5: Y hi
000A7C  1  8D 23 9F        sta VERA_data0
000A7F  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000A81  1  8D 23 9F        sta VERA_data0
000A84  1  A9 00           lda #SPR_8x8_PAL0            ; byte 7: 8x8, palette 0
000A86  1  8D 23 9F        sta VERA_data0
000A89  1               
000A89  1                  ; --- upload explosion pixel data to VRAM $00440 ---
000A89  1  A9 10 8D 22     VERA_SET_ADDR VRAM_EXPLOSION, 1
000A8D  1  9F A9 04 8D  
000A91  1  21 9F A9 40  
000A98  1  A2 00           ldx #0
000A9A  1               @up_exp:
000A9A  1  BD F1 1C        lda explosion_pixels,x
000A9D  1  8D 23 9F        sta VERA_data0
000AA0  1  E8              inx
000AA1  1  E0 80           cpx #128
000AA3  1  D0 F5           bne @up_exp
000AA5  1               
000AA5  1                  ; --- write sprite 4 attributes (initially disabled) ---
000AA5  1                  ; addr[12:5] = VRAM_EXPLOSION>>5 = $00440>>5 = $22
000AA5  1  A9 11 8D 22     VERA_SET_ADDR EXPLODE_SPRITE_ATTR, 1
000AA9  1  9F A9 FC 8D  
000AAD  1  21 9F A9 20  
000AB4  1  A9 22           lda #$22                     ; byte 0: addr[12:5]
000AB6  1  8D 23 9F        sta VERA_data0
000AB9  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000ABB  1  8D 23 9F        sta VERA_data0
000ABE  1  A9 00           lda #$00                     ; byte 2: X lo (placeholder)
000AC0  1  8D 23 9F        sta VERA_data0
000AC3  1  A9 00           lda #$00                     ; byte 3: X hi
000AC5  1  8D 23 9F        sta VERA_data0
000AC8  1  A9 00           lda #$00                     ; byte 4: Y lo (placeholder)
000ACA  1  8D 23 9F        sta VERA_data0
000ACD  1  A9 00           lda #$00                     ; byte 5: Y hi
000ACF  1  8D 23 9F        sta VERA_data0
000AD2  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000AD4  1  8D 23 9F        sta VERA_data0
000AD7  1  A9 50           lda #SPR_16x16_PAL0          ; byte 7: 16x16, palette 0
000AD9  1  8D 23 9F        sta VERA_data0
000ADC  1               
000ADC  1  64 rr           stz exp_timer
000ADE  1               
000ADE  1                  ; --- upload invader bullet pixel data to VRAM $00420 ---
000ADE  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_BULLET, 1
000AE2  1  9F A9 04 8D  
000AE6  1  21 9F A9 20  
000AED  1  A2 00           ldx #0
000AEF  1               @up_ibul:
000AEF  1  BD D1 1C        lda inv_bullet_spr_data,x
000AF2  1  8D 23 9F        sta VERA_data0
000AF5  1  E8              inx
000AF6  1  E0 20           cpx #32
000AF8  1  D0 F5           bne @up_ibul
000AFA  1               
000AFA  1                  ; --- init 3 invader bullet sprites (slots 5-7, base $1FC28), all disabled ---
000AFA  1                  ; addr[12:5] = VRAM_INV_BULLET>>5 = $00420>>5 = $21
000AFA  1  A9 11 8D 22     VERA_SET_ADDR INV_BULLET_SPR_BASE, 1
000AFE  1  9F A9 FC 8D  
000B02  1  21 9F A9 28  
000B09  1  A2 03           ldx #3                       ; 3 sprites
000B0B  1               @init_ibspr:
000B0B  1  A9 21           lda #$21                     ; byte 0: addr[12:5] = $21
000B0D  1  8D 23 9F        sta VERA_data0
000B10  1  A9 00           lda #$00
000B12  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, bank 0
000B15  1  8D 23 9F        sta VERA_data0               ; byte 2: X lo
000B18  1  8D 23 9F        sta VERA_data0               ; byte 3: X hi
000B1B  1  8D 23 9F        sta VERA_data0               ; byte 4: Y lo
000B1E  1  8D 23 9F        sta VERA_data0               ; byte 5: Y hi
000B21  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=0 → disabled
000B24  1  8D 23 9F        sta VERA_data0               ; byte 7: 8x8, palette 0
000B27  1  CA              dex
000B28  1  D0 E1           bne @init_ibspr
000B2A  1               
000B2A  1                  ; --- clear invader bullet state ---
000B2A  1  64 rr           stz ibul_active+0
000B2C  1  64 rr           stz ibul_active+1
000B2E  1  64 rr           stz ibul_active+2
000B30  1  A9 5A           lda #INV_FIRE_TIMER_INIT
000B32  1  85 rr           sta inv_fire_timer
000B34  1               
000B34  1                  ; --- upload UFO pixel data → VRAM $01500 ---
000B34  1  A9 10 8D 22     VERA_SET_ADDR VRAM_UFO, 1
000B38  1  9F A9 15 8D  
000B3C  1  21 9F A9 00  
000B43  1  A2 80           ldx #128
000B45  1  BD F1 1C     @up_ufo: lda ufo_spr_data-128,x
000B48  1  8D 23 9F        sta VERA_data0
000B4B  1  E8              inx
000B4C  1  D0 F7           bne @up_ufo
000B4E  1               
000B4E  1                  ; --- write sprite 3 (UFO) attributes (initially disabled) ---
000B4E  1                  ; addr[12:5] = VRAM_UFO>>5 = $01500>>5 = $A8
000B4E  1  A9 11 8D 22     VERA_SET_ADDR UFO_SPRITE_ATTR, 1
000B52  1  9F A9 FC 8D  
000B56  1  21 9F A9 18  
000B5D  1  A9 A8           lda #$A8                     ; byte 0: addr[12:5]
000B5F  1  8D 23 9F        sta VERA_data0
000B62  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000B64  1  8D 23 9F        sta VERA_data0
000B67  1  A9 00           lda #$00                     ; byte 2: X lo
000B69  1  8D 23 9F        sta VERA_data0
000B6C  1  A9 00           lda #$00                     ; byte 3: X hi
000B6E  1  8D 23 9F        sta VERA_data0
000B71  1  A9 20           lda #<UFO_Y                  ; byte 4: Y lo
000B73  1  8D 23 9F        sta VERA_data0
000B76  1  A9 00           lda #>UFO_Y                  ; byte 5: Y hi
000B78  1  8D 23 9F        sta VERA_data0
000B7B  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000B7D  1  8D 23 9F        sta VERA_data0
000B80  1  A9 50           lda #SPR_16x16_PAL0          ; byte 7: 16x16, palette 0
000B82  1  8D 23 9F        sta VERA_data0
000B85  1               
000B85  1  60              rts
000B86  1               
000B86  1               ;******************************************************************
000B86  1               ; init_invaders — upload invader pixel data, init grid state, place sprites
000B86  1               ;******************************************************************
000B86  1               init_invaders:
000B86  1  9C 25 9F        stz VERA_ctrl
000B89  1               
000B89  1                  ; --- upload Type A frame 0 → VRAM $00100 ---
000B89  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F0, 1
000B8D  1  9F A9 01 8D  
000B91  1  21 9F A9 00  
000B98  1  A2 80           ldx #128
000B9A  1  BD 71 1D     @up_af0: lda inv_a_spr_f0-128,x
000B9D  1  8D 23 9F        sta VERA_data0
000BA0  1  E8              inx
000BA1  1  D0 F7           bne @up_af0
000BA3  1               
000BA3  1                  ; --- upload Type A frame 1 → VRAM $00180 ---
000BA3  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F1, 1
000BA7  1  9F A9 01 8D  
000BAB  1  21 9F A9 80  
000BB2  1  A2 80           ldx #128
000BB4  1  BD F1 1D     @up_af1: lda inv_a_spr_f1-128,x
000BB7  1  8D 23 9F        sta VERA_data0
000BBA  1  E8              inx
000BBB  1  D0 F7           bne @up_af1
000BBD  1               
000BBD  1                  ; --- upload Type B frame 0 → VRAM $00200 ---
000BBD  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F0, 1
000BC1  1  9F A9 02 8D  
000BC5  1  21 9F A9 00  
000BCC  1  A2 80           ldx #128
000BCE  1  BD 71 1E     @up_bf0: lda inv_b_spr_f0-128,x
000BD1  1  8D 23 9F        sta VERA_data0
000BD4  1  E8              inx
000BD5  1  D0 F7           bne @up_bf0
000BD7  1               
000BD7  1                  ; --- upload Type B frame 1 → VRAM $00280 ---
000BD7  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F1, 1
000BDB  1  9F A9 02 8D  
000BDF  1  21 9F A9 80  
000BE6  1  A2 80           ldx #128
000BE8  1  BD F1 1E     @up_bf1: lda inv_b_spr_f1-128,x
000BEB  1  8D 23 9F        sta VERA_data0
000BEE  1  E8              inx
000BEF  1  D0 F7           bne @up_bf1
000BF1  1               
000BF1  1                  ; --- upload Type C frame 0 → VRAM $00300 ---
000BF1  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F0, 1
000BF5  1  9F A9 03 8D  
000BF9  1  21 9F A9 00  
000C00  1  A2 80           ldx #128
000C02  1  BD 71 1F     @up_cf0: lda inv_c_spr_f0-128,x
000C05  1  8D 23 9F        sta VERA_data0
000C08  1  E8              inx
000C09  1  D0 F7           bne @up_cf0
000C0B  1               
000C0B  1                  ; --- upload Type C frame 1 → VRAM $00380 ---
000C0B  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F1, 1
000C0F  1  9F A9 03 8D  
000C13  1  21 9F A9 80  
000C1A  1  A2 80           ldx #128
000C1C  1  BD F1 1F     @up_cf1: lda inv_c_spr_f1-128,x
000C1F  1  8D 23 9F        sta VERA_data0
000C22  1  E8              inx
000C23  1  D0 F7           bne @up_cf1
000C25  1               
000C25  1                  ; --- initialize zero-page grid variables ---
000C25  1  A9 70           lda #<INV_GRID_X_INIT
000C27  1  85 rr           sta inv_grid_x_lo
000C29  1  A9 00           lda #>INV_GRID_X_INIT
000C2B  1  85 rr           sta inv_grid_x_hi
000C2D  1  64 rr           stz inv_offset_y
000C2F  1  64 rr           stz inv_direction
000C31  1  64 rr           stz inv_anim_frame
000C33  1  64 rr           stz inv_drop_flag
000C35  1               
000C35  1                  ; all 55 invaders alive: bytes 0-5 = $FF, byte 6 = $7F (55 bits)
000C35  1  A9 FF           lda #$FF
000C37  1  85 rr           sta inv_alive+0
000C39  1  85 rr           sta inv_alive+1
000C3B  1  85 rr           sta inv_alive+2
000C3D  1  85 rr           sta inv_alive+3
000C3F  1  85 rr           sta inv_alive+4
000C41  1  85 rr           sta inv_alive+5
000C43  1  A9 7F           lda #$7F
000C45  1  85 rr           sta inv_alive+6
000C47  1               
000C47  1  A9 37           lda #INV_COUNT_INIT
000C49  1  85 rr           sta inv_count
000C4B  1  A5 rr           lda wave_init_speed
000C4D  1  85 rr           sta inv_move_speed
000C4F  1  85 rr           sta inv_move_timer
000C51  1               
000C51  1                  ; --- write initial sprite attributes for all 55 invaders ---
000C51  1  20 BA 0C        jsr update_invader_sprites
000C54  1  60              rts
000C55  1               
000C55  1               ;******************************************************************
000C55  1               ; step_invaders — one march step: move or drop grid, toggle anim frame
000C55  1               ;   Called when inv_move_timer reaches 0.
000C55  1               ;   Updates inv_grid_x / inv_offset_y, sets inv_drop_flag as needed,
000C55  1               ;   then refreshes all VERA sprite positions.
000C55  1               ;******************************************************************
000C55  1               step_invaders:
000C55  1                  ; toggle animation frame
000C55  1  A5 rr           lda inv_anim_frame
000C57  1  49 01           eor #1
000C59  1  85 rr           sta inv_anim_frame
000C5B  1               
000C5B  1                  ; if drop flag is set: drop grid this step, skip march
000C5B  1  A5 rr           lda inv_drop_flag
000C5D  1  F0 0B           beq @do_march
000C5F  1  64 rr           stz inv_drop_flag
000C61  1  A5 rr           lda inv_offset_y
000C63  1  18              clc
000C64  1  69 10           adc #INV_DROP_Y
000C66  1  85 rr           sta inv_offset_y
000C68  1  80 4C           bra @sprites_done
000C6A  1               
000C6A  1               @do_march:
000C6A  1  A5 rr           lda inv_direction
000C6C  1  D0 25           bne @march_left
000C6E  1               
000C6E  1                  ; --- march right ---
000C6E  1  A5 rr           lda inv_grid_x_lo
000C70  1  18              clc
000C71  1  69 04           adc #INV_STEP_X
000C73  1  85 rr           sta inv_grid_x_lo
000C75  1  90 02           bcc @chk_right
000C77  1  E6 rr           inc inv_grid_x_hi
000C79  1               @chk_right:
000C79  1                  ; hit right if grid_x > INV_X_RIGHT_LIM (208, fits in 1 byte, hi always 0)
000C79  1  A5 rr           lda inv_grid_x_hi
000C7B  1  D0 06           bne @clamp_right          ; hi > 0 → definitely over limit
000C7D  1  A5 rr           lda inv_grid_x_lo
000C7F  1  C9 D1           cmp #INV_X_RIGHT_LIM + 1  ; C set if lo > limit
000C81  1  90 33           bcc @sprites_done
000C83  1               @clamp_right:
000C83  1  A9 D0           lda #<INV_X_RIGHT_LIM
000C85  1  85 rr           sta inv_grid_x_lo
000C87  1  A9 00           lda #>INV_X_RIGHT_LIM
000C89  1  85 rr           sta inv_grid_x_hi
000C8B  1  A9 01           lda #1
000C8D  1  85 rr           sta inv_direction
000C8F  1  85 rr           sta inv_drop_flag
000C91  1  80 23           bra @sprites_done
000C93  1               
000C93  1                  ; --- march left ---
000C93  1               @march_left:
000C93  1  A5 rr           lda inv_grid_x_lo
000C95  1  38              sec
000C96  1  E9 04           sbc #INV_STEP_X
000C98  1  85 rr           sta inv_grid_x_lo
000C9A  1  B0 02           bcs @chk_left             ; no borrow
000C9C  1  C6 rr           dec inv_grid_x_hi
000C9E  1               @chk_left:
000C9E  1                  ; hit left if hi went negative OR lo < INV_X_LEFT_LIM
000C9E  1  A5 rr           lda inv_grid_x_hi
000CA0  1  30 06           bmi @clamp_left
000CA2  1  A5 rr           lda inv_grid_x_lo
000CA4  1  C9 10           cmp #INV_X_LEFT_LIM
000CA6  1  B0 0E           bcs @sprites_done         ; lo >= left limit → ok
000CA8  1               @clamp_left:
000CA8  1  A9 10           lda #<INV_X_LEFT_LIM
000CAA  1  85 rr           sta inv_grid_x_lo
000CAC  1  A9 00           lda #>INV_X_LEFT_LIM
000CAE  1  85 rr           sta inv_grid_x_hi
000CB0  1  64 rr           stz inv_direction
000CB2  1  A9 01           lda #1
000CB4  1  85 rr           sta inv_drop_flag
000CB6  1               
000CB6  1               @sprites_done:
000CB6  1  20 BA 0C        jsr update_invader_sprites
000CB9  1  60              rts
000CBA  1               
000CBA  1               ;******************************************************************
000CBA  1               ; update_invader_sprites — write all 55 invader sprite attributes to VERA
000CBA  1               ;
000CBA  1               ;   VERA sprite slots 11-65 hold the 55 invaders.
000CBA  1               ;   Attributes base: $1FC58 ($1FC00 + 11*8).
000CBA  1               ;   With stride=1 the VERA address auto-increments, so we set it
000CBA  1               ;   once and write all 440 bytes sequentially.
000CBA  1               ;
000CBA  1               ;   Byte layout per sprite:
000CBA  1               ;     0: data addr[12:5]   (encodes VRAM pixel data address + frame)
000CBA  1               ;     1: $00               (4bpp, addr[16:13]=0)
000CBA  1               ;     2: X[7:0]
000CBA  1               ;     3: X[9:8]
000CBA  1               ;     4: Y[7:0]
000CBA  1               ;     5: Y[9:8]
000CBA  1               ;     6: z-depth/collision
000CBA  1               ;     7: palette / size
000CBA  1               ;
000CBA  1               ;   Invader index i = row*11 + col; alive bit i in inv_alive bitmap.
000CBA  1               ;   For Phase 3 all invaders are alive; alive check will be added Phase 4.
000CBA  1               ;******************************************************************
000CBA  1               update_invader_sprites:
000CBA  1  9C 25 9F        stz VERA_ctrl
000CBD  1  A9 11           lda #$11              ; stride=1, VRAM bank bit=1 (addr $1Fxxxx)
000CBF  1  8D 22 9F        sta VERA_addr_bank
000CC2  1  A9 FC           lda #$FC
000CC4  1  8D 21 9F        sta VERA_addr_high
000CC7  1  A9 58           lda #$58
000CC9  1  8D 20 9F        sta VERA_addr_low     ; VERA now at $1FC58, auto-increments by 1
000CCC  1               
000CCC  1                  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000CCC  1  A9 50           lda #<INV_GRID_Y_BASE
000CCE  1  18              clc
000CCF  1  65 rr           adc inv_offset_y
000CD1  1  85 rr           sta zp_y_base_lo
000CD3  1  A9 00           lda #>INV_GRID_Y_BASE
000CD5  1  69 00           adc #0
000CD7  1  85 rr           sta zp_y_base_hi
000CD9  1               
000CD9  1  64 rr           stz zp_row
000CDB  1               @row_loop:
000CDB  1                  ; compute row Y: zp_row_y = zp_y_base + row_y_offsets[row]
000CDB  1  A4 rr           ldy zp_row
000CDD  1  B9 5F 1C        lda row_y_offsets,y
000CE0  1  18              clc
000CE1  1  65 rr           adc zp_y_base_lo
000CE3  1  85 rr           sta zp_row_y_lo
000CE5  1  A9 00           lda #0
000CE7  1  65 rr           adc zp_y_base_hi
000CE9  1  85 rr           sta zp_row_y_hi
000CEB  1               
000CEB  1                  ; select addr byte0 based on row type and animation frame
000CEB  1  A4 rr           ldy zp_row
000CED  1  A5 rr           lda inv_anim_frame
000CEF  1  F0 05           beq @use_f0
000CF1  1  B9 44 1C        lda inv_addr_b0_f1,y
000CF4  1  80 03           bra @got_b0
000CF6  1               @use_f0:
000CF6  1  B9 3F 1C        lda inv_addr_b0_f0,y
000CF9  1               @got_b0:
000CF9  1  85 rr           sta zp_addr_b0
000CFB  1               
000CFB  1  20 07 0D        jsr update_invader_row
000CFE  1               
000CFE  1  E6 rr           inc zp_row
000D00  1  A5 rr           lda zp_row
000D02  1  C9 05           cmp #5
000D04  1  D0 D5           bne @row_loop
000D06  1               
000D06  1  60              rts
000D07  1               
000D07  1               ;******************************************************************
000D07  1               ; update_invader_row — write 11 sprite attribute blocks for one row
000D07  1               ;
000D07  1               ;   Inputs (ZP): zp_row, zp_addr_b0, zp_row_y_lo/hi, inv_grid_x_lo/hi
000D07  1               ;   VERA address register must already be set to the first sprite slot
000D07  1               ;   for this row on entry (maintained by the sequential write stream).
000D07  1               ;******************************************************************
000D07  1               update_invader_row:
000D07  1  64 rr           stz zp_col
000D09  1               @col_loop:
000D09  1                  ; --- determine z-depth from alive bitmap ---
000D09  1                  ; index = inv_row_base[row] + col; byte = index>>3; bit = index&7
000D09  1  A4 rr           ldy zp_row
000D0B  1  B9 64 1C        lda inv_row_base,y
000D0E  1  18              clc
000D0F  1  65 rr           adc zp_col
000D11  1  A8              tay                   ; Y = invader index
000D12  1  29 07           and #$07
000D14  1  AA              tax                   ; X = bit index
000D15  1  BD 69 1C        lda bit_masks,x
000D18  1  48              pha                   ; save bit mask
000D19  1  98              tya
000D1A  1  4A              lsr
000D1B  1  4A              lsr
000D1C  1  4A              lsr
000D1D  1  A8              tay                   ; Y = byte index into inv_alive
000D1E  1  68              pla                   ; A = bit mask
000D1F  1  39 rr rr        and inv_alive,y
000D22  1  F0 04           beq @zdepth_off
000D24  1  A9 0C           lda #SPR_Z_FRONT
000D26  1  80 02           bra @zdepth_done
000D28  1               @zdepth_off:
000D28  1  A9 00           lda #0
000D2A  1               @zdepth_done:
000D2A  1  85 rr           sta zp_scratch_lo     ; save z-depth before VERA stream starts
000D2C  1               
000D2C  1                  ; --- compute sprite X = inv_grid_x + col_x_offsets[col] ---
000D2C  1  A4 rr           ldy zp_col
000D2E  1  B9 49 1C        lda col_x_lo,y
000D31  1  18              clc
000D32  1  65 rr           adc inv_grid_x_lo
000D34  1  85 rr           sta zp_x_lo
000D36  1  B9 54 1C        lda col_x_hi,y
000D39  1  65 rr           adc inv_grid_x_hi
000D3B  1  85 rr           sta zp_x_hi
000D3D  1               
000D3D  1                  ; --- write 8 attribute bytes (VERA auto-increments) ---
000D3D  1  A5 rr           lda zp_addr_b0
000D3F  1  8D 23 9F        sta VERA_data0        ; byte 0: data addr[12:5]
000D42  1  9C 23 9F        stz VERA_data0        ; byte 1: 4bpp, addr[16:13]=0
000D45  1  A5 rr           lda zp_x_lo
000D47  1  8D 23 9F        sta VERA_data0        ; byte 2: X[7:0]
000D4A  1  A5 rr           lda zp_x_hi
000D4C  1  29 03           and #$03
000D4E  1  8D 23 9F        sta VERA_data0        ; byte 3: X[9:8]
000D51  1  A5 rr           lda zp_row_y_lo
000D53  1  8D 23 9F        sta VERA_data0        ; byte 4: Y[7:0]
000D56  1  A5 rr           lda zp_row_y_hi
000D58  1  29 03           and #$03
000D5A  1  8D 23 9F        sta VERA_data0        ; byte 5: Y[9:8]
000D5D  1  A5 rr           lda zp_scratch_lo
000D5F  1  8D 23 9F        sta VERA_data0        ; byte 6: z-depth (SPR_Z_FRONT if alive, 0 if dead)
000D62  1  A9 50           lda #SPR_16x16_PAL0
000D64  1  8D 23 9F        sta VERA_data0        ; byte 7: 16x16, palette offset 0
000D67  1               
000D67  1  E6 rr           inc zp_col
000D69  1  A5 rr           lda zp_col
000D6B  1  C9 0B           cmp #11
000D6D  1  D0 9A           bne @col_loop
000D6F  1               
000D6F  1  60              rts
000D70  1               
000D70  1               ;******************************************************************
000D70  1               ; move_player — apply key_flags movement and clamp to screen edges
000D70  1               ;******************************************************************
000D70  1               move_player:
000D70  1  A5 rr           lda key_flags
000D72  1               
000D72  1                  ; --- move left ---
000D72  1  29 01           and #KEY_LEFT
000D74  1  F0 1F           beq @check_right
000D76  1  A5 rr           lda player_x_lo
000D78  1  38              sec
000D79  1  E9 04           sbc #PLAYER_SPEED
000D7B  1  85 rr           sta player_x_lo
000D7D  1  B0 02           bcs @clamp_left              ; no borrow → hi unchanged
000D7F  1  C6 rr           dec player_x_hi
000D81  1               @clamp_left:
000D81  1                  ; Clamp: if hi went negative ($FF) or (hi=0 AND lo < min) → set to min
000D81  1  A5 rr           lda player_x_hi
000D83  1  30 08           bmi @set_min                 ; $80–$FF = underflowed
000D85  1  D0 0E           bne @check_right             ; hi > 0 → still above minimum
000D87  1  A5 rr           lda player_x_lo
000D89  1  C9 08           cmp #PLAYER_X_MIN
000D8B  1  B0 08           bcs @check_right             ; lo >= min → ok
000D8D  1               @set_min:
000D8D  1  A9 08           lda #<PLAYER_X_MIN
000D8F  1  85 rr           sta player_x_lo
000D91  1  A9 00           lda #>PLAYER_X_MIN
000D93  1  85 rr           sta player_x_hi
000D95  1               
000D95  1                  ; --- move right ---
000D95  1               @check_right:
000D95  1  A5 rr           lda key_flags
000D97  1  29 02           and #KEY_RIGHT
000D99  1  F0 23           beq @move_done
000D9B  1  A5 rr           lda player_x_lo
000D9D  1  18              clc
000D9E  1  69 04           adc #PLAYER_SPEED
000DA0  1  85 rr           sta player_x_lo
000DA2  1  90 02           bcc @clamp_right             ; no carry → hi unchanged
000DA4  1  E6 rr           inc player_x_hi
000DA6  1               @clamp_right:
000DA6  1                  ; Clamp: if hi > max_hi, OR (hi == max_hi AND lo > max_lo) → set to max
000DA6  1  A5 rr           lda player_x_hi
000DA8  1  C9 02           cmp #>PLAYER_X_MAX
000DAA  1  90 12           bcc @move_done               ; hi < max_hi → definitely ok
000DAC  1  D0 08           bne @set_max                 ; hi > max_hi → over limit
000DAE  1  A5 rr           lda player_x_lo
000DB0  1  C9 68           cmp #<PLAYER_X_MAX
000DB2  1  90 0A           bcc @move_done               ; lo < max_lo when hi == max_hi → ok
000DB4  1  F0 08           beq @move_done               ; lo == max_lo → exactly at max, ok
000DB6  1               @set_max:
000DB6  1  A9 68           lda #<PLAYER_X_MAX
000DB8  1  85 rr           sta player_x_lo
000DBA  1  A9 02           lda #>PLAYER_X_MAX
000DBC  1  85 rr           sta player_x_hi
000DBE  1               
000DBE  1               @move_done:
000DBE  1  60              rts
000DBF  1               
000DBF  1               ;******************************************************************
000DBF  1               ; update_player_sprite — write current X position to sprite 1 in VERA
000DBF  1               ;   Only X needs updating (Y is fixed)
000DBF  1               ;******************************************************************
000DBF  1               update_player_sprite:
000DBF  1  9C 25 9F        stz VERA_ctrl
000DC2  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 2), 1
000DC6  1  9F A9 FC 8D  
000DCA  1  21 9F A9 0A  
000DD1  1  A5 rr           lda player_x_lo
000DD3  1  8D 23 9F        sta VERA_data0               ; sprite byte 2: X[7:0]
000DD6  1  A5 rr           lda player_x_hi
000DD8  1  29 03           and #$03
000DDA  1  8D 23 9F        sta VERA_data0               ; sprite byte 3: X[9:8]
000DDD  1                  ; update z-depth based on inv_hit_timer:
000DDD  1                  ;   timer = 0        → show solid (not hit)
000DDD  1                  ;   timer = 61-120   → hidden solid (1-second respawn delay)
000DDD  1                  ;   timer = 1-60     → flashing (invincible, visible warning)
000DDD  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 6), 1
000DE1  1  9F A9 FC 8D  
000DE5  1  21 9F A9 0E  
000DEC  1  A5 rr           lda inv_hit_timer
000DEE  1  F0 08           beq @show                    ; timer=0 → show solid
000DF0  1  C9 3D           cmp #61
000DF2  1  B0 08           bcs @hide                    ; timer>=61 → first second: fully hidden
000DF4  1  29 08           and #$08                     ; timer 1-60: bit 3 flips every 8 frames → ~4 Hz flash
000DF6  1  D0 04           bne @hide
000DF8  1               @show:
000DF8  1  A9 0C           lda #SPR_Z_FRONT
000DFA  1  80 02           bra @write_z
000DFC  1               @hide:
000DFC  1  A9 00           lda #0
000DFE  1               @write_z:
000DFE  1  8D 23 9F        sta VERA_data0               ; sprite byte 6: z-depth
000E01  1  60              rts
000E02  1               
000E02  1               ;******************************************************************
000E02  1               ; fire_bullet — activate player bullet at cannon tip, update sprite
000E02  1               ;   Bullet X centers the 8-px bullet over the 16-px player ship:
000E02  1               ;     bullet_x = player_x + 4
000E02  1               ;   Bullet Y starts 8 VERA pixels above the player sprite top.
000E02  1               ;   Caller must check bullet_active == 0 before calling.
000E02  1               ;******************************************************************
000E02  1               fire_bullet:
000E02  1  A5 rr           lda player_x_lo
000E04  1  18              clc
000E05  1  69 04           adc #4
000E07  1  85 rr           sta bullet_x_lo
000E09  1  A5 rr           lda player_x_hi
000E0B  1  69 00           adc #0
000E0D  1  85 rr           sta bullet_x_hi
000E0F  1               
000E0F  1  A9 9C           lda #<BULLET_Y_INIT
000E11  1  85 rr           sta bullet_y_lo
000E13  1  A9 01           lda #>BULLET_Y_INIT
000E15  1  85 rr           sta bullet_y_hi
000E17  1               
000E17  1  A9 01           lda #1
000E19  1  85 rr           sta bullet_active
000E1B  1  E6 rr           inc shot_count
000E1D  1  20 3A 0E        jsr update_bullet_sprite
000E20  1  60              rts
000E21  1               
000E21  1               ;******************************************************************
000E21  1               ; move_bullet — move bullet upward by BULLET_SPEED each frame;
000E21  1               ;   deactivate when it reaches the top of the screen (Y underflows 0)
000E21  1               ;******************************************************************
000E21  1               move_bullet:
000E21  1  A5 rr           lda bullet_y_lo
000E23  1  38              sec
000E24  1  E9 0C           sbc #BULLET_SPEED
000E26  1  85 rr           sta bullet_y_lo
000E28  1  A5 rr           lda bullet_y_hi
000E2A  1  E9 00           sbc #0
000E2C  1  85 rr           sta bullet_y_hi
000E2E  1  30 04           bmi @deactivate              ; 16-bit underflow past 0 → off screen
000E30  1               
000E30  1  20 3A 0E        jsr update_bullet_sprite
000E33  1  60              rts
000E34  1               
000E34  1               @deactivate:
000E34  1  64 rr           stz bullet_active
000E36  1  20 3A 0E        jsr update_bullet_sprite     ; disables sprite (z-depth=0)
000E39  1  60              rts
000E3A  1               
000E3A  1               ;******************************************************************
000E3A  1               ; update_bullet_sprite — write bullet position and enable/disable
000E3A  1               ;   to VERA sprite 2 (bytes 2-6); byte 7 set once at init.
000E3A  1               ;   z-depth = SPR_Z_FRONT when active, 0 when inactive.
000E3A  1               ;******************************************************************
000E3A  1               update_bullet_sprite:
000E3A  1  9C 25 9F        stz VERA_ctrl
000E3D  1  A9 11 8D 22     VERA_SET_ADDR (BULLET_SPRITE_ATTR + 2), 1
000E41  1  9F A9 FC 8D  
000E45  1  21 9F A9 12  
000E4C  1  A5 rr           lda bullet_x_lo
000E4E  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000E51  1  A5 rr           lda bullet_x_hi
000E53  1  29 03           and #$03
000E55  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000E58  1  A5 rr           lda bullet_y_lo
000E5A  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000E5D  1  A5 rr           lda bullet_y_hi
000E5F  1  29 03           and #$03
000E61  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000E64  1  A5 rr           lda bullet_active
000E66  1  F0 04           beq @z_off
000E68  1  A9 0C           lda #SPR_Z_FRONT
000E6A  1  80 02           bra @write_z
000E6C  1               @z_off:
000E6C  1  A9 00           lda #$00
000E6E  1               @write_z:
000E6E  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
000E71  1  60              rts
000E72  1               
000E72  1               ;******************************************************************
000E72  1               ; check_bullet_invader — scan all 55 invaders for a hit with the player bullet
000E72  1               ;
000E72  1               ;   Iterates rows 0-4, columns 0-10.  Skips dead invaders.
000E72  1               ;   For each live invader checks 16-bit AABB overlap:
000E72  1               ;     X: bullet_x+8 > inv_x  AND  bullet_x < inv_x+16
000E72  1               ;     Y: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000E72  1               ;   On hit: calls kill_invader_hit and returns immediately.
000E72  1               ;
000E72  1               ;   Scratch used: zp_y_base_lo/hi, zp_row_y_lo/hi, zp_x_lo/hi,
000E72  1               ;                 zp_scratch_lo/hi, zp_row, zp_col
000E72  1               ;******************************************************************
000E72  1               check_bullet_invader:
000E72  1  A5 rr           lda bullet_active
000E74  1  D0 01           bne :+
000E76  1  60              rts
000E77  1               :  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000E77  1  A9 50           lda #<INV_GRID_Y_BASE
000E79  1  18              clc
000E7A  1  65 rr           adc inv_offset_y
000E7C  1  85 rr           sta zp_y_base_lo
000E7E  1  A9 00           lda #>INV_GRID_Y_BASE
000E80  1  69 00           adc #0
000E82  1  85 rr           sta zp_y_base_hi
000E84  1               
000E84  1  64 rr           stz zp_row
000E86  1               @row_loop:
000E86  1                  ; row Y = y_base + row_y_offsets[row]
000E86  1  A4 rr           ldy zp_row
000E88  1  B9 5F 1C        lda row_y_offsets,y
000E8B  1  18              clc
000E8C  1  65 rr           adc zp_y_base_lo
000E8E  1  85 rr           sta zp_row_y_lo
000E90  1  A9 00           lda #0
000E92  1  65 rr           adc zp_y_base_hi
000E94  1  85 rr           sta zp_row_y_hi
000E96  1               
000E96  1                  ; --- Quick Y range check for whole row ---
000E96  1                  ; Need: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000E96  1               
000E96  1                  ; (1) bullet_y+8 > inv_y  →  (bullet_y+8) - inv_y > 0
000E96  1                  ;     result negative (bmi) means bullet above this row
000E96  1  A5 rr           lda bullet_y_lo
000E98  1  18              clc
000E99  1  69 08           adc #8
000E9B  1  85 rr           sta zp_scratch_lo
000E9D  1  A5 rr           lda bullet_y_hi
000E9F  1  69 00           adc #0
000EA1  1  85 rr           sta zp_scratch_hi
000EA3  1  A5 rr           lda zp_scratch_lo
000EA5  1  38              sec
000EA6  1  E5 rr           sbc zp_row_y_lo
000EA8  1  A5 rr           lda zp_scratch_hi
000EAA  1  E5 rr           sbc zp_row_y_hi
000EAC  1  30 1D           bmi @next_row         ; bullet bottom above invader top → no hit in this row
000EAE  1               
000EAE  1                  ; (2) bullet_y < inv_y+16  →  bullet_y - (inv_y+16) < 0
000EAE  1                  ;     result >= 0 (bpl) means bullet below this row
000EAE  1  A5 rr           lda zp_row_y_lo
000EB0  1  18              clc
000EB1  1  69 10           adc #16
000EB3  1  85 rr           sta zp_scratch_lo
000EB5  1  A5 rr           lda zp_row_y_hi
000EB7  1  69 00           adc #0
000EB9  1  85 rr           sta zp_scratch_hi
000EBB  1  A5 rr           lda bullet_y_lo
000EBD  1  38              sec
000EBE  1  E5 rr           sbc zp_scratch_lo
000EC0  1  A5 rr           lda bullet_y_hi
000EC2  1  E5 rr           sbc zp_scratch_hi
000EC4  1  10 05           bpl @next_row         ; bullet top at or below invader bottom → no hit
000EC6  1               
000EC6  1                  ; Y overlaps this row — check each column
000EC6  1  20 D4 0E        jsr cbi_check_cols
000EC9  1  B0 08           bcs @done             ; hit found; bullet already handled
000ECB  1               
000ECB  1               @next_row:
000ECB  1  E6 rr           inc zp_row
000ECD  1  A5 rr           lda zp_row
000ECF  1  C9 05           cmp #5
000ED1  1  D0 B3           bne @row_loop
000ED3  1               
000ED3  1               @done:
000ED3  1  60              rts
000ED4  1               
000ED4  1               ;******************************************************************
000ED4  1               ; cbi_check_cols — column scan for check_bullet_invader
000ED4  1               ;
000ED4  1               ;   Scans all 11 columns of zp_row for an X overlap with the bullet.
000ED4  1               ;   Assumes Y overlap for this row has already been confirmed.
000ED4  1               ;   Returns: C set if hit (kill_invader_hit already called),
000ED4  1               ;            C clear if no hit.
000ED4  1               ;   Scratch used: zp_col, zp_x_lo/hi, zp_scratch_lo/hi
000ED4  1               ;******************************************************************
000ED4  1               cbi_check_cols:
000ED4  1  64 rr           stz zp_col
000ED6  1               @col_loop:
000ED6  1                  ; skip if invader is dead
000ED6  1  A4 rr           ldy zp_row
000ED8  1  B9 64 1C        lda inv_row_base,y
000EDB  1  18              clc
000EDC  1  65 rr           adc zp_col
000EDE  1  A8              tay                   ; Y = invader index
000EDF  1  29 07           and #$07
000EE1  1  AA              tax
000EE2  1  BD 69 1C        lda bit_masks,x
000EE5  1  48              pha
000EE6  1  98              tya
000EE7  1  4A              lsr
000EE8  1  4A              lsr
000EE9  1  4A              lsr
000EEA  1  A8              tay                   ; Y = byte index into inv_alive
000EEB  1  68              pla
000EEC  1  39 rr rr        and inv_alive,y
000EEF  1  F0 46           beq @next_col         ; dead
000EF1  1               
000EF1  1                  ; compute inv_x = inv_grid_x + col_x_offsets[col]
000EF1  1  A4 rr           ldy zp_col
000EF3  1  B9 49 1C        lda col_x_lo,y
000EF6  1  18              clc
000EF7  1  65 rr           adc inv_grid_x_lo
000EF9  1  85 rr           sta zp_x_lo
000EFB  1  B9 54 1C        lda col_x_hi,y
000EFE  1  65 rr           adc inv_grid_x_hi
000F00  1  85 rr           sta zp_x_hi
000F02  1               
000F02  1                  ; X check (1): bullet_x+8 > inv_x
000F02  1  A5 rr           lda bullet_x_lo
000F04  1  18              clc
000F05  1  69 08           adc #8
000F07  1  85 rr           sta zp_scratch_lo
000F09  1  A5 rr           lda bullet_x_hi
000F0B  1  69 00           adc #0
000F0D  1  85 rr           sta zp_scratch_hi
000F0F  1  A5 rr           lda zp_scratch_lo
000F11  1  38              sec
000F12  1  E5 rr           sbc zp_x_lo
000F14  1  A5 rr           lda zp_scratch_hi
000F16  1  E5 rr           sbc zp_x_hi
000F18  1  30 1D           bmi @next_col         ; bullet right edge left of invader → no hit
000F1A  1               
000F1A  1                  ; X check (2): bullet_x < inv_x+16
000F1A  1  A5 rr           lda zp_x_lo
000F1C  1  18              clc
000F1D  1  69 10           adc #16
000F1F  1  85 rr           sta zp_scratch_lo
000F21  1  A5 rr           lda zp_x_hi
000F23  1  69 00           adc #0
000F25  1  85 rr           sta zp_scratch_hi
000F27  1  A5 rr           lda bullet_x_lo
000F29  1  38              sec
000F2A  1  E5 rr           sbc zp_scratch_lo
000F2C  1  A5 rr           lda bullet_x_hi
000F2E  1  E5 rr           sbc zp_scratch_hi
000F30  1  10 05           bpl @next_col         ; bullet left edge at or right of invader → no hit
000F32  1               
000F32  1                  ; --- HIT ---
000F32  1  20 41 0F        jsr kill_invader_hit
000F35  1  38              sec                   ; signal hit to caller
000F36  1  60              rts
000F37  1               
000F37  1               @next_col:
000F37  1  E6 rr           inc zp_col
000F39  1  A5 rr           lda zp_col
000F3B  1  C9 0B           cmp #11
000F3D  1  D0 97           bne @col_loop
000F3F  1               
000F3F  1  18              clc                   ; no hit
000F40  1  60              rts
000F41  1               
000F41  1               ;******************************************************************
000F41  1               ; kill_invader_hit — clear alive bit, deactivate bullet, update score & speed
000F41  1               ;   Expects zp_row, zp_col to identify the hit invader.
000F41  1               ;******************************************************************
000F41  1               kill_invader_hit:
000F41  1                  ; --- clear alive bit ---
000F41  1  A4 rr           ldy zp_row
000F43  1  B9 64 1C        lda inv_row_base,y
000F46  1  18              clc
000F47  1  65 rr           adc zp_col
000F49  1  A8              tay                   ; Y = invader index
000F4A  1  29 07           and #$07
000F4C  1  AA              tax
000F4D  1  BD 69 1C        lda bit_masks,x       ; bit mask for this invader
000F50  1  48              pha
000F51  1  98              tya
000F52  1  4A              lsr
000F53  1  4A              lsr
000F54  1  4A              lsr
000F55  1  A8              tay                   ; Y = byte index into inv_alive
000F56  1  68              pla
000F57  1  49 FF           eor #$FF              ; invert → clear mask
000F59  1  39 rr rr        and inv_alive,y
000F5C  1  99 rr rr        sta inv_alive,y
000F5F  1               
000F5F  1                  ; --- start explosion at the hit invader's position ---
000F5F  1                  ; zp_x_lo/hi and zp_row_y_lo/hi still hold the invader coords from collision detection
000F5F  1  20 8D 0F        jsr start_explosion
000F62  1               
000F62  1                  ; --- deactivate bullet ---
000F62  1  64 rr           stz bullet_active
000F64  1  20 3A 0E        jsr update_bullet_sprite
000F67  1               
000F67  1                  ; --- decrement inv_count ---
000F67  1  C6 rr           dec inv_count
000F69  1               
000F69  1                  ; --- update inv_move_speed: proportional to remaining count ---
000F69  1  A6 rr           ldx inv_count
000F6B  1  BD 76 1C        lda inv_speed_table,x
000F6E  1  85 rr           sta inv_move_speed
000F70  1               
000F70  1                  ; --- add score for this row's invader type ---
000F70  1  A4 rr           ldy zp_row
000F72  1  B9 71 1C        lda score_by_row_bcd,y
000F75  1  20 79 0F        jsr add_score
000F78  1  60              rts
000F79  1               
000F79  1               ;******************************************************************
000F79  1               ; add_score — add BCD value in A to score_lo/mid/hi
000F79  1               ;******************************************************************
000F79  1               add_score:
000F79  1  F8              sed
000F7A  1  18              clc
000F7B  1  65 rr           adc score_lo
000F7D  1  85 rr           sta score_lo
000F7F  1  A5 rr           lda score_mid
000F81  1  69 00           adc #0
000F83  1  85 rr           sta score_mid
000F85  1  A5 rr           lda score_hi
000F87  1  69 00           adc #0
000F89  1  85 rr           sta score_hi
000F8B  1  D8              cld
000F8C  1  60              rts
000F8D  1               
000F8D  1               ;******************************************************************
000F8D  1               ; start_explosion — position sprite 4 at the hit invader and start timer
000F8D  1               ;
000F8D  1               ;   Inputs: zp_x_lo/hi     — invader X (VERA coords)
000F8D  1               ;           zp_row_y_lo/hi — invader Y (VERA coords)
000F8D  1               ;   Sets exp_timer = EXPLODE_FRAMES and enables sprite 4.
000F8D  1               ;******************************************************************
000F8D  1               start_explosion:
000F8D  1  9C 25 9F        stz VERA_ctrl
000F90  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 2), 1  ; start at byte 2 (X lo)
000F94  1  9F A9 FC 8D  
000F98  1  21 9F A9 22  
000F9F  1  A5 rr           lda zp_x_lo
000FA1  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000FA4  1  A5 rr           lda zp_x_hi
000FA6  1  29 03           and #$03
000FA8  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000FAB  1  A5 rr           lda zp_row_y_lo
000FAD  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000FB0  1  A5 rr           lda zp_row_y_hi
000FB2  1  29 03           and #$03
000FB4  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000FB7  1  A9 0C           lda #SPR_Z_FRONT
000FB9  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3 → enabled, in front
000FBC  1  A9 1E           lda #EXPLODE_FRAMES
000FBE  1  85 rr           sta exp_timer
000FC0  1  60              rts
000FC1  1               
000FC1  1               ;******************************************************************
000FC1  1               ; update_explosion — decrement exp_timer; disable sprite when it hits 0
000FC1  1               ;******************************************************************
000FC1  1               update_explosion:
000FC1  1  A5 rr           lda exp_timer
000FC3  1  F0 1B           beq @inactive
000FC5  1  C6 rr           dec exp_timer
000FC7  1  D0 17           bne @inactive
000FC9  1                  ; timer just expired — disable sprite 4
000FC9  1  9C 25 9F        stz VERA_ctrl
000FCC  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1  ; byte 6 = z-depth
000FD0  1  9F A9 FC 8D  
000FD4  1  21 9F A9 26  
000FDB  1  A9 00           lda #$00
000FDD  1  8D 23 9F        sta VERA_data0               ; z-depth=0 → disabled
000FE0  1               @inactive:
000FE0  1  60              rts
000FE1  1               
000FE1  1               ;******************************************************************
000FE1  1               ; prng — 16-bit Galois LFSR, feedback polynomial $B400
000FE1  1               ;   Updates rand_seed_lo/hi; returns pseudo-random byte in A.
000FE1  1               ;******************************************************************
000FE1  1               prng:
000FE1  1  46 rr           lsr rand_seed_hi          ; shift 16-bit state right; carry = old hi[0]
000FE3  1  66 rr           ror rand_seed_lo          ; lo[7] = old hi[0]; carry = old lo[0] (feedback bit)
000FE5  1  90 06           bcc @done                 ; feedback bit=0: no XOR
000FE7  1  A5 rr           lda rand_seed_hi
000FE9  1  49 B4           eor #$B4                  ; XOR hi byte with feedback poly ($B400 >> 8)
000FEB  1  85 rr           sta rand_seed_hi
000FED  1               @done:
000FED  1  A5 rr           lda rand_seed_lo
000FEF  1  60              rts
000FF0  1               
000FF0  1               ;******************************************************************
000FF0  1               ; update_inv_bullets — fire timer, move active bullets, boundary check,
000FF0  1               ;   update VERA sprites for all 3 invader bullet slots.
000FF0  1               ;******************************************************************
000FF0  1               update_inv_bullets:
000FF0  1                  ; --- fire timer ---
000FF0  1  C6 rr           dec inv_fire_timer
000FF2  1  D0 0D           bne @move_loop
000FF4  1                  ; reset timer = max(inv_move_speed, INV_FIRE_TIMER_MIN)
000FF4  1  A5 rr           lda inv_move_speed
000FF6  1  C9 0A           cmp #INV_FIRE_TIMER_MIN
000FF8  1  B0 02           bcs @set_timer
000FFA  1  A9 0A           lda #INV_FIRE_TIMER_MIN
000FFC  1               @set_timer:
000FFC  1  85 rr           sta inv_fire_timer
000FFE  1  20 6B 10        jsr try_fire_inv_bullet
001001  1               
001001  1               @move_loop:
001001  1  A2 00           ldx #0
001003  1               @slot_loop:
001003  1  B5 rr           lda ibul_active,x
001005  1  F0 1B           beq @update_spr           ; inactive: just hide sprite
001007  1               
001007  1                  ; move bullet down by INV_BULLET_SPEED
001007  1  B5 rr           lda ibul_y_lo,x
001009  1  18              clc
00100A  1  69 06           adc #INV_BULLET_SPEED
00100C  1  95 rr           sta ibul_y_lo,x
00100E  1  B5 rr           lda ibul_y_hi,x
001010  1  69 00           adc #0
001012  1  95 rr           sta ibul_y_hi,x
001014  1               
001014  1                  ; boundary: deactivate if Y >= 480 ($01E0)
001014  1  C9 01           cmp #>480                 ; A = new hi byte; compare with 1
001016  1  90 0A           bcc @update_spr           ; hi < 1: still on screen
001018  1  D0 06           bne @deactivate           ; hi > 1: off screen
00101A  1  B5 rr           lda ibul_y_lo,x
00101C  1  C9 E0           cmp #<480                 ; compare lo with $E0
00101E  1  90 02           bcc @update_spr           ; lo < $E0: still on screen
001020  1               @deactivate:
001020  1  74 rr           stz ibul_active,x
001022  1               
001022  1               @update_spr:
001022  1  20 2B 10        jsr update_inv_bullet_sprite   ; preserves X
001025  1  E8              inx
001026  1  E0 03           cpx #3
001028  1  D0 D9           bne @slot_loop
00102A  1  60              rts
00102B  1               
00102B  1               ;******************************************************************
00102B  1               ; update_inv_bullet_sprite — write VERA sprite attrs bytes 2-6 for slot X
00102B  1               ;   X = slot index (0-2).  Preserves X.
00102B  1               ;******************************************************************
00102B  1               update_inv_bullet_sprite:
00102B  1  86 rr           stx zp_scratch_lo              ; preserve slot index
00102D  1  9C 25 9F        stz VERA_ctrl
001030  1  A9 11           lda #$11                       ; stride=1, bank bit=1
001032  1  8D 22 9F        sta VERA_addr_bank
001035  1  A9 FC           lda #$FC
001037  1  8D 21 9F        sta VERA_addr_high
00103A  1  BD AE 1C        lda ibul_spr_lo,x
00103D  1  18              clc
00103E  1  69 02           adc #2                         ; point to byte 2 (X position)
001040  1  8D 20 9F        sta VERA_addr_low
001043  1  B5 rr           lda ibul_x_lo,x
001045  1  8D 23 9F        sta VERA_data0                 ; byte 2: X lo
001048  1  B5 rr           lda ibul_x_hi,x
00104A  1  29 03           and #$03
00104C  1  8D 23 9F        sta VERA_data0                 ; byte 3: X hi
00104F  1  B5 rr           lda ibul_y_lo,x
001051  1  8D 23 9F        sta VERA_data0                 ; byte 4: Y lo
001054  1  B5 rr           lda ibul_y_hi,x
001056  1  29 03           and #$03
001058  1  8D 23 9F        sta VERA_data0                 ; byte 5: Y hi
00105B  1  B5 rr           lda ibul_active,x
00105D  1  F0 04           beq @disabled
00105F  1  A9 0C           lda #SPR_Z_FRONT
001061  1  80 02           bra @write_z
001063  1               @disabled:
001063  1  A9 00           lda #0
001065  1               @write_z:
001065  1  8D 23 9F        sta VERA_data0                 ; byte 6: z-depth
001068  1  A6 rr           ldx zp_scratch_lo
00106A  1  60              rts
00106B  1               
00106B  1               ;******************************************************************
00106B  1               ; try_fire_inv_bullet — find a free slot and spawn a bullet from the
00106B  1               ;   bottommost live invader in a randomly chosen column.
00106B  1               ;   Returns immediately if all slots busy or chosen column is empty.
00106B  1               ;   Scratch used: zp_row, zp_col, zp_scratch_lo (slot index)
00106B  1               ;******************************************************************
00106B  1               try_fire_inv_bullet:
00106B  1                  ; find a free bullet slot
00106B  1  A2 00           ldx #0
00106D  1               @find_slot:
00106D  1  B5 rr           lda ibul_active,x
00106F  1  F0 06           beq @slot_found
001071  1  E8              inx
001072  1  E0 03           cpx #3
001074  1  D0 F7           bne @find_slot
001076  1  60              rts                            ; all slots busy
001077  1               
001077  1               @slot_found:
001077  1  86 rr           stx zp_scratch_lo              ; save free slot index
001079  1               
001079  1                  ; pick a random column 0-10
001079  1  20 E1 0F        jsr prng
00107C  1  29 0F           and #$0F                       ; 0-15
00107E  1  C9 0B           cmp #11
001080  1  90 03           bcc @col_ok
001082  1  38              sec
001083  1  E9 0B           sbc #11                        ; wrap 11-15 → 0-4 (slight bias, acceptable)
001085  1               @col_ok:
001085  1  85 rr           sta zp_col
001087  1               
001087  1                  ; scan rows 4 down to 0 for bottommost live invader in this column
001087  1  A9 04           lda #4
001089  1  85 rr           sta zp_row
00108B  1               @row_scan:
00108B  1  A4 rr           ldy zp_row
00108D  1  B9 64 1C        lda inv_row_base,y
001090  1  18              clc
001091  1  65 rr           adc zp_col
001093  1  A8              tay                            ; Y = invader index
001094  1  29 07           and #$07
001096  1  AA              tax                            ; X = bit position
001097  1  BD 69 1C        lda bit_masks,x
00109A  1  48              pha
00109B  1  98              tya
00109C  1  4A              lsr
00109D  1  4A              lsr
00109E  1  4A              lsr
00109F  1  A8              tay                            ; Y = byte index into inv_alive
0010A0  1  68              pla
0010A1  1  39 rr rr        and inv_alive,y
0010A4  1  D0 09           bne @found_invader
0010A6  1  A5 rr           lda zp_row
0010A8  1  F0 04           beq @no_invader                ; checked row 0, nothing alive
0010AA  1  C6 rr           dec zp_row
0010AC  1  80 DD           bra @row_scan
0010AE  1               
0010AE  1               @no_invader:
0010AE  1  60              rts                            ; column empty, skip fire
0010AF  1               
0010AF  1               @found_invader:
0010AF  1  A6 rr           ldx zp_scratch_lo              ; restore free slot index
0010B1  1  A9 01           lda #1
0010B3  1  95 rr           sta ibul_active,x
0010B5  1               
0010B5  1                  ; spawn X = inv_grid_x + col_x_offsets[col]  (16-bit, matching update_invader_sprites)
0010B5  1  A4 rr           ldy zp_col
0010B7  1  B9 49 1C        lda col_x_lo,y
0010BA  1  18              clc
0010BB  1  65 rr           adc inv_grid_x_lo
0010BD  1  95 rr           sta ibul_x_lo,x
0010BF  1  B9 54 1C        lda col_x_hi,y
0010C2  1  65 rr           adc inv_grid_x_hi
0010C4  1  95 rr           sta ibul_x_hi,x
0010C6  1                  ; add +4 as a separate 16-bit step to centre the 8px bullet in the 16px invader
0010C6  1  B5 rr           lda ibul_x_lo,x
0010C8  1  18              clc
0010C9  1  69 04           adc #4
0010CB  1  95 rr           sta ibul_x_lo,x
0010CD  1  B5 rr           lda ibul_x_hi,x
0010CF  1  69 00           adc #0
0010D1  1  95 rr           sta ibul_x_hi,x
0010D3  1               
0010D3  1                  ; spawn Y: compute y_base first (same two-step pattern as update_invader_sprites)
0010D3  1                  ; step 1: y_base = INV_GRID_Y_BASE + inv_offset_y  (16-bit)
0010D3  1  A9 50           lda #<INV_GRID_Y_BASE
0010D5  1  18              clc
0010D6  1  65 rr           adc inv_offset_y
0010D8  1  85 rr           sta zp_y_base_lo
0010DA  1  A9 00           lda #>INV_GRID_Y_BASE
0010DC  1  69 00           adc #0
0010DE  1  85 rr           sta zp_y_base_hi
0010E0  1                  ; step 2: spawn_y = y_base + row_y_offsets[row]
0010E0  1  A4 rr           ldy zp_row
0010E2  1  B9 5F 1C        lda row_y_offsets,y
0010E5  1  18              clc
0010E6  1  65 rr           adc zp_y_base_lo
0010E8  1  95 rr           sta ibul_y_lo,x
0010EA  1  A9 00           lda #0
0010EC  1  65 rr           adc zp_y_base_hi
0010EE  1  95 rr           sta ibul_y_hi,x
0010F0  1                  ; step 3: +16 to place bullet at the bottom edge of the 16px invader
0010F0  1  B5 rr           lda ibul_y_lo,x
0010F2  1  18              clc
0010F3  1  69 10           adc #16
0010F5  1  95 rr           sta ibul_y_lo,x
0010F7  1  B5 rr           lda ibul_y_hi,x
0010F9  1  69 00           adc #0
0010FB  1  95 rr           sta ibul_y_hi,x
0010FD  1               
0010FD  1  60              rts
0010FE  1               
0010FE  1               ;******************************************************************
0010FE  1               ; check_inv_bullet_player — AABB test each active invader bullet vs. player
0010FE  1               ;
0010FE  1               ;   Player rect: (player_x, PLAYER_Y) to (player_x+15, PLAYER_Y+15), 16x16
0010FE  1               ;   Bullet rect: (ibul_x,   ibul_y)   to (ibul_x+7,   ibul_y+7),     8x8
0010FE  1               ;
0010FE  1               ;   On hit: bullet deactivated, jsr player_hit called, loop continues
0010FE  1               ;   (remaining bullets checked — at most one hit landing per frame).
0010FE  1               ;   Scratch: zp_scratch_lo/hi, X (slot index)
0010FE  1               ;******************************************************************
0010FE  1               check_inv_bullet_player:
0010FE  1  A2 00           ldx #0
001100  1               @slot_loop:
001100  1  B5 rr           lda ibul_active,x
001102  1  F0 5B           beq @next_slot
001104  1               
001104  1                  ; --- Y check 1: (bullet_y + 8) > PLAYER_Y  →  bullet_y + 8 - PLAYER_Y > 0 ---
001104  1  B5 rr           lda ibul_y_lo,x
001106  1  18              clc
001107  1  69 08           adc #8
001109  1  85 rr           sta zp_scratch_lo
00110B  1  B5 rr           lda ibul_y_hi,x
00110D  1  69 00           adc #0
00110F  1  85 rr           sta zp_scratch_hi
001111  1  A5 rr           lda zp_scratch_lo
001113  1  38              sec
001114  1  E9 A4           sbc #<PLAYER_Y
001116  1  A5 rr           lda zp_scratch_hi
001118  1  E9 01           sbc #>PLAYER_Y
00111A  1  30 43           bmi @next_slot            ; bullet bottom above player top → no hit
00111C  1               
00111C  1                  ; --- Y check 2: bullet_y < PLAYER_Y + 16 → bullet_y - (PLAYER_Y+16) < 0 ---
00111C  1  B5 rr           lda ibul_y_lo,x
00111E  1  38              sec
00111F  1  E9 B4           sbc #<(PLAYER_Y+16)
001121  1  B5 rr           lda ibul_y_hi,x
001123  1  E9 01           sbc #>(PLAYER_Y+16)
001125  1  10 38           bpl @next_slot            ; bullet top at or below player bottom → no hit
001127  1               
001127  1                  ; --- X check 1: (bullet_x + 8) > player_x ---
001127  1  B5 rr           lda ibul_x_lo,x
001129  1  18              clc
00112A  1  69 08           adc #8
00112C  1  85 rr           sta zp_scratch_lo
00112E  1  B5 rr           lda ibul_x_hi,x
001130  1  69 00           adc #0
001132  1  85 rr           sta zp_scratch_hi
001134  1  A5 rr           lda zp_scratch_lo
001136  1  38              sec
001137  1  E5 rr           sbc player_x_lo
001139  1  A5 rr           lda zp_scratch_hi
00113B  1  E5 rr           sbc player_x_hi
00113D  1  30 20           bmi @next_slot            ; bullet right edge left of player → no hit
00113F  1               
00113F  1                  ; --- X check 2: bullet_x < player_x + 16 ---
00113F  1  A5 rr           lda player_x_lo
001141  1  18              clc
001142  1  69 10           adc #16
001144  1  85 rr           sta zp_scratch_lo
001146  1  A5 rr           lda player_x_hi
001148  1  69 00           adc #0
00114A  1  85 rr           sta zp_scratch_hi
00114C  1  B5 rr           lda ibul_x_lo,x
00114E  1  38              sec
00114F  1  E5 rr           sbc zp_scratch_lo
001151  1  B5 rr           lda ibul_x_hi,x
001153  1  E5 rr           sbc zp_scratch_hi
001155  1  10 08           bpl @next_slot            ; bullet left edge at or right of player → no hit
001157  1               
001157  1                  ; --- HIT ---
001157  1  74 rr           stz ibul_active,x         ; deactivate this bullet
001159  1  20 2B 10        jsr update_inv_bullet_sprite
00115C  1  20 65 11        jsr player_hit
00115F  1               
00115F  1               @next_slot:
00115F  1  E8              inx
001160  1  E0 03           cpx #3
001162  1  D0 9C           bne @slot_loop
001164  1  60              rts
001165  1               
001165  1               ;******************************************************************
001165  1               ; player_hit — handle a bullet-player collision:
001165  1               ;   explosion at player position, decrement lives, respawn, invincibility
001165  1               ;******************************************************************
001165  1               player_hit:
001165  1                  ; start explosion at player position
001165  1  A5 rr           lda player_x_lo
001167  1  85 rr           sta zp_x_lo
001169  1  A5 rr           lda player_x_hi
00116B  1  85 rr           sta zp_x_hi
00116D  1  A9 A4           lda #<PLAYER_Y
00116F  1  85 rr           sta zp_row_y_lo
001171  1  A9 01           lda #>PLAYER_Y
001173  1  85 rr           sta zp_row_y_hi
001175  1  20 8D 0F        jsr start_explosion
001178  1               
001178  1                  ; decrement lives
001178  1  C6 rr           dec lives
00117A  1  F0 0D           beq @game_over            ; lives hit 0 → end game (Phase 6 will handle this properly)
00117C  1               
00117C  1                  ; grant invincibility and re-centre the ship
00117C  1  A9 78           lda #INV_HIT_FRAMES
00117E  1  85 rr           sta inv_hit_timer
001180  1  A9 38           lda #<PLAYER_X_INIT
001182  1  85 rr           sta player_x_lo
001184  1  A9 01           lda #>PLAYER_X_INIT
001186  1  85 rr           sta player_x_hi
001188  1  60              rts
001189  1               
001189  1               @game_over:
001189  1  4C 8C 11        jmp game_over_screen
00118C  1               
00118C  1               ;******************************************************************
00118C  1               ; game_over_screen — update hi-score, draw GAME OVER, wait for input
00118C  1               ;   SPACE     → restart_game (full state reset + main_loop)
00118C  1               ;   RUN/STOP  → exit to BASIC
00118C  1               ;
00118C  1               ;   Layout (40-col text):
00118C  1               ;     Row  9, col 15: "GAME OVER"
00118C  1               ;     Row 11, col 13: "SCORE: " + 6 BCD digits
00118C  1               ;     Row 12, col 12: "HI-SCORE: " + 6 BCD digits
00118C  1               ;     Row 15, col 11: "SPACE = PLAY AGAIN"  (blinks)
00118C  1               ;     Row 17, col 12: "RUN/STOP TO QUIT"
00118C  1               ;******************************************************************
00118C  1               game_over_screen:
00118C  1  20 2A 1A        jsr snd_stop_ufo_drone    ; silence drone if UFO was active
00118F  1               
00118F  1  20 5E 12        jsr update_hi_score       ; copy score → hi_score if score is higher
001192  1               
001192  1  20 22 15        jsr hide_all_inv_sprites  ; clear play field sprites
001195  1               
001195  1  A9 93           lda #PETSCII_CLR
001197  1  20 D2 FF        jsr CHROUT
00119A  1               
00119A  1  A9 09           lda #9
00119C  1  A0 0F           ldy #15
00119E  1  18              clc
00119F  1  20 F0 FF        jsr PLOT
0011A2  1  A2 00           ldx #0
0011A4  1  BD 2C 1B     @go1: lda str_game_over, x
0011A7  1  F0 06           beq @go1d
0011A9  1  20 D2 FF        jsr CHROUT
0011AC  1  E8              inx
0011AD  1  80 F5           bra @go1
0011AF  1               @go1d:
0011AF  1               
0011AF  1  A9 0B           lda #11
0011B1  1  A0 0D           ldy #13
0011B3  1  18              clc
