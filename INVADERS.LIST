00199A  1               ;******************************************************************
00199A  1               ; update_ufo — per-frame UFO logic: spawn timer + movement
00199A  1               ;
00199A  1               ;   Inactive: 16-bit ufo_timer counts down each frame.
00199A  1               ;   On zero: UFO spawns at left edge (X=0), timer reset to
00199A  1               ;             UFO_TIMER_INIT + (prng() & $7F) for next cycle.
00199A  1               ;   Active: move right UFO_SPEED VERA pixels/frame.
00199A  1               ;           Deactivate when X >= 640 (off right edge).
00199A  1               ;   Updates VERA sprite 3 after any state change.
00199A  1               ;******************************************************************
00199A  1               update_ufo:
00199A  1  A5 rr           lda ufo_active
00199C  1  D0 36           bne @move_ufo
00199E  1               
00199E  1                  ; --- timer countdown (16-bit decrement) ---
00199E  1  A5 rr           lda ufo_timer_lo
0019A0  1  D0 0B           bne @dec_lo
0019A2  1  A5 rr           lda ufo_timer_hi
0019A4  1  F0 0F           beq @spawn                   ; both zero → spawn (guard against stuck state)
0019A6  1  C6 rr           dec ufo_timer_hi
0019A8  1  A9 FF           lda #$FF
0019AA  1  85 rr           sta ufo_timer_lo
0019AC  1  60              rts
0019AD  1               @dec_lo:
0019AD  1  C6 rr           dec ufo_timer_lo
0019AF  1  A5 rr           lda ufo_timer_lo
0019B1  1  05 rr           ora ufo_timer_hi
0019B3  1  D0 47           bne @ufo_done                ; timer not yet zero
0019B5  1               
0019B5  1               @spawn:
0019B5  1  A9 01           lda #1
0019B7  1  85 rr           sta ufo_active
0019B9  1  64 rr           stz ufo_x_lo
0019BB  1  64 rr           stz ufo_x_hi
0019BD  1                  ; next timer = UFO_TIMER_INIT + (prng() & $7F) so interval varies by 0-127 frames
0019BD  1  20 0D 10        jsr prng
0019C0  1  29 7F           and #$7F
0019C2  1  18              clc
0019C3  1  69 58           adc #<UFO_TIMER_INIT
0019C5  1  85 rr           sta ufo_timer_lo
0019C7  1  A9 02           lda #>UFO_TIMER_INIT
0019C9  1  69 00           adc #0
0019CB  1  85 rr           sta ufo_timer_hi
0019CD  1  20 FD 19        jsr update_ufo_sprite
0019D0  1  20 BF 1A        jsr snd_start_ufo_drone
0019D3  1  60              rts
0019D4  1               
0019D4  1                  ; --- move UFO right ---
0019D4  1               @move_ufo:
0019D4  1  A5 rr           lda ufo_x_lo
0019D6  1  18              clc
0019D7  1  69 02           adc #UFO_SPEED
0019D9  1  85 rr           sta ufo_x_lo
0019DB  1  A5 rr           lda ufo_x_hi
0019DD  1  69 00           adc #0
0019DF  1  85 rr           sta ufo_x_hi
0019E1  1                  ; deactivate if X high byte >= 3 (≥ 768, safely off the 640-wide screen)
0019E1  1                  ; simpler guard: X hi > 0 means X >= 256; combined with lo check
0019E1  1  C9 02           cmp #>640                    ; A = new hi; >640 = 2
0019E3  1  90 11           bcc @ufo_on_screen           ; hi < 2 → still visible
0019E5  1  D0 06           bne @ufo_off_screen          ; hi > 2 → gone
0019E7  1  A5 rr           lda ufo_x_lo
0019E9  1  C9 80           cmp #<640
0019EB  1  90 09           bcc @ufo_on_screen           ; hi=2, lo < 128 → past edge but close; still off
0019ED  1               @ufo_off_screen:
0019ED  1  64 rr           stz ufo_active
0019EF  1  20 FD 19        jsr update_ufo_sprite
0019F2  1  20 F2 1A        jsr snd_stop_ufo_drone
0019F5  1  60              rts
0019F6  1               @ufo_on_screen:
0019F6  1  20 FD 19        jsr update_ufo_sprite
0019F9  1  20 0A 1B        jsr snd_update_ufo_drone
0019FC  1               @ufo_done:
0019FC  1  60              rts
0019FD  1               
0019FD  1               ;******************************************************************
0019FD  1               ; update_ufo_sprite — write sprite 3 (UFO) position + enable/disable
0019FD  1               ;   addr[12:5] = VRAM_UFO>>5 = $01500>>5 = $A8
0019FD  1               ;   Writes bytes 2-6; bytes 0-1 and 7 set once at init.
0019FD  1               ;******************************************************************
0019FD  1               update_ufo_sprite:
0019FD  1  9C 25 9F        stz VERA_ctrl
001A00  1  A9 11 8D 22     VERA_SET_ADDR (UFO_SPRITE_ATTR + 2), 1
001A04  1  9F A9 FC 8D  
001A08  1  21 9F A9 1A  
001A0F  1  A5 rr           lda ufo_x_lo
001A11  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
001A14  1  A5 rr           lda ufo_x_hi
001A16  1  29 03           and #$03
001A18  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
001A1B  1  A9 20           lda #<UFO_Y
001A1D  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
001A20  1  A9 00           lda #>UFO_Y
001A22  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
001A25  1  A5 rr           lda ufo_active
001A27  1  F0 04           beq @z_off
001A29  1  A9 0C           lda #SPR_Z_FRONT
001A2B  1  80 02           bra @write_z
001A2D  1               @z_off:
001A2D  1  A9 00           lda #0
001A2F  1               @write_z:
001A2F  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
001A32  1  60              rts
001A33  1               
001A33  1               ;******************************************************************
001A33  1               ; check_bullet_ufo — AABB test: player bullet vs. UFO sprite (16x16)
001A33  1               ;   Bullet rect: (bullet_x, bullet_y)+(7,7);  UFO rect: (ufo_x, UFO_Y)+(15,15)
001A33  1               ;   On hit: bullet deactivated, UFO killed, score added, explosion started.
001A33  1               ;   Scratch: zp_scratch_lo/hi, zp_x_lo/hi, zp_row_y_lo/hi
001A33  1               ;******************************************************************
001A33  1               check_bullet_ufo:
001A33  1  A5 rr           lda bullet_active
001A35  1  D0 01           bne :+
001A37  1  60              rts
001A38  1  A5 rr        :  lda ufo_active
001A3A  1  D0 01           bne :+
001A3C  1  60              rts
001A3D  1               :
001A3D  1               
001A3D  1                  ; --- Y check 1: bullet_y+8 > UFO_Y ---
001A3D  1  A5 rr           lda bullet_y_lo
001A3F  1  18              clc
001A40  1  69 08           adc #8
001A42  1  85 rr           sta zp_scratch_lo
001A44  1  A5 rr           lda bullet_y_hi
001A46  1  69 00           adc #0
001A48  1  85 rr           sta zp_scratch_hi
001A4A  1  A5 rr           lda zp_scratch_lo
001A4C  1  38              sec
001A4D  1  E9 20           sbc #<UFO_Y
001A4F  1  A5 rr           lda zp_scratch_hi
001A51  1  E9 00           sbc #>UFO_Y
001A53  1  30 69           bmi @done                    ; bullet bottom above UFO top → no hit
001A55  1               
001A55  1                  ; --- Y check 2: bullet_y < UFO_Y+16 ---
001A55  1  A5 rr           lda bullet_y_lo
001A57  1  38              sec
001A58  1  E9 30           sbc #<(UFO_Y + 16)
001A5A  1  A5 rr           lda bullet_y_hi
001A5C  1  E9 00           sbc #>(UFO_Y + 16)
001A5E  1  10 5E           bpl @done                    ; bullet top at or below UFO bottom → no hit
001A60  1               
001A60  1                  ; --- X check 1: bullet_x+8 > ufo_x ---
001A60  1  A5 rr           lda bullet_x_lo
001A62  1  18              clc
001A63  1  69 08           adc #8
001A65  1  85 rr           sta zp_scratch_lo
001A67  1  A5 rr           lda bullet_x_hi
001A69  1  69 00           adc #0
001A6B  1  85 rr           sta zp_scratch_hi
001A6D  1  A5 rr           lda zp_scratch_lo
001A6F  1  38              sec
001A70  1  E5 rr           sbc ufo_x_lo
001A72  1  A5 rr           lda zp_scratch_hi
001A74  1  E5 rr           sbc ufo_x_hi
001A76  1  30 46           bmi @done                    ; bullet right edge left of UFO left edge → no hit
001A78  1               
001A78  1                  ; --- X check 2: bullet_x < ufo_x+16 ---
001A78  1  A5 rr           lda ufo_x_lo
001A7A  1  18              clc
001A7B  1  69 10           adc #16
001A7D  1  85 rr           sta zp_scratch_lo
001A7F  1  A5 rr           lda ufo_x_hi
001A81  1  69 00           adc #0
001A83  1  85 rr           sta zp_scratch_hi
001A85  1  A5 rr           lda bullet_x_lo
001A87  1  38              sec
001A88  1  E5 rr           sbc zp_scratch_lo
001A8A  1  A5 rr           lda bullet_x_hi
001A8C  1  E5 rr           sbc zp_scratch_hi
001A8E  1  10 2E           bpl @done                    ; bullet left edge at or right of UFO right edge → no hit
001A90  1               
001A90  1                  ; --- HIT ---
001A90  1  A5 rr           lda ufo_x_lo
001A92  1  85 rr           sta zp_x_lo
001A94  1  A5 rr           lda ufo_x_hi
001A96  1  85 rr           sta zp_x_hi
001A98  1  A9 20           lda #<UFO_Y
001A9A  1  85 rr           sta zp_row_y_lo
001A9C  1  A9 00           lda #>UFO_Y
001A9E  1  85 rr           sta zp_row_y_hi
001AA0  1  20 B6 0F        jsr start_explosion
001AA3  1               
001AA3  1  64 rr           stz bullet_active
001AA5  1  20 63 0E        jsr update_bullet_sprite
001AA8  1               
001AA8  1  64 rr           stz ufo_active
001AAA  1  20 FD 19        jsr update_ufo_sprite
001AAD  1  20 F2 1A        jsr snd_stop_ufo_drone
001AB0  1               
001AB0  1                  ; score: ufo_score table indexed by shot_count & 7
001AB0  1  A5 rr           lda shot_count
001AB2  1  29 07           and #$07
001AB4  1  AA              tax
001AB5  1  BD 06 1F        lda ufo_score_lo, x
001AB8  1  BC 0E 1F        ldy ufo_score_hi, x
001ABB  1  20 87 19        jsr add_score_bcd
001ABE  1               
001ABE  1               @done:
001ABE  1  60              rts
001ABF  1               
001ABF  1               ;******************************************************************
001ABF  1               ; snd_start_ufo_drone — enable VERA PSG voice 3 (sawtooth, full vol, freq1)
001ABF  1               ;   Called once when UFO spawns.
001ABF  1               ;******************************************************************
001ABF  1               snd_start_ufo_drone:
001ABF  1                  ; set starting UFO_DRONE_FREQ
001ABF  1  A9 00           lda #<UFO_DRONE_FREQ1
001AC1  1  85 rr           sta UFO_DRONE_FREQ
001AC3  1  A9 04           lda #>UFO_DRONE_FREQ1
001AC5  1  85 rr           sta UFO_DRONE_FREQ + 1
001AC7  1  A9 FF           lda #$ff
001AC9  1  85 rr           sta UFO_FREQ_DIR
001ACB  1                  ; set VERA
001ACB  1  9C 25 9F        stz VERA_ctrl
001ACE  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
001AD2  1  9F A9 F9 8D  
001AD6  1  21 9F A9 CC  
001ADD  1  A5 rr           lda UFO_DRONE_FREQ
001ADF  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L
001AE2  1  A5 rr           lda UFO_DRONE_FREQ + 1
001AE4  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
001AE7  1  A9 DF           lda #PSG_VOL_HALF
001AE9  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001AEC  1  A9 40           lda #PSG_WAVE_SAW
001AEE  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
001AF1  1  60              rts
001AF2  1               
001AF2  1               ;******************************************************************
001AF2  1               ; snd_stop_ufo_drone — silence VERA PSG voice 3
001AF2  1               ;   Called when UFO leaves screen or is destroyed.
001AF2  1               ;******************************************************************
001AF2  1               snd_stop_ufo_drone:
001AF2  1  9C 25 9F        stz VERA_ctrl
001AF5  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE3 + 2), 1   ; byte 2 = volume/enable
001AF9  1  9F A9 F9 8D  
001AFD  1  21 9F A9 CE  
001B04  1  A9 00           lda #$00
001B06  1  8D 23 9F        sta VERA_data0               ; zero volume → silent
001B09  1  60              rts
001B0A  1               
001B0A  1               ;******************************************************************
001B0A  1               ; snd_update_ufo_drone — warble between freq1/freq2 using frame_count
001B0A  1               ;   bit 3 (flips every 8 frames ≈ 3.75 Hz wobble rate).
001B0A  1               ;   Call every frame while UFO is active.
001B0A  1               ;   Rewrites all 4 voice bytes (keeps volume/waveform stable).
001B0A  1               ;******************************************************************
001B0A  1               snd_update_ufo_drone:
001B0A  1  9C 25 9F        stz VERA_ctrl
001B0D  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
001B11  1  9F A9 F9 8D  
001B15  1  21 9F A9 CC  
001B1C  1  A5 rr           lda UFO_DRONE_FREQ
001B1E  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L
001B21  1  A5 rr           lda UFO_DRONE_FREQ + 1
001B23  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
001B26  1  A9 DF           lda #PSG_VOL_HALF
001B28  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001B2B  1  A9 40           lda #PSG_WAVE_SAW
001B2D  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
001B30  1                  ; change the frequency
001B30  1  A5 rr           lda UFO_FREQ_DIR
001B32  1  F0 16           beq @ufo_tone_down
001B34  1  A9 10           lda #$10
001B36  1  18              clc
001B37  1  65 rr           adc UFO_DRONE_FREQ
001B39  1  85 rr           sta UFO_DRONE_FREQ
001B3B  1  A9 00           lda #$00
001B3D  1  65 rr           adc UFO_DRONE_FREQ + 1
001B3F  1  85 rr           sta UFO_DRONE_FREQ + 1
001B41  1  C9 06           cmp #>UFO_DRONE_FREQ2
001B43  1  D0 1A           bne @ufo_update_done
001B45  1  64 rr           stz UFO_FREQ_DIR
001B47  1  4C 5F 1B        jmp @ufo_update_done
001B4A  1               @ufo_tone_down:
001B4A  1  A5 rr           lda UFO_DRONE_FREQ
001B4C  1  38              sec
001B4D  1  E9 10           sbc #$10
001B4F  1  85 rr           sta UFO_DRONE_FREQ
001B51  1  A5 rr           lda UFO_DRONE_FREQ + 1
001B53  1  E9 00           sbc #$00
001B55  1  85 rr           sta UFO_DRONE_FREQ + 1
001B57  1  C9 04           cmp #>UFO_DRONE_FREQ1
001B59  1  D0 04           bne @ufo_update_done
001B5B  1  A9 FF           lda #$ff
001B5D  1  85 rr           sta UFO_FREQ_DIR
001B5F  1               @ufo_update_done:
001B5F  1  60              rts
001B60  1               
001B60  1               ;******************************************************************
001B60  1               ; snd_march_step — advance march_beat and play next note on PSG voice 0
001B60  1               ;   Called once per invader march step (from step_invaders).
001B60  1               ;   Increments beat index mod 4, writes freq/vol/wave to voice 0,
001B60  1               ;   and arms march_snd_timer so snd_tick_march will silence it.
001B60  1               ;******************************************************************
001B60  1               snd_march_step:
001B60  1  E6 rr           inc march_beat
001B62  1  A5 rr           lda march_beat
001B64  1  29 03           and #$03
001B66  1  85 rr           sta march_beat
001B68  1  AA              tax                            ; X = note index 0-3
001B69  1  9C 25 9F        stz VERA_ctrl
001B6C  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE0, 1
001B70  1  9F A9 F9 8D  
001B74  1  21 9F A9 C0  
001B7B  1  BD FE 1E        lda march_freq_lo, x
001B7E  1  8D 23 9F        sta VERA_data0                 ; byte 0: FREQ_L
001B81  1  BD 02 1F        lda march_freq_hi, x
001B84  1  8D 23 9F        sta VERA_data0                 ; byte 1: FREQ_H
001B87  1  A9 FF           lda #PSG_MARCH_VOL
001B89  1  8D 23 9F        sta VERA_data0                 ; byte 2: volume (stereo, full)
001B8C  1  A9 C0           lda #PSG_WAVE_PULSE
001B8E  1  8D 23 9F        sta VERA_data0                 ; byte 3: pulse waveform
001B91  1  A9 06           lda #MARCH_NOTE_FRAMES
001B93  1  85 rr           sta march_snd_timer
001B95  1  60              rts
001B96  1               
001B96  1               ;******************************************************************
001B96  1               ; snd_tick_march — decrement march note timer; silence voice 0 when it expires
001B96  1               ;   Call once per frame from main_loop.
001B96  1               ;******************************************************************
001B96  1               snd_tick_march:
001B96  1  A5 rr           lda march_snd_timer
001B98  1  F0 1B           beq @done
001B9A  1  C6 rr           dec march_snd_timer
001B9C  1  D0 17           bne @done
001B9E  1  9C 25 9F        stz VERA_ctrl
001BA1  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE0 + 2), 1
001BA5  1  9F A9 F9 8D  
001BA9  1  21 9F A9 C2  
001BB0  1  A9 00           lda #$00
001BB2  1  8D 23 9F        sta VERA_data0                 ; zero volume → silent
001BB5  1               @done:
001BB5  1  60              rts
001BB6  1               
001BB6  1               ;******************************************************************
001BB6  1               ; snd_stop_march — immediately silence PSG voice 0 and clear timer
001BB6  1               ;   Call when leaving gameplay (game over, wave clear, restart).
001BB6  1               ;******************************************************************
001BB6  1               snd_stop_march:
001BB6  1  64 rr           stz march_snd_timer
001BB8  1  9C 25 9F        stz VERA_ctrl
001BBB  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE0 + 2), 1
001BBF  1  9F A9 F9 8D  
001BC3  1  21 9F A9 C2  
001BCA  1  A9 00           lda #$00
001BCC  1  8D 23 9F        sta VERA_data0
001BCF  1  60              rts
001BD0  1               
001BD0  1               ;******************************************************************
001BD0  1               ; snd_fire — play short high-pitched pulse on PSG voice 1 (~800 Hz, 5 frames)
001BD0  1               ;   Called from fire_bullet.
001BD0  1               ;******************************************************************
001BD0  1               snd_fire:
001BD0  1  9C 25 9F        stz VERA_ctrl
001BD3  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE1, 1
001BD7  1  9F A9 F9 8D  
001BDB  1  21 9F A9 C4  
001BE2  1  A9 63           lda #PSG_FIRE_FREQ_L
001BE4  1  8D 23 9F        sta VERA_data0                 ; byte 0: FREQ_L
001BE7  1  A9 7F           lda #PSG_FIRE_FREQ_H
001BE9  1  8D 23 9F        sta VERA_data0                 ; byte 1: FREQ_H
001BEC  1  A9 FF           lda #PSG_MARCH_VOL             ; reuse full-volume constant
001BEE  1  8D 23 9F        sta VERA_data0                 ; byte 2: volume
001BF1  1  A9 C0           lda #PSG_WAVE_PULSE
001BF3  1  8D 23 9F        sta VERA_data0                 ; byte 3: pulse waveform
001BF6  1  A9 05           lda #FIRE_NOTE_FRAMES
001BF8  1  85 rr           sta fire_snd_timer
001BFA  1  60              rts
001BFB  1               
001BFB  1               ;******************************************************************
001BFB  1               ; snd_tick_fire — decrement fire timer; silence voice 1 when it expires
001BFB  1               ;   Call once per frame from main_loop.
001BFB  1               ;******************************************************************
001BFB  1               snd_tick_fire:
001BFB  1  A5 rr           lda fire_snd_timer
001BFD  1  F0 1B           beq @done
001BFF  1  C6 rr           dec fire_snd_timer
001C01  1  D0 17           bne @done
001C03  1  9C 25 9F        stz VERA_ctrl
001C06  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE1 + 2), 1
001C0A  1  9F A9 F9 8D  
001C0E  1  21 9F A9 C6  
001C15  1  A9 00           lda #$00
001C17  1  8D 23 9F        sta VERA_data0
001C1A  1               @done:
001C1A  1  60              rts
001C1B  1               
001C1B  1               ;******************************************************************
001C1B  1               ; snd_stop_fire — immediately silence PSG voice 1 and clear timer
001C1B  1               ;******************************************************************
001C1B  1               snd_stop_fire:
001C1B  1  64 rr           stz fire_snd_timer
001C1D  1  9C 25 9F        stz VERA_ctrl
001C20  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE1 + 2), 1
001C24  1  9F A9 F9 8D  
001C28  1  21 9F A9 C6  
001C2F  1  A9 00           lda #$00
001C31  1  8D 23 9F        sta VERA_data0
001C34  1  60              rts
001C35  1               
001C35  1               ;******************************************************************
001C35  1               ; snd_explosion — play low-frequency noise burst on PSG voice 2 (20 frames)
001C35  1               ;   Called from start_explosion (covers invader kills, UFO, player hit).
001C35  1               ;******************************************************************
001C35  1               snd_explosion:
001C35  1  9C 25 9F        stz VERA_ctrl
001C38  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE2, 1
001C3C  1  9F A9 F9 8D  
001C40  1  21 9F A9 C8  
001C47  1  A9 40           lda #PSG_EXP_FREQ_L
001C49  1  8D 23 9F        sta VERA_data0                 ; byte 0: FREQ_L (slow noise clock → deep rumble)
001C4C  1  A9 00           lda #PSG_EXP_FREQ_H
001C4E  1  8D 23 9F        sta VERA_data0                 ; byte 1: FREQ_H
001C51  1  A9 FF           lda #PSG_MARCH_VOL             ; reuse full-volume constant
001C53  1  8D 23 9F        sta VERA_data0                 ; byte 2: volume
001C56  1  A9 C0           lda #PSG_WAVE_NOISE
001C58  1  8D 23 9F        sta VERA_data0                 ; byte 3: noise waveform
001C5B  1  A9 14           lda #EXP_NOTE_FRAMES
001C5D  1  85 rr           sta exp_snd_timer
001C5F  1  60              rts
001C60  1               
001C60  1               ;******************************************************************
001C60  1               ; snd_tick_exp — decrement explosion timer; silence voice 2 when it expires
001C60  1               ;   Call once per frame from main_loop.
001C60  1               ;******************************************************************
001C60  1               snd_tick_exp:
001C60  1  A5 rr           lda exp_snd_timer
001C62  1  F0 1B           beq @done
001C64  1  C6 rr           dec exp_snd_timer
001C66  1  D0 17           bne @done
001C68  1  9C 25 9F        stz VERA_ctrl
001C6B  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE2 + 2), 1
001C6F  1  9F A9 F9 8D  
001C73  1  21 9F A9 CA  
001C7A  1  A9 00           lda #$00
001C7C  1  8D 23 9F        sta VERA_data0
001C7F  1               @done:
001C7F  1  60              rts
001C80  1               
001C80  1               ;******************************************************************
001C80  1               ; snd_stop_exp — immediately silence PSG voice 2 and clear timer
001C80  1               ;******************************************************************
001C80  1               snd_stop_exp:
001C80  1  64 rr           stz exp_snd_timer
001C82  1  9C 25 9F        stz VERA_ctrl
001C85  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE2 + 2), 1
001C89  1  9F A9 F9 8D  
001C8D  1  21 9F A9 CA  
001C94  1  A9 00           lda #$00
001C96  1  8D 23 9F        sta VERA_data0
001C99  1  60              rts
001C9A  1               
001C9A  1               ;******************************************************************
001C9A  1               ; update_hud — rewrite dynamic HUD values each frame
001C9A  1               ;   Row  1, col  0: 6-digit BCD score
001C9A  1               ;   Row  1, col 16: 6-digit BCD hi-score
001C9A  1               ;   Row 29, col  1: LIVES: N
001C9A  1               ;   Row 29, col 20: WAVE: N
001C9A  1               ;   Overwrites fixed positions; no full redraw needed.
001C9A  1               ;   Note: KERNAL PLOT convention for X16: A = row, Y = col, CLC.
001C9A  1               ;******************************************************************
001C9A  1               update_hud:
001C9A  1                  ; --- score: row 1, col 0 (Plot: Set X to Row, Set Y to Col) ---
001C9A  1  A2 01           ldx #1
001C9C  1  A0 0A           ldy #10
001C9E  1  18              clc
001C9F  1  20 F0 FF        jsr PLOT
001CA2  1  A5 rr           lda score_hi
001CA4  1  20 07 1D        jsr print_hex_byte
001CA7  1  A5 rr           lda score_mid
001CA9  1  20 07 1D        jsr print_hex_byte
001CAC  1  A5 rr           lda score_lo
001CAE  1  20 07 1D        jsr print_hex_byte
001CB1  1               
001CB1  1                  ; --- hi-score: row 1, col 16  (Plot: Set X to Row, Set Y to Col) ---
001CB1  1  A2 01           ldx #1
001CB3  1  A0 49           ldy #73
001CB5  1  18              clc
