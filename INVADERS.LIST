000810  1               ; Constants
000810  1               ;******************************************************************
000810  1               
000810  1               ; VERA display control
000810  1               VERA_SPRITE_EN  = %01000000      ; VERA_dc_video bit 6: enable sprites
000810  1               VERA_SPRITE_DIS = %10111111      ; VERA_dc_video bit 6: disable sprites
000810  1               
000810  1               ; PETSCII control codes
000810  1               PETSCII_WHITE   = $05            ; set text color to white
000810  1               PETSCII_CLR     = $93            ; clear screen and home cursor
000810  1               PETSCII_HOME    = $13            ; home cursor (no clear)
000810  1               PETSCII_RETURN  = $0D            ; carriage return
000810  1               
000810  1               ; SCREEN_SET_CHARSET font numbers (call address $FF62)
000810  1               CHARSET_UPPER   = 1              ; Commodore upper/graphics: $41-$5A = A-Z
000810  1               CHARSET_LOWER   = 2              ; Commodore lower/upper:    $41-$5A = a-z (lowercase)
000810  1               
000810  1               ; Key codes (PETSCII)
000810  1               ; KEY_RUN_STOP    = $03            ; RUN/STOP — exit game
000810  1               CHAR_Q          = $51            ; Q — exit game
000810  1               
000810  1               ; Input flag bits (key_flags)
000810  1               KEY_LEFT        = %00000001
000810  1               KEY_RIGHT       = %00000010
000810  1               KEY_FIRE        = %00000100
000810  1               
000810  1               ; JOYSTICK_GET .A return: {B,Y,Sel,Sta,Up,Dn,Left,Right} active low
000810  1               JOY_RIGHT       = %00000001     ; bit 0
000810  1               JOY_LEFT        = %00000010     ; bit 1
000810  1               
000810  1               ; Player ship — all positions in VERA 640x480 coordinate space
000810  1               PLAYER_Y        = 420            ; fixed Y, near bottom (479 = bottom edge)
000810  1               PLAYER_X_INIT   = 312            ; starting X, centred  ((640-16)/2)
000810  1               PLAYER_X_MIN    = 8              ; left  boundary (sprite left edge)
000810  1               PLAYER_X_MAX    = 616            ; right boundary (640 - 16px sprite - 8px margin)
000810  1               PLAYER_SPEED    = 4              ; pixels per frame
000810  1               
000810  1               ; Sprite attribute encoding helpers
000810  1               SPRITE1_ATTR    = $1FC08 ; sprite 1 attribute base ($1FC00=sprite 0, reserved for KERNAL mouse)
000810  1               SPR_Z_FRONT     = %00001100     ; byte 6: z-depth = %11 in bits 3-2 (in front of all layers)
000810  1               SPR_16x16_PAL0  = %01010000     ; byte 7: width=1(16px), height=1(16px), palette_off=0
000810  1               SPR_32x16_PAL0  = %10010000     ; byte 7: width=2(32px), height=1(16px), palette_off=0
000810  1               SPR_32x32_PAL0  = %10100000     ; byte 7: width=2(32px), height=2(32px), palette_off=0
000810  1               SPR_8x8_PAL0    = %00000000     ; byte 7: width=0(8px),  height=0(8px),  palette_off=0
000810  1               
000810  1               ; Explosion sprite (slot 4)
000810  1               VRAM_EXPLOSION     = $00440     ; explosion pixel data (128 bytes, 16x16 4bpp)
000810  1               EXPLODE_SPRITE_ATTR = $1FC20    ; sprite 4 attribute base (explosion)
000810  1               EXPLODE_FRAMES     = 30         ; display duration in frames (~0.5 sec at 60 Hz)
000810  1               
000810  1               ; Invader bullets (sprite slots 5-7)
000810  1               VRAM_INV_BULLET    = $00420     ; invader bullet pixel data (32 bytes, 8x8 4bpp)
000810  1               INV_BULLET_SPR_BASE = $1FC28    ; sprite 5 attribute base (first invader bullet)
000810  1               INV_BULLET_SPEED   = 6          ; VERA pixels per frame downward (=3 game pixels)
000810  1               INV_FIRE_TIMER_MIN = 10         ; minimum frames between fire attempts
000810  1               INV_FIRE_TIMER_INIT = 90        ; frames before first shot
000810  1               
000810  1               ; Player lives
000810  1               LIVES_INIT         = 3          ; starting lives
000810  1               INV_HIT_FRAMES     = 120        ; invincibility duration after being hit (2 sec at 60 Hz)
000810  1               
000810  1               ; UFO saucer (sprite slot 3)
000810  1               UFO_SPRITE_ATTR    = $1FC18      ; sprite 3 attribute base ($1FC00 + 3*8)
000810  1               VRAM_UFO           = $01500      ; UFO pixel data (128 bytes, 16x16 4bpp, after shield tiles)
000810  1               UFO_Y              = 32          ; VERA Y coord (= display pixel 16, top of play field)
000810  1               UFO_SPEED          = 2           ; VERA pixels per frame rightward (1 display pixel/frame)
000810  1               UFO_TIMER_INIT     = 600         ; frames between UFO appearances (≈10 sec at 60 Hz)
000810  1               
000810  1               ; Wave progression
000810  1               WAVE_CLEAR_FRAMES  = 180         ; auto-advance delay after wave clear (≈3 sec at 60 Hz)
000810  1               WAVE_SPEED_STEP    = 5           ; inv_move_speed decreases by this each wave
000810  1               
000810  1               ; VERA PSG voice 0 — march beat (base addr $1F9C0)
000810  1               ; 4-note cycle: ~120 Hz, ~100 Hz, ~80 Hz, ~100 Hz
000810  1               ; freq_reg = freq_hz * 25000000 / (512 * 131072) ≈ freq_hz * 2.684
000810  1               VRAM_PSG_VOICE0    = VRAM_psg + 0    ; $1F9C0 — voice 0 registers (march)
000810  1               PSG_MARCH_VOL      = $FF             ; stereo, full volume
000810  1               PSG_WAVE_PULSE     = %11000000       ; pulse waveform (bits 7:6 = 00)
000810  1               MARCH_NOTE_FRAMES  = 6               ; frames to hold each march note (~100ms)
000810  1               ; Note frequencies: 120Hz→322=$0142, 100Hz→268=$010C, 80Hz→215=$00D7
000810  1               MARCH_FREQ0_L      = $42             ; note 0: 120 Hz
000810  1               MARCH_FREQ0_H      = $01
000810  1               MARCH_FREQ1_L      = $0C             ; note 1: 100 Hz
000810  1               MARCH_FREQ1_H      = $01
000810  1               MARCH_FREQ2_L      = $D7             ; note 2:  80 Hz
000810  1               MARCH_FREQ2_H      = $00
000810  1               MARCH_FREQ3_L      = $0C             ; note 3: 100 Hz
000810  1               MARCH_FREQ3_H      = $01
000810  1               
000810  1               ; VERA PSG voice 1 — player fire sound ($1F9C0 + 1*4 = $1F9C4)
000810  1               ; ~800 Hz pulse wave: 800 * 2.684 ≈ 2147 = $0863
000810  1               VRAM_PSG_VOICE1    = VRAM_psg + 4    ; $1F9C4
000810  1               PSG_FIRE_FREQ_L    = $63             ; freq low byte (~900 Hz)
000810  1               PSG_FIRE_FREQ_H    = $7F             ; freq high byte
000810  1               FIRE_NOTE_FRAMES   = 5               ; frames to hold fire tone (~83ms)
000810  1               
000810  1               ; VERA PSG voice 2 — explosion noise burst ($1F9C0 + 2*4 = $1F9C8)
000810  1               VRAM_PSG_VOICE2    = VRAM_psg + 8    ; $1F9C8
000810  1               PSG_WAVE_NOISE     = %11000000       ; noise waveform (bits 7:6 = 11)
000810  1               PSG_EXP_FREQ_L     = $40             ; low noise clock rate → deep rumble
000810  1               PSG_EXP_FREQ_H     = $00
000810  1               EXP_NOTE_FRAMES    = 20              ; frames to hold explosion noise (~333ms)
000810  1               
000810  1               ; VERA PSG voice 3 — UFO drone (base addr $1F9C0 + 3*4 = $1F9CC)
000810  1               ; PSG byte layout: 0=FREQ_L, 1=FREQ_H, 2=volume([7]=R,[6]=L,[5:0]=vol 0-63), 3=waveform([7:6])
000810  1               ; Waveform codes: 00=pulse, 01=sawtooth, 10=triangle, 11=noise
000810  1               ; freq_hz ≈ freq_reg * 25000000 / (512 * 131072)  →  freq_reg ≈ freq_hz * 2.684
000810  1               VRAM_PSG_VOICE3    = VRAM_psg + 12   ; $1F9CC — voice 3 registers
000810  1               PSG_VOL_FULL       = $FF             ; R enable + L enable + volume 63
000810  1               PSG_VOL_HALF       = $DF             ; R enable + L enable + volume 63
000810  1               PSG_WAVE_SAW       = %01000000       ; sawtooth waveform (bits 7:6 = 01)
000810  1               UFO_DRONE_FREQ1    = $0400            ; ≈400 Hz  ($0432)
000810  1               UFO_DRONE_FREQ2    = $0600            ; ≈600 Hz  ($064B)
000810  1               
000810  1               ; Shields
000810  1               SHIELD_Y           = 352        ; VERA Y coordinate for all 4 shields (176 display pixels)
000810  1               SHIELD_SPR_BASE    = $1FE10     ; sprite slot 66 attr ($1FC00 + 66*8); slots 8-65 in use
000810  1               VRAM_SHIELD_FULL   = $00500     ; 512-byte 32x32 4bpp tile: intact
000810  1               VRAM_SHIELD_DMG1   = $00700     ; 12% damaged
000810  1               VRAM_SHIELD_DMG2   = $00900     ; 25% damaged
000810  1               VRAM_SHIELD_DMG3   = $00B00     ; 37% damaged
000810  1               VRAM_SHIELD_DMG4   = $00D00     ; 50% damaged
000810  1               VRAM_SHIELD_DMG5   = $00F00     ; 62% damaged
000810  1               VRAM_SHIELD_DMG6   = $01100     ; 75% damaged
000810  1               VRAM_SHIELD_DMG7   = $01300     ; nearly destroyed
000810  1               
000810  1               ; Player bullet
000810  1               BULLET_SPRITE_ATTR = $1FC10     ; sprite 2 attribute base (player bullet)
000810  1               VRAM_BULLET     = $00400        ; player bullet pixel data (32 bytes, 8x8 4bpp)
000810  1               BULLET_SPEED    = 12            ; VERA pixels per frame upward (= 6 game pixels)
000810  1               BULLET_Y_INIT   = PLAYER_Y - 8 ; bullet starts just above player ship top
000810  1               
000810  1               ; Invader grid geometry (VERA 640x480 coordinate space)
000810  1               INV_GRID_X_INIT   = 112         ; left-column X at start (centered: (640 - 10*40 - 16) / 2 = 112)
000810  1               INV_GRID_Y_BASE   = 80          ; top-row Y, fixed base (drops added via inv_offset_y)
000810  1               INV_SPACING_X     = 40          ; VERA pixels between invader column origins
000810  1               INV_SPACING_Y     = 48          ; VERA pixels between invader row origins
000810  1               INV_STEP_X        = 4           ; VERA pixels per march step
000810  1               INV_DROP_Y        = 16          ; VERA pixels per grid drop
000810  1               INV_MOVE_SPEED_INIT = 50        ; frames between march steps (initial)
000810  1               INV_COUNT_INIT    = 55
000810  1               INV_MOVE_SPEED_MIN = 5           ; minimum frames per march step
000810  1               
000810  1               ; Grid boundary: when grid_x reaches these values, reverse and drop
000810  1               ; Rightmost invader base X = grid_x + 10*INV_SPACING_X (=400). Right wall = 624 (640-16px).
000810  1               ; So right limit = 624 - 400 - 16 = 208
000810  1               INV_X_RIGHT_LIM   = 208
000810  1               INV_X_LEFT_LIM    = 16          ; leftmost sprite at x=grid_x must stay >= 16
000810  1               
000810  1               ; VRAM addresses for invader sprite pixel data (128 bytes each, 16x16 4bpp)
000810  1               VRAM_INV_A_F0   = $00100        ; Type A (crab,   bottom rows 3-4), frame 0
000810  1               VRAM_INV_A_F1   = $00180        ; Type A frame 1
000810  1               VRAM_INV_B_F0   = $00200        ; Type B (octopus, middle rows 1-2), frame 0
000810  1               VRAM_INV_B_F1   = $00280        ; Type B frame 1
000810  1               VRAM_INV_C_F0   = $00300        ; Type C (squid,   top row 0), frame 0
000810  1               VRAM_INV_C_F1   = $00380        ; Type C frame 1
000810  1               
000810  1               ; Sprite addr[12:5] byte values for each type/frame (= VRAM_addr >> 5)
000810  1               ;   VRAM $00100>>5=$08  $00180>>5=$0C  $00200>>5=$10  $00280>>5=$14  $00300>>5=$18  $00380>>5=$1C
000810  1               INV_ATTR_BASE   = $1FC58        ; sprite slot 11 = first invader ($1FC00 + 11*8)
000810  1               INV_SPRITE_SLOT = 11            ; first invader sprite slot index
000810  1               
000810  1               ;******************************************************************
000810  1               ; start — main program entry point
000810  1               ;******************************************************************
000810  1               start:
000810  1  78              sei                           ; disable interrupts during init
000811  1               
000811  1                  ; Switch to 40-column text mode (mode 0)
000811  1                  ; Carry clear = SET mode (carry set = READ mode)
000811  1  18              clc
000812  1  A9 00           lda #$00
000814  1  20 5F FF        jsr SCREEN_MODE
000817  1               
000817  1                  ; Seed PRNG with hardware entropy
000817  1  20 CF FE        jsr ENTROPY_GET
00081A  1  85 rr           sta rand_seed_lo
00081C  1  86 rr           stx rand_seed_hi
00081E  1               
00081E  1                  ; Enable sprites in VERA display controller
00081E  1  9C 25 9F        stz VERA_ctrl                 ; DCSEL=0, ADDRSEL=0
000821  1  AD 29 9F        lda VERA_dc_video
000824  1  09 40           ora #VERA_SPRITE_EN
000826  1  8D 29 9F        sta VERA_dc_video
000829  1               
000829  1               
000829  1                  ; Clear game variables
000829  1  64 rr           stz key_last
00082B  1  64 rr           stz key_flags
00082D  1  64 rr           stz frame_count
00082F  1  64 rr           stz bullet_active
000831  1  64 rr           stz score_lo
000833  1  64 rr           stz score_mid
000835  1  64 rr           stz score_hi
000837  1  64 rr           stz hi_score_lo
000839  1  64 rr           stz hi_score_mid
00083B  1  64 rr           stz hi_score_hi
00083D  1  64 rr           stz ufo_active
00083F  1  A9 58           lda #<UFO_TIMER_INIT
000841  1  85 rr           sta ufo_timer_lo
000843  1  A9 02           lda #>UFO_TIMER_INIT
000845  1  85 rr           sta ufo_timer_hi
000847  1  64 rr           stz shot_count
000849  1  64 rr           stz march_beat
00084B  1  64 rr           stz march_snd_timer
00084D  1  64 rr           stz fire_snd_timer
00084F  1  64 rr           stz exp_snd_timer
000851  1  A9 01           lda #1
000853  1  85 rr           sta wave
000855  1  A9 32           lda #INV_MOVE_SPEED_INIT
000857  1  85 rr           sta wave_init_speed
000859  1               
000859  1                  ; Set initial player position before sprite init reads it
000859  1  20 9B 09        jsr init_player
00085C  1               
00085C  1  58              cli                           ; re-enable interrupts
00085D  1               
00085D  1                  ; Switch to Commodore uppercase/graphics charset: $41-$5A = A-Z
00085D  1                  ; Must be called AFTER SCREEN_MODE (which resets to lowercase by default)
00085D  1  A9 01           lda #CHARSET_UPPER
00085F  1  20 62 FF        jsr SCREEN_SET_CHARSET
000862  1               
000862  1                  ; Clear screen and set text color
000862  1  A9 05           lda #PETSCII_WHITE
000864  1  20 D2 FF        jsr CHROUT
000867  1  A9 93           lda #PETSCII_CLR
000869  1  20 D2 FF        jsr CHROUT
00086C  1               
00086C  1                  ; Upload sprite pixel data and configure sprite 1 attributes
00086C  1  20 AA 09        jsr init_sprites
00086F  1               
00086F  1                  ; Upload invader sprite data, set palette, init grid state, place sprites
00086F  1  20 A9 0B        jsr init_invaders
000872  1  20 DE 15        jsr hide_all_inv_sprites     ; hide all 55 during title screen
000875  1               
000875  1  20 87 14        jsr draw_title_screen
000878  1               
000878  1               ;------------------------------------------------------------------
000878  1               ; title_loop — wait for SPACE; blink "PRESS SPACE TO START"
000878  1               ;------------------------------------------------------------------
000878  1               title_loop:
000878  1  20 4E 09        jsr wait_vsync
00087B  1  E6 rr           inc frame_count
00087D  1  20 50 09        jsr update_input
000880  1               
000880  1  A5 rr           lda key_last
000882  1  C9 51           cmp #CHAR_Q
000884  1  D0 03           bne @tl_no_exit
000886  1  4C 3B 09        jmp exit_game
000889  1               @tl_no_exit:
000889  1               
000889  1  A5 rr           lda key_flags
00088B  1  29 04           and #KEY_FIRE
00088D  1  D0 33           bne start_game
00088F  1               
00088F  1                  ; blink using frame_count bit 5 (~2 Hz)
00088F  1  A5 rr           lda frame_count
000891  1  29 20           and #$20
000893  1  D0 15           bne @tl_on
000895  1               @tl_off:
000895  1  A2 21           ldx #33
000897  1  A0 1E           ldy #30
000899  1  18              clc
00089A  1  20 F0 FF        jsr PLOT
00089D  1  A2 14           ldx #20                      ; erase 20 chars of "PRESS SPACE TO START"
00089F  1  A9 20        @tl_erase: lda #' '
0008A1  1  20 D2 FF        jsr CHROUT
0008A4  1  CA              dex
0008A5  1  D0 F8           bne @tl_erase
0008A7  1  4C 78 08        jmp title_loop
0008AA  1               @tl_on:
0008AA  1  A2 21           ldx #33
0008AC  1  A0 1E           ldy #30
0008AE  1  18              clc
0008AF  1  20 F0 FF        jsr PLOT
0008B2  1  A2 00           ldx #0
0008B4  1  BD 6C 1D     @tl_print: lda str_press_space, x
0008B7  1  F0 06           beq @tl_print_done
0008B9  1  20 D2 FF        jsr CHROUT
0008BC  1  E8              inx
0008BD  1  80 F5           bra @tl_print
0008BF  1               @tl_print_done:
0008BF  1  4C 78 08        jmp title_loop
0008C2  1               
0008C2  1               start_game:
0008C2  1  20 E0 0C        jsr update_invader_sprites   ; re-enable all 55 invaders at grid positions
0008C5  1  20 FB 15        jsr init_shields             ; upload shield tiles, init damage counters, place sprites
0008C8  1  A9 93           lda #PETSCII_CLR
0008CA  1  20 D2 FF        jsr CHROUT                   ; clear title text, leave sprites visible
0008CD  1  20 5C 14        jsr draw_score_labels        ; paint "SCORE" / "HI-SCORE" headings
0008D0  1               
0008D0  1               ;******************************************************************
0008D0  1               ; main_loop — one iteration per video frame (60 Hz)
0008D0  1               ;******************************************************************
0008D0  1               main_loop:
0008D0  1  20 4E 09        jsr wait_vsync
0008D3  1               
0008D3  1  E6 rr           inc frame_count
0008D5  1               
0008D5  1  20 50 09        jsr update_input              ; fills key_flags (joystick) + key_last (GETIN)
0008D8  1               
0008D8  1  A5 rr           lda key_last
0008DA  1  C9 51           cmp #CHAR_Q
0008DC  1  F0 5D           beq exit_game
0008DE  1               
0008DE  1                  ; --- invincibility timer ---
0008DE  1  A5 rr           lda inv_hit_timer
0008E0  1  F0 02           beq @no_inv_dec
0008E2  1  C6 rr           dec inv_hit_timer
0008E4  1               @no_inv_dec:
0008E4  1               
0008E4  1  20 96 0D        jsr move_player               ; apply movement, clamp to boundaries
0008E7  1  20 E5 0D        jsr update_player_sprite      ; write new X to VERA sprite 1
0008EA  1               
0008EA  1                  ; --- fire player bullet (SPACE pressed, bullet inactive, and player not dead) ---
0008EA  1  A5 rr           lda key_flags
0008EC  1  29 04           and #KEY_FIRE
0008EE  1  F0 0B           beq @skip_fire
0008F0  1  A5 rr           lda bullet_active
0008F2  1  D0 07           bne @skip_fire
0008F4  1  A5 rr           lda inv_hit_timer
0008F6  1  D0 03           bne @skip_fire
0008F8  1  20 28 0E        jsr fire_bullet
0008FB  1               @skip_fire:
0008FB  1               
0008FB  1                  ; --- move bullet if active ---
0008FB  1  A5 rr           lda bullet_active
0008FD  1  F0 03           beq @skip_bullet_move
0008FF  1  20 4A 0E        jsr move_bullet
000902  1               @skip_bullet_move:
000902  1               
000902  1                  ; --- check player bullet vs invader collision ---
000902  1  20 9B 0E        jsr check_bullet_invader
000905  1               
000905  1                  ; --- check player bullet vs shield collision ---
000905  1  20 87 18        jsr check_bullet_shields
000908  1               
000908  1                  ; --- explosion timer ---
000908  1  20 ED 0F        jsr update_explosion
00090B  1               
00090B  1                  ; --- invader bullets: move, spawn, boundary check ---
00090B  1  20 1C 10        jsr update_inv_bullets
00090E  1               
00090E  1                  ; --- invader bullet vs player collision ---
00090E  1  20 2A 11        jsr check_inv_bullet_player
000911  1               
000911  1                  ; --- invader bullet vs shield collision ---
000911  1  20 F9 18        jsr check_invbullet_shields
000914  1               
000914  1                  ; --- UFO spawn/move and player bullet collision ---
000914  1  20 9A 19        jsr update_ufo
000917  1  20 33 1A        jsr check_bullet_ufo
00091A  1               
00091A  1                  ; --- Invader march timer ---
00091A  1  C6 rr           dec inv_move_timer
00091C  1  D0 07           bne @skip_inv_step
00091E  1  20 78 0C        jsr step_invaders             ; move grid, check bounds, update sprites
000921  1  A5 rr           lda inv_move_speed
000923  1  85 rr           sta inv_move_timer
000925  1               @skip_inv_step:
000925  1               
000925  1                  ; --- check wave clear (all 55 invaders dead) ---
000925  1  A5 rr           lda inv_count
000927  1  D0 03           bne @no_wave_clear
000929  1  4C 69 13        jmp wave_clear_screen
00092C  1               @no_wave_clear:
00092C  1               
00092C  1  20 96 1B        jsr snd_tick_march            ; silence march note when timer expires
00092F  1  20 FB 1B        jsr snd_tick_fire             ; silence fire tone when timer expires
000932  1  20 60 1C        jsr snd_tick_exp              ; silence explosion noise when timer expires
000935  1  20 9A 1C        jsr update_hud                ; refresh text readouts
000938  1               
000938  1  4C D0 08        jmp main_loop
00093B  1               
00093B  1               ;------------------------------------------------------------------
00093B  1               exit_game:
00093B  1                  ; Didable sprites in VERA display controller
00093B  1  9C 25 9F        stz VERA_ctrl                 ; DCSEL=0, ADDRSEL=0
00093E  1  AD 29 9F        lda VERA_dc_video
000941  1  25 BF           and VERA_SPRITE_DIS
000943  1  8D 29 9F        sta VERA_dc_video
000946  1               
000946  1  A9 93           lda #PETSCII_CLR
000948  1  20 D2 FF        jsr CHROUT
00094B  1               
00094B  1  4C 47 FF        jmp ENTER_BASIC
00094E  1               
00094E  1               ;******************************************************************
00094E  1               ; wait_vsync — busy-poll VERA_isr until VSYNC, then clear flag
00094E  1               ;******************************************************************
00094E  1               wait_vsync:
00094E  1                  ; WAI sleeps the CPU until any IRQ fires.  The KERNAL's VSYNC IRQ
00094E  1                  ; handler (60 Hz) wakes us up and has already cleared VERA_isr bit 0
00094E  1                  ; by the time execution returns here, so polling VERA_isr would loop
00094E  1                  ; forever.  Just return — one WAI ≈ one frame.
00094E  1  CB              wai
00094F  1  60              rts
000950  1               
000950  1               ;******************************************************************
000950  1               ; update_input — joystick + GETIN keyboard input each frame
000950  1               ;
000950  1               ;   key_flags bits set this frame:
000950  1               ;     KEY_LEFT  — left arrow held
000950  1               ;     KEY_RIGHT — right arrow held
000950  1               ;     KEY_FIRE  — space bar pressed
000950  1               ;   key_last   — raw PETSCII from GETIN (Q etc.)
000950  1               ;
000950  1               ;   JOYSTICK_GET(0) = keyboard-as-joystick; gives smooth held-key
000950  1               ;   movement with no repeat delay.  GETIN handles space and Q.
000950  1               ;******************************************************************
000950  1               update_input:
000950  1  64 rr           stz key_flags
000952  1  64 rr           stz key_last
000954  1               
000954  1                  ; --- joystick 0 = keyboard d-pad (active low: 0 = pressed) ---
000954  1                  ; Byte returned: {B,Y,Sel,Sta,Up,Dn,Left,Right} bits 7–0
000954  1  A9 00           lda #0
000956  1  20 56 FF        jsr JOYSTICK_GET
000959  1  48              pha                           ; save — AND destroys .A
00095A  1               
00095A  1  29 01           and #JOY_RIGHT                ; bit 0: right arrow
00095C  1  D0 06           bne @not_right
00095E  1  A5 rr           lda key_flags
000960  1  09 02           ora #KEY_RIGHT
000962  1  85 rr           sta key_flags
000964  1               @not_right:
000964  1  68              pla
000965  1  29 02           and #JOY_LEFT                 ; bit 1: left arrow
000967  1  D0 06           bne @not_left
000969  1  A5 rr           lda key_flags
00096B  1  09 01           ora #KEY_LEFT
00096D  1  85 rr           sta key_flags
00096F  1               @not_left:
00096F  1               
00096F  1                  ; --- GETIN — discrete events: fire, Q, arrow fallback ---
00096F  1               @getin_drain:
00096F  1  20 E4 FF        jsr GETIN
000972  1  F0 26           beq @getin_done               ; buffer empty
000974  1  85 rr           sta key_last
000976  1  C9 9D           cmp #$9D                      ; cursor left (PETSCII)
000978  1  D0 08           bne @chk_right_getin
00097A  1  A5 rr           lda key_flags
00097C  1  09 01           ora #KEY_LEFT
00097E  1  85 rr           sta key_flags
000980  1  80 ED           bra @getin_drain
000982  1               @chk_right_getin:
000982  1  C9 1D           cmp #$1D                      ; cursor right (PETSCII)
000984  1  D0 08           bne @chk_fire_getin
000986  1  A5 rr           lda key_flags
000988  1  09 02           ora #KEY_RIGHT
00098A  1  85 rr           sta key_flags
00098C  1  80 E1           bra @getin_drain
00098E  1               @chk_fire_getin:
00098E  1  C9 20           cmp #$20                      ; space = fire
000990  1  D0 DD           bne @getin_drain
000992  1  A5 rr           lda key_flags
000994  1  09 04           ora #KEY_FIRE
000996  1  85 rr           sta key_flags
000998  1  80 D5           bra @getin_drain
00099A  1               @getin_done:
00099A  1  60              rts
00099B  1               
00099B  1               ;******************************************************************
00099B  1               ; init_player — set player_x to starting position
00099B  1               ;******************************************************************
00099B  1               init_player:
00099B  1  A9 38           lda #<PLAYER_X_INIT
00099D  1  85 rr           sta player_x_lo
00099F  1  A9 01           lda #>PLAYER_X_INIT
0009A1  1  85 rr           sta player_x_hi
0009A3  1  A9 03           lda #LIVES_INIT
0009A5  1  85 rr           sta lives
0009A7  1  64 rr           stz inv_hit_timer
0009A9  1  60              rts
0009AA  1               
0009AA  1               ;******************************************************************
0009AA  1               ; init_sprites — upload pixel data + write sprite 1 attributes
0009AA  1               ;
0009AA  1               ;   Sprite 0 ($1FC00) is reserved by the KERNAL mouse cursor —
0009AA  1               ;   we disable it and keep clear of $1FC00.
0009AA  1               ;
0009AA  1               ;   Sprite 1 ($1FC08) = player ship
0009AA  1               ;   Pixel data at VRAM $00080 (128 bytes, 16x16 4bpp)
0009AA  1               ;   Address encoding:  addr[12:5] = $00080>>5 = $04  → byte 0 = $04
0009AA  1               ;                      4bpp, addr[16:13] = 0          → byte 1 = $00
0009AA  1               ;******************************************************************
0009AA  1               init_sprites:
0009AA  1  9C 25 9F        stz VERA_ctrl
0009AD  1               
0009AD  1                  ; --- set palette entries 1-4 ---
0009AD  1                  ; VERA palette entry N is 2 bytes at VRAM_palette + N*2
0009AD  1                  ; Byte 0: [7:4]=Green [3:0]=Blue   Byte 1: [3:0]=Red (bits 7-4 unused)
0009AD  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_palette + 2), 1   ; entry 1 (player white); stride=1 auto-advances
0009B1  1  9F A9 FA 8D  
0009B5  1  21 9F A9 02  
0009BC  1  A9 FF           lda #$FF                               ; G=$F, B=$F
0009BE  1  8D 23 9F        sta VERA_data0
0009C1  1  A9 0F           lda #$0F                               ; R=$F  → white
0009C3  1  8D 23 9F        sta VERA_data0
0009C6  1                  ; entry 2 = cyan  (R=0, G=$F, B=$F)
0009C6  1  A9 FF           lda #$FF                               ; G=$F, B=$F
0009C8  1  8D 23 9F        sta VERA_data0
0009CB  1  A9 00           lda #$00                               ; R=$0
0009CD  1  8D 23 9F        sta VERA_data0
0009D0  1                  ; entry 3 = magenta (R=$F, G=0, B=$F)
0009D0  1  A9 0F           lda #$0F                               ; G=$0, B=$F
0009D2  1  8D 23 9F        sta VERA_data0
0009D5  1  A9 0F           lda #$0F                               ; R=$F
0009D7  1  8D 23 9F        sta VERA_data0
0009DA  1                  ; entry 4 = green  (R=0, G=$F, B=0)
0009DA  1  A9 F0           lda #$F0                               ; G=$F, B=$0
0009DC  1  8D 23 9F        sta VERA_data0
0009DF  1  A9 00           lda #$00                               ; R=$0
0009E1  1  8D 23 9F        sta VERA_data0
0009E4  1                  ; entry 5 = red    (R=$F, G=0, B=0)
0009E4  1  A9 00           lda #$00                               ; G=$0, B=$0
0009E6  1  8D 23 9F        sta VERA_data0
0009E9  1  A9 0F           lda #$0F                               ; R=$F
0009EB  1  8D 23 9F        sta VERA_data0
0009EE  1                  ; --- disable sprite 0 (KERNAL mouse cursor) ---
0009EE  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_sprattr + 6), 1   ; sprite 0 byte 6 = z-depth
0009F2  1  9F A9 FC 8D  
0009F6  1  21 9F A9 06  
0009FD  1  A9 00           lda #$00                               ; z-depth=0 → disabled
0009FF  1  8D 23 9F        sta VERA_data0
000A02  1               
000A02  1                  ; --- upload player sprite pixel data to VRAM $00080 ---
000A02  1  A9 10 8D 22     VERA_SET_ADDR $00080, 1
000A06  1  9F A9 00 8D  
000A0A  1  21 9F A9 80  
000A11  1  A2 00           ldx #0
000A13  1               @upload:
000A13  1  BD EC 1D        lda player_spr_data,x
000A16  1  8D 23 9F        sta VERA_data0
000A19  1  E8              inx
000A1A  1  E0 80           cpx #128
000A1C  1  D0 F5           bne @upload
000A1E  1               
000A1E  1                  ; --- write sprite 1 attribute bytes ---
000A1E  1  A9 11 8D 22     VERA_SET_ADDR SPRITE1_ATTR, 1
000A22  1  9F A9 FC 8D  
000A26  1  21 9F A9 08  
000A2D  1  A9 04           lda #$04
000A2F  1  8D 23 9F        sta VERA_data0               ; byte 0: addr[12:5] = $00080>>5 = $04
000A32  1  A9 00           lda #$00
000A34  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, addr[16:13] = 0
000A37  1  A5 rr           lda player_x_lo
000A39  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000A3C  1  A5 rr           lda player_x_hi
000A3E  1  29 03           and #$03
000A40  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000A43  1  A9 A4           lda #<PLAYER_Y
000A45  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000A48  1  A9 01           lda #>PLAYER_Y
000A4A  1  29 03           and #$03
000A4C  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000A4F  1  A9 0C           lda #SPR_Z_FRONT
000A51  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3, no collision, no flip
000A54  1  A9 50           lda #SPR_16x16_PAL0
000A56  1  8D 23 9F        sta VERA_data0               ; byte 7: palette 0, 16x16
000A59  1               
000A59  1                  ; --- upload player bullet pixel data to VRAM $00400 ---
000A59  1  A9 10 8D 22     VERA_SET_ADDR VRAM_BULLET, 1
000A5D  1  9F A9 04 8D  
000A61  1  21 9F A9 00  
000A68  1  A2 00           ldx #0
000A6A  1               @up_bullet:
000A6A  1  BD 6C 1E        lda bullet_spr_data,x
000A6D  1  8D 23 9F        sta VERA_data0
000A70  1  E8              inx
000A71  1  E0 20           cpx #32
000A73  1  D0 F5           bne @up_bullet
000A75  1               
000A75  1                  ; --- write sprite 2 attributes (initially disabled, z-depth=0) ---
000A75  1  A9 11 8D 22     VERA_SET_ADDR BULLET_SPRITE_ATTR, 1
000A79  1  9F A9 FC 8D  
000A7D  1  21 9F A9 10  
000A84  1  A9 20           lda #$20                     ; byte 0: addr[12:5] = $00400>>5 = $20
000A86  1  8D 23 9F        sta VERA_data0
000A89  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000A8B  1  8D 23 9F        sta VERA_data0
000A8E  1  A9 00           lda #$00                     ; byte 2: X lo (arbitrary; sprite disabled)
000A90  1  8D 23 9F        sta VERA_data0
000A93  1  A9 00           lda #$00                     ; byte 3: X hi
000A95  1  8D 23 9F        sta VERA_data0
000A98  1  A9 00           lda #$00                     ; byte 4: Y lo
000A9A  1  8D 23 9F        sta VERA_data0
000A9D  1  A9 00           lda #$00                     ; byte 5: Y hi
000A9F  1  8D 23 9F        sta VERA_data0
000AA2  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000AA4  1  8D 23 9F        sta VERA_data0
000AA7  1  A9 00           lda #SPR_8x8_PAL0            ; byte 7: 8x8, palette 0
000AA9  1  8D 23 9F        sta VERA_data0
000AAC  1               
000AAC  1                  ; --- upload explosion pixel data to VRAM $00440 ---
000AAC  1  A9 10 8D 22     VERA_SET_ADDR VRAM_EXPLOSION, 1
000AB0  1  9F A9 04 8D  
000AB4  1  21 9F A9 40  
000ABB  1  A2 00           ldx #0
000ABD  1               @up_exp:
000ABD  1  BD 46 1F        lda explosion_pixels,x
000AC0  1  8D 23 9F        sta VERA_data0
000AC3  1  E8              inx
000AC4  1  E0 80           cpx #128
000AC6  1  D0 F5           bne @up_exp
000AC8  1               
000AC8  1                  ; --- write sprite 4 attributes (initially disabled) ---
000AC8  1                  ; addr[12:5] = VRAM_EXPLOSION>>5 = $00440>>5 = $22
000AC8  1  A9 11 8D 22     VERA_SET_ADDR EXPLODE_SPRITE_ATTR, 1
000ACC  1  9F A9 FC 8D  
000AD0  1  21 9F A9 20  
000AD7  1  A9 22           lda #$22                     ; byte 0: addr[12:5]
000AD9  1  8D 23 9F        sta VERA_data0
000ADC  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000ADE  1  8D 23 9F        sta VERA_data0
000AE1  1  A9 00           lda #$00                     ; byte 2: X lo (placeholder)
000AE3  1  8D 23 9F        sta VERA_data0
000AE6  1  A9 00           lda #$00                     ; byte 3: X hi
000AE8  1  8D 23 9F        sta VERA_data0
000AEB  1  A9 00           lda #$00                     ; byte 4: Y lo (placeholder)
000AED  1  8D 23 9F        sta VERA_data0
000AF0  1  A9 00           lda #$00                     ; byte 5: Y hi
000AF2  1  8D 23 9F        sta VERA_data0
000AF5  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000AF7  1  8D 23 9F        sta VERA_data0
000AFA  1  A9 50           lda #SPR_16x16_PAL0          ; byte 7: 16x16, palette 0
000AFC  1  8D 23 9F        sta VERA_data0
000AFF  1               
000AFF  1  64 rr           stz exp_timer
000B01  1               
000B01  1                  ; --- upload invader bullet pixel data to VRAM $00420 ---
000B01  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_BULLET, 1
000B05  1  9F A9 04 8D  
000B09  1  21 9F A9 20  
000B10  1  A2 00           ldx #0
000B12  1               @up_ibul:
000B12  1  BD 26 1F        lda inv_bullet_spr_data,x
000B15  1  8D 23 9F        sta VERA_data0
000B18  1  E8              inx
000B19  1  E0 20           cpx #32
000B1B  1  D0 F5           bne @up_ibul
000B1D  1               
000B1D  1                  ; --- init 3 invader bullet sprites (slots 5-7, base $1FC28), all disabled ---
000B1D  1                  ; addr[12:5] = VRAM_INV_BULLET>>5 = $00420>>5 = $21
000B1D  1  A9 11 8D 22     VERA_SET_ADDR INV_BULLET_SPR_BASE, 1
000B21  1  9F A9 FC 8D  
000B25  1  21 9F A9 28  
000B2C  1  A2 03           ldx #3                       ; 3 sprites
000B2E  1               @init_ibspr:
000B2E  1  A9 21           lda #$21                     ; byte 0: addr[12:5] = $21
000B30  1  8D 23 9F        sta VERA_data0
000B33  1  A9 00           lda #$00
000B35  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, bank 0
000B38  1  8D 23 9F        sta VERA_data0               ; byte 2: X lo
000B3B  1  8D 23 9F        sta VERA_data0               ; byte 3: X hi
000B3E  1  8D 23 9F        sta VERA_data0               ; byte 4: Y lo
000B41  1  8D 23 9F        sta VERA_data0               ; byte 5: Y hi
000B44  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=0 → disabled
000B47  1  8D 23 9F        sta VERA_data0               ; byte 7: 8x8, palette 0
000B4A  1  CA              dex
000B4B  1  D0 E1           bne @init_ibspr
000B4D  1               
000B4D  1                  ; --- clear invader bullet state ---
000B4D  1  64 rr           stz ibul_active+0
000B4F  1  64 rr           stz ibul_active+1
000B51  1  64 rr           stz ibul_active+2
000B53  1  A9 5A           lda #INV_FIRE_TIMER_INIT
000B55  1  85 rr           sta inv_fire_timer
000B57  1               
000B57  1                  ; --- upload UFO pixel data → VRAM $01500 ---
000B57  1  A9 10 8D 22     VERA_SET_ADDR VRAM_UFO, 1
000B5B  1  9F A9 15 8D  
000B5F  1  21 9F A9 00  
000B66  1  A2 80           ldx #128
000B68  1  BD 46 1F     @up_ufo: lda ufo_spr_data-128,x
000B6B  1  8D 23 9F        sta VERA_data0
000B6E  1  E8              inx
000B6F  1  D0 F7           bne @up_ufo
000B71  1               
000B71  1                  ; --- write sprite 3 (UFO) attributes (initially disabled) ---
000B71  1                  ; addr[12:5] = VRAM_UFO>>5 = $01500>>5 = $A8
000B71  1  A9 11 8D 22     VERA_SET_ADDR UFO_SPRITE_ATTR, 1
000B75  1  9F A9 FC 8D  
000B79  1  21 9F A9 18  
000B80  1  A9 A8           lda #$A8                     ; byte 0: addr[12:5]
000B82  1  8D 23 9F        sta VERA_data0
000B85  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000B87  1  8D 23 9F        sta VERA_data0
000B8A  1  A9 00           lda #$00                     ; byte 2: X lo
000B8C  1  8D 23 9F        sta VERA_data0
000B8F  1  A9 00           lda #$00                     ; byte 3: X hi
000B91  1  8D 23 9F        sta VERA_data0
000B94  1  A9 20           lda #<UFO_Y                  ; byte 4: Y lo
000B96  1  8D 23 9F        sta VERA_data0
000B99  1  A9 00           lda #>UFO_Y                  ; byte 5: Y hi
000B9B  1  8D 23 9F        sta VERA_data0
000B9E  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000BA0  1  8D 23 9F        sta VERA_data0
000BA3  1  A9 50           lda #SPR_16x16_PAL0          ; byte 7: 16x16, palette 0
000BA5  1  8D 23 9F        sta VERA_data0
000BA8  1               
000BA8  1  60              rts
000BA9  1               
000BA9  1               ;******************************************************************
000BA9  1               ; init_invaders — upload invader pixel data, init grid state, place sprites
000BA9  1               ;******************************************************************
000BA9  1               init_invaders:
000BA9  1  9C 25 9F        stz VERA_ctrl
000BAC  1               
000BAC  1                  ; --- upload Type A frame 0 → VRAM $00100 ---
000BAC  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F0, 1
000BB0  1  9F A9 01 8D  
000BB4  1  21 9F A9 00  
000BBB  1  A2 80           ldx #128
000BBD  1  BD C6 1F     @up_af0: lda inv_a_spr_f0-128,x
000BC0  1  8D 23 9F        sta VERA_data0
000BC3  1  E8              inx
000BC4  1  D0 F7           bne @up_af0
000BC6  1               
000BC6  1                  ; --- upload Type A frame 1 → VRAM $00180 ---
000BC6  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F1, 1
000BCA  1  9F A9 01 8D  
000BCE  1  21 9F A9 80  
000BD5  1  A2 80           ldx #128
000BD7  1  BD 46 20     @up_af1: lda inv_a_spr_f1-128,x
000BDA  1  8D 23 9F        sta VERA_data0
000BDD  1  E8              inx
000BDE  1  D0 F7           bne @up_af1
000BE0  1               
000BE0  1                  ; --- upload Type B frame 0 → VRAM $00200 ---
000BE0  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F0, 1
000BE4  1  9F A9 02 8D  
000BE8  1  21 9F A9 00  
000BEF  1  A2 80           ldx #128
000BF1  1  BD C6 20     @up_bf0: lda inv_b_spr_f0-128,x
000BF4  1  8D 23 9F        sta VERA_data0
000BF7  1  E8              inx
000BF8  1  D0 F7           bne @up_bf0
000BFA  1               
000BFA  1                  ; --- upload Type B frame 1 → VRAM $00280 ---
000BFA  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F1, 1
000BFE  1  9F A9 02 8D  
000C02  1  21 9F A9 80  
000C09  1  A2 80           ldx #128
000C0B  1  BD 46 21     @up_bf1: lda inv_b_spr_f1-128,x
000C0E  1  8D 23 9F        sta VERA_data0
000C11  1  E8              inx
000C12  1  D0 F7           bne @up_bf1
000C14  1               
000C14  1                  ; --- upload Type C frame 0 → VRAM $00300 ---
000C14  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F0, 1
000C18  1  9F A9 03 8D  
000C1C  1  21 9F A9 00  
000C23  1  A2 80           ldx #128
000C25  1  BD C6 21     @up_cf0: lda inv_c_spr_f0-128,x
000C28  1  8D 23 9F        sta VERA_data0
000C2B  1  E8              inx
000C2C  1  D0 F7           bne @up_cf0
000C2E  1               
000C2E  1                  ; --- upload Type C frame 1 → VRAM $00380 ---
000C2E  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F1, 1
000C32  1  9F A9 03 8D  
000C36  1  21 9F A9 80  
000C3D  1  A2 80           ldx #128
000C3F  1  BD 46 22     @up_cf1: lda inv_c_spr_f1-128,x
000C42  1  8D 23 9F        sta VERA_data0
000C45  1  E8              inx
000C46  1  D0 F7           bne @up_cf1
000C48  1               
000C48  1                  ; --- initialize zero-page grid variables ---
000C48  1  A9 70           lda #<INV_GRID_X_INIT
000C4A  1  85 rr           sta inv_grid_x_lo
000C4C  1  A9 00           lda #>INV_GRID_X_INIT
000C4E  1  85 rr           sta inv_grid_x_hi
000C50  1  64 rr           stz inv_offset_y
000C52  1  64 rr           stz inv_direction
000C54  1  64 rr           stz inv_anim_frame
000C56  1  64 rr           stz inv_drop_flag
000C58  1               
000C58  1                  ; all 55 invaders alive: bytes 0-5 = $FF, byte 6 = $7F (55 bits)
000C58  1  A9 FF           lda #$FF
000C5A  1  85 rr           sta inv_alive+0
000C5C  1  85 rr           sta inv_alive+1
000C5E  1  85 rr           sta inv_alive+2
000C60  1  85 rr           sta inv_alive+3
000C62  1  85 rr           sta inv_alive+4
000C64  1  85 rr           sta inv_alive+5
000C66  1  A9 7F           lda #$7F
000C68  1  85 rr           sta inv_alive+6
000C6A  1               
000C6A  1  A9 37           lda #INV_COUNT_INIT
000C6C  1  85 rr           sta inv_count
000C6E  1  A5 rr           lda wave_init_speed
000C70  1  85 rr           sta inv_move_speed
000C72  1  85 rr           sta inv_move_timer
000C74  1               
000C74  1                  ; --- write initial sprite attributes for all 55 invaders ---
000C74  1  20 E0 0C        jsr update_invader_sprites
000C77  1  60              rts
000C78  1               
000C78  1               ;******************************************************************
000C78  1               ; step_invaders — one march step: move or drop grid, toggle anim frame
000C78  1               ;   Called when inv_move_timer reaches 0.
000C78  1               ;   Updates inv_grid_x / inv_offset_y, sets inv_drop_flag as needed,
000C78  1               ;   then refreshes all VERA sprite positions.
000C78  1               ;******************************************************************
000C78  1               step_invaders:
000C78  1                  ; toggle animation frame
000C78  1  A5 rr           lda inv_anim_frame
000C7A  1  49 01           eor #1
000C7C  1  85 rr           sta inv_anim_frame
000C7E  1               
000C7E  1                  ; if drop flag is set: drop grid this step, skip march
000C7E  1  A5 rr           lda inv_drop_flag
000C80  1  F0 0B           beq @do_march
000C82  1  64 rr           stz inv_drop_flag
000C84  1  A5 rr           lda inv_offset_y
000C86  1  18              clc
000C87  1  69 10           adc #INV_DROP_Y
000C89  1  85 rr           sta inv_offset_y
000C8B  1  80 4C           bra @sprites_done
000C8D  1               
000C8D  1               @do_march:
000C8D  1  A5 rr           lda inv_direction
000C8F  1  D0 25           bne @march_left
000C91  1               
000C91  1                  ; --- march right ---
000C91  1  A5 rr           lda inv_grid_x_lo
000C93  1  18              clc
000C94  1  69 04           adc #INV_STEP_X
000C96  1  85 rr           sta inv_grid_x_lo
000C98  1  90 02           bcc @chk_right
000C9A  1  E6 rr           inc inv_grid_x_hi
000C9C  1               @chk_right:
000C9C  1                  ; hit right if grid_x > INV_X_RIGHT_LIM (208, fits in 1 byte, hi always 0)
000C9C  1  A5 rr           lda inv_grid_x_hi
000C9E  1  D0 06           bne @clamp_right          ; hi > 0 → definitely over limit
000CA0  1  A5 rr           lda inv_grid_x_lo
000CA2  1  C9 D1           cmp #INV_X_RIGHT_LIM + 1  ; C set if lo > limit
000CA4  1  90 33           bcc @sprites_done
000CA6  1               @clamp_right:
000CA6  1  A9 D0           lda #<INV_X_RIGHT_LIM
000CA8  1  85 rr           sta inv_grid_x_lo
000CAA  1  A9 00           lda #>INV_X_RIGHT_LIM
000CAC  1  85 rr           sta inv_grid_x_hi
000CAE  1  A9 01           lda #1
000CB0  1  85 rr           sta inv_direction
000CB2  1  85 rr           sta inv_drop_flag
000CB4  1  80 23           bra @sprites_done
000CB6  1               
000CB6  1                  ; --- march left ---
000CB6  1               @march_left:
000CB6  1  A5 rr           lda inv_grid_x_lo
000CB8  1  38              sec
000CB9  1  E9 04           sbc #INV_STEP_X
000CBB  1  85 rr           sta inv_grid_x_lo
000CBD  1  B0 02           bcs @chk_left             ; no borrow
000CBF  1  C6 rr           dec inv_grid_x_hi
000CC1  1               @chk_left:
000CC1  1                  ; hit left if hi went negative OR lo < INV_X_LEFT_LIM
000CC1  1  A5 rr           lda inv_grid_x_hi
000CC3  1  30 06           bmi @clamp_left
000CC5  1  A5 rr           lda inv_grid_x_lo
000CC7  1  C9 10           cmp #INV_X_LEFT_LIM
000CC9  1  B0 0E           bcs @sprites_done         ; lo >= left limit → ok
000CCB  1               @clamp_left:
000CCB  1  A9 10           lda #<INV_X_LEFT_LIM
000CCD  1  85 rr           sta inv_grid_x_lo
000CCF  1  A9 00           lda #>INV_X_LEFT_LIM
000CD1  1  85 rr           sta inv_grid_x_hi
000CD3  1  64 rr           stz inv_direction
000CD5  1  A9 01           lda #1
000CD7  1  85 rr           sta inv_drop_flag
000CD9  1               
000CD9  1               @sprites_done:
000CD9  1  20 60 1B        jsr snd_march_step
000CDC  1  20 E0 0C        jsr update_invader_sprites
000CDF  1  60              rts
000CE0  1               
000CE0  1               ;******************************************************************
000CE0  1               ; update_invader_sprites — write all 55 invader sprite attributes to VERA
000CE0  1               ;
000CE0  1               ;   VERA sprite slots 11-65 hold the 55 invaders.
000CE0  1               ;   Attributes base: $1FC58 ($1FC00 + 11*8).
000CE0  1               ;   With stride=1 the VERA address auto-increments, so we set it
000CE0  1               ;   once and write all 440 bytes sequentially.
000CE0  1               ;
000CE0  1               ;   Byte layout per sprite:
000CE0  1               ;     0: data addr[12:5]   (encodes VRAM pixel data address + frame)
000CE0  1               ;     1: $00               (4bpp, addr[16:13]=0)
000CE0  1               ;     2: X[7:0]
000CE0  1               ;     3: X[9:8]
000CE0  1               ;     4: Y[7:0]
000CE0  1               ;     5: Y[9:8]
000CE0  1               ;     6: z-depth/collision
000CE0  1               ;     7: palette / size
000CE0  1               ;
000CE0  1               ;   Invader index i = row*11 + col; alive bit i in inv_alive bitmap.
000CE0  1               ;   For Phase 3 all invaders are alive; alive check will be added Phase 4.
000CE0  1               ;******************************************************************
000CE0  1               update_invader_sprites:
000CE0  1  9C 25 9F        stz VERA_ctrl
000CE3  1  A9 11           lda #$11              ; stride=1, VRAM bank bit=1 (addr $1Fxxxx)
000CE5  1  8D 22 9F        sta VERA_addr_bank
000CE8  1  A9 FC           lda #$FC
000CEA  1  8D 21 9F        sta VERA_addr_high
000CED  1  A9 58           lda #$58
000CEF  1  8D 20 9F        sta VERA_addr_low     ; VERA now at $1FC58, auto-increments by 1
000CF2  1               
000CF2  1                  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000CF2  1  A9 50           lda #<INV_GRID_Y_BASE
000CF4  1  18              clc
000CF5  1  65 rr           adc inv_offset_y
000CF7  1  85 rr           sta zp_y_base_lo
000CF9  1  A9 00           lda #>INV_GRID_Y_BASE
000CFB  1  69 00           adc #0
000CFD  1  85 rr           sta zp_y_base_hi
000CFF  1               
000CFF  1  64 rr           stz zp_row
000D01  1               @row_loop:
000D01  1                  ; compute row Y: zp_row_y = zp_y_base + row_y_offsets[row]
000D01  1  A4 rr           ldy zp_row
000D03  1  B9 AC 1E        lda row_y_offsets,y
000D06  1  18              clc
000D07  1  65 rr           adc zp_y_base_lo
000D09  1  85 rr           sta zp_row_y_lo
000D0B  1  A9 00           lda #0
000D0D  1  65 rr           adc zp_y_base_hi
000D0F  1  85 rr           sta zp_row_y_hi
000D11  1               
000D11  1                  ; select addr byte0 based on row type and animation frame
000D11  1  A4 rr           ldy zp_row
000D13  1  A5 rr           lda inv_anim_frame
000D15  1  F0 05           beq @use_f0
000D17  1  B9 91 1E        lda inv_addr_b0_f1,y
000D1A  1  80 03           bra @got_b0
000D1C  1               @use_f0:
000D1C  1  B9 8C 1E        lda inv_addr_b0_f0,y
000D1F  1               @got_b0:
000D1F  1  85 rr           sta zp_addr_b0
000D21  1               
000D21  1  20 2D 0D        jsr update_invader_row
000D24  1               
000D24  1  E6 rr           inc zp_row
000D26  1  A5 rr           lda zp_row
000D28  1  C9 05           cmp #5
000D2A  1  D0 D5           bne @row_loop
000D2C  1               
000D2C  1  60              rts
000D2D  1               
000D2D  1               ;******************************************************************
000D2D  1               ; update_invader_row — write 11 sprite attribute blocks for one row
000D2D  1               ;
000D2D  1               ;   Inputs (ZP): zp_row, zp_addr_b0, zp_row_y_lo/hi, inv_grid_x_lo/hi
000D2D  1               ;   VERA address register must already be set to the first sprite slot
000D2D  1               ;   for this row on entry (maintained by the sequential write stream).
000D2D  1               ;******************************************************************
000D2D  1               update_invader_row:
000D2D  1  64 rr           stz zp_col
000D2F  1               @col_loop:
000D2F  1                  ; --- determine z-depth from alive bitmap ---
000D2F  1                  ; index = inv_row_base[row] + col; byte = index>>3; bit = index&7
000D2F  1  A4 rr           ldy zp_row
000D31  1  B9 B1 1E        lda inv_row_base,y
000D34  1  18              clc
000D35  1  65 rr           adc zp_col
000D37  1  A8              tay                   ; Y = invader index
000D38  1  29 07           and #$07
000D3A  1  AA              tax                   ; X = bit index
000D3B  1  BD B6 1E        lda bit_masks,x
000D3E  1  48              pha                   ; save bit mask
000D3F  1  98              tya
000D40  1  4A              lsr
000D41  1  4A              lsr
000D42  1  4A              lsr
000D43  1  A8              tay                   ; Y = byte index into inv_alive
000D44  1  68              pla                   ; A = bit mask
000D45  1  39 rr rr        and inv_alive,y
000D48  1  F0 04           beq @zdepth_off
000D4A  1  A9 0C           lda #SPR_Z_FRONT
000D4C  1  80 02           bra @zdepth_done
000D4E  1               @zdepth_off:
000D4E  1  A9 00           lda #0
000D50  1               @zdepth_done:
000D50  1  85 rr           sta zp_scratch_lo     ; save z-depth before VERA stream starts
000D52  1               
000D52  1                  ; --- compute sprite X = inv_grid_x + col_x_offsets[col] ---
000D52  1  A4 rr           ldy zp_col
000D54  1  B9 96 1E        lda col_x_lo,y
000D57  1  18              clc
000D58  1  65 rr           adc inv_grid_x_lo
000D5A  1  85 rr           sta zp_x_lo
000D5C  1  B9 A1 1E        lda col_x_hi,y
000D5F  1  65 rr           adc inv_grid_x_hi
000D61  1  85 rr           sta zp_x_hi
000D63  1               
000D63  1                  ; --- write 8 attribute bytes (VERA auto-increments) ---
000D63  1  A5 rr           lda zp_addr_b0
000D65  1  8D 23 9F        sta VERA_data0        ; byte 0: data addr[12:5]
000D68  1  9C 23 9F        stz VERA_data0        ; byte 1: 4bpp, addr[16:13]=0
000D6B  1  A5 rr           lda zp_x_lo
000D6D  1  8D 23 9F        sta VERA_data0        ; byte 2: X[7:0]
000D70  1  A5 rr           lda zp_x_hi
000D72  1  29 03           and #$03
000D74  1  8D 23 9F        sta VERA_data0        ; byte 3: X[9:8]
000D77  1  A5 rr           lda zp_row_y_lo
000D79  1  8D 23 9F        sta VERA_data0        ; byte 4: Y[7:0]
000D7C  1  A5 rr           lda zp_row_y_hi
000D7E  1  29 03           and #$03
000D80  1  8D 23 9F        sta VERA_data0        ; byte 5: Y[9:8]
000D83  1  A5 rr           lda zp_scratch_lo
000D85  1  8D 23 9F        sta VERA_data0        ; byte 6: z-depth (SPR_Z_FRONT if alive, 0 if dead)
000D88  1  A9 50           lda #SPR_16x16_PAL0
000D8A  1  8D 23 9F        sta VERA_data0        ; byte 7: 16x16, palette offset 0
000D8D  1               
000D8D  1  E6 rr           inc zp_col
000D8F  1  A5 rr           lda zp_col
000D91  1  C9 0B           cmp #11
000D93  1  D0 9A           bne @col_loop
000D95  1               
000D95  1  60              rts
000D96  1               
000D96  1               ;******************************************************************
000D96  1               ; move_player — apply key_flags movement and clamp to screen edges
000D96  1               ;******************************************************************
000D96  1               move_player:
000D96  1  A5 rr           lda key_flags
000D98  1               
000D98  1                  ; --- move left ---
000D98  1  29 01           and #KEY_LEFT
000D9A  1  F0 1F           beq @check_right
000D9C  1  A5 rr           lda player_x_lo
000D9E  1  38              sec
000D9F  1  E9 04           sbc #PLAYER_SPEED
000DA1  1  85 rr           sta player_x_lo
000DA3  1  B0 02           bcs @clamp_left              ; no borrow → hi unchanged
000DA5  1  C6 rr           dec player_x_hi
000DA7  1               @clamp_left:
000DA7  1                  ; Clamp: if hi went negative ($FF) or (hi=0 AND lo < min) → set to min
000DA7  1  A5 rr           lda player_x_hi
000DA9  1  30 08           bmi @set_min                 ; $80–$FF = underflowed
000DAB  1  D0 0E           bne @check_right             ; hi > 0 → still above minimum
000DAD  1  A5 rr           lda player_x_lo
000DAF  1  C9 08           cmp #PLAYER_X_MIN
000DB1  1  B0 08           bcs @check_right             ; lo >= min → ok
000DB3  1               @set_min:
000DB3  1  A9 08           lda #<PLAYER_X_MIN
000DB5  1  85 rr           sta player_x_lo
000DB7  1  A9 00           lda #>PLAYER_X_MIN
000DB9  1  85 rr           sta player_x_hi
000DBB  1               
000DBB  1                  ; --- move right ---
000DBB  1               @check_right:
000DBB  1  A5 rr           lda key_flags
000DBD  1  29 02           and #KEY_RIGHT
000DBF  1  F0 23           beq @move_done
000DC1  1  A5 rr           lda player_x_lo
000DC3  1  18              clc
000DC4  1  69 04           adc #PLAYER_SPEED
000DC6  1  85 rr           sta player_x_lo
000DC8  1  90 02           bcc @clamp_right             ; no carry → hi unchanged
000DCA  1  E6 rr           inc player_x_hi
000DCC  1               @clamp_right:
000DCC  1                  ; Clamp: if hi > max_hi, OR (hi == max_hi AND lo > max_lo) → set to max
000DCC  1  A5 rr           lda player_x_hi
000DCE  1  C9 02           cmp #>PLAYER_X_MAX
000DD0  1  90 12           bcc @move_done               ; hi < max_hi → definitely ok
000DD2  1  D0 08           bne @set_max                 ; hi > max_hi → over limit
000DD4  1  A5 rr           lda player_x_lo
000DD6  1  C9 68           cmp #<PLAYER_X_MAX
000DD8  1  90 0A           bcc @move_done               ; lo < max_lo when hi == max_hi → ok
000DDA  1  F0 08           beq @move_done               ; lo == max_lo → exactly at max, ok
000DDC  1               @set_max:
000DDC  1  A9 68           lda #<PLAYER_X_MAX
000DDE  1  85 rr           sta player_x_lo
000DE0  1  A9 02           lda #>PLAYER_X_MAX
000DE2  1  85 rr           sta player_x_hi
000DE4  1               
000DE4  1               @move_done:
000DE4  1  60              rts
000DE5  1               
000DE5  1               ;******************************************************************
000DE5  1               ; update_player_sprite — write current X position to sprite 1 in VERA
000DE5  1               ;   Only X needs updating (Y is fixed)
000DE5  1               ;******************************************************************
000DE5  1               update_player_sprite:
000DE5  1  9C 25 9F        stz VERA_ctrl
000DE8  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 2), 1
000DEC  1  9F A9 FC 8D  
000DF0  1  21 9F A9 0A  
000DF7  1  A5 rr           lda player_x_lo
000DF9  1  8D 23 9F        sta VERA_data0               ; sprite byte 2: X[7:0]
000DFC  1  A5 rr           lda player_x_hi
000DFE  1  29 03           and #$03
000E00  1  8D 23 9F        sta VERA_data0               ; sprite byte 3: X[9:8]
000E03  1                  ; update z-depth based on inv_hit_timer:
000E03  1                  ;   timer = 0        → show solid (not hit)
000E03  1                  ;   timer = 61-120   → hidden solid (1-second respawn delay)
000E03  1                  ;   timer = 1-60     → flashing (invincible, visible warning)
000E03  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 6), 1
000E07  1  9F A9 FC 8D  
000E0B  1  21 9F A9 0E  
000E12  1  A5 rr           lda inv_hit_timer
000E14  1  F0 08           beq @show                    ; timer=0 → show solid
000E16  1  C9 3D           cmp #61
000E18  1  B0 08           bcs @hide                    ; timer>=61 → first second: fully hidden
000E1A  1  29 08           and #$08                     ; timer 1-60: bit 3 flips every 8 frames → ~4 Hz flash
000E1C  1  D0 04           bne @hide
000E1E  1               @show:
000E1E  1  A9 0C           lda #SPR_Z_FRONT
000E20  1  80 02           bra @write_z
000E22  1               @hide:
000E22  1  A9 00           lda #0
000E24  1               @write_z:
000E24  1  8D 23 9F        sta VERA_data0               ; sprite byte 6: z-depth
000E27  1  60              rts
000E28  1               
000E28  1               ;******************************************************************
000E28  1               ; fire_bullet — activate player bullet at cannon tip, update sprite
000E28  1               ;   Bullet X centers the 8-px bullet over the 16-px player ship:
000E28  1               ;     bullet_x = player_x + 4
000E28  1               ;   Bullet Y starts 8 VERA pixels above the player sprite top.
000E28  1               ;   Caller must check bullet_active == 0 before calling.
000E28  1               ;******************************************************************
000E28  1               fire_bullet:
000E28  1  A5 rr           lda player_x_lo
000E2A  1  18              clc
000E2B  1  69 04           adc #4
000E2D  1  85 rr           sta bullet_x_lo
000E2F  1  A5 rr           lda player_x_hi
000E31  1  69 00           adc #0
000E33  1  85 rr           sta bullet_x_hi
000E35  1               
000E35  1  A9 9C           lda #<BULLET_Y_INIT
000E37  1  85 rr           sta bullet_y_lo
000E39  1  A9 01           lda #>BULLET_Y_INIT
000E3B  1  85 rr           sta bullet_y_hi
000E3D  1               
000E3D  1  A9 01           lda #1
000E3F  1  85 rr           sta bullet_active
000E41  1  E6 rr           inc shot_count
000E43  1  20 63 0E        jsr update_bullet_sprite
000E46  1  20 D0 1B        jsr snd_fire
000E49  1  60              rts
000E4A  1               
000E4A  1               ;******************************************************************
000E4A  1               ; move_bullet — move bullet upward by BULLET_SPEED each frame;
000E4A  1               ;   deactivate when it reaches the top of the screen (Y underflows 0)
000E4A  1               ;******************************************************************
000E4A  1               move_bullet:
000E4A  1  A5 rr           lda bullet_y_lo
000E4C  1  38              sec
000E4D  1  E9 0C           sbc #BULLET_SPEED
000E4F  1  85 rr           sta bullet_y_lo
000E51  1  A5 rr           lda bullet_y_hi
000E53  1  E9 00           sbc #0
000E55  1  85 rr           sta bullet_y_hi
000E57  1  30 04           bmi @deactivate              ; 16-bit underflow past 0 → off screen
000E59  1               
000E59  1  20 63 0E        jsr update_bullet_sprite
000E5C  1  60              rts
000E5D  1               
000E5D  1               @deactivate:
000E5D  1  64 rr           stz bullet_active
000E5F  1  20 63 0E        jsr update_bullet_sprite     ; disables sprite (z-depth=0)
000E62  1  60              rts
000E63  1               
000E63  1               ;******************************************************************
000E63  1               ; update_bullet_sprite — write bullet position and enable/disable
000E63  1               ;   to VERA sprite 2 (bytes 2-6); byte 7 set once at init.
000E63  1               ;   z-depth = SPR_Z_FRONT when active, 0 when inactive.
000E63  1               ;******************************************************************
000E63  1               update_bullet_sprite:
000E63  1  9C 25 9F        stz VERA_ctrl
000E66  1  A9 11 8D 22     VERA_SET_ADDR (BULLET_SPRITE_ATTR + 2), 1
000E6A  1  9F A9 FC 8D  
000E6E  1  21 9F A9 12  
000E75  1  A5 rr           lda bullet_x_lo
000E77  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000E7A  1  A5 rr           lda bullet_x_hi
000E7C  1  29 03           and #$03
000E7E  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000E81  1  A5 rr           lda bullet_y_lo
000E83  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000E86  1  A5 rr           lda bullet_y_hi
000E88  1  29 03           and #$03
000E8A  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000E8D  1  A5 rr           lda bullet_active
000E8F  1  F0 04           beq @z_off
000E91  1  A9 0C           lda #SPR_Z_FRONT
000E93  1  80 02           bra @write_z
000E95  1               @z_off:
000E95  1  A9 00           lda #$00
000E97  1               @write_z:
000E97  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
000E9A  1  60              rts
000E9B  1               
000E9B  1               ;******************************************************************
000E9B  1               ; check_bullet_invader — scan all 55 invaders for a hit with the player bullet
000E9B  1               ;
000E9B  1               ;   Iterates rows 0-4, columns 0-10.  Skips dead invaders.
000E9B  1               ;   For each live invader checks 16-bit AABB overlap:
000E9B  1               ;     X: bullet_x+8 > inv_x  AND  bullet_x < inv_x+16
000E9B  1               ;     Y: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000E9B  1               ;   On hit: calls kill_invader_hit and returns immediately.
000E9B  1               ;
000E9B  1               ;   Scratch used: zp_y_base_lo/hi, zp_row_y_lo/hi, zp_x_lo/hi,
000E9B  1               ;                 zp_scratch_lo/hi, zp_row, zp_col
000E9B  1               ;******************************************************************
000E9B  1               check_bullet_invader:
000E9B  1  A5 rr           lda bullet_active
000E9D  1  D0 01           bne :+
000E9F  1  60              rts
000EA0  1               :  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000EA0  1  A9 50           lda #<INV_GRID_Y_BASE
000EA2  1  18              clc
000EA3  1  65 rr           adc inv_offset_y
000EA5  1  85 rr           sta zp_y_base_lo
000EA7  1  A9 00           lda #>INV_GRID_Y_BASE
000EA9  1  69 00           adc #0
000EAB  1  85 rr           sta zp_y_base_hi
000EAD  1               
000EAD  1  64 rr           stz zp_row
000EAF  1               @row_loop:
000EAF  1                  ; row Y = y_base + row_y_offsets[row]
000EAF  1  A4 rr           ldy zp_row
000EB1  1  B9 AC 1E        lda row_y_offsets,y
000EB4  1  18              clc
000EB5  1  65 rr           adc zp_y_base_lo
000EB7  1  85 rr           sta zp_row_y_lo
000EB9  1  A9 00           lda #0
000EBB  1  65 rr           adc zp_y_base_hi
000EBD  1  85 rr           sta zp_row_y_hi
000EBF  1               
000EBF  1                  ; --- Quick Y range check for whole row ---
000EBF  1                  ; Need: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000EBF  1               
000EBF  1                  ; (1) bullet_y+8 > inv_y  →  (bullet_y+8) - inv_y > 0
000EBF  1                  ;     result negative (bmi) means bullet above this row
000EBF  1  A5 rr           lda bullet_y_lo
000EC1  1  18              clc
000EC2  1  69 08           adc #8
000EC4  1  85 rr           sta zp_scratch_lo
000EC6  1  A5 rr           lda bullet_y_hi
000EC8  1  69 00           adc #0
000ECA  1  85 rr           sta zp_scratch_hi
000ECC  1  A5 rr           lda zp_scratch_lo
000ECE  1  38              sec
000ECF  1  E5 rr           sbc zp_row_y_lo
000ED1  1  A5 rr           lda zp_scratch_hi
000ED3  1  E5 rr           sbc zp_row_y_hi
000ED5  1  30 1D           bmi @next_row         ; bullet bottom above invader top → no hit in this row
000ED7  1               
000ED7  1                  ; (2) bullet_y < inv_y+16  →  bullet_y - (inv_y+16) < 0
000ED7  1                  ;     result >= 0 (bpl) means bullet below this row
000ED7  1  A5 rr           lda zp_row_y_lo
000ED9  1  18              clc
000EDA  1  69 10           adc #16
000EDC  1  85 rr           sta zp_scratch_lo
000EDE  1  A5 rr           lda zp_row_y_hi
000EE0  1  69 00           adc #0
000EE2  1  85 rr           sta zp_scratch_hi
000EE4  1  A5 rr           lda bullet_y_lo
000EE6  1  38              sec
000EE7  1  E5 rr           sbc zp_scratch_lo
000EE9  1  A5 rr           lda bullet_y_hi
000EEB  1  E5 rr           sbc zp_scratch_hi
000EED  1  10 05           bpl @next_row         ; bullet top at or below invader bottom → no hit
000EEF  1               
000EEF  1                  ; Y overlaps this row — check each column
000EEF  1  20 FD 0E        jsr cbi_check_cols
000EF2  1  B0 08           bcs @done             ; hit found; bullet already handled
000EF4  1               
000EF4  1               @next_row:
000EF4  1  E6 rr           inc zp_row
000EF6  1  A5 rr           lda zp_row
000EF8  1  C9 05           cmp #5
000EFA  1  D0 B3           bne @row_loop
000EFC  1               
000EFC  1               @done:
000EFC  1  60              rts
000EFD  1               
000EFD  1               ;******************************************************************
000EFD  1               ; cbi_check_cols — column scan for check_bullet_invader
000EFD  1               ;
000EFD  1               ;   Scans all 11 columns of zp_row for an X overlap with the bullet.
000EFD  1               ;   Assumes Y overlap for this row has already been confirmed.
000EFD  1               ;   Returns: C set if hit (kill_invader_hit already called),
000EFD  1               ;            C clear if no hit.
000EFD  1               ;   Scratch used: zp_col, zp_x_lo/hi, zp_scratch_lo/hi
000EFD  1               ;******************************************************************
000EFD  1               cbi_check_cols:
000EFD  1  64 rr           stz zp_col
000EFF  1               @col_loop:
000EFF  1                  ; skip if invader is dead
000EFF  1  A4 rr           ldy zp_row
000F01  1  B9 B1 1E        lda inv_row_base,y
000F04  1  18              clc
000F05  1  65 rr           adc zp_col
000F07  1  A8              tay                   ; Y = invader index
000F08  1  29 07           and #$07
000F0A  1  AA              tax
000F0B  1  BD B6 1E        lda bit_masks,x
000F0E  1  48              pha
000F0F  1  98              tya
000F10  1  4A              lsr
000F11  1  4A              lsr
000F12  1  4A              lsr
000F13  1  A8              tay                   ; Y = byte index into inv_alive
000F14  1  68              pla
000F15  1  39 rr rr        and inv_alive,y
000F18  1  F0 46           beq @next_col         ; dead
000F1A  1               
000F1A  1                  ; compute inv_x = inv_grid_x + col_x_offsets[col]
000F1A  1  A4 rr           ldy zp_col
000F1C  1  B9 96 1E        lda col_x_lo,y
000F1F  1  18              clc
000F20  1  65 rr           adc inv_grid_x_lo
000F22  1  85 rr           sta zp_x_lo
000F24  1  B9 A1 1E        lda col_x_hi,y
000F27  1  65 rr           adc inv_grid_x_hi
000F29  1  85 rr           sta zp_x_hi
000F2B  1               
000F2B  1                  ; X check (1): bullet_x+8 > inv_x
000F2B  1  A5 rr           lda bullet_x_lo
000F2D  1  18              clc
000F2E  1  69 08           adc #8
000F30  1  85 rr           sta zp_scratch_lo
000F32  1  A5 rr           lda bullet_x_hi
000F34  1  69 00           adc #0
000F36  1  85 rr           sta zp_scratch_hi
000F38  1  A5 rr           lda zp_scratch_lo
000F3A  1  38              sec
000F3B  1  E5 rr           sbc zp_x_lo
000F3D  1  A5 rr           lda zp_scratch_hi
000F3F  1  E5 rr           sbc zp_x_hi
000F41  1  30 1D           bmi @next_col         ; bullet right edge left of invader → no hit
000F43  1               
000F43  1                  ; X check (2): bullet_x < inv_x+16
000F43  1  A5 rr           lda zp_x_lo
000F45  1  18              clc
000F46  1  69 10           adc #16
000F48  1  85 rr           sta zp_scratch_lo
000F4A  1  A5 rr           lda zp_x_hi
000F4C  1  69 00           adc #0
000F4E  1  85 rr           sta zp_scratch_hi
000F50  1  A5 rr           lda bullet_x_lo
000F52  1  38              sec
000F53  1  E5 rr           sbc zp_scratch_lo
000F55  1  A5 rr           lda bullet_x_hi
000F57  1  E5 rr           sbc zp_scratch_hi
000F59  1  10 05           bpl @next_col         ; bullet left edge at or right of invader → no hit
000F5B  1               
000F5B  1                  ; --- HIT ---
000F5B  1  20 6A 0F        jsr kill_invader_hit
000F5E  1  38              sec                   ; signal hit to caller
000F5F  1  60              rts
000F60  1               
000F60  1               @next_col:
000F60  1  E6 rr           inc zp_col
000F62  1  A5 rr           lda zp_col
000F64  1  C9 0B           cmp #11
000F66  1  D0 97           bne @col_loop
000F68  1               
000F68  1  18              clc                   ; no hit
000F69  1  60              rts
000F6A  1               
000F6A  1               ;******************************************************************
000F6A  1               ; kill_invader_hit — clear alive bit, deactivate bullet, update score & speed
000F6A  1               ;   Expects zp_row, zp_col to identify the hit invader.
000F6A  1               ;******************************************************************
000F6A  1               kill_invader_hit:
000F6A  1                  ; --- clear alive bit ---
000F6A  1  A4 rr           ldy zp_row
000F6C  1  B9 B1 1E        lda inv_row_base,y
000F6F  1  18              clc
000F70  1  65 rr           adc zp_col
000F72  1  A8              tay                   ; Y = invader index
000F73  1  29 07           and #$07
000F75  1  AA              tax
000F76  1  BD B6 1E        lda bit_masks,x       ; bit mask for this invader
000F79  1  48              pha
000F7A  1  98              tya
000F7B  1  4A              lsr
000F7C  1  4A              lsr
000F7D  1  4A              lsr
000F7E  1  A8              tay                   ; Y = byte index into inv_alive
000F7F  1  68              pla
000F80  1  49 FF           eor #$FF              ; invert → clear mask
000F82  1  39 rr rr        and inv_alive,y
000F85  1  99 rr rr        sta inv_alive,y
000F88  1               
000F88  1                  ; --- start explosion at the hit invader's position ---
000F88  1                  ; zp_x_lo/hi and zp_row_y_lo/hi still hold the invader coords from collision detection
000F88  1  20 B6 0F        jsr start_explosion
000F8B  1               
000F8B  1                  ; --- deactivate bullet ---
000F8B  1  64 rr           stz bullet_active
000F8D  1  20 63 0E        jsr update_bullet_sprite
000F90  1               
000F90  1                  ; --- decrement inv_count ---
000F90  1  C6 rr           dec inv_count
000F92  1               
000F92  1                  ; --- update inv_move_speed: proportional to remaining count ---
000F92  1  A6 rr           ldx inv_count
000F94  1  BD C3 1E        lda inv_speed_table,x
000F97  1  85 rr           sta inv_move_speed
000F99  1               
000F99  1                  ; --- add score for this row's invader type ---
000F99  1  A4 rr           ldy zp_row
000F9B  1  B9 BE 1E        lda score_by_row_bcd,y
000F9E  1  20 A2 0F        jsr add_score
000FA1  1  60              rts
000FA2  1               
000FA2  1               ;******************************************************************
000FA2  1               ; add_score — add BCD value in A to score_lo/mid/hi
000FA2  1               ;******************************************************************
000FA2  1               add_score:
000FA2  1  F8              sed
000FA3  1  18              clc
000FA4  1  65 rr           adc score_lo
000FA6  1  85 rr           sta score_lo
000FA8  1  A5 rr           lda score_mid
000FAA  1  69 00           adc #0
000FAC  1  85 rr           sta score_mid
000FAE  1  A5 rr           lda score_hi
000FB0  1  69 00           adc #0
000FB2  1  85 rr           sta score_hi
000FB4  1  D8              cld
000FB5  1  60              rts
000FB6  1               
000FB6  1               ;******************************************************************
000FB6  1               ; start_explosion — position sprite 4 at the hit invader and start timer
000FB6  1               ;
000FB6  1               ;   Inputs: zp_x_lo/hi     — invader X (VERA coords)
000FB6  1               ;           zp_row_y_lo/hi — invader Y (VERA coords)
000FB6  1               ;   Sets exp_timer = EXPLODE_FRAMES and enables sprite 4.
000FB6  1               ;******************************************************************
000FB6  1               start_explosion:
000FB6  1  9C 25 9F        stz VERA_ctrl
000FB9  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 2), 1  ; start at byte 2 (X lo)
000FBD  1  9F A9 FC 8D  
000FC1  1  21 9F A9 22  
000FC8  1  A5 rr           lda zp_x_lo
000FCA  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000FCD  1  A5 rr           lda zp_x_hi
000FCF  1  29 03           and #$03
000FD1  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000FD4  1  A5 rr           lda zp_row_y_lo
000FD6  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000FD9  1  A5 rr           lda zp_row_y_hi
000FDB  1  29 03           and #$03
000FDD  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000FE0  1  A9 0C           lda #SPR_Z_FRONT
000FE2  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3 → enabled, in front
000FE5  1  A9 1E           lda #EXPLODE_FRAMES
000FE7  1  85 rr           sta exp_timer
000FE9  1  20 35 1C        jsr snd_explosion
000FEC  1  60              rts
000FED  1               
000FED  1               ;******************************************************************
000FED  1               ; update_explosion — decrement exp_timer; disable sprite when it hits 0
000FED  1               ;******************************************************************
000FED  1               update_explosion:
000FED  1  A5 rr           lda exp_timer
000FEF  1  F0 1B           beq @inactive
000FF1  1  C6 rr           dec exp_timer
000FF3  1  D0 17           bne @inactive
000FF5  1                  ; timer just expired — disable sprite 4
000FF5  1  9C 25 9F        stz VERA_ctrl
000FF8  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1  ; byte 6 = z-depth
000FFC  1  9F A9 FC 8D  
001000  1  21 9F A9 26  
001007  1  A9 00           lda #$00
001009  1  8D 23 9F        sta VERA_data0               ; z-depth=0 → disabled
00100C  1               @inactive:
00100C  1  60              rts
00100D  1               
00100D  1               ;******************************************************************
00100D  1               ; prng — 16-bit Galois LFSR, feedback polynomial $B400
00100D  1               ;   Updates rand_seed_lo/hi; returns pseudo-random byte in A.
00100D  1               ;******************************************************************
00100D  1               prng:
00100D  1  46 rr           lsr rand_seed_hi          ; shift 16-bit state right; carry = old hi[0]
00100F  1  66 rr           ror rand_seed_lo          ; lo[7] = old hi[0]; carry = old lo[0] (feedback bit)
001011  1  90 06           bcc @done                 ; feedback bit=0: no XOR
001013  1  A5 rr           lda rand_seed_hi
001015  1  49 B4           eor #$B4                  ; XOR hi byte with feedback poly ($B400 >> 8)
001017  1  85 rr           sta rand_seed_hi
001019  1               @done:
001019  1  A5 rr           lda rand_seed_lo
00101B  1  60              rts
00101C  1               
00101C  1               ;******************************************************************
00101C  1               ; update_inv_bullets — fire timer, move active bullets, boundary check,
00101C  1               ;   update VERA sprites for all 3 invader bullet slots.
00101C  1               ;******************************************************************
00101C  1               update_inv_bullets:
00101C  1                  ; --- fire timer ---
00101C  1  C6 rr           dec inv_fire_timer
00101E  1  D0 0D           bne @move_loop
001020  1                  ; reset timer = max(inv_move_speed, INV_FIRE_TIMER_MIN)
001020  1  A5 rr           lda inv_move_speed
001022  1  C9 0A           cmp #INV_FIRE_TIMER_MIN
001024  1  B0 02           bcs @set_timer
001026  1  A9 0A           lda #INV_FIRE_TIMER_MIN
001028  1               @set_timer:
001028  1  85 rr           sta inv_fire_timer
00102A  1  20 97 10        jsr try_fire_inv_bullet
00102D  1               
00102D  1               @move_loop:
00102D  1  A2 00           ldx #0
00102F  1               @slot_loop:
00102F  1  B5 rr           lda ibul_active,x
001031  1  F0 1B           beq @update_spr           ; inactive: just hide sprite
001033  1               
001033  1                  ; move bullet down by INV_BULLET_SPEED
001033  1  B5 rr           lda ibul_y_lo,x
001035  1  18              clc
001036  1  69 06           adc #INV_BULLET_SPEED
001038  1  95 rr           sta ibul_y_lo,x
00103A  1  B5 rr           lda ibul_y_hi,x
00103C  1  69 00           adc #0
00103E  1  95 rr           sta ibul_y_hi,x
001040  1               
001040  1                  ; boundary: deactivate if Y >= 480 ($01E0)
001040  1  C9 01           cmp #>480                 ; A = new hi byte; compare with 1
001042  1  90 0A           bcc @update_spr           ; hi < 1: still on screen
001044  1  D0 06           bne @deactivate           ; hi > 1: off screen
001046  1  B5 rr           lda ibul_y_lo,x
001048  1  C9 E0           cmp #<480                 ; compare lo with $E0
00104A  1  90 02           bcc @update_spr           ; lo < $E0: still on screen
00104C  1               @deactivate:
00104C  1  74 rr           stz ibul_active,x
00104E  1               
00104E  1               @update_spr:
00104E  1  20 57 10        jsr update_inv_bullet_sprite   ; preserves X
001051  1  E8              inx
001052  1  E0 03           cpx #3
001054  1  D0 D9           bne @slot_loop
001056  1  60              rts
001057  1               
001057  1               ;******************************************************************
001057  1               ; update_inv_bullet_sprite — write VERA sprite attrs bytes 2-6 for slot X
001057  1               ;   X = slot index (0-2).  Preserves X.
001057  1               ;******************************************************************
001057  1               update_inv_bullet_sprite:
001057  1  86 rr           stx zp_scratch_lo              ; preserve slot index
001059  1  9C 25 9F        stz VERA_ctrl
00105C  1  A9 11           lda #$11                       ; stride=1, bank bit=1
00105E  1  8D 22 9F        sta VERA_addr_bank
001061  1  A9 FC           lda #$FC
001063  1  8D 21 9F        sta VERA_addr_high
001066  1  BD FB 1E        lda ibul_spr_lo,x
001069  1  18              clc
00106A  1  69 02           adc #2                         ; point to byte 2 (X position)
00106C  1  8D 20 9F        sta VERA_addr_low
00106F  1  B5 rr           lda ibul_x_lo,x
001071  1  8D 23 9F        sta VERA_data0                 ; byte 2: X lo
001074  1  B5 rr           lda ibul_x_hi,x
001076  1  29 03           and #$03
001078  1  8D 23 9F        sta VERA_data0                 ; byte 3: X hi
00107B  1  B5 rr           lda ibul_y_lo,x
00107D  1  8D 23 9F        sta VERA_data0                 ; byte 4: Y lo
001080  1  B5 rr           lda ibul_y_hi,x
001082  1  29 03           and #$03
001084  1  8D 23 9F        sta VERA_data0                 ; byte 5: Y hi
001087  1  B5 rr           lda ibul_active,x
001089  1  F0 04           beq @disabled
00108B  1  A9 0C           lda #SPR_Z_FRONT
00108D  1  80 02           bra @write_z
00108F  1               @disabled:
00108F  1  A9 00           lda #0
001091  1               @write_z:
001091  1  8D 23 9F        sta VERA_data0                 ; byte 6: z-depth
001094  1  A6 rr           ldx zp_scratch_lo
001096  1  60              rts
001097  1               
001097  1               ;******************************************************************
001097  1               ; try_fire_inv_bullet — find a free slot and spawn a bullet from the
001097  1               ;   bottommost live invader in a randomly chosen column.
001097  1               ;   Returns immediately if all slots busy or chosen column is empty.
001097  1               ;   Scratch used: zp_row, zp_col, zp_scratch_lo (slot index)
001097  1               ;******************************************************************
001097  1               try_fire_inv_bullet:
001097  1                  ; find a free bullet slot
001097  1  A2 00           ldx #0
001099  1               @find_slot:
001099  1  B5 rr           lda ibul_active,x
00109B  1  F0 06           beq @slot_found
00109D  1  E8              inx
00109E  1  E0 03           cpx #3
0010A0  1  D0 F7           bne @find_slot
0010A2  1  60              rts                            ; all slots busy
0010A3  1               
0010A3  1               @slot_found:
0010A3  1  86 rr           stx zp_scratch_lo              ; save free slot index
0010A5  1               
0010A5  1                  ; pick a random column 0-10
0010A5  1  20 0D 10        jsr prng
0010A8  1  29 0F           and #$0F                       ; 0-15
0010AA  1  C9 0B           cmp #11
0010AC  1  90 03           bcc @col_ok
0010AE  1  38              sec
0010AF  1  E9 0B           sbc #11                        ; wrap 11-15 → 0-4 (slight bias, acceptable)
0010B1  1               @col_ok:
0010B1  1  85 rr           sta zp_col
0010B3  1               
0010B3  1                  ; scan rows 4 down to 0 for bottommost live invader in this column
0010B3  1  A9 04           lda #4
0010B5  1  85 rr           sta zp_row
0010B7  1               @row_scan:
0010B7  1  A4 rr           ldy zp_row
0010B9  1  B9 B1 1E        lda inv_row_base,y
0010BC  1  18              clc
0010BD  1  65 rr           adc zp_col
0010BF  1  A8              tay                            ; Y = invader index
0010C0  1  29 07           and #$07
0010C2  1  AA              tax                            ; X = bit position
0010C3  1  BD B6 1E        lda bit_masks,x
0010C6  1  48              pha
0010C7  1  98              tya
0010C8  1  4A              lsr
0010C9  1  4A              lsr
0010CA  1  4A              lsr
0010CB  1  A8              tay                            ; Y = byte index into inv_alive
0010CC  1  68              pla
0010CD  1  39 rr rr        and inv_alive,y
0010D0  1  D0 09           bne @found_invader
0010D2  1  A5 rr           lda zp_row
0010D4  1  F0 04           beq @no_invader                ; checked row 0, nothing alive
0010D6  1  C6 rr           dec zp_row
0010D8  1  80 DD           bra @row_scan
0010DA  1               
0010DA  1               @no_invader:
0010DA  1  60              rts                            ; column empty, skip fire
0010DB  1               
0010DB  1               @found_invader:
0010DB  1  A6 rr           ldx zp_scratch_lo              ; restore free slot index
0010DD  1  A9 01           lda #1
0010DF  1  95 rr           sta ibul_active,x
0010E1  1               
0010E1  1                  ; spawn X = inv_grid_x + col_x_offsets[col]  (16-bit, matching update_invader_sprites)
0010E1  1  A4 rr           ldy zp_col
0010E3  1  B9 96 1E        lda col_x_lo,y
0010E6  1  18              clc
0010E7  1  65 rr           adc inv_grid_x_lo
0010E9  1  95 rr           sta ibul_x_lo,x
0010EB  1  B9 A1 1E        lda col_x_hi,y
0010EE  1  65 rr           adc inv_grid_x_hi
0010F0  1  95 rr           sta ibul_x_hi,x
0010F2  1                  ; add +4 as a separate 16-bit step to centre the 8px bullet in the 16px invader
0010F2  1  B5 rr           lda ibul_x_lo,x
0010F4  1  18              clc
0010F5  1  69 04           adc #4
0010F7  1  95 rr           sta ibul_x_lo,x
0010F9  1  B5 rr           lda ibul_x_hi,x
0010FB  1  69 00           adc #0
0010FD  1  95 rr           sta ibul_x_hi,x
0010FF  1               
0010FF  1                  ; spawn Y: compute y_base first (same two-step pattern as update_invader_sprites)
0010FF  1                  ; step 1: y_base = INV_GRID_Y_BASE + inv_offset_y  (16-bit)
0010FF  1  A9 50           lda #<INV_GRID_Y_BASE
001101  1  18              clc
001102  1  65 rr           adc inv_offset_y
001104  1  85 rr           sta zp_y_base_lo
001106  1  A9 00           lda #>INV_GRID_Y_BASE
001108  1  69 00           adc #0
00110A  1  85 rr           sta zp_y_base_hi
00110C  1                  ; step 2: spawn_y = y_base + row_y_offsets[row]
00110C  1  A4 rr           ldy zp_row
00110E  1  B9 AC 1E        lda row_y_offsets,y
001111  1  18              clc
001112  1  65 rr           adc zp_y_base_lo
001114  1  95 rr           sta ibul_y_lo,x
001116  1  A9 00           lda #0
001118  1  65 rr           adc zp_y_base_hi
00111A  1  95 rr           sta ibul_y_hi,x
00111C  1                  ; step 3: +16 to place bullet at the bottom edge of the 16px invader
00111C  1  B5 rr           lda ibul_y_lo,x
00111E  1  18              clc
00111F  1  69 10           adc #16
001121  1  95 rr           sta ibul_y_lo,x
001123  1  B5 rr           lda ibul_y_hi,x
001125  1  69 00           adc #0
001127  1  95 rr           sta ibul_y_hi,x
001129  1               
001129  1  60              rts
00112A  1               
00112A  1               ;******************************************************************
00112A  1               ; check_inv_bullet_player — AABB test each active invader bullet vs. player
00112A  1               ;
00112A  1               ;   Player rect: (player_x, PLAYER_Y) to (player_x+15, PLAYER_Y+15), 16x16
00112A  1               ;   Bullet rect: (ibul_x,   ibul_y)   to (ibul_x+7,   ibul_y+7),     8x8
00112A  1               ;
00112A  1               ;   On hit: bullet deactivated, jsr player_hit called, loop continues
00112A  1               ;   (remaining bullets checked — at most one hit landing per frame).
00112A  1               ;   Scratch: zp_scratch_lo/hi, X (slot index)
00112A  1               ;******************************************************************
00112A  1               check_inv_bullet_player:
00112A  1  A2 00           ldx #0
00112C  1               @slot_loop:
00112C  1  B5 rr           lda ibul_active,x
00112E  1  F0 5B           beq @next_slot
001130  1               
001130  1                  ; --- Y check 1: (bullet_y + 8) > PLAYER_Y  →  bullet_y + 8 - PLAYER_Y > 0 ---
001130  1  B5 rr           lda ibul_y_lo,x
001132  1  18              clc
001133  1  69 08           adc #8
001135  1  85 rr           sta zp_scratch_lo
001137  1  B5 rr           lda ibul_y_hi,x
001139  1  69 00           adc #0
00113B  1  85 rr           sta zp_scratch_hi
00113D  1  A5 rr           lda zp_scratch_lo
00113F  1  38              sec
001140  1  E9 A4           sbc #<PLAYER_Y
001142  1  A5 rr           lda zp_scratch_hi
001144  1  E9 01           sbc #>PLAYER_Y
001146  1  30 43           bmi @next_slot            ; bullet bottom above player top → no hit
001148  1               
001148  1                  ; --- Y check 2: bullet_y < PLAYER_Y + 16 → bullet_y - (PLAYER_Y+16) < 0 ---
001148  1  B5 rr           lda ibul_y_lo,x
00114A  1  38              sec
00114B  1  E9 B4           sbc #<(PLAYER_Y+16)
00114D  1  B5 rr           lda ibul_y_hi,x
00114F  1  E9 01           sbc #>(PLAYER_Y+16)
001151  1  10 38           bpl @next_slot            ; bullet top at or below player bottom → no hit
001153  1               
001153  1                  ; --- X check 1: (bullet_x + 8) > player_x ---
001153  1  B5 rr           lda ibul_x_lo,x
001155  1  18              clc
001156  1  69 08           adc #8
001158  1  85 rr           sta zp_scratch_lo
00115A  1  B5 rr           lda ibul_x_hi,x
00115C  1  69 00           adc #0
00115E  1  85 rr           sta zp_scratch_hi
001160  1  A5 rr           lda zp_scratch_lo
001162  1  38              sec
001163  1  E5 rr           sbc player_x_lo
001165  1  A5 rr           lda zp_scratch_hi
001167  1  E5 rr           sbc player_x_hi
001169  1  30 20           bmi @next_slot            ; bullet right edge left of player → no hit
00116B  1               
00116B  1                  ; --- X check 2: bullet_x < player_x + 16 ---
00116B  1  A5 rr           lda player_x_lo
00116D  1  18              clc
