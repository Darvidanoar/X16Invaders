0013EE  1               ;******************************************************************
0013EE  1               ; print_dec_byte — print .A as 1 or 2 decimal digits (values 0-99)
0013EE  1               ;   Suppresses leading zero for single-digit numbers.
0013EE  1               ;   Clobbers: A, X.  Carry is cleared on exit.
0013EE  1               ;******************************************************************
0013EE  1               print_dec_byte:
0013EE  1  A2 00           ldx #0
0013F0  1               @pdb_loop:
0013F0  1  C9 0A           cmp #10
0013F2  1  90 05           bcc @pdb_units            ; A < 10 → done dividing
0013F4  1  E8              inx
0013F5  1  E9 0A           sbc #10                   ; carry is set by cmp, so sbc = A - 10
0013F7  1  80 F7           bra @pdb_loop
0013F9  1               @pdb_units:
0013F9  1  48              pha                       ; save units digit
0013FA  1  8A              txa                       ; tens digit count
0013FB  1  F0 05           beq @pdb_skip_tens        ; zero → suppress leading zero
0013FD  1  69 30           adc #$30                  ; carry=0 here (from last bcc), so adc = X + $30
0013FF  1  20 D2 FF        jsr CHROUT
001402  1               @pdb_skip_tens:
001402  1  68              pla                       ; units digit (0-9; carry=0)
001403  1  69 30           adc #$30
001405  1  20 D2 FF        jsr CHROUT
001408  1  60              rts
001409  1               
001409  1               ;******************************************************************
001409  1               ; draw_score_labels — paint "SCORE" (row 0, col 0) and "HI-SCORE" (row 0, col 16)
001409  1               ; Called once after screen clear, before main_loop.
001409  1               ;******************************************************************
001409  1               draw_score_labels:
001409  1  A9 00           lda #0
00140B  1  A0 00           ldy #0
00140D  1  18              clc
00140E  1  20 F0 FF        jsr PLOT
001411  1  A2 00           ldx #0
001413  1  BD B4 1C     @sl1: lda str_score_title, x
001416  1  F0 06           beq @sl1d
001418  1  20 D2 FF        jsr CHROUT
00141B  1  E8              inx
00141C  1  80 F5           bra @sl1
00141E  1               @sl1d:
00141E  1  A9 00           lda #0
001420  1  A0 10           ldy #16
001422  1  18              clc
001423  1  20 F0 FF        jsr PLOT
001426  1  A2 00           ldx #0
001428  1  BD BA 1C     @sl2: lda str_hi_score_lbl, x
00142B  1  F0 06           beq @sl2d
00142D  1  20 D2 FF        jsr CHROUT
001430  1  E8              inx
