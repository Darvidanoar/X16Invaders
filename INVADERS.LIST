000A5B  1  BD F5 1D        lda bullet_spr_data,x
000A5E  1  8D 23 9F        sta VERA_data0
000A61  1  E8              inx
000A62  1  E0 20           cpx #32
000A64  1  D0 F5           bne @up_bullet
000A66  1               
