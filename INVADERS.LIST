001284  1               ;******************************************************************
001284  1               ; update_hi_score — copy score → hi_score when score > hi_score
001284  1               ;   BCD compare: check hi byte, then mid, then lo.
001284  1               ;******************************************************************
001284  1               update_hi_score:
001284  1  A5 rr           lda score_hi
001286  1  C5 rr           cmp hi_score_hi
001288  1  90 1E           bcc @no_update
00128A  1  D0 10           bne @do_update
00128C  1  A5 rr           lda score_mid
00128E  1  C5 rr           cmp hi_score_mid
001290  1  90 16           bcc @no_update
001292  1  D0 08           bne @do_update
001294  1  A5 rr           lda score_lo
001296  1  C5 rr           cmp hi_score_lo
001298  1  90 0E           bcc @no_update
00129A  1  F0 0C           beq @no_update            ; equal → no change
00129C  1               @do_update:
00129C  1  A5 rr           lda score_lo
00129E  1  85 rr           sta hi_score_lo
0012A0  1  A5 rr           lda score_mid
0012A2  1  85 rr           sta hi_score_mid
0012A4  1  A5 rr           lda score_hi
0012A6  1  85 rr           sta hi_score_hi
0012A8  1               @no_update:
0012A8  1  60              rts
0012A9  1               
0012A9  1               ;******************************************************************
0012A9  1               ; restart_game — reset all gameplay state; reuse VRAM data; jump to main_loop
0012A9  1               ;   Does NOT reset hi-score.
0012A9  1               ;******************************************************************
0012A9  1               restart_game:
0012A9  1  64 rr           stz score_lo
0012AB  1  64 rr           stz score_mid
0012AD  1  64 rr           stz score_hi
0012AF  1  A9 01           lda #1
0012B1  1  85 rr           sta wave
0012B3  1  A9 32           lda #INV_MOVE_SPEED_INIT
0012B5  1  85 rr           sta wave_init_speed
0012B7  1               
0012B7  1  20 8C 09        jsr init_player           ; resets player_x, lives=3, inv_hit_timer=0
0012BA  1               
0012BA  1                  ; hide + deactivate player bullet
0012BA  1  64 rr           stz bullet_active
0012BC  1  20 54 0E        jsr update_bullet_sprite
0012BF  1               
0012BF  1                  ; reset explosion timer and hide sprite 4
0012BF  1  64 rr           stz exp_timer
0012C1  1  9C 25 9F        stz VERA_ctrl
0012C4  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1
0012C8  1  9F A9 FC 8D  
0012CC  1  21 9F A9 26  
