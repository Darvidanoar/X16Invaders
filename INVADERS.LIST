00120C  1               ; game_over_loop — blink "SPACE = PLAY AGAIN"; wait for input
00120C  1               ;------------------------------------------------------------------
00120C  1               game_over_loop:
00120C  1  20 2B 09        jsr wait_vsync
00120F  1  E6 rr           inc frame_count
001211  1  20 2D 09        jsr update_input
001214  1               
