0011A4  1                  ; decrement lives
0011A4  1  C6 rr           dec lives
0011A6  1  F0 0D           beq @game_over            ; lives hit 0 → end game (Phase 6 will handle this properly)
0011A8  1               
0011A8  1                  ; grant invincibility and re-centre the ship
0011A8  1  A9 78           lda #INV_HIT_FRAMES
0011AA  1  85 rr           sta inv_hit_timer
0011AC  1  A9 38           lda #<PLAYER_X_INIT
