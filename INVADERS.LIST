001265  1               ;******************************************************************
001265  1               ; hide_all_inv_sprites — set z-depth=0 for all 55 invader sprites
001265  1               ;   Uses VERA stride=8 to write only byte 6 (z-depth) of each block.
001265  1               ;   First invader sprite byte 6: $1FC00 + 11*8 + 6 = $1FC5E
001265  1               ;******************************************************************
001265  1               hide_all_inv_sprites:
001265  1  9C 25 9F        stz VERA_ctrl
001268  1  A9 41           lda #$41               ; stride=8 (code $4 in high nibble), bank=1
00126A  1  8D 22 9F        sta VERA_addr_bank
00126D  1  A9 FC           lda #$FC
00126F  1  8D 21 9F        sta VERA_addr_high
001272  1  A9 5E           lda #$5E               ; low byte of $1FC5E  ($1FC58+6)
001274  1  8D 20 9F        sta VERA_addr_low
001277  1  A9 00           lda #0                 ; z-depth=0 → disabled
001279  1  A2 37           ldx #55
00127B  1               @loop:
00127B  1  8D 23 9F        sta VERA_data0         ; writes byte 6; addr auto-advances by 8
00127E  1  CA              dex
00127F  1  D0 FA           bne @loop
001281  1  60              rts
001282  1               
001282  1               ;******************************************************************
001282  1               ; init_shields — upload 4 damage tiles, set palette entry 7 to dark
001282  1               ;   green, init shield_damage counters, write sprite attributes for
001282  1               ;   all 4 shields (slots 66–69, base $1FE10).
001282  1               ;
001282  1               ;   Sprite positions: X = shield_x_lo/hi[n], Y = SHIELD_Y (352)
001282  1               ;   Each shield sprite: 16x16, palette 0 (entry 7 = dark green).
001282  1               ;******************************************************************
001282  1               init_shields:
001282  1  9C 25 9F        stz VERA_ctrl
001285  1               
001285  1                  ; --- palette entry 7 → dark green (R=0, G=$A, B=0) ---
001285  1                  ; Palette byte 0: G[3:0] B[3:0] = $A0;  byte 1: R[3:0] = $00
001285  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_palette + 14), 1   ; entry 7 = offset 14 bytes
001289  1  9F A9 FA 8D  
00128D  1  21 9F A9 0E  
001294  1  A9 A0           lda #$A0
001296  1  8D 23 9F        sta VERA_data0
001299  1  A9 00           lda #$00
00129B  1  8D 23 9F        sta VERA_data0
00129E  1               
00129E  1                  ; --- upload shield_tile_full → $00500 ---
00129E  1  A9 10 8D 22     VERA_SET_ADDR VRAM_SHIELD_FULL, 1
0012A2  1  9F A9 05 8D  
0012A6  1  21 9F A9 00  
0012AD  1  A2 80           ldx #128
0012AF  1  BD B4 19     @up_s0: lda shield_tile_full - 128, x
0012B2  1  8D 23 9F        sta VERA_data0
0012B5  1  E8              inx
0012B6  1  D0 F7           bne @up_s0
0012B8  1               
0012B8  1                  ; --- upload shield_tile_dmg1 → $00580 ---
0012B8  1  A9 10 8D 22     VERA_SET_ADDR VRAM_SHIELD_DMG1, 1
0012BC  1  9F A9 05 8D  
0012C0  1  21 9F A9 80  
0012C7  1  A2 80           ldx #128
0012C9  1  BD 34 1A     @up_s1: lda shield_tile_dmg1 - 128, x
0012CC  1  8D 23 9F        sta VERA_data0
0012CF  1  E8              inx
0012D0  1  D0 F7           bne @up_s1
0012D2  1               
0012D2  1                  ; --- upload shield_tile_dmg2 → $00600 ---
0012D2  1  A9 10 8D 22     VERA_SET_ADDR VRAM_SHIELD_DMG2, 1
0012D6  1  9F A9 06 8D  
0012DA  1  21 9F A9 00  
0012E1  1  A2 80           ldx #128
0012E3  1  BD B4 1A     @up_s2: lda shield_tile_dmg2 - 128, x
0012E6  1  8D 23 9F        sta VERA_data0
0012E9  1  E8              inx
0012EA  1  D0 F7           bne @up_s2
0012EC  1               
0012EC  1                  ; --- upload shield_tile_dmg3 → $00680 ---
0012EC  1  A9 10 8D 22     VERA_SET_ADDR VRAM_SHIELD_DMG3, 1
0012F0  1  9F A9 06 8D  
0012F4  1  21 9F A9 80  
0012FB  1  A2 80           ldx #128
0012FD  1  BD 34 1B     @up_s3: lda shield_tile_dmg3 - 128, x
001300  1  8D 23 9F        sta VERA_data0
001303  1  E8              inx
001304  1  D0 F7           bne @up_s3
001306  1               
001306  1                  ; --- reset damage counters ---
001306  1  64 rr           stz shield_damage+0
001308  1  64 rr           stz shield_damage+1
00130A  1  64 rr           stz shield_damage+2
00130C  1  64 rr           stz shield_damage+3
00130E  1               
00130E  1                  ; --- write sprite attributes for 4 shields (sequential VERA write) ---
00130E  1                  ; Slots 66–69: $1FE10, $1FE18, $1FE20, $1FE28  (high=$FE, bank=1)
00130E  1  A9 11           lda #$11               ; stride=1, bank=1
001310  1  8D 22 9F        sta VERA_addr_bank
001313  1  A9 FE           lda #$FE
001315  1  8D 21 9F        sta VERA_addr_high
001318  1  A9 10           lda #$10               ; low byte of $1FE10
00131A  1  8D 20 9F        sta VERA_addr_low
00131D  1               
00131D  1  A2 00           ldx #0
00131F  1               @spr_init:
00131F  1  A9 28           lda #$28               ; byte 0: addr[12:5] = VRAM_SHIELD_FULL>>5 = $00500>>5
001321  1  8D 23 9F        sta VERA_data0
001324  1  A9 00           lda #$00               ; byte 1: 4bpp, addr[16:13]=0
001326  1  8D 23 9F        sta VERA_data0
001329  1  BD 88 16        lda shield_x_lo, x     ; byte 2: X lo
00132C  1  8D 23 9F        sta VERA_data0
00132F  1  BD 8C 16        lda shield_x_hi, x     ; byte 3: X hi
001332  1  8D 23 9F        sta VERA_data0
001335  1  A9 60           lda #<SHIELD_Y         ; byte 4: Y lo
001337  1  8D 23 9F        sta VERA_data0
00133A  1  A9 01           lda #>SHIELD_Y         ; byte 5: Y hi
00133C  1  8D 23 9F        sta VERA_data0
00133F  1  A9 0C           lda #SPR_Z_FRONT       ; byte 6: z-depth=3 (in front of all layers)
001341  1  8D 23 9F        sta VERA_data0
001344  1  A9 50           lda #SPR_16x16_PAL0    ; byte 7: 16x16, palette 0
001346  1  8D 23 9F        sta VERA_data0
001349  1  E8              inx
00134A  1  E0 04           cpx #4
00134C  1  D0 D1           bne @spr_init
00134E  1               
00134E  1  60              rts
00134F  1               
00134F  1               ;******************************************************************
00134F  1               ; update_shield_sprite — write new data-addr byte to shield sprite N
00134F  1               ;   Input:  X = shield index (0–3)
00134F  1               ;           shield_damage[X] = current damage level (1–3)
00134F  1               ;   Writes sprite byte 0 (addr[12:5]) using shield_addr_b0 lookup.
00134F  1               ;   VERA addr for byte 0 of sprite N: $1FE10 + N*8
00134F  1               ;******************************************************************
00134F  1               update_shield_sprite:
00134F  1  9C 25 9F        stz VERA_ctrl
001352  1  A9 11           lda #$11               ; stride=1, bank=1
001354  1  8D 22 9F        sta VERA_addr_bank
001357  1  A9 FE           lda #$FE
001359  1  8D 21 9F        sta VERA_addr_high
00135C  1  8A              txa                    ; A = shield index
00135D  1  0A              asl                    ; ×2
00135E  1  0A              asl                    ; ×4
00135F  1  0A              asl                    ; ×8
001360  1  18              clc
001361  1  69 10           adc #$10               ; + low byte of $1FE10
001363  1  8D 20 9F        sta VERA_addr_low
001366  1  B4 rr           ldy shield_damage, x   ; Y = damage level (1-3)
001368  1  B9 90 16        lda shield_addr_b0, y  ; addr[12:5] for this tile
00136B  1  8D 23 9F        sta VERA_data0
00136E  1  60              rts
00136F  1               
00136F  1               ;******************************************************************
00136F  1               ; hide_shield_sprite — disable sprite for shield N (z-depth=0)
00136F  1               ;   Input: X = shield index (0–3)
00136F  1               ;   Writes sprite byte 6 at $1FE10 + N*8 + 6 = $1FE16 + N*8
00136F  1               ;******************************************************************
00136F  1               hide_shield_sprite:
00136F  1  9C 25 9F        stz VERA_ctrl
001372  1  A9 11           lda #$11
001374  1  8D 22 9F        sta VERA_addr_bank
001377  1  A9 FE           lda #$FE
001379  1  8D 21 9F        sta VERA_addr_high
00137C  1  8A              txa
00137D  1  0A              asl
00137E  1  0A              asl
00137F  1  0A              asl
001380  1  18              clc
001381  1  69 16           adc #$16               ; low($1FE10) + 6 = $16, + N*8
001383  1  8D 20 9F        sta VERA_addr_low
001386  1  A9 00           lda #0                 ; z-depth=0 → sprite disabled
001388  1  8D 23 9F        sta VERA_data0
00138B  1  60              rts
00138C  1               
00138C  1               ;******************************************************************
00138C  1               ; damage_shield — increment damage counter for shield X and update
00138C  1               ;   sprite (or disable it when counter reaches 4 = destroyed).
00138C  1               ;   Input:  X = shield index (0–3)
00138C  1               ;   Clobbers: A, Y, VERA registers.  Preserves X.
00138C  1               ;******************************************************************
00138C  1               damage_shield:
00138C  1  F6 rr           inc shield_damage, x
00138E  1  B5 rr           lda shield_damage, x
001390  1  C9 04           cmp #4
001392  1  F0 06           beq @destroy
001394  1  B0 07           bcs @done              ; already at 4 (safety guard)
001396  1  20 4F 13        jsr update_shield_sprite
001399  1  60              rts
00139A  1               @destroy:
00139A  1  20 6F 13        jsr hide_shield_sprite
00139D  1               @done:
00139D  1  60              rts
00139E  1               
00139E  1               ;******************************************************************
00139E  1               ; check_bullet_shields — test active player bullet vs all 4 shields
00139E  1               ;
00139E  1               ;   Overlap condition (AABB, all values VERA 16-bit):
00139E  1               ;     X: bullet_x+8 > shield_x  AND  bullet_x < shield_x+16
00139E  1               ;     Y: bullet_y+8 > SHIELD_Y  AND  bullet_y < SHIELD_Y+16
00139E  1               ;
00139E  1               ;   On hit: calls damage_shield, deactivates bullet, returns.
00139E  1               ;   Scratch used: zp_scratch_lo/hi.  Preserves nothing.
00139E  1               ;******************************************************************
00139E  1               check_bullet_shields:
00139E  1  A5 rr           lda bullet_active
0013A0  1  F0 6D           beq @done
0013A2  1               
0013A2  1                  ; --- Y quick check (same band for all shields) ---
0013A2  1                  ; (1) bullet_y+8 > SHIELD_Y
0013A2  1  A5 rr           lda bullet_y_lo
0013A4  1  18              clc
0013A5  1  69 08           adc #8
0013A7  1  85 rr           sta zp_scratch_lo
0013A9  1  A5 rr           lda bullet_y_hi
0013AB  1  69 00           adc #0
0013AD  1  85 rr           sta zp_scratch_hi
0013AF  1  A5 rr           lda zp_scratch_lo
0013B1  1  38              sec
0013B2  1  E9 60           sbc #<SHIELD_Y
0013B4  1  A5 rr           lda zp_scratch_hi
0013B6  1  E9 01           sbc #>SHIELD_Y
0013B8  1  30 55           bmi @done              ; bullet bottom above shield top
0013BA  1               
0013BA  1                  ; (2) bullet_y < SHIELD_Y+16
0013BA  1  A5 rr           lda bullet_y_lo
0013BC  1  38              sec
0013BD  1  E9 70           sbc #<(SHIELD_Y + 16)
0013BF  1  A5 rr           lda bullet_y_hi
0013C1  1  E9 01           sbc #>(SHIELD_Y + 16)
0013C3  1  10 4A           bpl @done              ; bullet top at or below shield bottom
0013C5  1               
0013C5  1                  ; --- Y overlaps: scan each shield ---
0013C5  1  A2 00           ldx #0
0013C7  1               @sld_loop:
0013C7  1  B5 rr           lda shield_damage, x
0013C9  1  C9 04           cmp #4
0013CB  1  F0 3D           beq @next_sld          ; destroyed, skip
0013CD  1               
0013CD  1                  ; X check (1): bullet_x+8 > shield_x[x]
0013CD  1  A5 rr           lda bullet_x_lo
0013CF  1  18              clc
0013D0  1  69 08           adc #8
0013D2  1  85 rr           sta zp_scratch_lo
0013D4  1  A5 rr           lda bullet_x_hi
0013D6  1  69 00           adc #0
0013D8  1  85 rr           sta zp_scratch_hi
0013DA  1  A5 rr           lda zp_scratch_lo
0013DC  1  38              sec
0013DD  1  FD 88 16        sbc shield_x_lo, x
0013E0  1  A5 rr           lda zp_scratch_hi
0013E2  1  FD 8C 16        sbc shield_x_hi, x
0013E5  1  30 23           bmi @next_sld
0013E7  1               
0013E7  1                  ; X check (2): bullet_x < shield_x[x]+16
0013E7  1  BD 88 16        lda shield_x_lo, x
0013EA  1  18              clc
0013EB  1  69 10           adc #16
0013ED  1  85 rr           sta zp_scratch_lo
0013EF  1  BD 8C 16        lda shield_x_hi, x
0013F2  1  69 00           adc #0
0013F4  1  85 rr           sta zp_scratch_hi
0013F6  1  A5 rr           lda bullet_x_lo
0013F8  1  38              sec
0013F9  1  E5 rr           sbc zp_scratch_lo
0013FB  1  A5 rr           lda bullet_x_hi
0013FD  1  E5 rr           sbc zp_scratch_hi
0013FF  1  10 09           bpl @next_sld
001401  1               
001401  1                  ; --- HIT ---
001401  1  20 8C 13        jsr damage_shield      ; X = shield index
001404  1  64 rr           stz bullet_active
001406  1  20 BC 0D        jsr update_bullet_sprite
001409  1  60              rts
00140A  1               
00140A  1               @next_sld:
00140A  1  E8              inx
00140B  1  E0 04           cpx #4
00140D  1  D0 B8           bne @sld_loop
00140F  1               @done:
00140F  1  60              rts
001410  1               
001410  1               ;******************************************************************
001410  1               ; check_invbullet_shields — test each active invader bullet vs all
001410  1               ;   4 shields.  Same AABB logic as check_bullet_shields but loops
001410  1               ;   over 3 bullet slots (ibul_active / ibul_x / ibul_y arrays).
001410  1               ;
001410  1               ;   Scratch: zp_scratch_lo/hi, zp_row (bullet slot index),
001410  1               ;            zp_col (shield index during inner scan).
001410  1               ;******************************************************************
001410  1               check_invbullet_shields:
001410  1  A2 00           ldx #0                 ; outer loop: invader bullet slot
001412  1               @ibul_loop:
001412  1  86 rr           stx zp_row             ; save slot before any branch
001414  1  B5 rr           lda ibul_active, x
001416  1  F0 7B           beq @next_ibul
001418  1               
001418  1                  ; --- Y quick check ---
001418  1                  ; (1) ibul_y+8 > SHIELD_Y
001418  1  B5 rr           lda ibul_y_lo, x
00141A  1  18              clc
00141B  1  69 08           adc #8
00141D  1  85 rr           sta zp_scratch_lo
00141F  1  B5 rr           lda ibul_y_hi, x
001421  1  69 00           adc #0
001423  1  85 rr           sta zp_scratch_hi
001425  1  A5 rr           lda zp_scratch_lo
001427  1  38              sec
001428  1  E9 60           sbc #<SHIELD_Y
00142A  1  A5 rr           lda zp_scratch_hi
00142C  1  E9 01           sbc #>SHIELD_Y
00142E  1  30 63           bmi @next_ibul
001430  1               
001430  1                  ; (2) ibul_y < SHIELD_Y+16
001430  1  A6 rr           ldx zp_row
001432  1  B5 rr           lda ibul_y_lo, x
001434  1  38              sec
001435  1  E9 70           sbc #<(SHIELD_Y + 16)
001437  1  B5 rr           lda ibul_y_hi, x
001439  1  E9 01           sbc #>(SHIELD_Y + 16)
00143B  1  10 56           bpl @next_ibul
00143D  1               
00143D  1                  ; --- Y overlaps: scan shields with Y register ---
00143D  1  A0 00           ldy #0
00143F  1               @sld_scan:
00143F  1  B9 rr rr        lda shield_damage, y
001442  1  C9 04           cmp #4
001444  1  F0 48           beq @next_sld_y        ; destroyed
001446  1               
001446  1                  ; X check (1): ibul_x+8 > shield_x[y]
001446  1  A6 rr           ldx zp_row
001448  1  B5 rr           lda ibul_x_lo, x
00144A  1  18              clc
00144B  1  69 08           adc #8
00144D  1  85 rr           sta zp_scratch_lo
00144F  1  B5 rr           lda ibul_x_hi, x
001451  1  69 00           adc #0
001453  1  85 rr           sta zp_scratch_hi
001455  1  A5 rr           lda zp_scratch_lo
001457  1  38              sec
001458  1  F9 88 16        sbc shield_x_lo, y
00145B  1  A5 rr           lda zp_scratch_hi
00145D  1  F9 8C 16        sbc shield_x_hi, y
001460  1  30 2C           bmi @next_sld_y
001462  1               
001462  1                  ; X check (2): ibul_x < shield_x[y]+16
001462  1  B9 88 16        lda shield_x_lo, y
001465  1  18              clc
001466  1  69 10           adc #16
001468  1  85 rr           sta zp_scratch_lo
00146A  1  B9 8C 16        lda shield_x_hi, y
00146D  1  69 00           adc #0
00146F  1  85 rr           sta zp_scratch_hi
001471  1  A6 rr           ldx zp_row
001473  1  B5 rr           lda ibul_x_lo, x
001475  1  38              sec
001476  1  E5 rr           sbc zp_scratch_lo
001478  1  B5 rr           lda ibul_x_hi, x
00147A  1  E5 rr           sbc zp_scratch_hi
00147C  1  10 10           bpl @next_sld_y
00147E  1               
00147E  1                  ; --- HIT ---
00147E  1  98              tya                    ; shield index → A → X for damage_shield
00147F  1  AA              tax
001480  1  20 8C 13        jsr damage_shield
001483  1  A6 rr           ldx zp_row             ; restore bullet slot
001485  1  74 rr           stz ibul_active, x
001487  1  20 AD 0F        jsr update_inv_bullet_sprite
00148A  1  A6 rr           ldx zp_row
00148C  1  80 05           bra @next_ibul         ; done with this bullet
00148E  1               
00148E  1               @next_sld_y:
00148E  1  C8              iny
00148F  1  C0 04           cpy #4
001491  1  D0 AC           bne @sld_scan
001493  1               
001493  1               @next_ibul:
001493  1  A6 rr           ldx zp_row
001495  1  E8              inx
001496  1  E0 03           cpx #3
001498  1  F0 03           beq @cis_done
00149A  1  4C 12 14        jmp @ibul_loop
