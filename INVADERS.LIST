001412  1               ;******************************************************************
001412  1               ; draw_title_screen — paint the title screen; called once before title_loop
001412  1               ;
001412  1               ;   Layout (40-col text, VERA Y=row*16):
001412  1               ;     Row  1, col 14: "X16 INVADERS"      (12 chars, centred)
001412  1               ;     Row  3, col 16: "HI-SCORE"          (8 chars, centred)
001412  1               ;     Row  4, col 17: 000000              (6-digit BCD hi-score)
001412  1               ;     Row  5, col  5: "?UFO? = ??? PTS"
001412  1               ;     Row  7, col  9: "= 30 PTS"          + Type C sprite at X=96,Y=112
001412  1               ;     Row 10, col  9: "= 20 PTS"          + Type B sprite at X=96,Y=160
001412  1               ;     Row 13, col  9: "= 10 PTS"          + Type A sprite at X=96,Y=208
001412  1               ;     Row 17, col 10: (PRESS SPACE TO START — blinked by title_loop)
001412  1               ;     Row 19, col 12: "RUN/STOP TO QUIT"
001412  1               ;******************************************************************
001412  1               draw_title_screen:
001412  1                  ; Row 1, col 14: "X16 INVADERS"
001412  1  A9 01           lda #1
001414  1  A0 0E           ldy #14
001416  1  18              clc
001417  1  20 F0 FF        jsr PLOT
00141A  1  A2 00           ldx #0
00141C  1  BD BB 1B     @lp1: lda str_title_main, x
00141F  1  F0 06           beq @lp1_done
001421  1  20 D2 FF        jsr CHROUT
001424  1  E8              inx
001425  1  80 F5           bra @lp1
001427  1               @lp1_done:
001427  1               
001427  1                  ; Row 3, col 16: "HI-SCORE"
001427  1  A9 03           lda #3
001429  1  A0 10           ldy #16
00142B  1  18              clc
00142C  1  20 F0 FF        jsr PLOT
00142F  1  A2 00           ldx #0
001431  1  BD CE 1B     @lp2: lda str_hi_score_lbl, x
001434  1  F0 06           beq @lp2_done
001436  1  20 D2 FF        jsr CHROUT
001439  1  E8              inx
00143A  1  80 F5           bra @lp2
00143C  1               @lp2_done:
00143C  1               
00143C  1                  ; Row 4, col 17: hi-score 6 BCD digits (000000 at start)
00143C  1  A9 04           lda #4
00143E  1  A0 11           ldy #17
001440  1  18              clc
001441  1  20 F0 FF        jsr PLOT
001444  1  A5 rr           lda hi_score_hi
