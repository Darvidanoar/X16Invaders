001556  1               ; hide_all_inv_sprites — set z-depth=0 for all 55 invader sprites
001556  1               ;   Uses VERA stride=8 to write only byte 6 (z-depth) of each block.
001556  1               ;   First invader sprite byte 6: $1FC00 + 11*8 + 6 = $1FC5E
001556  1               ;******************************************************************
001556  1               hide_all_inv_sprites:
001556  1  9C 25 9F        stz VERA_ctrl
001559  1  A9 41           lda #$41               ; stride=8 (code $4 in high nibble), bank=1
00155B  1  8D 22 9F        sta VERA_addr_bank
00155E  1  A9 FC           lda #$FC
001560  1  8D 21 9F        sta VERA_addr_high
001563  1  A9 5E           lda #$5E               ; low byte of $1FC5E  ($1FC58+6)
001565  1  8D 20 9F        sta VERA_addr_low
001568  1  A9 00           lda #0                 ; z-depth=0 → disabled
00156A  1  A2 37           ldx #55
00156C  1               @loop:
00156C  1  8D 23 9F        sta VERA_data0         ; writes byte 6; addr auto-advances by 8
00156F  1  CA              dex
001570  1  D0 FA           bne @loop
001572  1  60              rts
