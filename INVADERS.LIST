001CCC  1  00 0B 16 21  inv_row_base:   .byte   0, 11, 22, 33, 44
001CD0  1  2C           
001CD1  1               
001CD1  1               ; single-bit masks for bits 0-7
001CD1  1  01 02 04 08  bit_masks:      .byte   1,  2,  4,  8, 16, 32, 64,128
001CD5  1  10 20 40 80  
001CD9  1               
001CD9  1               ; BCD score per invader row (row 0=Type C, rows 1-2=Type B, rows 3-4=Type A)
001CD9  1  30 20 20 10  score_by_row_bcd: .byte $30, $20, $20, $10, $10
001CDD  1  10           
