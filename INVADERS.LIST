0014A9  1  8D 23 9F        sta VERA_data0
0014AC  1  A9 00           lda #0                 ; byte 5: Y hi
0014AE  1  8D 23 9F        sta VERA_data0
0014B1  1  A9 0C           lda #SPR_Z_FRONT       ; byte 6: z-depth=3
0014B3  1  8D 23 9F        sta VERA_data0
0014B6  1  A9 50           lda #SPR_16x16_PAL0    ; byte 7: 16x16, palette 0
0014B8  1  8D 23 9F        sta VERA_data0
