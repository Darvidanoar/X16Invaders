001191  1               ;******************************************************************
001191  1               ; player_hit — handle a bullet-player collision:
001191  1               ;   explosion at player position, decrement lives, respawn, invincibility
001191  1               ;******************************************************************
001191  1               player_hit:
001191  1                  ; start explosion at player position
001191  1  A5 rr           lda player_x_lo
