001377  1  20 E1 1B        jsr snd_stop_march        ; silence march beat
00137A  1  20 46 1C        jsr snd_stop_fire         ; silence fire tone
00137D  1  20 AB 1C        jsr snd_stop_exp          ; silence explosion noise
001380  1  64 rr           stz ufo_active
001382  1  20 28 1A        jsr update_ufo_sprite
