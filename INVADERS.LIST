0012EA  1  85 rr           sta inv_fire_timer
0012EC  1               
0012EC  1                  ; reset UFO state and silence all sounds
0012EC  1  64 rr           stz ufo_active
0012EE  1  20 93 1A        jsr snd_stop_ufo_drone
0012F1  1  20 37 1B        jsr snd_stop_march
0012F4  1  20 9C 1B        jsr snd_stop_fire
0012F7  1  20 01 1C        jsr snd_stop_exp
