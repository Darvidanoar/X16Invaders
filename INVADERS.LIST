00121C  1               ;------------------------------------------------------------------
00121C  1               ; game_over_loop — blink "SPACE = PLAY AGAIN"; wait for input
00121C  1               ;------------------------------------------------------------------
00121C  1               game_over_loop:
00121C  1  20 35 09        jsr wait_vsync
00121F  1  E6 rr           inc frame_count
001221  1  20 37 09        jsr update_input
001224  1               
001224  1  A5 rr           lda key_last
001226  1  C9 03           cmp #KEY_RUN_STOP
001228  1  F0 39           beq @go_quit
00122A  1               
