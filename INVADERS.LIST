001822  1                  ; --- write sprite attributes for 4 shields (sequential VERA write) ---
001822  1                  ; Slots 66–69: $1FE10, $1FE18, $1FE20, $1FE28  (high=$FE, bank=1)
001822  1  A9 11           lda #$11               ; stride=1, bank=1
001824  1  8D 22 9F        sta VERA_addr_bank
001827  1  A9 FE           lda #$FE
001829  1  8D 21 9F        sta VERA_addr_high
00182C  1  A9 10           lda #$10               ; low byte of $1FE10
00182E  1  8D 20 9F        sta VERA_addr_low
001831  1               
001831  1  A2 00           ldx #0
001833  1               @spr_init:
001833  1  A9 28           lda #$28               ; byte 0: addr[12:5] = VRAM_SHIELD_FULL>>5 = $00500>>5 = $28
001835  1  8D 23 9F        sta VERA_data0
001838  1  A9 00           lda #$00               ; byte 1: 4bpp, addr[16:13]=0
00183A  1  8D 23 9F        sta VERA_data0
00183D  1  BD 41 1F        lda shield_x_lo, x     ; byte 2: X lo
001840  1  8D 23 9F        sta VERA_data0
001843  1  BD 45 1F        lda shield_x_hi, x     ; byte 3: X hi
001846  1  8D 23 9F        sta VERA_data0
