0015A8  1               ;******************************************************************
0015A8  1               ; init_shields — upload 8 damage tiles, set palette entry 7 to dark
0015A8  1               ;   green, init shield_damage counters, write sprite attributes for
0015A8  1               ;   all 4 shields (slots 66–69, base $1FE10).
0015A8  1               ;
0015A8  1               ;   Sprite positions: X = shield_x_lo/hi[n], Y = SHIELD_Y (352)
0015A8  1               ;   Each shield sprite: 32x32, palette 0 (entry 7 = dark green).
0015A8  1               ;******************************************************************
0015A8  1               init_shields:
0015A8  1  9C 25 9F        stz VERA_ctrl
0015AB  1               
0015AB  1                  ; --- palette entry 7 → dark green (R=0, G=$A, B=0) ---
0015AB  1                  ; Palette byte 0: G[3:0] B[3:0] = $A0;  byte 1: R[3:0] = $00
0015AB  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_palette + 14), 1   ; entry 7 = offset 14 bytes
0015AF  1  9F A9 FA 8D  
0015B3  1  21 9F A9 0E  
0015BA  1  A9 A0           lda #$A0
