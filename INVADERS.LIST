001199  1               ;******************************************************************
001199  1               ; player_hit — handle a bullet-player collision:
001199  1               ;   explosion at player position, decrement lives, respawn, invincibility
001199  1               ;******************************************************************
001199  1               player_hit:
001199  1                  ; start explosion at player position
001199  1  A5 rr           lda player_x_lo
00119B  1  85 rr           sta zp_x_lo
00119D  1  A5 rr           lda player_x_hi
00119F  1  85 rr           sta zp_x_hi
