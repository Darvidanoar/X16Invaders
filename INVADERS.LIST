00125E  1               
00125E  1               ;******************************************************************
00125E  1               ; update_hi_score — copy score → hi_score when score > hi_score
00125E  1               ;   BCD compare: check hi byte, then mid, then lo.
00125E  1               ;******************************************************************
00125E  1               update_hi_score:
00125E  1  A5 rr           lda score_hi
001260  1  C5 rr           cmp hi_score_hi
001262  1  90 1E           bcc @no_update
001264  1  D0 10           bne @do_update
001266  1  A5 rr           lda score_mid
001268  1  C5 rr           cmp hi_score_mid
00126A  1  90 16           bcc @no_update
00126C  1  D0 08           bne @do_update
00126E  1  A5 rr           lda score_lo
001270  1  C5 rr           cmp hi_score_lo
001272  1  90 0E           bcc @no_update
001274  1  F0 0C           beq @no_update            ; equal → no change
001276  1               @do_update:
001276  1  A5 rr           lda score_lo
001278  1  85 rr           sta hi_score_lo
00127A  1  A5 rr           lda score_mid
00127C  1  85 rr           sta hi_score_mid
00127E  1  A5 rr           lda score_hi
001280  1  85 rr           sta hi_score_hi
001282  1               @no_update:
001282  1  60              rts
001283  1               
001283  1               ;******************************************************************
001283  1               ; restart_game — reset all gameplay state; reuse VRAM data; jump to main_loop
001283  1               ;   Does NOT reset hi-score.
001283  1               ;******************************************************************
001283  1               restart_game:
001283  1  64 rr           stz score_lo
001285  1  64 rr           stz score_mid
001287  1  64 rr           stz score_hi
001289  1  A9 01           lda #1
00128B  1  85 rr           sta wave
00128D  1  A9 32           lda #INV_MOVE_SPEED_INIT
00128F  1  85 rr           sta wave_init_speed
001291  1               
001291  1  20 78 09        jsr init_player           ; resets player_x, lives=3, inv_hit_timer=0
001294  1               
001294  1                  ; hide + deactivate player bullet
001294  1  64 rr           stz bullet_active
001296  1  20 3A 0E        jsr update_bullet_sprite
001299  1               
001299  1                  ; reset explosion timer and hide sprite 4
001299  1  64 rr           stz exp_timer
00129B  1  9C 25 9F        stz VERA_ctrl
00129E  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1
0012A2  1  9F A9 FC 8D  
0012A6  1  21 9F A9 26  
0012AD  1  A9 00           lda #$00
0012AF  1  8D 23 9F        sta VERA_data0
0012B2  1               
0012B2  1                  ; deactivate all invader bullets and hide their sprites
0012B2  1  64 rr           stz ibul_active+0
0012B4  1  64 rr           stz ibul_active+1
0012B6  1  64 rr           stz ibul_active+2
0012B8  1  A2 00           ldx #0
