001219  1               ;******************************************************************
001219  1               ; player_spr_data — 16x16 4bpp sprite, 128 bytes
001219  1               ;
001219  1               ;   Color 0 = transparent, Color 1 = white (default palette index 1)
001219  1               ;   Design: classic upward-pointing triangular ship with engine notches
001219  1               ;
001219  1               ;   Each byte encodes 2 pixels: high nibble = left, low nibble = right
001219  1               ;   Columns: 0123456789ABCDEF
001219  1               ;
001219  1               ;   Row  0:  .......1........   cannon tip
001219  1               ;   Row  1:  .......11.......
001219  1               ;   Row  2:  ......111.......
001219  1               ;   Row  3:  ......111.......
001219  1               ;   Row  4:  .....11111......
001219  1               ;   Row  5:  .....1111111....
001219  1               ;   Row  6:  ...111111111....
001219  1               ;   Row  7:  ..11111111111...
001219  1               ;   Row  8:  .1111111111111..
001219  1               ;   Row  9:  1111111111111111   full base
001219  1               ;   Row 10:  1111111111111111
001219  1               ;   Row 11:  1111111111111111
001219  1               ;   Row 12:  11..11111111..11   engine notches
001219  1               ;   Row 13:  11..11111111..11
001219  1               ;   Row 14:  ................
001219  1               ;   Row 15:  ................
001219  1               ;******************************************************************
001219  1               player_spr_data:
001219  1                  ; row 0
001219  1  00 00 00 00     .byte $00,$00,$00,$00,$00,$00,$00,$00
00121D  1  00 00 00 00  
001221  1                  ; row 1
001221  1  00 00 00 01     .byte $00,$00,$00,$01,$10,$00,$00,$00
001225  1  10 00 00 00  
001229  1                  ; row 2
001229  1  00 00 00 01     .byte $00,$00,$00,$01,$10,$00,$00,$00
00122D  1  10 00 00 00  
001231  1                  ; row 3
001231  1  00 00 00 01     .byte $00,$00,$00,$01,$10,$00,$00,$00
001235  1  10 00 00 00  
001239  1                  ; row 4
001239  1  00 00 01 11     .byte $00,$00,$01,$11,$11,$10,$00,$00
00123D  1  11 10 00 00  
001241  1                  ; row 5
001241  1  00 00 11 11     .byte $00,$00,$11,$11,$11,$11,$00,$00
001245  1  11 11 00 00  
001249  1                  ; row 6
001249  1  00 01 11 11     .byte $00,$01,$11,$11,$11,$11,$10,$00
00124D  1  11 11 10 00  
001251  1                  ; row 7
001251  1  00 01 11 11     .byte $00,$01,$11,$11,$11,$11,$10,$00
001255  1  11 11 10 00  
001259  1                  ; row 8
001259  1  01 11 11 11     .byte $01,$11,$11,$11,$11,$11,$11,$10
00125D  1  11 11 11 10  
001261  1                  ; row 9
001261  1  11 11 11 11     .byte $11,$11,$11,$11,$11,$11,$11,$11
001265  1  11 11 11 11  
001269  1                  ; row 10
001269  1  11 11 11 11     .byte $11,$11,$11,$11,$11,$11,$11,$11
00126D  1  11 11 11 11  
001271  1                  ; row 11
001271  1  11 11 11 11     .byte $11,$11,$11,$11,$11,$11,$11,$11
001275  1  11 11 11 11  
001279  1                  ; row 12  (engine notches: cols 2-3 and 12-13 transparent)
001279  1  11 00 11 11     .byte $11,$00,$11,$11,$11,$11,$00,$11
00127D  1  11 11 00 11  
001281  1                  ; row 13
001281  1  11 00 11 11     .byte $11,$00,$11,$11,$11,$11,$00,$11
001285  1  11 11 00 11  
001289  1                  ; row 14
