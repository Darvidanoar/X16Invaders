00125C  1               ;******************************************************************
00125C  1               ; hide_all_inv_sprites — set z-depth=0 for all 55 invader sprites
00125C  1               ;   Uses VERA stride=8 to write only byte 6 (z-depth) of each block.
00125C  1               ;   First invader sprite byte 6: $1FC00 + 11*8 + 6 = $1FC5E
00125C  1               ;******************************************************************
00125C  1               hide_all_inv_sprites:
00125C  1  9C 25 9F        stz VERA_ctrl
00125F  1  A9 41           lda #$41               ; stride=8 (code $4 in high nibble), bank=1
001261  1  8D 22 9F        sta VERA_addr_bank
001264  1  A9 FC           lda #$FC
001266  1  8D 21 9F        sta VERA_addr_high
001269  1  A9 5E           lda #$5E               ; low byte of $1FC5E  ($1FC58+6)
00126B  1  8D 20 9F        sta VERA_addr_low
00126E  1  A9 00           lda #0                 ; z-depth=0 → disabled
001270  1  A2 37           ldx #55
001272  1               @loop:
001272  1  8D 23 9F        sta VERA_data0         ; writes byte 6; addr auto-advances by 8
001275  1  CA              dex
001276  1  D0 FA           bne @loop
001278  1  60              rts
