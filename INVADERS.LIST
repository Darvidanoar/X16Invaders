001490  1               ;******************************************************************
001490  1               ; draw_title_screen — paint the title screen; called once before title_loop
001490  1               ;
001490  1               ;   Layout (40-col text, VERA Y=row*16):
001490  1               ;     Row  1, col 14: "X16 INVADERS"      (12 chars, centred)
001490  1               ;     Row  3, col 16: "HI-SCORE"          (8 chars, centred)
001490  1               ;     Row  4, col 17: 000000              (6-digit BCD hi-score)
001490  1               ;     Row  5, col  5: "?UFO? = ??? PTS"
001490  1               ;     Row  7, col  9: "= 30 PTS"          + Type C sprite at X=96,Y=112
001490  1               ;     Row 10, col  9: "= 20 PTS"          + Type B sprite at X=96,Y=160
001490  1               ;     Row 13, col  9: "= 10 PTS"          + Type A sprite at X=96,Y=208
001490  1               ;     Row 17, col 10: (PRESS SPACE TO START — blinked by title_loop)
001490  1               ;     Row 19, col 12: "Q TO QUIT"
001490  1               ;******************************************************************
001490  1               draw_title_screen:
001490  1                  ; Row 1, col 14: "X16 INVADERS"
001490  1  A2 02           ldx #2
001492  1  A0 22           ldy #34
001494  1  18              clc
001495  1  20 F0 FF        jsr PLOT
001498  1  A2 00           ldx #0
00149A  1  BD 4C 1D     @lp1: lda str_title_main, x
00149D  1  F0 06           beq @lp1_done
00149F  1  20 D2 FF        jsr CHROUT
0014A2  1  E8              inx
0014A3  1  80 F5           bra @lp1
0014A5  1               @lp1_done:
0014A5  1               
0014A5  1                  ; Row 3, col 16: "HI-SCORE"
0014A5  1  A2 01           ldx #1
0014A7  1  A0 3F           ldy #63
0014A9  1  18              clc
0014AA  1  20 F0 FF        jsr PLOT
0014AD  1  A2 00           ldx #0
0014AF  1  BD 5F 1D     @lp2: lda str_hi_score_lbl, x
0014B2  1  F0 06           beq @lp2_done
0014B4  1  20 D2 FF        jsr CHROUT
0014B7  1  E8              inx
0014B8  1  80 F5           bra @lp2
0014BA  1               @lp2_done:
0014BA  1               
0014BA  1                  ; Row 4, col 17: hi-score 6 BCD digits (000000 at start)
0014BA  1  A2 01           ldx #1
0014BC  1  A0 49           ldy #73
0014BE  1  18              clc
0014BF  1  20 F0 FF        jsr PLOT
0014C2  1  A5 rr           lda hi_score_hi
0014C4  1  20 2D 1D        jsr print_hex_byte
0014C7  1  A5 rr           lda hi_score_mid
0014C9  1  20 2D 1D        jsr print_hex_byte
0014CC  1  A5 rr           lda hi_score_lo
0014CE  1  20 2D 1D        jsr print_hex_byte
0014D1  1               
0014D1  1                  ; Row 5, col 5: "?UFO? = ??? PTS"
0014D1  1  A2 09           ldx #9
0014D3  1  A0 09           ldy #9
0014D5  1  18              clc
0014D6  1  20 F0 FF        jsr PLOT
0014D9  1  A2 00           ldx #0
0014DB  1  BD 67 1D     @lp3: lda str_ufo_score, x
0014DE  1  F0 06           beq @lp3_done
0014E0  1  20 D2 FF        jsr CHROUT
0014E3  1  E8              inx
0014E4  1  80 F5           bra @lp3
0014E6  1               @lp3_done:
0014E6  1               
0014E6  1                  ; Sample invader sprites (Types C, B, A) + score labels
0014E6  1  20 FF 14        jsr show_title_sprites
0014E9  1               
0014E9  1                  ; Row 19, col 12: "Q TO QUIT"  (Plot: Set X to Row, Set Y to Col)
0014E9  1  A2 25           ldx #37
0014EB  1  A0 23           ldy #35
0014ED  1  18              clc
0014EE  1  20 F0 FF        jsr PLOT
0014F1  1  A2 00           ldx #0
0014F3  1  BD 00 1E     @lp4: lda str_run_stop_hint, x
0014F6  1  F0 06           beq @lp4_done
0014F8  1  20 D2 FF        jsr CHROUT
0014FB  1  E8              inx
0014FC  1  80 F5           bra @lp4
0014FE  1               @lp4_done:
0014FE  1               
0014FE  1  60              rts
