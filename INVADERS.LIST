00131F  1  20 B0 13        jsr print_dec_byte
001322  1               
001322  1  A9 0E           lda #14
001324  1  A0 08           ldy #8
001326  1  18              clc
001327  1  20 F0 FF        jsr PLOT
00132A  1  A2 00           ldx #0
00132C  1  BD 6E 1B     @wc3: lda str_wave_continue, x
00132F  1  F0 06           beq @wc3d
