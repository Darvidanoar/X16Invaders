001221  1  D0 3B           bne @go_restart
001223  1               
001223  1  A5 rr           lda frame_count
001225  1  29 20           and #$20                  ; bit 5: flips every 32 frames ≈ 2 Hz blink
001227  1  D0 15           bne @go_show
001229  1               @go_hide:
001229  1  A9 0F           lda #15
00122B  1  A0 0B           ldy #11
00122D  1  18              clc
