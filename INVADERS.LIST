001362  1               ;******************************************************************
001362  1               ; next_wave — advance wave counter, reduce speed, reset grid, resume play
001362  1               ;   Keeps: player X, lives, score, shields.
001362  1               ;   Clears: bullets, invaders, explosion, UFO.
001362  1               ;******************************************************************
001362  1               next_wave:
001362  1  E6 rr           inc wave
001364  1               
001364  1                  ; new wave_init_speed = max(current - WAVE_SPEED_STEP, INV_MOVE_SPEED_MIN)
001364  1  A5 rr           lda wave_init_speed
001366  1  38              sec
001367  1  E9 05           sbc #WAVE_SPEED_STEP
001369  1  C9 05           cmp #INV_MOVE_SPEED_MIN
00136B  1  B0 02           bcs @speed_ok
00136D  1  A9 05           lda #INV_MOVE_SPEED_MIN
00136F  1               @speed_ok:
00136F  1  85 rr           sta wave_init_speed
001371  1               
001371  1                  ; deactivate player bullet
001371  1  64 rr           stz bullet_active
001373  1  20 3D 0E        jsr update_bullet_sprite
001376  1               
001376  1                  ; reset explosion
001376  1  64 rr           stz exp_timer
001378  1  9C 25 9F        stz VERA_ctrl
00137B  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1
00137F  1  9F A9 FC 8D  
001383  1  21 9F A9 26  
00138A  1  A9 00           lda #$00
00138C  1  8D 23 9F        sta VERA_data0
00138F  1               
00138F  1                  ; deactivate invader bullets
00138F  1  64 rr           stz ibul_active+0
001391  1  64 rr           stz ibul_active+1
001393  1  64 rr           stz ibul_active+2
001395  1  A2 00           ldx #0
