0014A3  1               ;******************************************************************
0014A3  1               ; show_title_sprites — enable one sprite of each type at fixed
0014A3  1               ;   title-screen positions and print score labels beside them.
0014A3  1               ;
0014A3  1               ;   In VERA 640x480 space, 1 text row/col = 16 VERA pixels.
0014A3  1               ;   Sprites: X=96 (col 6), score labels at col 9.
0014A3  1               ;   Sprite 11 (Type C): Y=112 → text row 7,  "= 30 PTS"
0014A3  1               ;   Sprite 22 (Type B): Y=160 → text row 10, "= 20 PTS"
0014A3  1               ;   Sprite 44 (Type A): Y=208 → text row 13, "= 10 PTS"
0014A3  1               ;******************************************************************
0014A3  1               show_title_sprites:
0014A3  1  9C 25 9F        stz VERA_ctrl
0014A6  1                  ; --- sprite 11 (Type C, squid/cyan): attr $1FC00+11*8=$1FC58 ---
0014A6  1                  ; addr[12:5] = VRAM_INV_C_F0>>5 = $00300>>5 = $18
0014A6  1  A9 11           lda #$11               ; stride=1, bank=1
0014A8  1  8D 22 9F        sta VERA_addr_bank
0014AB  1  A9 FC           lda #$FC
0014AD  1  8D 21 9F        sta VERA_addr_high
0014B0  1  A9 58           lda #$58               ; low byte of $1FC58
0014B2  1  8D 20 9F        sta VERA_addr_low
0014B5  1  A9 18           lda #$18               ; byte 0: data addr[12:5]
0014B7  1  8D 23 9F        sta VERA_data0
0014BA  1  A9 00           lda #$00               ; byte 1: 4bpp, addr[16:13]=0
0014BC  1  8D 23 9F        sta VERA_data0
0014BF  1  A9 60           lda #96                ; byte 2: X lo
0014C1  1  8D 23 9F        sta VERA_data0
0014C4  1  A9 00           lda #0                 ; byte 3: X hi
0014C6  1  8D 23 9F        sta VERA_data0
0014C9  1  A9 70           lda #112               ; byte 4: Y lo (row 7: 7*16=112)
0014CB  1  8D 23 9F        sta VERA_data0
0014CE  1  A9 00           lda #0                 ; byte 5: Y hi
0014D0  1  8D 23 9F        sta VERA_data0
0014D3  1  A9 0C           lda #SPR_Z_FRONT       ; byte 6: z-depth=3
0014D5  1  8D 23 9F        sta VERA_data0
0014D8  1  A9 50           lda #SPR_16x16_PAL0    ; byte 7: 16x16, palette 0
0014DA  1  8D 23 9F        sta VERA_data0
0014DD  1               
0014DD  1  A9 07           lda #7
0014DF  1  A0 09           ldy #9
0014E1  1  18              clc
0014E2  1  20 F0 FF        jsr PLOT
