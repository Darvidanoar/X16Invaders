001375  1               ;******************************************************************
001375  1               ; next_wave — advance wave counter, reduce speed, reset grid, resume play
001375  1               ;   Keeps: player X, lives, score, shields.
001375  1               ;   Clears: bullets, invaders, explosion, UFO.
001375  1               ;******************************************************************
001375  1               next_wave:
001375  1  E6 rr           inc wave
001377  1               
001377  1                  ; new wave_init_speed = max(current - WAVE_SPEED_STEP, INV_MOVE_SPEED_MIN)
001377  1  A5 rr           lda wave_init_speed
001379  1  38              sec
00137A  1  E9 05           sbc #WAVE_SPEED_STEP
00137C  1  C9 05           cmp #INV_MOVE_SPEED_MIN
00137E  1  B0 02           bcs @speed_ok
001380  1  A9 05           lda #INV_MOVE_SPEED_MIN
001382  1               @speed_ok:
001382  1  85 rr           sta wave_init_speed
001384  1               
001384  1                  ; deactivate player bullet
001384  1  64 rr           stz bullet_active
001386  1  20 47 0E        jsr update_bullet_sprite
001389  1               
001389  1                  ; reset explosion
001389  1  64 rr           stz exp_timer
00138B  1  9C 25 9F        stz VERA_ctrl
00138E  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1
001392  1  9F A9 FC 8D  
001396  1  21 9F A9 26  
00139D  1  A9 00           lda #$00
00139F  1  8D 23 9F        sta VERA_data0
0013A2  1               
0013A2  1                  ; deactivate invader bullets
0013A2  1  64 rr           stz ibul_active+0
0013A4  1  64 rr           stz ibul_active+1
0013A6  1  64 rr           stz ibul_active+2
0013A8  1  A2 00           ldx #0
0013AA  1               @nw_ibul:
0013AA  1  20 38 10        jsr update_inv_bullet_sprite
0013AD  1  E8              inx
0013AE  1  E0 03           cpx #3
0013B0  1  D0 F8           bne @nw_ibul
0013B2  1  A9 5A           lda #INV_FIRE_TIMER_INIT
0013B4  1  85 rr           sta inv_fire_timer
0013B6  1               
0013B6  1                  ; reset UFO timer (UFO already inactive from wave_clear_screen)
0013B6  1  A9 58           lda #<UFO_TIMER_INIT
0013B8  1  85 rr           sta ufo_timer_lo
0013BA  1  A9 02           lda #>UFO_TIMER_INIT
0013BC  1  85 rr           sta ufo_timer_hi
0013BE  1               
