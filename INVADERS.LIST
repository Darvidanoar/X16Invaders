0011A0  1  A9 01           lda #>PLAYER_Y
0011A2  1  85 rr           sta zp_row_y_hi
0011A4  1  20 B9 0F        jsr start_explosion
0011A7  1               
0011A7  1                  ; decrement lives
0011A7  1  C6 rr           dec lives
0011A9  1  F0 0D           beq @game_over            ; lives hit 0 → end game (Phase 6 will handle this properly)
0011AB  1               
0011AB  1                  ; grant invincibility and re-centre the ship
0011AB  1  A9 78           lda #INV_HIT_FRAMES
0011AD  1  85 rr           sta inv_hit_timer
0011AF  1  A9 38           lda #<PLAYER_X_INIT
0011B1  1  85 rr           sta player_x_lo
0011B3  1  A9 01           lda #>PLAYER_X_INIT
0011B5  1  85 rr           sta player_x_hi
0011B7  1  60              rts
