001505  1  8D 20 9F        sta VERA_addr_low
001508  1  A9 18           lda #$18               ; byte 0: data addr[12:5]
00150A  1  8D 23 9F        sta VERA_data0
00150D  1  A9 00           lda #$00               ; byte 1: 4bpp, addr[16:13]=0
00150F  1  8D 23 9F        sta VERA_data0
001512  1  A9 60           lda #96                ; byte 2: X lo
001514  1  8D 23 9F        sta VERA_data0
001517  1  A9 00           lda #0                 ; byte 3: X hi
001519  1  8D 23 9F        sta VERA_data0
00151C  1  A9 70           lda #112               ; byte 4: Y lo (row 7: 7*16=112)
00151E  1  8D 23 9F        sta VERA_data0
001521  1  A9 00           lda #0                 ; byte 5: Y hi
001523  1  8D 23 9F        sta VERA_data0
001526  1  A9 0C           lda #SPR_Z_FRONT       ; byte 6: z-depth=3
001528  1  8D 23 9F        sta VERA_data0
00152B  1  A9 50           lda #SPR_16x16_PAL0    ; byte 7: 16x16, palette 0
00152D  1  8D 23 9F        sta VERA_data0
