001199  1               ;******************************************************************
001199  1               ; game_over_screen — update hi-score, draw GAME OVER, wait for input
001199  1               ;   SPACE     → restart_game (full state reset + main_loop)
001199  1               ;   RUN/STOP  → exit to BASIC
001199  1               ;
001199  1               ;   Layout (40-col text):
001199  1               ;     Row  9, col 15: "GAME OVER"
001199  1               ;     Row 11, col 13: "SCORE: " + 6 BCD digits
001199  1               ;     Row 12, col 12: "HI-SCORE: " + 6 BCD digits
001199  1               ;     Row 15, col 11: "SPACE = PLAY AGAIN"  (blinks)
001199  1               ;     Row 17, col 12: "RUN/STOP TO QUIT"
001199  1               ;******************************************************************
001199  1               game_over_screen:
001199  1  20 71 1A        jsr snd_stop_ufo_drone    ; silence drone if UFO was active
00119C  1  20 15 1B        jsr snd_stop_march        ; silence march beat
00119F  1               
00119F  1  20 6E 12        jsr update_hi_score       ; copy score → hi_score if score is higher
0011A2  1               
0011A2  1  20 69 15        jsr hide_all_inv_sprites  ; clear play field sprites
0011A5  1               
0011A5  1  A9 93           lda #PETSCII_CLR
0011A7  1  20 D2 FF        jsr CHROUT
0011AA  1               
0011AA  1                  ; (Plot: Set X to Row, Set Y to Col)
0011AA  1  A2 09           ldx #9
0011AC  1  A0 23           ldy #35
0011AE  1  18              clc
0011AF  1  20 F0 FF        jsr PLOT
0011B2  1  A2 00           ldx #0
0011B4  1  BD 17 1C     @go1: lda str_game_over, x
0011B7  1  F0 06           beq @go1d
0011B9  1  20 D2 FF        jsr CHROUT
0011BC  1  E8              inx
0011BD  1  80 F5           bra @go1
0011BF  1               @go1d:
0011BF  1               
0011BF  1                  ; (Plot: Set X to Row, Set Y to Col)
0011BF  1  A2 0B           ldx #11
0011C1  1  A0 21           ldy #33
0011C3  1  18              clc
0011C4  1  20 F0 FF        jsr PLOT
0011C7  1  A2 00           ldx #0
0011C9  1  BD 21 1C     @go2: lda str_score_lbl, x
0011CC  1  F0 06           beq @go2d
0011CE  1  20 D2 FF        jsr CHROUT
0011D1  1  E8              inx
0011D2  1  80 F5           bra @go2
0011D4  1               @go2d:
0011D4  1  A5 rr           lda score_hi
0011D6  1  20 9C 1B        jsr print_hex_byte
0011D9  1  A5 rr           lda score_mid
0011DB  1  20 9C 1B        jsr print_hex_byte
0011DE  1  A5 rr           lda score_lo
0011E0  1  20 9C 1B        jsr print_hex_byte
0011E3  1               
0011E3  1                  ; (Plot: Set X to Row, Set Y to Col)
0011E3  1  A2 0C           ldx #12
0011E5  1  A0 20           ldy #32
0011E7  1  18              clc
0011E8  1  20 F0 FF        jsr PLOT
0011EB  1  A2 00           ldx #0
0011ED  1  BD 29 1C     @go3: lda str_hi_score_go, x
0011F0  1  F0 06           beq @go3d
0011F2  1  20 D2 FF        jsr CHROUT
0011F5  1  E8              inx
0011F6  1  80 F5           bra @go3
0011F8  1               @go3d:
0011F8  1  A5 rr           lda hi_score_hi
0011FA  1  20 9C 1B        jsr print_hex_byte
0011FD  1  A5 rr           lda hi_score_mid
0011FF  1  20 9C 1B        jsr print_hex_byte
001202  1  A5 rr           lda hi_score_lo
001204  1  20 9C 1B        jsr print_hex_byte
001207  1               
001207  1                  ; (Plot: Set X to Row, Set Y to Col)
001207  1  A2 11           ldx #17
001209  1  A0 20           ldy #32
00120B  1  18              clc
00120C  1  20 F0 FF        jsr PLOT
00120F  1  A2 00           ldx #0
001211  1  BD 70 1C     @go4: lda str_run_stop_hint, x
001214  1  F0 06           beq @go4d
001216  1  20 D2 FF        jsr CHROUT
001219  1  E8              inx
00121A  1  80 F5           bra @go4
