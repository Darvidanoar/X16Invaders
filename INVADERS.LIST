0015ED  1               ;******************************************************************
0015ED  1               ; hide_all_inv_sprites — set z-depth=0 for all 55 invader sprites
0015ED  1               ;   Uses VERA stride=8 to write only byte 6 (z-depth) of each block.
0015ED  1               ;   First invader sprite byte 6: $1FC00 + 11*8 + 6 = $1FC5E
0015ED  1               ;******************************************************************
0015ED  1               hide_all_inv_sprites:
0015ED  1  9C 25 9F        stz VERA_ctrl
0015F0  1  A9 41           lda #$41               ; stride=8 (code $4 in high nibble), bank=1
0015F2  1  8D 22 9F        sta VERA_addr_bank
0015F5  1  A9 FC           lda #$FC
0015F7  1  8D 21 9F        sta VERA_addr_high
0015FA  1  A9 5E           lda #$5E               ; low byte of $1FC5E  ($1FC58+6)
0015FC  1  8D 20 9F        sta VERA_addr_low
0015FF  1  A9 00           lda #0                 ; z-depth=0 → disabled
001601  1  A2 37           ldx #55
001603  1               @loop:
001603  1  8D 23 9F        sta VERA_data0         ; writes byte 6; addr auto-advances by 8
001606  1  CA              dex
001607  1  D0 FA           bne @loop
001609  1  60              rts
00160A  1               
00160A  1               ;******************************************************************
00160A  1               ; hide_all_sprites — set z-depth=0 for all 128 VERA sprite slots.
00160A  1               ;   Writes 0 to byte 6 of every slot starting at $1FC06, stride=8.
00160A  1               ;   Call before returning to BASIC so no sprites linger on screen.
00160A  1               ;******************************************************************
00160A  1               hide_all_sprites:
00160A  1  9C 25 9F        stz VERA_ctrl
00160D  1  A9 41           lda #$41               ; stride=8, bank=1
00160F  1  8D 22 9F        sta VERA_addr_bank
001612  1  A9 FC           lda #$FC
001614  1  8D 21 9F        sta VERA_addr_high
001617  1  A9 06           lda #$06               ; byte 6 of sprite 0 ($1FC06)
001619  1  8D 20 9F        sta VERA_addr_low
00161C  1  A9 00           lda #0                 ; z-depth=0 → disabled
00161E  1  A2 80           ldx #128
001620  1               @loop:
001620  1  8D 23 9F        sta VERA_data0         ; writes byte 6; addr auto-advances by 8
001623  1  CA              dex
001624  1  D0 FA           bne @loop
001626  1  60              rts
