0012C3  1  D0 F8           bne @rst_ibul
0012C5  1  A9 5A           lda #INV_FIRE_TIMER_INIT
0012C7  1  85 rr           sta inv_fire_timer
0012C9  1               
0012C9  1                  ; reset UFO state and silence drone
0012C9  1  64 rr           stz ufo_active
