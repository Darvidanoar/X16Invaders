000810  1               ;******************************************************************
000810  1               ; Constants
000810  1               ;******************************************************************
000810  1               
000810  1               ; VERA display control
000810  1               VERA_SPRITE_EN  = %01000000      ; VERA_dc_video bit 6: enable sprites
000810  1               
000810  1               ; PETSCII control codes
000810  1               PETSCII_WHITE   = $05            ; set text color to white
000810  1               PETSCII_CLR     = $93            ; clear screen and home cursor
000810  1               PETSCII_HOME    = $13            ; home cursor (no clear)
000810  1               PETSCII_RETURN  = $0D            ; carriage return
000810  1               
000810  1               ; SCREEN_SET_CHARSET font numbers (call address $FF62)
000810  1               CHARSET_UPPER   = 1              ; Commodore upper/graphics: $41-$5A = A-Z
000810  1               CHARSET_LOWER   = 2              ; Commodore lower/upper:    $41-$5A = a-z (lowercase)
000810  1               
000810  1               ; Key codes (PETSCII)
000810  1               KEY_RUN_STOP    = $03            ; RUN/STOP — exit game
000810  1               
000810  1               ; Input flag bits (key_flags)
000810  1               KEY_LEFT        = %00000001
000810  1               KEY_RIGHT       = %00000010
000810  1               KEY_FIRE        = %00000100
000810  1               
000810  1               ; JOYSTICK_GET .A return: {B,Y,Sel,Sta,Up,Dn,Left,Right} active low
000810  1               JOY_RIGHT       = %00000001     ; bit 0
000810  1               JOY_LEFT        = %00000010     ; bit 1
000810  1               
000810  1               ; Player ship — all positions in VERA 640x480 coordinate space
000810  1               PLAYER_Y        = 420            ; fixed Y, near bottom (479 = bottom edge)
000810  1               PLAYER_X_INIT   = 312            ; starting X, centred  ((640-16)/2)
000810  1               PLAYER_X_MIN    = 8              ; left  boundary (sprite left edge)
000810  1               PLAYER_X_MAX    = 616            ; right boundary (640 - 16px sprite - 8px margin)
000810  1               PLAYER_SPEED    = 4              ; pixels per frame
000810  1               
000810  1               ; Sprite attribute encoding helpers
000810  1               SPRITE1_ATTR    = $1FC08 ; sprite 1 attribute base ($1FC00=sprite 0, reserved for KERNAL mouse)
000810  1               SPR_Z_FRONT     = %00001100     ; byte 6: z-depth = %11 in bits 3-2 (in front of all layers)
000810  1               SPR_16x16_PAL0  = %01010000     ; byte 7: width=1(16px), height=1(16px), palette_off=0
000810  1               SPR_8x8_PAL0    = %00000000     ; byte 7: width=0(8px),  height=0(8px),  palette_off=0
000810  1               
000810  1               ; Explosion sprite (slot 4)
000810  1               VRAM_EXPLOSION     = $00440     ; explosion pixel data (128 bytes, 16x16 4bpp)
000810  1               EXPLODE_SPRITE_ATTR = $1FC20    ; sprite 4 attribute base (explosion)
000810  1               EXPLODE_FRAMES     = 30         ; display duration in frames (~0.5 sec at 60 Hz)
000810  1               
000810  1               ; Invader bullets (sprite slots 5-7)
000810  1               VRAM_INV_BULLET    = $00420     ; invader bullet pixel data (32 bytes, 8x8 4bpp)
000810  1               INV_BULLET_SPR_BASE = $1FC28    ; sprite 5 attribute base (first invader bullet)
000810  1               INV_BULLET_SPEED   = 6          ; VERA pixels per frame downward (=3 game pixels)
000810  1               INV_FIRE_TIMER_MIN = 10         ; minimum frames between fire attempts
000810  1               INV_FIRE_TIMER_INIT = 90        ; frames before first shot
000810  1               
000810  1               ; Player lives
000810  1               LIVES_INIT         = 3          ; starting lives
000810  1               INV_HIT_FRAMES     = 120        ; invincibility duration after being hit (2 sec at 60 Hz)
000810  1               
000810  1               ; Player bullet
000810  1               BULLET_SPRITE_ATTR = $1FC10     ; sprite 2 attribute base (player bullet)
000810  1               VRAM_BULLET     = $00400        ; player bullet pixel data (32 bytes, 8x8 4bpp)
000810  1               BULLET_SPEED    = 12            ; VERA pixels per frame upward (= 6 game pixels)
000810  1               BULLET_Y_INIT   = PLAYER_Y - 8 ; bullet starts just above player ship top
000810  1               
000810  1               ; Invader grid geometry (VERA 640x480 coordinate space)
000810  1               INV_GRID_X_INIT   = 112         ; left-column X at start (centered: (640 - 10*40 - 16) / 2 = 112)
000810  1               INV_GRID_Y_BASE   = 80          ; top-row Y, fixed base (drops added via inv_offset_y)
000810  1               INV_SPACING_X     = 40          ; VERA pixels between invader column origins
000810  1               INV_SPACING_Y     = 48          ; VERA pixels between invader row origins
000810  1               INV_STEP_X        = 4           ; VERA pixels per march step
000810  1               INV_DROP_Y        = 16          ; VERA pixels per grid drop
000810  1               INV_MOVE_SPEED_INIT = 50        ; frames between march steps (initial)
000810  1               INV_COUNT_INIT    = 55
000810  1               INV_MOVE_SPEED_MIN = 5           ; minimum frames per march step
000810  1               
000810  1               ; Grid boundary: when grid_x reaches these values, reverse and drop
000810  1               ; Rightmost invader base X = grid_x + 10*INV_SPACING_X (=400). Right wall = 624 (640-16px).
000810  1               ; So right limit = 624 - 400 - 16 = 208
000810  1               INV_X_RIGHT_LIM   = 208
000810  1               INV_X_LEFT_LIM    = 16          ; leftmost sprite at x=grid_x must stay >= 16
000810  1               
000810  1               ; VRAM addresses for invader sprite pixel data (128 bytes each, 16x16 4bpp)
000810  1               VRAM_INV_A_F0   = $00100        ; Type A (crab,   bottom rows 3-4), frame 0
000810  1               VRAM_INV_A_F1   = $00180        ; Type A frame 1
000810  1               VRAM_INV_B_F0   = $00200        ; Type B (octopus, middle rows 1-2), frame 0
000810  1               VRAM_INV_B_F1   = $00280        ; Type B frame 1
000810  1               VRAM_INV_C_F0   = $00300        ; Type C (squid,   top row 0), frame 0
000810  1               VRAM_INV_C_F1   = $00380        ; Type C frame 1
000810  1               
000810  1               ; Sprite addr[12:5] byte values for each type/frame (= VRAM_addr >> 5)
000810  1               ;   VRAM $00100>>5=$08  $00180>>5=$0C  $00200>>5=$10  $00280>>5=$14  $00300>>5=$18  $00380>>5=$1C
000810  1               INV_ATTR_BASE   = $1FC58        ; sprite slot 11 = first invader ($1FC00 + 11*8)
000810  1               INV_SPRITE_SLOT = 11            ; first invader sprite slot index
000810  1               
000810  1               ;******************************************************************
000810  1               ; start — main program entry point
000810  1               ;******************************************************************
000810  1               start:
000810  1  78              sei                           ; disable interrupts during init
000811  1               
000811  1                  ; Switch to 40-column text mode (mode 0)
000811  1                  ; Carry clear = SET mode (carry set = READ mode)
000811  1  18              clc
000812  1  A9 00           lda #$00
000814  1  20 5F FF        jsr SCREEN_MODE
000817  1               
000817  1                  ; Seed PRNG with hardware entropy
000817  1  20 CF FE        jsr ENTROPY_GET
00081A  1  85 rr           sta rand_seed_lo
00081C  1  86 rr           stx rand_seed_hi
00081E  1               
00081E  1                  ; Enable sprites in VERA display controller
00081E  1  9C 25 9F        stz VERA_ctrl                 ; DCSEL=0, ADDRSEL=0
000821  1  AD 29 9F        lda VERA_dc_video
000824  1  09 40           ora #VERA_SPRITE_EN
000826  1  8D 29 9F        sta VERA_dc_video
000829  1               
000829  1               
000829  1                  ; Clear game variables
000829  1  64 rr           stz key_last
00082B  1  64 rr           stz key_flags
00082D  1  64 rr           stz frame_count
00082F  1  64 rr           stz bullet_active
000831  1  64 rr           stz score_lo
000833  1  64 rr           stz score_mid
000835  1  64 rr           stz score_hi
000837  1               
000837  1                  ; Set initial player position before sprite init reads it
000837  1  20 F3 08        jsr init_player
00083A  1               
00083A  1  58              cli                           ; re-enable interrupts
00083B  1               
00083B  1                  ; Switch to Commodore uppercase/graphics charset: $41-$5A = A-Z
00083B  1                  ; Must be called AFTER SCREEN_MODE (which resets to lowercase by default)
00083B  1  A9 01           lda #CHARSET_UPPER
00083D  1  20 62 FF        jsr SCREEN_SET_CHARSET
000840  1               
000840  1                  ; Clear screen and set text color
000840  1  A9 05           lda #PETSCII_WHITE
000842  1  20 D2 FF        jsr CHROUT
000845  1  A9 93           lda #PETSCII_CLR
000847  1  20 D2 FF        jsr CHROUT
00084A  1               
00084A  1                  ; Upload sprite pixel data and configure sprite 1 attributes
00084A  1  20 02 09        jsr init_sprites
00084D  1               
00084D  1                  ; Upload invader sprite data, set palette, init grid state, place sprites
00084D  1  20 A6 0A        jsr init_invaders
000850  1               
000850  1  20 AA 10        jsr draw_title_screen
000853  1               
000853  1               ;******************************************************************
000853  1               ; main_loop — one iteration per video frame (60 Hz)
000853  1               ;******************************************************************
000853  1               main_loop:
000853  1  20 A6 08        jsr wait_vsync
000856  1               
000856  1  E6 rr           inc frame_count
000858  1               
000858  1  20 A8 08        jsr update_input              ; fills key_flags (joystick) + key_last (GETIN)
00085B  1               
00085B  1  A5 rr           lda key_last
00085D  1  C9 03           cmp #KEY_RUN_STOP
00085F  1  F0 3D           beq exit_game
000861  1               
000861  1                  ; --- invincibility timer ---
000861  1  A5 rr           lda inv_hit_timer
000863  1  F0 02           beq @no_inv_dec
000865  1  C6 rr           dec inv_hit_timer
000867  1               @no_inv_dec:
000867  1               
000867  1  20 90 0C        jsr move_player               ; apply movement, clamp to boundaries
00086A  1  20 DF 0C        jsr update_player_sprite      ; write new X to VERA sprite 1
00086D  1               
00086D  1                  ; --- fire player bullet (SPACE pressed and bullet not already active) ---
00086D  1  A5 rr           lda key_flags
00086F  1  29 04           and #KEY_FIRE
000871  1  F0 07           beq @skip_fire
000873  1  A5 rr           lda bullet_active
000875  1  D0 03           bne @skip_fire
000877  1  20 22 0D        jsr fire_bullet
00087A  1               @skip_fire:
00087A  1               
00087A  1                  ; --- move bullet if active ---
00087A  1  A5 rr           lda bullet_active
00087C  1  F0 03           beq @skip_bullet_move
00087E  1  20 3F 0D        jsr move_bullet
000881  1               @skip_bullet_move:
000881  1               
000881  1                  ; --- check player bullet vs invader collision ---
000881  1  20 90 0D        jsr check_bullet_invader
000884  1               
000884  1                  ; --- explosion timer ---
000884  1  20 DF 0E        jsr update_explosion
000887  1               
000887  1                  ; --- invader bullets: move, spawn, boundary check ---
000887  1  20 0E 0F        jsr update_inv_bullets
00088A  1               
00088A  1                  ; --- invader bullet vs player collision ---
00088A  1  20 1C 10        jsr check_inv_bullet_player
00088D  1               
00088D  1                  ; --- Invader march timer ---
00088D  1  C6 rr           dec inv_move_timer
00088F  1  D0 07           bne @skip_inv_step
000891  1  20 75 0B        jsr step_invaders             ; move grid, check bounds, update sprites
000894  1  A5 rr           lda inv_move_speed
000896  1  85 rr           sta inv_move_timer
000898  1               @skip_inv_step:
000898  1               
000898  1  20 29 11        jsr update_hud                ; refresh text readouts
00089B  1               
00089B  1  4C 53 08        jmp main_loop
00089E  1               
00089E  1               ;------------------------------------------------------------------
00089E  1               exit_game:
00089E  1  A9 93           lda #PETSCII_CLR
0008A0  1  20 D2 FF        jsr CHROUT
0008A3  1  4C 47 FF        jmp ENTER_BASIC
0008A6  1               
0008A6  1               ;******************************************************************
0008A6  1               ; wait_vsync — busy-poll VERA_isr until VSYNC, then clear flag
0008A6  1               ;******************************************************************
0008A6  1               wait_vsync:
0008A6  1                  ; WAI sleeps the CPU until any IRQ fires.  The KERNAL's VSYNC IRQ
0008A6  1                  ; handler (60 Hz) wakes us up and has already cleared VERA_isr bit 0
0008A6  1                  ; by the time execution returns here, so polling VERA_isr would loop
0008A6  1                  ; forever.  Just return — one WAI ≈ one frame.
0008A6  1  CB              wai
0008A7  1  60              rts
0008A8  1               
0008A8  1               ;******************************************************************
0008A8  1               ; update_input — joystick + GETIN keyboard input each frame
0008A8  1               ;
0008A8  1               ;   key_flags bits set this frame:
0008A8  1               ;     KEY_LEFT  — left arrow held
0008A8  1               ;     KEY_RIGHT — right arrow held
0008A8  1               ;     KEY_FIRE  — space bar pressed
0008A8  1               ;   key_last   — raw PETSCII from GETIN (RUN/STOP etc.)
0008A8  1               ;
0008A8  1               ;   JOYSTICK_GET(0) = keyboard-as-joystick; gives smooth held-key
0008A8  1               ;   movement with no repeat delay.  GETIN handles space and RUN/STOP.
0008A8  1               ;******************************************************************
0008A8  1               update_input:
0008A8  1  64 rr           stz key_flags
0008AA  1  64 rr           stz key_last
0008AC  1               
0008AC  1                  ; --- joystick 0 = keyboard d-pad (active low: 0 = pressed) ---
0008AC  1                  ; Byte returned: {B,Y,Sel,Sta,Up,Dn,Left,Right} bits 7–0
0008AC  1  A9 00           lda #0
0008AE  1  20 56 FF        jsr JOYSTICK_GET
0008B1  1  48              pha                           ; save — AND destroys .A
0008B2  1               
0008B2  1  29 01           and #JOY_RIGHT                ; bit 0: right arrow
0008B4  1  D0 06           bne @not_right
0008B6  1  A5 rr           lda key_flags
0008B8  1  09 02           ora #KEY_RIGHT
0008BA  1  85 rr           sta key_flags
0008BC  1               @not_right:
0008BC  1  68              pla
0008BD  1  29 02           and #JOY_LEFT                 ; bit 1: left arrow
0008BF  1  D0 06           bne @not_left
0008C1  1  A5 rr           lda key_flags
0008C3  1  09 01           ora #KEY_LEFT
0008C5  1  85 rr           sta key_flags
0008C7  1               @not_left:
0008C7  1               
0008C7  1                  ; --- GETIN — discrete events: fire, RUN/STOP, arrow fallback ---
0008C7  1               @getin_drain:
0008C7  1  20 E4 FF        jsr GETIN
0008CA  1  F0 26           beq @getin_done               ; buffer empty
0008CC  1  85 rr           sta key_last
0008CE  1  C9 9D           cmp #$9D                      ; cursor left (PETSCII)
0008D0  1  D0 08           bne @chk_right_getin
0008D2  1  A5 rr           lda key_flags
0008D4  1  09 01           ora #KEY_LEFT
0008D6  1  85 rr           sta key_flags
0008D8  1  80 ED           bra @getin_drain
0008DA  1               @chk_right_getin:
0008DA  1  C9 1D           cmp #$1D                      ; cursor right (PETSCII)
0008DC  1  D0 08           bne @chk_fire_getin
0008DE  1  A5 rr           lda key_flags
0008E0  1  09 02           ora #KEY_RIGHT
0008E2  1  85 rr           sta key_flags
0008E4  1  80 E1           bra @getin_drain
0008E6  1               @chk_fire_getin:
0008E6  1  C9 20           cmp #$20                      ; space = fire
0008E8  1  D0 DD           bne @getin_drain
0008EA  1  A5 rr           lda key_flags
0008EC  1  09 04           ora #KEY_FIRE
0008EE  1  85 rr           sta key_flags
0008F0  1  80 D5           bra @getin_drain
0008F2  1               @getin_done:
0008F2  1  60              rts
0008F3  1               
0008F3  1               ;******************************************************************
0008F3  1               ; init_player — set player_x to starting position
0008F3  1               ;******************************************************************
0008F3  1               init_player:
0008F3  1  A9 38           lda #<PLAYER_X_INIT
0008F5  1  85 rr           sta player_x_lo
0008F7  1  A9 01           lda #>PLAYER_X_INIT
0008F9  1  85 rr           sta player_x_hi
0008FB  1  A9 03           lda #LIVES_INIT
0008FD  1  85 rr           sta lives
0008FF  1  64 rr           stz inv_hit_timer
000901  1  60              rts
000902  1               
000902  1               ;******************************************************************
000902  1               ; init_sprites — upload pixel data + write sprite 1 attributes
000902  1               ;
000902  1               ;   Sprite 0 ($1FC00) is reserved by the KERNAL mouse cursor —
000902  1               ;   we disable it and keep clear of $1FC00.
000902  1               ;
000902  1               ;   Sprite 1 ($1FC08) = player ship
000902  1               ;   Pixel data at VRAM $00080 (128 bytes, 16x16 4bpp)
000902  1               ;   Address encoding:  addr[12:5] = $00080>>5 = $04  → byte 0 = $04
000902  1               ;                      4bpp, addr[16:13] = 0          → byte 1 = $00
000902  1               ;******************************************************************
000902  1               init_sprites:
000902  1  9C 25 9F        stz VERA_ctrl
000905  1               
000905  1                  ; --- set palette entries 1-4 ---
000905  1                  ; VERA palette entry N is 2 bytes at VRAM_palette + N*2
000905  1                  ; Byte 0: [7:4]=Green [3:0]=Blue   Byte 1: [3:0]=Red (bits 7-4 unused)
000905  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_palette + 2), 1   ; entry 1 (player white); stride=1 auto-advances
000909  1  9F A9 FA 8D  
00090D  1  21 9F A9 02  
000914  1  A9 FF           lda #$FF                               ; G=$F, B=$F
000916  1  8D 23 9F        sta VERA_data0
000919  1  A9 0F           lda #$0F                               ; R=$F  → white
00091B  1  8D 23 9F        sta VERA_data0
00091E  1                  ; entry 2 = cyan  (R=0, G=$F, B=$F)
00091E  1  A9 FF           lda #$FF                               ; G=$F, B=$F
000920  1  8D 23 9F        sta VERA_data0
000923  1  A9 00           lda #$00                               ; R=$0
000925  1  8D 23 9F        sta VERA_data0
000928  1                  ; entry 3 = magenta (R=$F, G=0, B=$F)
000928  1  A9 0F           lda #$0F                               ; G=$0, B=$F
00092A  1  8D 23 9F        sta VERA_data0
00092D  1  A9 0F           lda #$0F                               ; R=$F
00092F  1  8D 23 9F        sta VERA_data0
000932  1                  ; entry 4 = green  (R=0, G=$F, B=0)
000932  1  A9 F0           lda #$F0                               ; G=$F, B=$0
000934  1  8D 23 9F        sta VERA_data0
000937  1  A9 00           lda #$00                               ; R=$0
000939  1  8D 23 9F        sta VERA_data0
00093C  1                  ; --- disable sprite 0 (KERNAL mouse cursor) ---
00093C  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_sprattr + 6), 1   ; sprite 0 byte 6 = z-depth
000940  1  9F A9 FC 8D  
000944  1  21 9F A9 06  
00094B  1  A9 00           lda #$00                               ; z-depth=0 → disabled
00094D  1  8D 23 9F        sta VERA_data0
000950  1               
000950  1                  ; --- upload player sprite pixel data to VRAM $00080 ---
000950  1  A9 10 8D 22     VERA_SET_ADDR $00080, 1
000954  1  9F A9 00 8D  
000958  1  21 9F A9 80  
00095F  1  A2 00           ldx #0
000961  1               @upload:
000961  1  BD 19 12        lda player_spr_data,x
000964  1  8D 23 9F        sta VERA_data0
000967  1  E8              inx
000968  1  E0 80           cpx #128
00096A  1  D0 F5           bne @upload
00096C  1               
00096C  1                  ; --- write sprite 1 attribute bytes ---
00096C  1  A9 11 8D 22     VERA_SET_ADDR SPRITE1_ATTR, 1
000970  1  9F A9 FC 8D  
000974  1  21 9F A9 08  
00097B  1  A9 04           lda #$04
00097D  1  8D 23 9F        sta VERA_data0               ; byte 0: addr[12:5] = $00080>>5 = $04
000980  1  A9 00           lda #$00
000982  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, addr[16:13] = 0
000985  1  A5 rr           lda player_x_lo
000987  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
00098A  1  A5 rr           lda player_x_hi
00098C  1  29 03           and #$03
00098E  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000991  1  A9 A4           lda #<PLAYER_Y
000993  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000996  1  A9 01           lda #>PLAYER_Y
000998  1  29 03           and #$03
00099A  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
00099D  1  A9 0C           lda #SPR_Z_FRONT
00099F  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3, no collision, no flip
0009A2  1  A9 50           lda #SPR_16x16_PAL0
0009A4  1  8D 23 9F        sta VERA_data0               ; byte 7: palette 0, 16x16
0009A7  1               
0009A7  1                  ; --- upload player bullet pixel data to VRAM $00400 ---
0009A7  1  A9 10 8D 22     VERA_SET_ADDR VRAM_BULLET, 1
0009AB  1  9F A9 04 8D  
0009AF  1  21 9F A9 00  
0009B6  1  A2 00           ldx #0
0009B8  1               @up_bullet:
0009B8  1  BD 99 12        lda bullet_spr_data,x
0009BB  1  8D 23 9F        sta VERA_data0
0009BE  1  E8              inx
0009BF  1  E0 20           cpx #32
0009C1  1  D0 F5           bne @up_bullet
0009C3  1               
0009C3  1                  ; --- write sprite 2 attributes (initially disabled, z-depth=0) ---
0009C3  1  A9 11 8D 22     VERA_SET_ADDR BULLET_SPRITE_ATTR, 1
0009C7  1  9F A9 FC 8D  
0009CB  1  21 9F A9 10  
0009D2  1  A9 20           lda #$20                     ; byte 0: addr[12:5] = $00400>>5 = $20
0009D4  1  8D 23 9F        sta VERA_data0
0009D7  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
0009D9  1  8D 23 9F        sta VERA_data0
0009DC  1  A9 00           lda #$00                     ; byte 2: X lo (arbitrary; sprite disabled)
0009DE  1  8D 23 9F        sta VERA_data0
0009E1  1  A9 00           lda #$00                     ; byte 3: X hi
0009E3  1  8D 23 9F        sta VERA_data0
0009E6  1  A9 00           lda #$00                     ; byte 4: Y lo
0009E8  1  8D 23 9F        sta VERA_data0
0009EB  1  A9 00           lda #$00                     ; byte 5: Y hi
0009ED  1  8D 23 9F        sta VERA_data0
0009F0  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
0009F2  1  8D 23 9F        sta VERA_data0
0009F5  1  A9 00           lda #SPR_8x8_PAL0            ; byte 7: 8x8, palette 0
0009F7  1  8D 23 9F        sta VERA_data0
0009FA  1               
0009FA  1                  ; --- upload explosion pixel data to VRAM $00440 ---
0009FA  1  A9 10 8D 22     VERA_SET_ADDR VRAM_EXPLOSION, 1
0009FE  1  9F A9 04 8D  
000A02  1  21 9F A9 40  
000A09  1  A2 00           ldx #0
000A0B  1               @up_exp:
000A0B  1  BD 4B 13        lda explosion_pixels,x
000A0E  1  8D 23 9F        sta VERA_data0
000A11  1  E8              inx
000A12  1  E0 80           cpx #128
000A14  1  D0 F5           bne @up_exp
000A16  1               
000A16  1                  ; --- write sprite 4 attributes (initially disabled) ---
000A16  1                  ; addr[12:5] = VRAM_EXPLOSION>>5 = $00440>>5 = $22
000A16  1  A9 11 8D 22     VERA_SET_ADDR EXPLODE_SPRITE_ATTR, 1
000A1A  1  9F A9 FC 8D  
000A1E  1  21 9F A9 20  
000A25  1  A9 22           lda #$22                     ; byte 0: addr[12:5]
000A27  1  8D 23 9F        sta VERA_data0
000A2A  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000A2C  1  8D 23 9F        sta VERA_data0
000A2F  1  A9 00           lda #$00                     ; byte 2: X lo (placeholder)
000A31  1  8D 23 9F        sta VERA_data0
000A34  1  A9 00           lda #$00                     ; byte 3: X hi
000A36  1  8D 23 9F        sta VERA_data0
000A39  1  A9 00           lda #$00                     ; byte 4: Y lo (placeholder)
000A3B  1  8D 23 9F        sta VERA_data0
000A3E  1  A9 00           lda #$00                     ; byte 5: Y hi
000A40  1  8D 23 9F        sta VERA_data0
000A43  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000A45  1  8D 23 9F        sta VERA_data0
000A48  1  A9 50           lda #SPR_16x16_PAL0          ; byte 7: 16x16, palette 0
000A4A  1  8D 23 9F        sta VERA_data0
000A4D  1               
000A4D  1  64 rr           stz exp_timer
000A4F  1               
000A4F  1                  ; --- upload invader bullet pixel data to VRAM $00420 ---
000A4F  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_BULLET, 1
000A53  1  9F A9 04 8D  
000A57  1  21 9F A9 20  
000A5E  1  A2 00           ldx #0
000A60  1               @up_ibul:
000A60  1  BD 2B 13        lda inv_bullet_spr_data,x
000A63  1  8D 23 9F        sta VERA_data0
000A66  1  E8              inx
000A67  1  E0 20           cpx #32
000A69  1  D0 F5           bne @up_ibul
000A6B  1               
000A6B  1                  ; --- init 3 invader bullet sprites (slots 5-7, base $1FC28), all disabled ---
000A6B  1                  ; addr[12:5] = VRAM_INV_BULLET>>5 = $00420>>5 = $21
000A6B  1  A9 11 8D 22     VERA_SET_ADDR INV_BULLET_SPR_BASE, 1
000A6F  1  9F A9 FC 8D  
000A73  1  21 9F A9 28  
000A7A  1  A2 03           ldx #3                       ; 3 sprites
000A7C  1               @init_ibspr:
000A7C  1  A9 21           lda #$21                     ; byte 0: addr[12:5] = $21
000A7E  1  8D 23 9F        sta VERA_data0
000A81  1  A9 00           lda #$00
000A83  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, bank 0
000A86  1  8D 23 9F        sta VERA_data0               ; byte 2: X lo
000A89  1  8D 23 9F        sta VERA_data0               ; byte 3: X hi
000A8C  1  8D 23 9F        sta VERA_data0               ; byte 4: Y lo
000A8F  1  8D 23 9F        sta VERA_data0               ; byte 5: Y hi
000A92  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=0 → disabled
000A95  1  8D 23 9F        sta VERA_data0               ; byte 7: 8x8, palette 0
000A98  1  CA              dex
000A99  1  D0 E1           bne @init_ibspr
000A9B  1               
000A9B  1                  ; --- clear invader bullet state ---
000A9B  1  64 rr           stz ibul_active+0
000A9D  1  64 rr           stz ibul_active+1
000A9F  1  64 rr           stz ibul_active+2
000AA1  1  A9 5A           lda #INV_FIRE_TIMER_INIT
000AA3  1  85 rr           sta inv_fire_timer
000AA5  1               
000AA5  1  60              rts
000AA6  1               
000AA6  1               ;******************************************************************
000AA6  1               ; init_invaders — upload invader pixel data, init grid state, place sprites
000AA6  1               ;******************************************************************
000AA6  1               init_invaders:
000AA6  1  9C 25 9F        stz VERA_ctrl
000AA9  1               
000AA9  1                  ; --- upload Type A frame 0 → VRAM $00100 ---
000AA9  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F0, 1
000AAD  1  9F A9 01 8D  
000AB1  1  21 9F A9 00  
000AB8  1  A2 80           ldx #128
000ABA  1  BD 4B 13     @up_af0: lda inv_a_spr_f0-128,x
000ABD  1  8D 23 9F        sta VERA_data0
000AC0  1  E8              inx
000AC1  1  D0 F7           bne @up_af0
000AC3  1               
000AC3  1                  ; --- upload Type A frame 1 → VRAM $00180 ---
000AC3  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F1, 1
000AC7  1  9F A9 01 8D  
000ACB  1  21 9F A9 80  
000AD2  1  A2 80           ldx #128
000AD4  1  BD CB 13     @up_af1: lda inv_a_spr_f1-128,x
000AD7  1  8D 23 9F        sta VERA_data0
000ADA  1  E8              inx
000ADB  1  D0 F7           bne @up_af1
000ADD  1               
000ADD  1                  ; --- upload Type B frame 0 → VRAM $00200 ---
000ADD  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F0, 1
000AE1  1  9F A9 02 8D  
000AE5  1  21 9F A9 00  
000AEC  1  A2 80           ldx #128
000AEE  1  BD 4B 14     @up_bf0: lda inv_b_spr_f0-128,x
000AF1  1  8D 23 9F        sta VERA_data0
000AF4  1  E8              inx
000AF5  1  D0 F7           bne @up_bf0
000AF7  1               
000AF7  1                  ; --- upload Type B frame 1 → VRAM $00280 ---
000AF7  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F1, 1
000AFB  1  9F A9 02 8D  
000AFF  1  21 9F A9 80  
000B06  1  A2 80           ldx #128
000B08  1  BD CB 14     @up_bf1: lda inv_b_spr_f1-128,x
000B0B  1  8D 23 9F        sta VERA_data0
000B0E  1  E8              inx
000B0F  1  D0 F7           bne @up_bf1
000B11  1               
000B11  1                  ; --- upload Type C frame 0 → VRAM $00300 ---
000B11  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F0, 1
000B15  1  9F A9 03 8D  
000B19  1  21 9F A9 00  
000B20  1  A2 80           ldx #128
000B22  1  BD 4B 15     @up_cf0: lda inv_c_spr_f0-128,x
000B25  1  8D 23 9F        sta VERA_data0
000B28  1  E8              inx
000B29  1  D0 F7           bne @up_cf0
000B2B  1               
000B2B  1                  ; --- upload Type C frame 1 → VRAM $00380 ---
000B2B  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F1, 1
000B2F  1  9F A9 03 8D  
000B33  1  21 9F A9 80  
000B3A  1  A2 80           ldx #128
000B3C  1  BD CB 15     @up_cf1: lda inv_c_spr_f1-128,x
000B3F  1  8D 23 9F        sta VERA_data0
000B42  1  E8              inx
000B43  1  D0 F7           bne @up_cf1
000B45  1               
000B45  1                  ; --- initialize zero-page grid variables ---
000B45  1  A9 70           lda #<INV_GRID_X_INIT
000B47  1  85 rr           sta inv_grid_x_lo
000B49  1  A9 00           lda #>INV_GRID_X_INIT
000B4B  1  85 rr           sta inv_grid_x_hi
000B4D  1  64 rr           stz inv_offset_y
000B4F  1  64 rr           stz inv_direction
000B51  1  64 rr           stz inv_anim_frame
000B53  1  64 rr           stz inv_drop_flag
000B55  1               
000B55  1                  ; all 55 invaders alive: bytes 0-5 = $FF, byte 6 = $7F (55 bits)
000B55  1  A9 FF           lda #$FF
000B57  1  85 rr           sta inv_alive+0
000B59  1  85 rr           sta inv_alive+1
000B5B  1  85 rr           sta inv_alive+2
000B5D  1  85 rr           sta inv_alive+3
000B5F  1  85 rr           sta inv_alive+4
000B61  1  85 rr           sta inv_alive+5
000B63  1  A9 7F           lda #$7F
000B65  1  85 rr           sta inv_alive+6
000B67  1               
000B67  1  A9 37           lda #INV_COUNT_INIT
000B69  1  85 rr           sta inv_count
000B6B  1  A9 32           lda #INV_MOVE_SPEED_INIT
000B6D  1  85 rr           sta inv_move_speed
000B6F  1  85 rr           sta inv_move_timer
000B71  1               
000B71  1                  ; --- write initial sprite attributes for all 55 invaders ---
000B71  1  20 DA 0B        jsr update_invader_sprites
000B74  1  60              rts
000B75  1               
000B75  1               ;******************************************************************
000B75  1               ; step_invaders — one march step: move or drop grid, toggle anim frame
000B75  1               ;   Called when inv_move_timer reaches 0.
000B75  1               ;   Updates inv_grid_x / inv_offset_y, sets inv_drop_flag as needed,
000B75  1               ;   then refreshes all VERA sprite positions.
000B75  1               ;******************************************************************
000B75  1               step_invaders:
000B75  1                  ; toggle animation frame
000B75  1  A5 rr           lda inv_anim_frame
000B77  1  49 01           eor #1
000B79  1  85 rr           sta inv_anim_frame
000B7B  1               
000B7B  1                  ; if drop flag is set: drop grid this step, skip march
000B7B  1  A5 rr           lda inv_drop_flag
000B7D  1  F0 0B           beq @do_march
000B7F  1  64 rr           stz inv_drop_flag
000B81  1  A5 rr           lda inv_offset_y
000B83  1  18              clc
000B84  1  69 10           adc #INV_DROP_Y
000B86  1  85 rr           sta inv_offset_y
000B88  1  80 4C           bra @sprites_done
000B8A  1               
000B8A  1               @do_march:
000B8A  1  A5 rr           lda inv_direction
000B8C  1  D0 25           bne @march_left
000B8E  1               
000B8E  1                  ; --- march right ---
000B8E  1  A5 rr           lda inv_grid_x_lo
000B90  1  18              clc
000B91  1  69 04           adc #INV_STEP_X
000B93  1  85 rr           sta inv_grid_x_lo
000B95  1  90 02           bcc @chk_right
000B97  1  E6 rr           inc inv_grid_x_hi
000B99  1               @chk_right:
000B99  1                  ; hit right if grid_x > INV_X_RIGHT_LIM (208, fits in 1 byte, hi always 0)
000B99  1  A5 rr           lda inv_grid_x_hi
000B9B  1  D0 06           bne @clamp_right          ; hi > 0 → definitely over limit
000B9D  1  A5 rr           lda inv_grid_x_lo
000B9F  1  C9 D1           cmp #INV_X_RIGHT_LIM + 1  ; C set if lo > limit
000BA1  1  90 33           bcc @sprites_done
000BA3  1               @clamp_right:
000BA3  1  A9 D0           lda #<INV_X_RIGHT_LIM
000BA5  1  85 rr           sta inv_grid_x_lo
000BA7  1  A9 00           lda #>INV_X_RIGHT_LIM
000BA9  1  85 rr           sta inv_grid_x_hi
000BAB  1  A9 01           lda #1
000BAD  1  85 rr           sta inv_direction
000BAF  1  85 rr           sta inv_drop_flag
000BB1  1  80 23           bra @sprites_done
000BB3  1               
000BB3  1                  ; --- march left ---
000BB3  1               @march_left:
000BB3  1  A5 rr           lda inv_grid_x_lo
000BB5  1  38              sec
000BB6  1  E9 04           sbc #INV_STEP_X
000BB8  1  85 rr           sta inv_grid_x_lo
000BBA  1  B0 02           bcs @chk_left             ; no borrow
000BBC  1  C6 rr           dec inv_grid_x_hi
000BBE  1               @chk_left:
000BBE  1                  ; hit left if hi went negative OR lo < INV_X_LEFT_LIM
000BBE  1  A5 rr           lda inv_grid_x_hi
000BC0  1  30 06           bmi @clamp_left
000BC2  1  A5 rr           lda inv_grid_x_lo
000BC4  1  C9 10           cmp #INV_X_LEFT_LIM
000BC6  1  B0 0E           bcs @sprites_done         ; lo >= left limit → ok
000BC8  1               @clamp_left:
000BC8  1  A9 10           lda #<INV_X_LEFT_LIM
000BCA  1  85 rr           sta inv_grid_x_lo
000BCC  1  A9 00           lda #>INV_X_LEFT_LIM
000BCE  1  85 rr           sta inv_grid_x_hi
000BD0  1  64 rr           stz inv_direction
000BD2  1  A9 01           lda #1
000BD4  1  85 rr           sta inv_drop_flag
000BD6  1               
000BD6  1               @sprites_done:
000BD6  1  20 DA 0B        jsr update_invader_sprites
000BD9  1  60              rts
000BDA  1               
000BDA  1               ;******************************************************************
000BDA  1               ; update_invader_sprites — write all 55 invader sprite attributes to VERA
000BDA  1               ;
000BDA  1               ;   VERA sprite slots 11-65 hold the 55 invaders.
000BDA  1               ;   Attributes base: $1FC58 ($1FC00 + 11*8).
000BDA  1               ;   With stride=1 the VERA address auto-increments, so we set it
000BDA  1               ;   once and write all 440 bytes sequentially.
000BDA  1               ;
000BDA  1               ;   Byte layout per sprite:
000BDA  1               ;     0: data addr[12:5]   (encodes VRAM pixel data address + frame)
000BDA  1               ;     1: $00               (4bpp, addr[16:13]=0)
000BDA  1               ;     2: X[7:0]
000BDA  1               ;     3: X[9:8]
000BDA  1               ;     4: Y[7:0]
000BDA  1               ;     5: Y[9:8]
000BDA  1               ;     6: z-depth/collision
000BDA  1               ;     7: palette / size
000BDA  1               ;
000BDA  1               ;   Invader index i = row*11 + col; alive bit i in inv_alive bitmap.
000BDA  1               ;   For Phase 3 all invaders are alive; alive check will be added Phase 4.
000BDA  1               ;******************************************************************
000BDA  1               update_invader_sprites:
000BDA  1  9C 25 9F        stz VERA_ctrl
000BDD  1  A9 11           lda #$11              ; stride=1, VRAM bank bit=1 (addr $1Fxxxx)
000BDF  1  8D 22 9F        sta VERA_addr_bank
000BE2  1  A9 FC           lda #$FC
000BE4  1  8D 21 9F        sta VERA_addr_high
000BE7  1  A9 58           lda #$58
000BE9  1  8D 20 9F        sta VERA_addr_low     ; VERA now at $1FC58, auto-increments by 1
000BEC  1               
000BEC  1                  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000BEC  1  A9 50           lda #<INV_GRID_Y_BASE
000BEE  1  18              clc
000BEF  1  65 rr           adc inv_offset_y
000BF1  1  85 rr           sta zp_y_base_lo
000BF3  1  A9 00           lda #>INV_GRID_Y_BASE
000BF5  1  69 00           adc #0
000BF7  1  85 rr           sta zp_y_base_hi
000BF9  1               
000BF9  1  64 rr           stz zp_row
000BFB  1               @row_loop:
000BFB  1                  ; compute row Y: zp_row_y = zp_y_base + row_y_offsets[row]
000BFB  1  A4 rr           ldy zp_row
000BFD  1  B9 D9 12        lda row_y_offsets,y
000C00  1  18              clc
000C01  1  65 rr           adc zp_y_base_lo
000C03  1  85 rr           sta zp_row_y_lo
000C05  1  A9 00           lda #0
000C07  1  65 rr           adc zp_y_base_hi
000C09  1  85 rr           sta zp_row_y_hi
000C0B  1               
000C0B  1                  ; select addr byte0 based on row type and animation frame
000C0B  1  A4 rr           ldy zp_row
000C0D  1  A5 rr           lda inv_anim_frame
000C0F  1  F0 05           beq @use_f0
000C11  1  B9 BE 12        lda inv_addr_b0_f1,y
000C14  1  80 03           bra @got_b0
000C16  1               @use_f0:
000C16  1  B9 B9 12        lda inv_addr_b0_f0,y
000C19  1               @got_b0:
000C19  1  85 rr           sta zp_addr_b0
000C1B  1               
000C1B  1  20 27 0C        jsr update_invader_row
000C1E  1               
000C1E  1  E6 rr           inc zp_row
000C20  1  A5 rr           lda zp_row
000C22  1  C9 05           cmp #5
000C24  1  D0 D5           bne @row_loop
000C26  1               
000C26  1  60              rts
000C27  1               
000C27  1               ;******************************************************************
000C27  1               ; update_invader_row — write 11 sprite attribute blocks for one row
000C27  1               ;
000C27  1               ;   Inputs (ZP): zp_row, zp_addr_b0, zp_row_y_lo/hi, inv_grid_x_lo/hi
000C27  1               ;   VERA address register must already be set to the first sprite slot
000C27  1               ;   for this row on entry (maintained by the sequential write stream).
000C27  1               ;******************************************************************
000C27  1               update_invader_row:
000C27  1  64 rr           stz zp_col
000C29  1               @col_loop:
000C29  1                  ; --- determine z-depth from alive bitmap ---
000C29  1                  ; index = inv_row_base[row] + col; byte = index>>3; bit = index&7
000C29  1  A4 rr           ldy zp_row
000C2B  1  B9 DE 12        lda inv_row_base,y
000C2E  1  18              clc
000C2F  1  65 rr           adc zp_col
000C31  1  A8              tay                   ; Y = invader index
000C32  1  29 07           and #$07
000C34  1  AA              tax                   ; X = bit index
000C35  1  BD E3 12        lda bit_masks,x
000C38  1  48              pha                   ; save bit mask
000C39  1  98              tya
000C3A  1  4A              lsr
000C3B  1  4A              lsr
000C3C  1  4A              lsr
000C3D  1  A8              tay                   ; Y = byte index into inv_alive
000C3E  1  68              pla                   ; A = bit mask
000C3F  1  39 rr rr        and inv_alive,y
000C42  1  F0 04           beq @zdepth_off
000C44  1  A9 0C           lda #SPR_Z_FRONT
000C46  1  80 02           bra @zdepth_done
000C48  1               @zdepth_off:
000C48  1  A9 00           lda #0
000C4A  1               @zdepth_done:
000C4A  1  85 rr           sta zp_scratch_lo     ; save z-depth before VERA stream starts
000C4C  1               
000C4C  1                  ; --- compute sprite X = inv_grid_x + col_x_offsets[col] ---
000C4C  1  A4 rr           ldy zp_col
000C4E  1  B9 C3 12        lda col_x_lo,y
000C51  1  18              clc
000C52  1  65 rr           adc inv_grid_x_lo
000C54  1  85 rr           sta zp_x_lo
000C56  1  B9 CE 12        lda col_x_hi,y
000C59  1  65 rr           adc inv_grid_x_hi
000C5B  1  85 rr           sta zp_x_hi
000C5D  1               
000C5D  1                  ; --- write 8 attribute bytes (VERA auto-increments) ---
000C5D  1  A5 rr           lda zp_addr_b0
000C5F  1  8D 23 9F        sta VERA_data0        ; byte 0: data addr[12:5]
000C62  1  9C 23 9F        stz VERA_data0        ; byte 1: 4bpp, addr[16:13]=0
000C65  1  A5 rr           lda zp_x_lo
000C67  1  8D 23 9F        sta VERA_data0        ; byte 2: X[7:0]
000C6A  1  A5 rr           lda zp_x_hi
000C6C  1  29 03           and #$03
000C6E  1  8D 23 9F        sta VERA_data0        ; byte 3: X[9:8]
000C71  1  A5 rr           lda zp_row_y_lo
000C73  1  8D 23 9F        sta VERA_data0        ; byte 4: Y[7:0]
000C76  1  A5 rr           lda zp_row_y_hi
000C78  1  29 03           and #$03
000C7A  1  8D 23 9F        sta VERA_data0        ; byte 5: Y[9:8]
000C7D  1  A5 rr           lda zp_scratch_lo
000C7F  1  8D 23 9F        sta VERA_data0        ; byte 6: z-depth (SPR_Z_FRONT if alive, 0 if dead)
000C82  1  A9 50           lda #SPR_16x16_PAL0
000C84  1  8D 23 9F        sta VERA_data0        ; byte 7: 16x16, palette offset 0
000C87  1               
000C87  1  E6 rr           inc zp_col
000C89  1  A5 rr           lda zp_col
000C8B  1  C9 0B           cmp #11
000C8D  1  D0 9A           bne @col_loop
000C8F  1               
000C8F  1  60              rts
000C90  1               
000C90  1               ;******************************************************************
000C90  1               ; move_player — apply key_flags movement and clamp to screen edges
000C90  1               ;******************************************************************
000C90  1               move_player:
000C90  1  A5 rr           lda key_flags
000C92  1               
000C92  1                  ; --- move left ---
000C92  1  29 01           and #KEY_LEFT
000C94  1  F0 1F           beq @check_right
000C96  1  A5 rr           lda player_x_lo
000C98  1  38              sec
000C99  1  E9 04           sbc #PLAYER_SPEED
000C9B  1  85 rr           sta player_x_lo
000C9D  1  B0 02           bcs @clamp_left              ; no borrow → hi unchanged
000C9F  1  C6 rr           dec player_x_hi
000CA1  1               @clamp_left:
000CA1  1                  ; Clamp: if hi went negative ($FF) or (hi=0 AND lo < min) → set to min
000CA1  1  A5 rr           lda player_x_hi
000CA3  1  30 08           bmi @set_min                 ; $80–$FF = underflowed
000CA5  1  D0 0E           bne @check_right             ; hi > 0 → still above minimum
000CA7  1  A5 rr           lda player_x_lo
000CA9  1  C9 08           cmp #PLAYER_X_MIN
000CAB  1  B0 08           bcs @check_right             ; lo >= min → ok
000CAD  1               @set_min:
000CAD  1  A9 08           lda #<PLAYER_X_MIN
000CAF  1  85 rr           sta player_x_lo
000CB1  1  A9 00           lda #>PLAYER_X_MIN
000CB3  1  85 rr           sta player_x_hi
000CB5  1               
000CB5  1                  ; --- move right ---
000CB5  1               @check_right:
000CB5  1  A5 rr           lda key_flags
000CB7  1  29 02           and #KEY_RIGHT
000CB9  1  F0 23           beq @move_done
000CBB  1  A5 rr           lda player_x_lo
000CBD  1  18              clc
000CBE  1  69 04           adc #PLAYER_SPEED
000CC0  1  85 rr           sta player_x_lo
000CC2  1  90 02           bcc @clamp_right             ; no carry → hi unchanged
000CC4  1  E6 rr           inc player_x_hi
000CC6  1               @clamp_right:
000CC6  1                  ; Clamp: if hi > max_hi, OR (hi == max_hi AND lo > max_lo) → set to max
000CC6  1  A5 rr           lda player_x_hi
000CC8  1  C9 02           cmp #>PLAYER_X_MAX
000CCA  1  90 12           bcc @move_done               ; hi < max_hi → definitely ok
000CCC  1  D0 08           bne @set_max                 ; hi > max_hi → over limit
000CCE  1  A5 rr           lda player_x_lo
000CD0  1  C9 68           cmp #<PLAYER_X_MAX
000CD2  1  90 0A           bcc @move_done               ; lo < max_lo when hi == max_hi → ok
000CD4  1  F0 08           beq @move_done               ; lo == max_lo → exactly at max, ok
000CD6  1               @set_max:
000CD6  1  A9 68           lda #<PLAYER_X_MAX
000CD8  1  85 rr           sta player_x_lo
000CDA  1  A9 02           lda #>PLAYER_X_MAX
000CDC  1  85 rr           sta player_x_hi
000CDE  1               
000CDE  1               @move_done:
000CDE  1  60              rts
000CDF  1               
000CDF  1               ;******************************************************************
000CDF  1               ; update_player_sprite — write current X position to sprite 1 in VERA
000CDF  1               ;   Only X needs updating (Y is fixed)
000CDF  1               ;******************************************************************
000CDF  1               update_player_sprite:
000CDF  1  9C 25 9F        stz VERA_ctrl
000CE2  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 2), 1
000CE6  1  9F A9 FC 8D  
000CEA  1  21 9F A9 0A  
000CF1  1  A5 rr           lda player_x_lo
000CF3  1  8D 23 9F        sta VERA_data0               ; sprite byte 2: X[7:0]
000CF6  1  A5 rr           lda player_x_hi
000CF8  1  29 03           and #$03
000CFA  1  8D 23 9F        sta VERA_data0               ; sprite byte 3: X[9:8]
000CFD  1                  ; update z-depth based on inv_hit_timer:
000CFD  1                  ;   timer = 0        → show solid (not hit)
000CFD  1                  ;   timer = 61-120   → hidden solid (1-second respawn delay)
000CFD  1                  ;   timer = 1-60     → flashing (invincible, visible warning)
000CFD  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 6), 1
000D01  1  9F A9 FC 8D  
000D05  1  21 9F A9 0E  
000D0C  1  A5 rr           lda inv_hit_timer
000D0E  1  F0 08           beq @show                    ; timer=0 → show solid
000D10  1  C9 3D           cmp #61
000D12  1  B0 08           bcs @hide                    ; timer>=61 → first second: fully hidden
000D14  1  29 08           and #$08                     ; timer 1-60: bit 3 flips every 8 frames → ~4 Hz flash
000D16  1  D0 04           bne @hide
000D18  1               @show:
000D18  1  A9 0C           lda #SPR_Z_FRONT
000D1A  1  80 02           bra @write_z
000D1C  1               @hide:
000D1C  1  A9 00           lda #0
000D1E  1               @write_z:
000D1E  1  8D 23 9F        sta VERA_data0               ; sprite byte 6: z-depth
000D21  1  60              rts
000D22  1               
000D22  1               ;******************************************************************
000D22  1               ; fire_bullet — activate player bullet at cannon tip, update sprite
000D22  1               ;   Bullet X centers the 8-px bullet over the 16-px player ship:
000D22  1               ;     bullet_x = player_x + 4
000D22  1               ;   Bullet Y starts 8 VERA pixels above the player sprite top.
000D22  1               ;   Caller must check bullet_active == 0 before calling.
000D22  1               ;******************************************************************
000D22  1               fire_bullet:
000D22  1  A5 rr           lda player_x_lo
000D24  1  18              clc
000D25  1  69 04           adc #4
000D27  1  85 rr           sta bullet_x_lo
000D29  1  A5 rr           lda player_x_hi
000D2B  1  69 00           adc #0
000D2D  1  85 rr           sta bullet_x_hi
000D2F  1               
000D2F  1  A9 9C           lda #<BULLET_Y_INIT
000D31  1  85 rr           sta bullet_y_lo
000D33  1  A9 01           lda #>BULLET_Y_INIT
000D35  1  85 rr           sta bullet_y_hi
000D37  1               
000D37  1  A9 01           lda #1
000D39  1  85 rr           sta bullet_active
000D3B  1  20 58 0D        jsr update_bullet_sprite
000D3E  1  60              rts
000D3F  1               
000D3F  1               ;******************************************************************
000D3F  1               ; move_bullet — move bullet upward by BULLET_SPEED each frame;
000D3F  1               ;   deactivate when it reaches the top of the screen (Y underflows 0)
000D3F  1               ;******************************************************************
000D3F  1               move_bullet:
000D3F  1  A5 rr           lda bullet_y_lo
000D41  1  38              sec
000D42  1  E9 0C           sbc #BULLET_SPEED
000D44  1  85 rr           sta bullet_y_lo
000D46  1  A5 rr           lda bullet_y_hi
000D48  1  E9 00           sbc #0
000D4A  1  85 rr           sta bullet_y_hi
000D4C  1  30 04           bmi @deactivate              ; 16-bit underflow past 0 → off screen
000D4E  1               
000D4E  1  20 58 0D        jsr update_bullet_sprite
000D51  1  60              rts
000D52  1               
000D52  1               @deactivate:
000D52  1  64 rr           stz bullet_active
000D54  1  20 58 0D        jsr update_bullet_sprite     ; disables sprite (z-depth=0)
000D57  1  60              rts
000D58  1               
000D58  1               ;******************************************************************
000D58  1               ; update_bullet_sprite — write bullet position and enable/disable
000D58  1               ;   to VERA sprite 2 (bytes 2-6); byte 7 set once at init.
000D58  1               ;   z-depth = SPR_Z_FRONT when active, 0 when inactive.
000D58  1               ;******************************************************************
000D58  1               update_bullet_sprite:
000D58  1  9C 25 9F        stz VERA_ctrl
000D5B  1  A9 11 8D 22     VERA_SET_ADDR (BULLET_SPRITE_ATTR + 2), 1
000D5F  1  9F A9 FC 8D  
000D63  1  21 9F A9 12  
000D6A  1  A5 rr           lda bullet_x_lo
000D6C  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000D6F  1  A5 rr           lda bullet_x_hi
000D71  1  29 03           and #$03
000D73  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000D76  1  A5 rr           lda bullet_y_lo
000D78  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000D7B  1  A5 rr           lda bullet_y_hi
000D7D  1  29 03           and #$03
000D7F  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000D82  1  A5 rr           lda bullet_active
000D84  1  F0 04           beq @z_off
000D86  1  A9 0C           lda #SPR_Z_FRONT
000D88  1  80 02           bra @write_z
000D8A  1               @z_off:
000D8A  1  A9 00           lda #$00
000D8C  1               @write_z:
000D8C  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
000D8F  1  60              rts
000D90  1               
000D90  1               ;******************************************************************
000D90  1               ; check_bullet_invader — scan all 55 invaders for a hit with the player bullet
000D90  1               ;
000D90  1               ;   Iterates rows 0-4, columns 0-10.  Skips dead invaders.
000D90  1               ;   For each live invader checks 16-bit AABB overlap:
000D90  1               ;     X: bullet_x+8 > inv_x  AND  bullet_x < inv_x+16
000D90  1               ;     Y: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000D90  1               ;   On hit: calls kill_invader_hit and returns immediately.
000D90  1               ;
000D90  1               ;   Scratch used: zp_y_base_lo/hi, zp_row_y_lo/hi, zp_x_lo/hi,
000D90  1               ;                 zp_scratch_lo/hi, zp_row, zp_col
000D90  1               ;******************************************************************
000D90  1               check_bullet_invader:
000D90  1  A5 rr           lda bullet_active
000D92  1  D0 01           bne :+
000D94  1  60              rts
000D95  1               :  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000D95  1  A9 50           lda #<INV_GRID_Y_BASE
000D97  1  18              clc
000D98  1  65 rr           adc inv_offset_y
000D9A  1  85 rr           sta zp_y_base_lo
000D9C  1  A9 00           lda #>INV_GRID_Y_BASE
000D9E  1  69 00           adc #0
000DA0  1  85 rr           sta zp_y_base_hi
000DA2  1               
000DA2  1  64 rr           stz zp_row
000DA4  1               @row_loop:
000DA4  1                  ; row Y = y_base + row_y_offsets[row]
000DA4  1  A4 rr           ldy zp_row
000DA6  1  B9 D9 12        lda row_y_offsets,y
000DA9  1  18              clc
000DAA  1  65 rr           adc zp_y_base_lo
000DAC  1  85 rr           sta zp_row_y_lo
000DAE  1  A9 00           lda #0
000DB0  1  65 rr           adc zp_y_base_hi
000DB2  1  85 rr           sta zp_row_y_hi
000DB4  1               
000DB4  1                  ; --- Quick Y range check for whole row ---
000DB4  1                  ; Need: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000DB4  1               
000DB4  1                  ; (1) bullet_y+8 > inv_y  →  (bullet_y+8) - inv_y > 0
000DB4  1                  ;     result negative (bmi) means bullet above this row
000DB4  1  A5 rr           lda bullet_y_lo
000DB6  1  18              clc
000DB7  1  69 08           adc #8
000DB9  1  85 rr           sta zp_scratch_lo
000DBB  1  A5 rr           lda bullet_y_hi
000DBD  1  69 00           adc #0
000DBF  1  85 rr           sta zp_scratch_hi
000DC1  1  A5 rr           lda zp_scratch_lo
000DC3  1  38              sec
000DC4  1  E5 rr           sbc zp_row_y_lo
000DC6  1  A5 rr           lda zp_scratch_hi
000DC8  1  E5 rr           sbc zp_row_y_hi
000DCA  1  30 1D           bmi @next_row         ; bullet bottom above invader top → no hit in this row
000DCC  1               
000DCC  1                  ; (2) bullet_y < inv_y+16  →  bullet_y - (inv_y+16) < 0
000DCC  1                  ;     result >= 0 (bpl) means bullet below this row
000DCC  1  A5 rr           lda zp_row_y_lo
000DCE  1  18              clc
000DCF  1  69 10           adc #16
000DD1  1  85 rr           sta zp_scratch_lo
000DD3  1  A5 rr           lda zp_row_y_hi
000DD5  1  69 00           adc #0
000DD7  1  85 rr           sta zp_scratch_hi
000DD9  1  A5 rr           lda bullet_y_lo
000DDB  1  38              sec
000DDC  1  E5 rr           sbc zp_scratch_lo
000DDE  1  A5 rr           lda bullet_y_hi
000DE0  1  E5 rr           sbc zp_scratch_hi
000DE2  1  10 05           bpl @next_row         ; bullet top at or below invader bottom → no hit
000DE4  1               
000DE4  1                  ; Y overlaps this row — check each column
000DE4  1  20 F2 0D        jsr cbi_check_cols
000DE7  1  B0 08           bcs @done             ; hit found; bullet already handled
000DE9  1               
000DE9  1               @next_row:
000DE9  1  E6 rr           inc zp_row
000DEB  1  A5 rr           lda zp_row
000DED  1  C9 05           cmp #5
000DEF  1  D0 B3           bne @row_loop
000DF1  1               
000DF1  1               @done:
000DF1  1  60              rts
000DF2  1               
000DF2  1               ;******************************************************************
000DF2  1               ; cbi_check_cols — column scan for check_bullet_invader
000DF2  1               ;
000DF2  1               ;   Scans all 11 columns of zp_row for an X overlap with the bullet.
000DF2  1               ;   Assumes Y overlap for this row has already been confirmed.
000DF2  1               ;   Returns: C set if hit (kill_invader_hit already called),
000DF2  1               ;            C clear if no hit.
000DF2  1               ;   Scratch used: zp_col, zp_x_lo/hi, zp_scratch_lo/hi
000DF2  1               ;******************************************************************
000DF2  1               cbi_check_cols:
000DF2  1  64 rr           stz zp_col
000DF4  1               @col_loop:
000DF4  1                  ; skip if invader is dead
000DF4  1  A4 rr           ldy zp_row
000DF6  1  B9 DE 12        lda inv_row_base,y
000DF9  1  18              clc
000DFA  1  65 rr           adc zp_col
000DFC  1  A8              tay                   ; Y = invader index
000DFD  1  29 07           and #$07
000DFF  1  AA              tax
000E00  1  BD E3 12        lda bit_masks,x
000E03  1  48              pha
000E04  1  98              tya
000E05  1  4A              lsr
000E06  1  4A              lsr
000E07  1  4A              lsr
000E08  1  A8              tay                   ; Y = byte index into inv_alive
000E09  1  68              pla
000E0A  1  39 rr rr        and inv_alive,y
000E0D  1  F0 46           beq @next_col         ; dead
000E0F  1               
000E0F  1                  ; compute inv_x = inv_grid_x + col_x_offsets[col]
000E0F  1  A4 rr           ldy zp_col
000E11  1  B9 C3 12        lda col_x_lo,y
000E14  1  18              clc
000E15  1  65 rr           adc inv_grid_x_lo
000E17  1  85 rr           sta zp_x_lo
000E19  1  B9 CE 12        lda col_x_hi,y
000E1C  1  65 rr           adc inv_grid_x_hi
000E1E  1  85 rr           sta zp_x_hi
000E20  1               
000E20  1                  ; X check (1): bullet_x+8 > inv_x
000E20  1  A5 rr           lda bullet_x_lo
000E22  1  18              clc
000E23  1  69 08           adc #8
000E25  1  85 rr           sta zp_scratch_lo
000E27  1  A5 rr           lda bullet_x_hi
000E29  1  69 00           adc #0
000E2B  1  85 rr           sta zp_scratch_hi
000E2D  1  A5 rr           lda zp_scratch_lo
000E2F  1  38              sec
000E30  1  E5 rr           sbc zp_x_lo
000E32  1  A5 rr           lda zp_scratch_hi
000E34  1  E5 rr           sbc zp_x_hi
000E36  1  30 1D           bmi @next_col         ; bullet right edge left of invader → no hit
000E38  1               
000E38  1                  ; X check (2): bullet_x < inv_x+16
000E38  1  A5 rr           lda zp_x_lo
000E3A  1  18              clc
000E3B  1  69 10           adc #16
000E3D  1  85 rr           sta zp_scratch_lo
000E3F  1  A5 rr           lda zp_x_hi
000E41  1  69 00           adc #0
000E43  1  85 rr           sta zp_scratch_hi
000E45  1  A5 rr           lda bullet_x_lo
000E47  1  38              sec
000E48  1  E5 rr           sbc zp_scratch_lo
000E4A  1  A5 rr           lda bullet_x_hi
000E4C  1  E5 rr           sbc zp_scratch_hi
000E4E  1  10 05           bpl @next_col         ; bullet left edge at or right of invader → no hit
000E50  1               
000E50  1                  ; --- HIT ---
000E50  1  20 5F 0E        jsr kill_invader_hit
000E53  1  38              sec                   ; signal hit to caller
000E54  1  60              rts
000E55  1               
000E55  1               @next_col:
000E55  1  E6 rr           inc zp_col
000E57  1  A5 rr           lda zp_col
000E59  1  C9 0B           cmp #11
000E5B  1  D0 97           bne @col_loop
000E5D  1               
000E5D  1  18              clc                   ; no hit
000E5E  1  60              rts
000E5F  1               
000E5F  1               ;******************************************************************
000E5F  1               ; kill_invader_hit — clear alive bit, deactivate bullet, update score & speed
000E5F  1               ;   Expects zp_row, zp_col to identify the hit invader.
000E5F  1               ;******************************************************************
000E5F  1               kill_invader_hit:
000E5F  1                  ; --- clear alive bit ---
000E5F  1  A4 rr           ldy zp_row
000E61  1  B9 DE 12        lda inv_row_base,y
000E64  1  18              clc
000E65  1  65 rr           adc zp_col
000E67  1  A8              tay                   ; Y = invader index
000E68  1  29 07           and #$07
000E6A  1  AA              tax
000E6B  1  BD E3 12        lda bit_masks,x       ; bit mask for this invader
000E6E  1  48              pha
000E6F  1  98              tya
000E70  1  4A              lsr
000E71  1  4A              lsr
000E72  1  4A              lsr
000E73  1  A8              tay                   ; Y = byte index into inv_alive
000E74  1  68              pla
000E75  1  49 FF           eor #$FF              ; invert → clear mask
000E77  1  39 rr rr        and inv_alive,y
000E7A  1  99 rr rr        sta inv_alive,y
000E7D  1               
000E7D  1                  ; --- start explosion at the hit invader's position ---
000E7D  1                  ; zp_x_lo/hi and zp_row_y_lo/hi still hold the invader coords from collision detection
000E7D  1  20 AB 0E        jsr start_explosion
000E80  1               
000E80  1                  ; --- deactivate bullet ---
000E80  1  64 rr           stz bullet_active
000E82  1  20 58 0D        jsr update_bullet_sprite
000E85  1               
000E85  1                  ; --- decrement inv_count ---
000E85  1  C6 rr           dec inv_count
000E87  1               
000E87  1                  ; --- update inv_move_speed: proportional to remaining count ---
000E87  1  A6 rr           ldx inv_count
000E89  1  BD F0 12        lda inv_speed_table,x
000E8C  1  85 rr           sta inv_move_speed
000E8E  1               
000E8E  1                  ; --- add score for this row's invader type ---
000E8E  1  A4 rr           ldy zp_row
000E90  1  B9 EB 12        lda score_by_row_bcd,y
000E93  1  20 97 0E        jsr add_score
000E96  1  60              rts
000E97  1               
000E97  1               ;******************************************************************
000E97  1               ; add_score — add BCD value in A to score_lo/mid/hi
000E97  1               ;******************************************************************
000E97  1               add_score:
000E97  1  F8              sed
000E98  1  18              clc
000E99  1  65 rr           adc score_lo
000E9B  1  85 rr           sta score_lo
000E9D  1  A5 rr           lda score_mid
000E9F  1  69 00           adc #0
000EA1  1  85 rr           sta score_mid
000EA3  1  A5 rr           lda score_hi
000EA5  1  69 00           adc #0
000EA7  1  85 rr           sta score_hi
000EA9  1  D8              cld
000EAA  1  60              rts
000EAB  1               
000EAB  1               ;******************************************************************
000EAB  1               ; start_explosion — position sprite 4 at the hit invader and start timer
000EAB  1               ;
000EAB  1               ;   Inputs: zp_x_lo/hi     — invader X (VERA coords)
000EAB  1               ;           zp_row_y_lo/hi — invader Y (VERA coords)
000EAB  1               ;   Sets exp_timer = EXPLODE_FRAMES and enables sprite 4.
000EAB  1               ;******************************************************************
000EAB  1               start_explosion:
000EAB  1  9C 25 9F        stz VERA_ctrl
000EAE  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 2), 1  ; start at byte 2 (X lo)
000EB2  1  9F A9 FC 8D  
000EB6  1  21 9F A9 22  
000EBD  1  A5 rr           lda zp_x_lo
000EBF  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000EC2  1  A5 rr           lda zp_x_hi
000EC4  1  29 03           and #$03
000EC6  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000EC9  1  A5 rr           lda zp_row_y_lo
000ECB  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000ECE  1  A5 rr           lda zp_row_y_hi
000ED0  1  29 03           and #$03
000ED2  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000ED5  1  A9 0C           lda #SPR_Z_FRONT
000ED7  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3 → enabled, in front
000EDA  1  A9 1E           lda #EXPLODE_FRAMES
000EDC  1  85 rr           sta exp_timer
000EDE  1  60              rts
000EDF  1               
000EDF  1               ;******************************************************************
000EDF  1               ; update_explosion — decrement exp_timer; disable sprite when it hits 0
000EDF  1               ;******************************************************************
000EDF  1               update_explosion:
000EDF  1  A5 rr           lda exp_timer
000EE1  1  F0 1B           beq @inactive
000EE3  1  C6 rr           dec exp_timer
000EE5  1  D0 17           bne @inactive
000EE7  1                  ; timer just expired — disable sprite 4
000EE7  1  9C 25 9F        stz VERA_ctrl
000EEA  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1  ; byte 6 = z-depth
000EEE  1  9F A9 FC 8D  
000EF2  1  21 9F A9 26  
000EF9  1  A9 00           lda #$00
000EFB  1  8D 23 9F        sta VERA_data0               ; z-depth=0 → disabled
000EFE  1               @inactive:
000EFE  1  60              rts
000EFF  1               
000EFF  1               ;******************************************************************
000EFF  1               ; prng — 16-bit Galois LFSR, feedback polynomial $B400
000EFF  1               ;   Updates rand_seed_lo/hi; returns pseudo-random byte in A.
000EFF  1               ;******************************************************************
000EFF  1               prng:
000EFF  1  46 rr           lsr rand_seed_hi          ; shift 16-bit state right; carry = old hi[0]
000F01  1  66 rr           ror rand_seed_lo          ; lo[7] = old hi[0]; carry = old lo[0] (feedback bit)
000F03  1  90 06           bcc @done                 ; feedback bit=0: no XOR
000F05  1  A5 rr           lda rand_seed_hi
000F07  1  49 B4           eor #$B4                  ; XOR hi byte with feedback poly ($B400 >> 8)
000F09  1  85 rr           sta rand_seed_hi
000F0B  1               @done:
000F0B  1  A5 rr           lda rand_seed_lo
000F0D  1  60              rts
000F0E  1               
000F0E  1               ;******************************************************************
000F0E  1               ; update_inv_bullets — fire timer, move active bullets, boundary check,
000F0E  1               ;   update VERA sprites for all 3 invader bullet slots.
000F0E  1               ;******************************************************************
000F0E  1               update_inv_bullets:
000F0E  1                  ; --- fire timer ---
000F0E  1  C6 rr           dec inv_fire_timer
000F10  1  D0 0D           bne @move_loop
000F12  1                  ; reset timer = max(inv_move_speed, INV_FIRE_TIMER_MIN)
000F12  1  A5 rr           lda inv_move_speed
000F14  1  C9 0A           cmp #INV_FIRE_TIMER_MIN
000F16  1  B0 02           bcs @set_timer
000F18  1  A9 0A           lda #INV_FIRE_TIMER_MIN
000F1A  1               @set_timer:
000F1A  1  85 rr           sta inv_fire_timer
000F1C  1  20 89 0F        jsr try_fire_inv_bullet
000F1F  1               
000F1F  1               @move_loop:
000F1F  1  A2 00           ldx #0
000F21  1               @slot_loop:
000F21  1  B5 rr           lda ibul_active,x
000F23  1  F0 1B           beq @update_spr           ; inactive: just hide sprite
000F25  1               
000F25  1                  ; move bullet down by INV_BULLET_SPEED
000F25  1  B5 rr           lda ibul_y_lo,x
000F27  1  18              clc
000F28  1  69 06           adc #INV_BULLET_SPEED
000F2A  1  95 rr           sta ibul_y_lo,x
000F2C  1  B5 rr           lda ibul_y_hi,x
000F2E  1  69 00           adc #0
000F30  1  95 rr           sta ibul_y_hi,x
000F32  1               
000F32  1                  ; boundary: deactivate if Y >= 480 ($01E0)
000F32  1  C9 01           cmp #>480                 ; A = new hi byte; compare with 1
000F34  1  90 0A           bcc @update_spr           ; hi < 1: still on screen
000F36  1  D0 06           bne @deactivate           ; hi > 1: off screen
000F38  1  B5 rr           lda ibul_y_lo,x
000F3A  1  C9 E0           cmp #<480                 ; compare lo with $E0
000F3C  1  90 02           bcc @update_spr           ; lo < $E0: still on screen
000F3E  1               @deactivate:
000F3E  1  74 rr           stz ibul_active,x
000F40  1               
000F40  1               @update_spr:
000F40  1  20 49 0F        jsr update_inv_bullet_sprite   ; preserves X
000F43  1  E8              inx
000F44  1  E0 03           cpx #3
000F46  1  D0 D9           bne @slot_loop
000F48  1  60              rts
000F49  1               
000F49  1               ;******************************************************************
000F49  1               ; update_inv_bullet_sprite — write VERA sprite attrs bytes 2-6 for slot X
000F49  1               ;   X = slot index (0-2).  Preserves X.
000F49  1               ;******************************************************************
000F49  1               update_inv_bullet_sprite:
000F49  1  86 rr           stx zp_scratch_lo              ; preserve slot index
000F4B  1  9C 25 9F        stz VERA_ctrl
000F4E  1  A9 11           lda #$11                       ; stride=1, bank bit=1
000F50  1  8D 22 9F        sta VERA_addr_bank
000F53  1  A9 FC           lda #$FC
000F55  1  8D 21 9F        sta VERA_addr_high
000F58  1  BD 28 13        lda ibul_spr_lo,x
000F5B  1  18              clc
000F5C  1  69 02           adc #2                         ; point to byte 2 (X position)
000F5E  1  8D 20 9F        sta VERA_addr_low
000F61  1  B5 rr           lda ibul_x_lo,x
000F63  1  8D 23 9F        sta VERA_data0                 ; byte 2: X lo
000F66  1  B5 rr           lda ibul_x_hi,x
000F68  1  29 03           and #$03
000F6A  1  8D 23 9F        sta VERA_data0                 ; byte 3: X hi
000F6D  1  B5 rr           lda ibul_y_lo,x
000F6F  1  8D 23 9F        sta VERA_data0                 ; byte 4: Y lo
000F72  1  B5 rr           lda ibul_y_hi,x
000F74  1  29 03           and #$03
000F76  1  8D 23 9F        sta VERA_data0                 ; byte 5: Y hi
000F79  1  B5 rr           lda ibul_active,x
000F7B  1  F0 04           beq @disabled
000F7D  1  A9 0C           lda #SPR_Z_FRONT
000F7F  1  80 02           bra @write_z
000F81  1               @disabled:
000F81  1  A9 00           lda #0
000F83  1               @write_z:
000F83  1  8D 23 9F        sta VERA_data0                 ; byte 6: z-depth
000F86  1  A6 rr           ldx zp_scratch_lo
000F88  1  60              rts
000F89  1               
000F89  1               ;******************************************************************
000F89  1               ; try_fire_inv_bullet — find a free slot and spawn a bullet from the
000F89  1               ;   bottommost live invader in a randomly chosen column.
000F89  1               ;   Returns immediately if all slots busy or chosen column is empty.
000F89  1               ;   Scratch used: zp_row, zp_col, zp_scratch_lo (slot index)
000F89  1               ;******************************************************************
000F89  1               try_fire_inv_bullet:
000F89  1                  ; find a free bullet slot
000F89  1  A2 00           ldx #0
000F8B  1               @find_slot:
000F8B  1  B5 rr           lda ibul_active,x
000F8D  1  F0 06           beq @slot_found
000F8F  1  E8              inx
000F90  1  E0 03           cpx #3
000F92  1  D0 F7           bne @find_slot
000F94  1  60              rts                            ; all slots busy
000F95  1               
000F95  1               @slot_found:
000F95  1  86 rr           stx zp_scratch_lo              ; save free slot index
000F97  1               
000F97  1                  ; pick a random column 0-10
000F97  1  20 FF 0E        jsr prng
000F9A  1  29 0F           and #$0F                       ; 0-15
000F9C  1  C9 0B           cmp #11
000F9E  1  90 03           bcc @col_ok
000FA0  1  38              sec
000FA1  1  E9 0B           sbc #11                        ; wrap 11-15 → 0-4 (slight bias, acceptable)
000FA3  1               @col_ok:
000FA3  1  85 rr           sta zp_col
000FA5  1               
000FA5  1                  ; scan rows 4 down to 0 for bottommost live invader in this column
000FA5  1  A9 04           lda #4
000FA7  1  85 rr           sta zp_row
000FA9  1               @row_scan:
000FA9  1  A4 rr           ldy zp_row
000FAB  1  B9 DE 12        lda inv_row_base,y
000FAE  1  18              clc
000FAF  1  65 rr           adc zp_col
000FB1  1  A8              tay                            ; Y = invader index
000FB2  1  29 07           and #$07
000FB4  1  AA              tax                            ; X = bit position
000FB5  1  BD E3 12        lda bit_masks,x
000FB8  1  48              pha
000FB9  1  98              tya
000FBA  1  4A              lsr
000FBB  1  4A              lsr
000FBC  1  4A              lsr
000FBD  1  A8              tay                            ; Y = byte index into inv_alive
000FBE  1  68              pla
000FBF  1  39 rr rr        and inv_alive,y
000FC2  1  D0 09           bne @found_invader
000FC4  1  A5 rr           lda zp_row
000FC6  1  F0 04           beq @no_invader                ; checked row 0, nothing alive
000FC8  1  C6 rr           dec zp_row
000FCA  1  80 DD           bra @row_scan
000FCC  1               
000FCC  1               @no_invader:
000FCC  1  60              rts                            ; column empty, skip fire
000FCD  1               
000FCD  1               @found_invader:
000FCD  1  A6 rr           ldx zp_scratch_lo              ; restore free slot index
000FCF  1  A9 01           lda #1
000FD1  1  95 rr           sta ibul_active,x
000FD3  1               
000FD3  1                  ; spawn X = inv_grid_x + col_x_offsets[col]  (16-bit, matching update_invader_sprites)
000FD3  1  A4 rr           ldy zp_col
000FD5  1  B9 C3 12        lda col_x_lo,y
000FD8  1  18              clc
000FD9  1  65 rr           adc inv_grid_x_lo
000FDB  1  95 rr           sta ibul_x_lo,x
000FDD  1  B9 CE 12        lda col_x_hi,y
000FE0  1  65 rr           adc inv_grid_x_hi
000FE2  1  95 rr           sta ibul_x_hi,x
000FE4  1                  ; add +4 as a separate 16-bit step to centre the 8px bullet in the 16px invader
000FE4  1  B5 rr           lda ibul_x_lo,x
000FE6  1  18              clc
000FE7  1  69 04           adc #4
000FE9  1  95 rr           sta ibul_x_lo,x
000FEB  1  B5 rr           lda ibul_x_hi,x
000FED  1  69 00           adc #0
000FEF  1  95 rr           sta ibul_x_hi,x
000FF1  1               
000FF1  1                  ; spawn Y: compute y_base first (same two-step pattern as update_invader_sprites)
000FF1  1                  ; step 1: y_base = INV_GRID_Y_BASE + inv_offset_y  (16-bit)
000FF1  1  A9 50           lda #<INV_GRID_Y_BASE
000FF3  1  18              clc
000FF4  1  65 rr           adc inv_offset_y
000FF6  1  85 rr           sta zp_y_base_lo
000FF8  1  A9 00           lda #>INV_GRID_Y_BASE
000FFA  1  69 00           adc #0
000FFC  1  85 rr           sta zp_y_base_hi
000FFE  1                  ; step 2: spawn_y = y_base + row_y_offsets[row]
000FFE  1  A4 rr           ldy zp_row
001000  1  B9 D9 12        lda row_y_offsets,y
001003  1  18              clc
001004  1  65 rr           adc zp_y_base_lo
001006  1  95 rr           sta ibul_y_lo,x
001008  1  A9 00           lda #0
00100A  1  65 rr           adc zp_y_base_hi
00100C  1  95 rr           sta ibul_y_hi,x
00100E  1                  ; step 3: +16 to place bullet at the bottom edge of the 16px invader
00100E  1  B5 rr           lda ibul_y_lo,x
001010  1  18              clc
001011  1  69 10           adc #16
001013  1  95 rr           sta ibul_y_lo,x
001015  1  B5 rr           lda ibul_y_hi,x
001017  1  69 00           adc #0
001019  1  95 rr           sta ibul_y_hi,x
00101B  1               
00101B  1  60              rts
00101C  1               
00101C  1               ;******************************************************************
00101C  1               ; check_inv_bullet_player — AABB test each active invader bullet vs. player
00101C  1               ;
00101C  1               ;   Player rect: (player_x, PLAYER_Y) to (player_x+15, PLAYER_Y+15), 16x16
00101C  1               ;   Bullet rect: (ibul_x,   ibul_y)   to (ibul_x+7,   ibul_y+7),     8x8
00101C  1               ;
00101C  1               ;   On hit: bullet deactivated, jsr player_hit called, loop continues
00101C  1               ;   (remaining bullets checked — at most one hit landing per frame).
00101C  1               ;   Scratch: zp_scratch_lo/hi, X (slot index)
00101C  1               ;******************************************************************
00101C  1               check_inv_bullet_player:
00101C  1  A2 00           ldx #0
00101E  1               @slot_loop:
00101E  1  B5 rr           lda ibul_active,x
001020  1  F0 5B           beq @next_slot
001022  1               
001022  1                  ; --- Y check 1: (bullet_y + 8) > PLAYER_Y  →  bullet_y + 8 - PLAYER_Y > 0 ---
001022  1  B5 rr           lda ibul_y_lo,x
001024  1  18              clc
001025  1  69 08           adc #8
001027  1  85 rr           sta zp_scratch_lo
001029  1  B5 rr           lda ibul_y_hi,x
00102B  1  69 00           adc #0
00102D  1  85 rr           sta zp_scratch_hi
00102F  1  A5 rr           lda zp_scratch_lo
001031  1  38              sec
001032  1  E9 A4           sbc #<PLAYER_Y
001034  1  A5 rr           lda zp_scratch_hi
001036  1  E9 01           sbc #>PLAYER_Y
001038  1  30 43           bmi @next_slot            ; bullet bottom above player top → no hit
00103A  1               
00103A  1                  ; --- Y check 2: bullet_y < PLAYER_Y + 16 → bullet_y - (PLAYER_Y+16) < 0 ---
00103A  1  B5 rr           lda ibul_y_lo,x
00103C  1  38              sec
00103D  1  E9 B4           sbc #<(PLAYER_Y+16)
00103F  1  B5 rr           lda ibul_y_hi,x
001041  1  E9 01           sbc #>(PLAYER_Y+16)
001043  1  10 38           bpl @next_slot            ; bullet top at or below player bottom → no hit
001045  1               
001045  1                  ; --- X check 1: (bullet_x + 8) > player_x ---
001045  1  B5 rr           lda ibul_x_lo,x
001047  1  18              clc
001048  1  69 08           adc #8
00104A  1  85 rr           sta zp_scratch_lo
00104C  1  B5 rr           lda ibul_x_hi,x
00104E  1  69 00           adc #0
001050  1  85 rr           sta zp_scratch_hi
001052  1  A5 rr           lda zp_scratch_lo
001054  1  38              sec
001055  1  E5 rr           sbc player_x_lo
001057  1  A5 rr           lda zp_scratch_hi
001059  1  E5 rr           sbc player_x_hi
00105B  1  30 20           bmi @next_slot            ; bullet right edge left of player → no hit
00105D  1               
00105D  1                  ; --- X check 2: bullet_x < player_x + 16 ---
00105D  1  A5 rr           lda player_x_lo
00105F  1  18              clc
001060  1  69 10           adc #16
001062  1  85 rr           sta zp_scratch_lo
001064  1  A5 rr           lda player_x_hi
001066  1  69 00           adc #0
001068  1  85 rr           sta zp_scratch_hi
00106A  1  B5 rr           lda ibul_x_lo,x
00106C  1  38              sec
00106D  1  E5 rr           sbc zp_scratch_lo
00106F  1  B5 rr           lda ibul_x_hi,x
001071  1  E5 rr           sbc zp_scratch_hi
001073  1  10 08           bpl @next_slot            ; bullet left edge at or right of player → no hit
001075  1               
001075  1                  ; --- HIT ---
001075  1  74 rr           stz ibul_active,x         ; deactivate this bullet
001077  1  20 49 0F        jsr update_inv_bullet_sprite
00107A  1  20 83 10        jsr player_hit
00107D  1               
00107D  1               @next_slot:
00107D  1  E8              inx
00107E  1  E0 03           cpx #3
001080  1  D0 9C           bne @slot_loop
001082  1  60              rts
001083  1               
001083  1               ;******************************************************************
001083  1               ; player_hit — handle a bullet-player collision:
001083  1               ;   explosion at player position, decrement lives, respawn, invincibility
001083  1               ;******************************************************************
001083  1               player_hit:
001083  1                  ; start explosion at player position
001083  1  A5 rr           lda player_x_lo
001085  1  85 rr           sta zp_x_lo
001087  1  A5 rr           lda player_x_hi
001089  1  85 rr           sta zp_x_hi
00108B  1  A9 A4           lda #<PLAYER_Y
00108D  1  85 rr           sta zp_row_y_lo
00108F  1  A9 01           lda #>PLAYER_Y
001091  1  85 rr           sta zp_row_y_hi
001093  1  20 AB 0E        jsr start_explosion
001096  1               
001096  1                  ; decrement lives
001096  1  C6 rr           dec lives
001098  1  F0 0D           beq @game_over            ; lives hit 0 → end game (Phase 6 will handle this properly)
00109A  1               
00109A  1                  ; grant invincibility and re-centre the ship
00109A  1  A9 78           lda #INV_HIT_FRAMES
00109C  1  85 rr           sta inv_hit_timer
00109E  1  A9 38           lda #<PLAYER_X_INIT
0010A0  1  85 rr           sta player_x_lo
0010A2  1  A9 01           lda #>PLAYER_X_INIT
0010A4  1  85 rr           sta player_x_hi
0010A6  1  60              rts
0010A7  1               
0010A7  1               @game_over:
0010A7  1  4C 9E 08        jmp exit_game             ; placeholder: Phase 6 will show a game-over screen
0010AA  1               
0010AA  1               ;******************************************************************
0010AA  1               ; draw_title_screen — print static Phase 1 info to screen
0010AA  1               ;   Called once at startup; static text stays until screen cleared
0010AA  1               ;******************************************************************
0010AA  1               draw_title_screen:
0010AA  1                  ; Row 2, col 14: "X16 INVADERS"
0010AA  1  A9 02           lda #2
0010AC  1  A0 0E           ldy #14
0010AE  1  18              clc
0010AF  1  20 F0 FF        jsr PLOT
0010B2  1  A2 00           ldx #0
0010B4  1  BD 82 11     @lp1: lda str_title,x
0010B7  1  F0 06           beq @lp1_done
0010B9  1  20 D2 FF        jsr CHROUT
0010BC  1  E8              inx
0010BD  1  80 F5           bra @lp1
0010BF  1               @lp1_done:
0010BF  1               
0010BF  1                  ; Row 4, col 10: "PHASE 1 - FOUNDATION"
0010BF  1  A9 04           lda #4
0010C1  1  A0 0A           ldy #10
0010C3  1  18              clc
0010C4  1  20 F0 FF        jsr PLOT
0010C7  1  A2 00           ldx #0
0010C9  1  BD 8F 11     @lp2: lda str_subtitle,x
0010CC  1  F0 06           beq @lp2_done
0010CE  1  20 D2 FF        jsr CHROUT
0010D1  1  E8              inx
0010D2  1  80 F5           bra @lp2
0010D4  1               @lp2_done:
0010D4  1               
0010D4  1                  ; Row 8, col 2: status lines
0010D4  1  A9 08           lda #8
0010D6  1  A0 02           ldy #2
0010D8  1  18              clc
0010D9  1  20 F0 FF        jsr PLOT
0010DC  1  A2 00           ldx #0
0010DE  1  BD A6 11     @lp3: lda str_status_vsync,x
0010E1  1  F0 06           beq @lp3_done
0010E3  1  20 D2 FF        jsr CHROUT
0010E6  1  E8              inx
0010E7  1  80 F5           bra @lp3
0010E9  1               @lp3_done:
0010E9  1               
0010E9  1  A9 0A           lda #10
0010EB  1  A0 02           ldy #2
0010ED  1  18              clc
0010EE  1  20 F0 FF        jsr PLOT
0010F1  1  A2 00           ldx #0
0010F3  1  BD BD 11     @lp4: lda str_status_kbd,x
0010F6  1  F0 06           beq @lp4_done
0010F8  1  20 D2 FF        jsr CHROUT
0010FB  1  E8              inx
0010FC  1  80 F5           bra @lp4
0010FE  1               @lp4_done:
0010FE  1               
0010FE  1  A9 0C           lda #12
001100  1  A0 02           ldy #2
001102  1  18              clc
001103  1  20 F0 FF        jsr PLOT
001106  1  A2 00           ldx #0
001108  1  BD D8 11     @lp5: lda str_status_spr,x
00110B  1  F0 06           beq @lp5_done
00110D  1  20 D2 FF        jsr CHROUT
001110  1  E8              inx
001111  1  80 F5           bra @lp5
001113  1               @lp5_done:
001113  1               
001113  1                  ; Row 15, col 2: exit hint
001113  1  A9 0F           lda #15
001115  1  A0 02           ldy #2
001117  1  18              clc
001118  1  20 F0 FF        jsr PLOT
00111B  1  A2 00           ldx #0
00111D  1  BD EA 11     @lp6: lda str_exit_hint,x
001120  1  F0 06           beq @lp6_done
001122  1  20 D2 FF        jsr CHROUT
001125  1  E8              inx
001126  1  80 F5           bra @lp6
001128  1               @lp6_done:
001128  1               
001128  1  60              rts
001129  1               
001129  1               ;******************************************************************
001129  1               ; update_hud — rewrite dynamic values each frame
001129  1               ;   Overwrites fixed screen positions; no full redraw needed
001129  1               ;******************************************************************
001129  1               update_hud:
001129  1                  ; Frame counter at row 19, col 2
001129  1  A9 13           lda #19
00112B  1  A0 02           ldy #2
00112D  1  18              clc
00112E  1  20 F0 FF        jsr PLOT
001131  1  A2 00           ldx #0
001133  1  BD 01 12     @fc_lbl: lda str_frame_lbl,x
001136  1  F0 06           beq @fc_val
001138  1  20 D2 FF        jsr CHROUT
00113B  1  E8              inx
00113C  1  80 F5           bra @fc_lbl
00113E  1               @fc_val:
00113E  1  A5 rr           lda frame_count
001140  1  20 63 11        jsr print_hex_byte
001143  1               
001143  1                  ; Last key at row 21, col 2
001143  1  A9 15           lda #21
001145  1  A0 02           ldy #2
001147  1  18              clc
001148  1  20 F0 FF        jsr PLOT
00114B  1  A2 00           ldx #0
00114D  1  BD 0D 12     @kl_lbl: lda str_key_lbl,x
001150  1  F0 06           beq @kl_val
001152  1  20 D2 FF        jsr CHROUT
001155  1  E8              inx
001156  1  80 F5           bra @kl_lbl
001158  1               @kl_val:
001158  1  A5 rr           lda key_last
00115A  1  20 63 11        jsr print_hex_byte
00115D  1  A9 20           lda #' '
00115F  1  20 D2 FF        jsr CHROUT                    ; erase stale digit if value shrank
001162  1               
001162  1  60              rts
001163  1               
001163  1               ;******************************************************************
001163  1               ; print_hex_byte — print .A as two uppercase hex digits via CHROUT
001163  1               ;******************************************************************
001163  1               print_hex_byte:
001163  1  48              pha
001164  1  4A              lsr                           ; shift high nibble down
001165  1  4A              lsr
001166  1  4A              lsr
001167  1  4A              lsr
001168  1  20 72 11        jsr print_hex_nybble
00116B  1  68              pla
00116C  1  29 0F           and #$0F                      ; isolate low nibble
00116E  1  20 72 11        jsr print_hex_nybble
001171  1  60              rts
001172  1               
001172  1               ; print_hex_nybble — print lower 4 bits of .A as one hex digit
001172  1               ;   Relies on carry state from CMP to select digit vs. letter range
001172  1               print_hex_nybble:
001172  1  C9 0A           cmp #10
001174  1  90 06           bcc @digit                    ; carry clear → 0-9
001176  1  69 36           adc #($41 - 10 - 1)          ; A-F: 'A'=65; carry set adds 1
001178  1  20 D2 FF        jsr CHROUT
00117B  1  60              rts
00117C  1               @digit:
00117C  1  69 30           adc #$30                      ; 0-9: '0'=48; carry clear adds 0
00117E  1  20 D2 FF        jsr CHROUT
001181  1  60              rts
001182  1               
001182  1               ;******************************************************************
001182  1               ; String data — null-terminated, PETSCII uppercase
001182  1               ;******************************************************************
001182  1               str_title:
001182  1  D8 31 36 20     .byte "X16 INVADERS", 0
001186  1  C9 CE D6 C1  
00118A  1  C4 C5 D2 D3  
00118F  1               str_subtitle:
00118F  1  D0 C8 C1 D3     .byte "PHASE 3 - INVADER GRID", 0
001193  1  C5 20 33 20  
001197  1  2D 20 C9 CE  
0011A6  1               str_status_vsync:
0011A6  1  D6 D3 D9 CE     .byte "VSYNC : WAI (60HZ IRQ)", 0
0011AA  1  C3 20 3A 20  
0011AE  1  D7 C1 C9 20  
0011BD  1               str_status_kbd:
0011BD  1  CB C5 D9 C2     .byte "KEYBOARD: JOYSTICK + GETIN", 0
0011C1  1  CF C1 D2 C4  
0011C5  1  3A 20 CA CF  
0011D8  1               str_status_spr:
0011D8  1  D3 D0 D2 C9     .byte "SPRITES : ENABLED", 0
0011DC  1  D4 C5 D3 20  
0011E0  1  3A 20 C5 CE  
0011EA  1               str_exit_hint:
0011EA  1  D0 D2 C5 D3     .byte "PRESS RUN/STOP TO EXIT", 0
0011EE  1  D3 20 D2 D5  
0011F2  1  CE 2F D3 D4  
001201  1               str_frame_lbl:
001201  1  C6 D2 C1 CD     .byte "FRAME   : $", 0
001205  1  C5 20 20 20  
001209  1  3A 20 24 00  
00120D  1               str_key_lbl:
