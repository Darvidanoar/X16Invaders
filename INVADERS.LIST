001864  1               ;******************************************************************
001864  1               ; update_shield_sprite — write new data-addr byte to shield sprite N
001864  1               ;   Input:  X = shield index (0–3)
001864  1               ;           shield_damage[X] = current damage level (1–7)
001864  1               ;   Writes sprite byte 0 (addr[12:5]) using shield_addr_b0 lookup.
001864  1               ;   VERA addr for byte 0 of sprite N: $1FE10 + N*8
001864  1               ;******************************************************************
001864  1               update_shield_sprite:
001864  1  9C 25 9F        stz VERA_ctrl
001867  1  A9 11           lda #$11               ; stride=1, bank=1
001869  1  8D 22 9F        sta VERA_addr_bank
00186C  1  A9 FE           lda #$FE
00186E  1  8D 21 9F        sta VERA_addr_high
001871  1  8A              txa                    ; A = shield index
001872  1  0A              asl                    ; ×2
001873  1  0A              asl                    ; ×4
001874  1  0A              asl                    ; ×8
001875  1  18              clc
001876  1  69 10           adc #$10               ; + low byte of $1FE10
001878  1  8D 20 9F        sta VERA_addr_low
00187B  1  B4 rr           ldy shield_damage, x   ; Y = damage level (1-3)
00187D  1  B9 4A 1F        lda shield_addr_b0, y  ; addr[12:5] for this tile
001880  1  8D 23 9F        sta VERA_data0
001883  1  60              rts
001884  1               
001884  1               ;******************************************************************
001884  1               ; hide_shield_sprite — disable sprite for shield N (z-depth=0)
001884  1               ;   Input: X = shield index (0–3)
001884  1               ;   Writes sprite byte 6 at $1FE10 + N*8 + 6 = $1FE16 + N*8
001884  1               ;******************************************************************
001884  1               hide_shield_sprite:
001884  1  9C 25 9F        stz VERA_ctrl
001887  1  A9 11           lda #$11
001889  1  8D 22 9F        sta VERA_addr_bank
00188C  1  A9 FE           lda #$FE
00188E  1  8D 21 9F        sta VERA_addr_high
001891  1  8A              txa
001892  1  0A              asl
001893  1  0A              asl
001894  1  0A              asl
001895  1  18              clc
001896  1  69 16           adc #$16               ; low($1FE10) + 6 = $16, + N*8
001898  1  8D 20 9F        sta VERA_addr_low
00189B  1  A9 00           lda #0                 ; z-depth=0 → sprite disabled
00189D  1  8D 23 9F        sta VERA_data0
0018A0  1  60              rts
0018A1  1               
0018A1  1               ;******************************************************************
0018A1  1               ; damage_shield — increment damage counter for shield X and update
0018A1  1               ;   sprite (or disable it when counter reaches 8 = destroyed).
0018A1  1               ;   Input:  X = shield index (0–3)
0018A1  1               ;   Clobbers: A, Y, VERA registers.  Preserves X.
0018A1  1               ;******************************************************************
0018A1  1               damage_shield:
0018A1  1  F6 rr           inc shield_damage, x
0018A3  1  B5 rr           lda shield_damage, x
0018A5  1  C9 08           cmp #8
0018A7  1  F0 06           beq @destroy
0018A9  1  B0 07           bcs @done              ; already at 8 (safety guard)
0018AB  1  20 64 18        jsr update_shield_sprite
0018AE  1  60              rts
0018AF  1               @destroy:
0018AF  1  20 84 18        jsr hide_shield_sprite
0018B2  1               @done:
0018B2  1  60              rts
0018B3  1               
0018B3  1               ;******************************************************************
0018B3  1               ; check_bullet_shields — test active player bullet vs all 4 shields
0018B3  1               ;
0018B3  1               ;   Overlap condition (AABB, all values VERA 16-bit):
0018B3  1               ;     X: bullet_x+8 > shield_x  AND  bullet_x < shield_x+16
0018B3  1               ;     Y: bullet_y+8 > SHIELD_Y  AND  bullet_y < SHIELD_Y+16
0018B3  1               ;
0018B3  1               ;   On hit: calls damage_shield, deactivates bullet, returns.
0018B3  1               ;   Scratch used: zp_scratch_lo/hi.  Preserves nothing.
0018B3  1               ;******************************************************************
0018B3  1               check_bullet_shields:
0018B3  1  A5 rr           lda bullet_active
0018B5  1  F0 6D           beq @done
0018B7  1               
0018B7  1                  ; --- Y quick check (same band for all shields) ---
0018B7  1                  ; (1) bullet_y+8 > SHIELD_Y
0018B7  1  A5 rr           lda bullet_y_lo
0018B9  1  18              clc
0018BA  1  69 08           adc #8
0018BC  1  85 rr           sta zp_scratch_lo
0018BE  1  A5 rr           lda bullet_y_hi
0018C0  1  69 00           adc #0
0018C2  1  85 rr           sta zp_scratch_hi
0018C4  1  A5 rr           lda zp_scratch_lo
0018C6  1  38              sec
0018C7  1  E9 60           sbc #<SHIELD_Y
0018C9  1  A5 rr           lda zp_scratch_hi
0018CB  1  E9 01           sbc #>SHIELD_Y
0018CD  1  30 55           bmi @done              ; bullet bottom above shield top
0018CF  1               
0018CF  1                  ; (2) bullet_y < SHIELD_Y+32
0018CF  1  A5 rr           lda bullet_y_lo
0018D1  1  38              sec
0018D2  1  E9 80           sbc #<(SHIELD_Y + 32)
0018D4  1  A5 rr           lda bullet_y_hi
0018D6  1  E9 01           sbc #>(SHIELD_Y + 32)
0018D8  1  10 4A           bpl @done              ; bullet top at or below shield bottom
0018DA  1               
0018DA  1                  ; --- Y overlaps: scan each shield ---
0018DA  1  A2 00           ldx #0
0018DC  1               @sld_loop:
0018DC  1  B5 rr           lda shield_damage, x
0018DE  1  C9 08           cmp #8
0018E0  1  B0 3D           bcs @next_sld          ; destroyed, skip
0018E2  1               
0018E2  1                  ; X check (1): bullet_x+8 > shield_x[x]
0018E2  1  A5 rr           lda bullet_x_lo
0018E4  1  18              clc
0018E5  1  69 08           adc #8
0018E7  1  85 rr           sta zp_scratch_lo
0018E9  1  A5 rr           lda bullet_x_hi
0018EB  1  69 00           adc #0
0018ED  1  85 rr           sta zp_scratch_hi
0018EF  1  A5 rr           lda zp_scratch_lo
0018F1  1  38              sec
0018F2  1  FD 42 1F        sbc shield_x_lo, x
0018F5  1  A5 rr           lda zp_scratch_hi
0018F7  1  FD 46 1F        sbc shield_x_hi, x
0018FA  1  30 23           bmi @next_sld
0018FC  1               
0018FC  1                  ; X check (2): bullet_x < shield_x[x]+32
0018FC  1  BD 42 1F        lda shield_x_lo, x
0018FF  1  18              clc
001900  1  69 20           adc #32
001902  1  85 rr           sta zp_scratch_lo
001904  1  BD 46 1F        lda shield_x_hi, x
001907  1  69 00           adc #0
001909  1  85 rr           sta zp_scratch_hi
00190B  1  A5 rr           lda bullet_x_lo
00190D  1  38              sec
00190E  1  E5 rr           sbc zp_scratch_lo
001910  1  A5 rr           lda bullet_x_hi
001912  1  E5 rr           sbc zp_scratch_hi
001914  1  10 09           bpl @next_sld
001916  1               
001916  1                  ; --- HIT ---
001916  1  20 A1 18        jsr damage_shield      ; X = shield index
001919  1  64 rr           stz bullet_active
00191B  1  20 66 0E        jsr update_bullet_sprite
00191E  1  60              rts
00191F  1               
00191F  1               @next_sld:
00191F  1  E8              inx
001920  1  E0 04           cpx #4
001922  1  D0 B8           bne @sld_loop
001924  1               @done:
001924  1  60              rts
