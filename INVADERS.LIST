001639  1  E8              inx
00163A  1  D0 F7           bne @up_s0b
00163C  1  A2 80           ldx #128
00163E  1  BD C6 23     @up_s0c: lda shield_tile_full + 128, x
001641  1  8D 23 9F        sta VERA_data0
001644  1  E8              inx
001645  1  D0 F7           bne @up_s0c
001647  1  A2 80           ldx #128
001649  1  BD 46 24     @up_s0d: lda shield_tile_full + 256, x
00164C  1  8D 23 9F        sta VERA_data0
00164F  1  E8              inx
001650  1  D0 F7           bne @up_s0d
