0012D5  1               ;******************************************************************
0012D5  1               ; update_hi_score — copy score → hi_score when score > hi_score
0012D5  1               ;   BCD compare: check hi byte, then mid, then lo.
0012D5  1               ;******************************************************************
0012D5  1               update_hi_score:
0012D5  1  A5 rr           lda score_hi
0012D7  1  C5 rr           cmp hi_score_hi
0012D9  1  90 1E           bcc @no_update
0012DB  1  D0 10           bne @do_update
0012DD  1  A5 rr           lda score_mid
0012DF  1  C5 rr           cmp hi_score_mid
0012E1  1  90 16           bcc @no_update
0012E3  1  D0 08           bne @do_update
0012E5  1  A5 rr           lda score_lo
0012E7  1  C5 rr           cmp hi_score_lo
0012E9  1  90 0E           bcc @no_update
0012EB  1  F0 0C           beq @no_update            ; equal → no change
0012ED  1               @do_update:
0012ED  1  A5 rr           lda score_lo
0012EF  1  85 rr           sta hi_score_lo
0012F1  1  A5 rr           lda score_mid
0012F3  1  85 rr           sta hi_score_mid
0012F5  1  A5 rr           lda score_hi
0012F7  1  85 rr           sta hi_score_hi
0012F9  1               @no_update:
0012F9  1  60              rts
