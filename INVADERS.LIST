00144F  1               ;******************************************************************
00144F  1               ; print_dec_byte — print .A as 1 or 2 decimal digits (values 0-99)
00144F  1               ;   Suppresses leading zero for single-digit numbers.
00144F  1               ;   Clobbers: A, X.  Carry is cleared on exit.
00144F  1               ;******************************************************************
00144F  1               print_dec_byte:
00144F  1  A2 00           ldx #0
001451  1               @pdb_loop:
001451  1  C9 0A           cmp #10
001453  1  90 05           bcc @pdb_units            ; A < 10 → done dividing
001455  1  E8              inx
001456  1  E9 0A           sbc #10                   ; carry is set by cmp, so sbc = A - 10
001458  1  80 F7           bra @pdb_loop
00145A  1               @pdb_units:
00145A  1  48              pha                       ; save units digit
00145B  1  8A              txa                       ; tens digit count
00145C  1  F0 05           beq @pdb_skip_tens        ; zero → suppress leading zero
00145E  1  69 30           adc #$30                  ; carry=0 here (from last bcc), so adc = X + $30
001460  1  20 D2 FF        jsr CHROUT
001463  1               @pdb_skip_tens:
001463  1  68              pla                       ; units digit (0-9; carry=0)
001464  1  69 30           adc #$30
001466  1  20 D2 FF        jsr CHROUT
001469  1  60              rts
