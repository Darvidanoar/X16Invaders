001434  1               ;******************************************************************
001434  1               ; draw_title_screen — paint the title screen; called once before title_loop
001434  1               ;
001434  1               ;   Layout (40-col text, VERA Y=row*16):
001434  1               ;     Row  1, col 14: "X16 INVADERS"      (12 chars, centred)
001434  1               ;     Row  3, col 16: "HI-SCORE"          (8 chars, centred)
001434  1               ;     Row  4, col 17: 000000              (6-digit BCD hi-score)
001434  1               ;     Row  5, col  5: "?UFO? = ??? PTS"
001434  1               ;     Row  7, col  9: "= 30 PTS"          + Type C sprite at X=96,Y=112
001434  1               ;     Row 10, col  9: "= 20 PTS"          + Type B sprite at X=96,Y=160
001434  1               ;     Row 13, col  9: "= 10 PTS"          + Type A sprite at X=96,Y=208
