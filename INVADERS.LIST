0013FF  1               ;******************************************************************
0013FF  1               ; draw_title_screen — paint the title screen; called once before title_loop
0013FF  1               ;
0013FF  1               ;   Layout (40-col text, VERA Y=row*16):
0013FF  1               ;     Row  1, col 14: "X16 INVADERS"      (12 chars, centred)
0013FF  1               ;     Row  3, col 16: "HI-SCORE"          (8 chars, centred)
0013FF  1               ;     Row  4, col 17: 000000              (6-digit BCD hi-score)
0013FF  1               ;     Row  5, col  5: "?UFO? = ??? PTS"
0013FF  1               ;     Row  7, col  9: "= 30 PTS"          + Type C sprite at X=96,Y=112
0013FF  1               ;     Row 10, col  9: "= 20 PTS"          + Type B sprite at X=96,Y=160
0013FF  1               ;     Row 13, col  9: "= 10 PTS"          + Type A sprite at X=96,Y=208
0013FF  1               ;     Row 17, col 10: (PRESS SPACE TO START — blinked by title_loop)
0013FF  1               ;     Row 19, col 12: "RUN/STOP TO QUIT"
0013FF  1               ;******************************************************************
0013FF  1               draw_title_screen:
0013FF  1                  ; Row 1, col 14: "X16 INVADERS"
0013FF  1  A9 01           lda #1
001401  1  A0 0E           ldy #14
001403  1  18              clc
001404  1  20 F0 FF        jsr PLOT
001407  1  A2 00           ldx #0
001409  1  BD 38 1B     @lp1: lda str_title_main, x
00140C  1  F0 06           beq @lp1_done
00140E  1  20 D2 FF        jsr CHROUT
001411  1  E8              inx
001412  1  80 F5           bra @lp1
001414  1               @lp1_done:
001414  1               
001414  1                  ; Row 3, col 16: "HI-SCORE"
001414  1  A9 03           lda #3
001416  1  A0 10           ldy #16
001418  1  18              clc
001419  1  20 F0 FF        jsr PLOT
00141C  1  A2 00           ldx #0
00141E  1  BD 4B 1B     @lp2: lda str_hi_score_lbl, x
001421  1  F0 06           beq @lp2_done
001423  1  20 D2 FF        jsr CHROUT
001426  1  E8              inx
001427  1  80 F5           bra @lp2
001429  1               @lp2_done:
001429  1               
001429  1                  ; Row 4, col 17: hi-score 6 BCD digits (000000 at start)
001429  1  A9 04           lda #4
00142B  1  A0 11           ldy #17
00142D  1  18              clc
00142E  1  20 F0 FF        jsr PLOT
001431  1  A5 rr           lda hi_score_hi
001433  1  20 19 1B        jsr print_hex_byte
001436  1  A5 rr           lda hi_score_mid
001438  1  20 19 1B        jsr print_hex_byte
00143B  1  A5 rr           lda hi_score_lo
00143D  1  20 19 1B        jsr print_hex_byte
001440  1               
001440  1                  ; Row 5, col 5: "?UFO? = ??? PTS"
001440  1  A9 05           lda #5
001442  1  A0 05           ldy #5
001444  1  18              clc
001445  1  20 F0 FF        jsr PLOT
001448  1  A2 00           ldx #0
00144A  1  BD 54 1B     @lp3: lda str_ufo_score, x
00144D  1  F0 06           beq @lp3_done
00144F  1  20 D2 FF        jsr CHROUT
001452  1  E8              inx
001453  1  80 F5           bra @lp3
001455  1               @lp3_done:
