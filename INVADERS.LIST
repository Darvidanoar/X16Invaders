000810  1               
000810  1               ;******************************************************************
000810  1               ; Constants
000810  1               ;******************************************************************
000810  1               
000810  1               ; VERA display control
000810  1               VERA_SPRITE_EN  = %01000000      ; VERA_dc_video bit 6: enable sprites
000810  1               
000810  1               ; PETSCII control codes
000810  1               PETSCII_WHITE   = $05            ; set text color to white
000810  1               PETSCII_CLR     = $93            ; clear screen and home cursor
000810  1               PETSCII_HOME    = $13            ; home cursor (no clear)
000810  1               PETSCII_RETURN  = $0D            ; carriage return
000810  1               
000810  1               ; SCREEN_SET_CHARSET font numbers (call address $FF62)
000810  1               CHARSET_UPPER   = 1              ; Commodore upper/graphics: $41-$5A = A-Z
000810  1               CHARSET_LOWER   = 2              ; Commodore lower/upper:    $41-$5A = a-z (lowercase)
000810  1               
000810  1               ; Key codes (PETSCII)
000810  1               KEY_RUN_STOP    = $03            ; RUN/STOP — exit game
000810  1               
000810  1               ;******************************************************************
000810  1               ; start — main program entry point
000810  1               ;******************************************************************
000810  1               start:
000810  1  78              sei                           ; disable interrupts during init
000811  1               
000811  1                  ; Switch to 40-column text mode (mode 0)
000811  1                  ; Carry clear = SET mode (carry set = READ mode)
000811  1  18              clc
000812  1  A9 00           lda #$00
000814  1  20 5F FF        jsr SCREEN_MODE
000817  1               
000817  1                  ; Seed PRNG with hardware entropy
000817  1  20 CF FE        jsr ENTROPY_GET
00081A  1  85 rr           sta rand_seed_lo
00081C  1  86 rr           stx rand_seed_hi
00081E  1               
00081E  1                  ; Enable sprites in VERA display controller
00081E  1  9C 25 9F        stz VERA_ctrl                 ; DCSEL=0, ADDRSEL=0
000821  1  AD 29 9F        lda VERA_dc_video
000824  1  09 40           ora #VERA_SPRITE_EN
000826  1  8D 29 9F        sta VERA_dc_video
000829  1               
000829  1                  ; Clear game variables
000829  1  64 rr           stz key_last
00082B  1  64 rr           stz frame_count
00082D  1               
00082D  1  58              cli                           ; re-enable interrupts
00082E  1               
00082E  1                  ; Switch to Commodore uppercase/graphics charset: $41-$5A = A-Z
00082E  1                  ; Must be called AFTER SCREEN_MODE (which resets to lowercase by default)
00082E  1  A9 01           lda #CHARSET_UPPER
000830  1  20 62 FF        jsr SCREEN_SET_CHARSET
000833  1               
000833  1                  ; Clear screen and set text color
000833  1  A9 05           lda #PETSCII_WHITE
000835  1  20 D2 FF        jsr CHROUT
000838  1  A9 93           lda #PETSCII_CLR
00083A  1  20 D2 FF        jsr CHROUT
00083D  1               
00083D  1  20 75 08        jsr draw_title_screen
000840  1               
000840  1               ;******************************************************************
000840  1               ; main_loop — one iteration per video frame (60 Hz)
000840  1               ;******************************************************************
000840  1               main_loop:
000840  1  20 5C 08        jsr wait_vsync
000843  1               
000843  1  E6 rr           inc frame_count
000845  1               
000845  1  20 69 08        jsr read_keyboard             ; fills key_last
000848  1               
000848  1  A5 rr           lda key_last
00084A  1  C9 03           cmp #KEY_RUN_STOP
00084C  1  F0 06           beq exit_game
00084E  1               
00084E  1  20 F4 08        jsr update_hud                ; refresh dynamic readouts
000851  1               
000851  1  4C 40 08        jmp main_loop
000854  1               
000854  1               ;------------------------------------------------------------------
000854  1               exit_game:
000854  1  A9 93           lda #PETSCII_CLR
000856  1  20 D2 FF        jsr CHROUT
000859  1  4C 47 FF        jmp ENTER_BASIC
00085C  1               
00085C  1               ;******************************************************************
00085C  1               ; wait_vsync — busy-poll VERA_isr until VSYNC, then clear flag
00085C  1               ;******************************************************************
00085C  1               wait_vsync:
00085C  1               @poll:
00085C  1  AD 27 9F        lda VERA_isr
00085F  1  29 01           and #$01                      ; bit 0 = VSYNC interrupt
000861  1  F0 F9           beq @poll
000863  1  A9 01           lda #$01
000865  1  8D 27 9F        sta VERA_isr                  ; write 1 to clear VSYNC bit only
000868  1  60              rts
000869  1               
000869  1               ;******************************************************************
000869  1               ; read_keyboard — drain GETIN buffer; key_last = last key seen
000869  1               ;   key_last = $00 means no key was pressed this frame
000869  1               ;******************************************************************
000869  1               read_keyboard:
000869  1  64 rr           stz key_last                  ; clear before each frame's poll
00086B  1               @drain:
00086B  1  20 E4 FF        jsr GETIN
00086E  1  F0 04           beq @done                     ; Z=1 → buffer empty
000870  1  85 rr           sta key_last
000872  1  80 F7           bra @drain                    ; keep draining buffer
000874  1               @done:
000874  1  60              rts
000875  1               
000875  1               ;******************************************************************
000875  1               ; draw_title_screen — print static Phase 1 info to screen
000875  1               ;   Called once at startup; static text stays until screen cleared
000875  1               ;******************************************************************
000875  1               draw_title_screen:
000875  1                  ; Row 2, col 14: "X16 INVADERS"
000875  1  A9 02           lda #2
000877  1  A0 0E           ldy #14
000879  1  18              clc
00087A  1  20 F0 FF        jsr PLOT
00087D  1  A2 00           ldx #0
00087F  1  BD 4D 09     @lp1: lda str_title,x
000882  1  F0 06           beq @lp1_done
000884  1  20 D2 FF        jsr CHROUT
000887  1  E8              inx
000888  1  80 F5           bra @lp1
00088A  1               @lp1_done:
00088A  1               
00088A  1                  ; Row 4, col 10: "PHASE 1 - FOUNDATION"
00088A  1  A9 04           lda #4
00088C  1  A0 0A           ldy #10
00088E  1  18              clc
00088F  1  20 F0 FF        jsr PLOT
000892  1  A2 00           ldx #0
000894  1  BD 5A 09     @lp2: lda str_subtitle,x
000897  1  F0 06           beq @lp2_done
000899  1  20 D2 FF        jsr CHROUT
00089C  1  E8              inx
00089D  1  80 F5           bra @lp2
00089F  1               @lp2_done:
00089F  1               
00089F  1                  ; Row 8, col 2: status lines
00089F  1  A9 08           lda #8
0008A1  1  A0 02           ldy #2
0008A3  1  18              clc
0008A4  1  20 F0 FF        jsr PLOT
0008A7  1  A2 00           ldx #0
0008A9  1  BD 6F 09     @lp3: lda str_status_vsync,x
0008AC  1  F0 06           beq @lp3_done
0008AE  1  20 D2 FF        jsr CHROUT
0008B1  1  E8              inx
0008B2  1  80 F5           bra @lp3
0008B4  1               @lp3_done:
0008B4  1               
0008B4  1  A9 0A           lda #10
0008B6  1  A0 02           ldy #2
0008B8  1  18              clc
0008B9  1  20 F0 FF        jsr PLOT
0008BC  1  A2 00           ldx #0
0008BE  1  BD 89 09     @lp4: lda str_status_kbd,x
0008C1  1  F0 06           beq @lp4_done
0008C3  1  20 D2 FF        jsr CHROUT
0008C6  1  E8              inx
0008C7  1  80 F5           bra @lp4
0008C9  1               @lp4_done:
0008C9  1               
0008C9  1  A9 0C           lda #12
0008CB  1  A0 02           ldy #2
0008CD  1  18              clc
0008CE  1  20 F0 FF        jsr PLOT
0008D1  1  A2 00           ldx #0
0008D3  1  BD A4 09     @lp5: lda str_status_spr,x
0008D6  1  F0 06           beq @lp5_done
0008D8  1  20 D2 FF        jsr CHROUT
0008DB  1  E8              inx
0008DC  1  80 F5           bra @lp5
0008DE  1               @lp5_done:
0008DE  1               
0008DE  1                  ; Row 15, col 2: exit hint
0008DE  1  A9 0F           lda #15
0008E0  1  A0 02           ldy #2
0008E2  1  18              clc
0008E3  1  20 F0 FF        jsr PLOT
0008E6  1  A2 00           ldx #0
0008E8  1  BD B6 09     @lp6: lda str_exit_hint,x
0008EB  1  F0 06           beq @lp6_done
0008ED  1  20 D2 FF        jsr CHROUT
0008F0  1  E8              inx
0008F1  1  80 F5           bra @lp6
0008F3  1               @lp6_done:
0008F3  1               
0008F3  1  60              rts
0008F4  1               
0008F4  1               ;******************************************************************
0008F4  1               ; update_hud — rewrite dynamic values each frame
0008F4  1               ;   Overwrites fixed screen positions; no full redraw needed
0008F4  1               ;******************************************************************
0008F4  1               update_hud:
0008F4  1                  ; Frame counter at row 19, col 2
0008F4  1  A9 13           lda #19
0008F6  1  A0 02           ldy #2
0008F8  1  18              clc
0008F9  1  20 F0 FF        jsr PLOT
0008FC  1  A2 00           ldx #0
0008FE  1  BD CD 09     @fc_lbl: lda str_frame_lbl,x
000901  1  F0 06           beq @fc_val
000903  1  20 D2 FF        jsr CHROUT
000906  1  E8              inx
000907  1  80 F5           bra @fc_lbl
000909  1               @fc_val:
000909  1  A5 rr           lda frame_count
00090B  1  20 2E 09        jsr print_hex_byte
