000000r 1               .segment "ZEROPAGE"
000000r 1               ; Zero Page variables ($22-$7F available)
000000r 1               
000000r 1  xx           key_last:       .res 1           ; most recent PETSCII key from GETIN ($00 = none)
000001r 1  xx           frame_count:    .res 1           ; wrapping frame counter (increments each VSYNC)
000002r 1  xx           rand_seed_lo:   .res 1           ; PRNG state - low byte
000003r 1  xx           rand_seed_hi:   .res 1           ; PRNG state - high byte
000004r 1  xx           player_x_lo:    .res 1           ; player X position, low byte  (VERA 640x480 space)
000005r 1  xx           player_x_hi:    .res 1           ; player X position, high byte (bits 1-0 only)
000006r 1  xx           key_flags:      .res 1           ; input flags this frame (see KEY_* constants)
000007r 1               
