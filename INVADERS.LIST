00158B  1               ;******************************************************************
00158B  1               ; hide_all_inv_sprites — set z-depth=0 for all 55 invader sprites
00158B  1               ;   Uses VERA stride=8 to write only byte 6 (z-depth) of each block.
00158B  1               ;   First invader sprite byte 6: $1FC00 + 11*8 + 6 = $1FC5E
00158B  1               ;******************************************************************
00158B  1               hide_all_inv_sprites:
00158B  1  9C 25 9F        stz VERA_ctrl
00158E  1  A9 41           lda #$41               ; stride=8 (code $4 in high nibble), bank=1
001590  1  8D 22 9F        sta VERA_addr_bank
001593  1  A9 FC           lda #$FC
001595  1  8D 21 9F        sta VERA_addr_high
001598  1  A9 5E           lda #$5E               ; low byte of $1FC5E  ($1FC58+6)
00159A  1  8D 20 9F        sta VERA_addr_low
00159D  1  A9 00           lda #0                 ; z-depth=0 → disabled
00159F  1  A2 37           ldx #55
0015A1  1               @loop:
0015A1  1  8D 23 9F        sta VERA_data0         ; writes byte 6; addr auto-advances by 8
0015A4  1  CA              dex
0015A5  1  D0 FA           bne @loop
0015A7  1  60              rts
