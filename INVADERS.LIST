0017B5  1               
0017B5  1               ;******************************************************************
0017B5  1               ; snd_start_ufo_drone — enable VERA PSG voice 3 (sawtooth, full vol, freq1)
0017B5  1               ;   Called once when UFO spawns.
0017B5  1               ;******************************************************************
0017B5  1               snd_start_ufo_drone:
0017B5  1  9C 25 9F        stz VERA_ctrl
0017B8  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
0017BC  1  9F A9 F9 8D  
0017C0  1  21 9F A9 CC  
0017C7  1  A9 32           lda #<UFO_DRONE_FREQ1
0017C9  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L
0017CC  1  A9 04           lda #>UFO_DRONE_FREQ1
0017CE  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
0017D1  1  A9 FF           lda #PSG_VOL_FULL
0017D3  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
0017D6  1  A9 40           lda #PSG_WAVE_SAW
0017D8  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
0017DB  1  60              rts
0017DC  1               
0017DC  1               ;******************************************************************
0017DC  1               ; snd_stop_ufo_drone — silence VERA PSG voice 3
0017DC  1               ;   Called when UFO leaves screen or is destroyed.
0017DC  1               ;******************************************************************
0017DC  1               snd_stop_ufo_drone:
0017DC  1  9C 25 9F        stz VERA_ctrl
0017DF  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE3 + 2), 1   ; byte 2 = volume/enable
0017E3  1  9F A9 F9 8D  
0017E7  1  21 9F A9 CE  
0017EE  1  A9 00           lda #$00
0017F0  1  8D 23 9F        sta VERA_data0               ; zero volume → silent
0017F3  1  60              rts
0017F4  1               
0017F4  1               ;******************************************************************
0017F4  1               ; snd_update_ufo_drone — warble between freq1/freq2 using frame_count
0017F4  1               ;   bit 3 (flips every 8 frames ≈ 3.75 Hz wobble rate).
0017F4  1               ;   Call every frame while UFO is active.
0017F4  1               ;   Rewrites all 4 voice bytes (keeps volume/waveform stable).
0017F4  1               ;******************************************************************
0017F4  1               snd_update_ufo_drone:
0017F4  1  9C 25 9F        stz VERA_ctrl
0017F7  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
0017FB  1  9F A9 F9 8D  
0017FF  1  21 9F A9 CC  
001806  1  A5 rr           lda frame_count
001808  1  29 08           and #$08                     ; bit 3: 0 for 8 frames, 1 for 8 frames
00180A  1  D0 09           bne @freq2
00180C  1  A9 32           lda #<UFO_DRONE_FREQ1
00180E  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L (freq1)
001811  1  A9 04           lda #>UFO_DRONE_FREQ1
001813  1  80 07           bra @rest
001815  1               @freq2:
001815  1  A9 4B           lda #<UFO_DRONE_FREQ2
001817  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L (freq2)
00181A  1  A9 06           lda #>UFO_DRONE_FREQ2
00181C  1               @rest:
00181C  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
00181F  1  A9 FF           lda #PSG_VOL_FULL
001821  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001824  1  A9 40           lda #PSG_WAVE_SAW
001826  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
001829  1  60              rts
00182A  1               
00182A  1               ;******************************************************************
00182A  1               ; update_hud — rewrite dynamic values each frame
00182A  1               ;   Overwrites fixed screen positions; no full redraw needed
00182A  1               ;******************************************************************
00182A  1               update_hud:
00182A  1                  ; Frame counter at row 19, col 2
00182A  1  A9 13           lda #19
00182C  1  A0 02           ldy #2
00182E  1  18              clc
00182F  1  20 F0 FF        jsr PLOT
001832  1  A2 00           ldx #0
001834  1  BD EA 18     @fc_lbl: lda str_frame_lbl,x
001837  1  F0 06           beq @fc_val
001839  1  20 D2 FF        jsr CHROUT
00183C  1  E8              inx
00183D  1  80 F5           bra @fc_lbl
00183F  1               @fc_val:
00183F  1  A5 rr           lda frame_count
001841  1  20 64 18        jsr print_hex_byte
001844  1               
001844  1                  ; Last key at row 21, col 2
001844  1  A9 15           lda #21
001846  1  A0 02           ldy #2
001848  1  18              clc
001849  1  20 F0 FF        jsr PLOT
00184C  1  A2 00           ldx #0
00184E  1  BD F6 18     @kl_lbl: lda str_key_lbl,x
001851  1  F0 06           beq @kl_val
001853  1  20 D2 FF        jsr CHROUT
001856  1  E8              inx
001857  1  80 F5           bra @kl_lbl
001859  1               @kl_val:
001859  1  A5 rr           lda key_last
00185B  1  20 64 18        jsr print_hex_byte
00185E  1  A9 20           lda #' '
001860  1  20 D2 FF        jsr CHROUT                    ; erase stale digit if value shrank
001863  1               
001863  1  60              rts
001864  1               
001864  1               ;******************************************************************
001864  1               ; print_hex_byte — print .A as two uppercase hex digits via CHROUT
001864  1               ;******************************************************************
001864  1               print_hex_byte:
001864  1  48              pha
001865  1  4A              lsr                           ; shift high nibble down
001866  1  4A              lsr
001867  1  4A              lsr
001868  1  4A              lsr
001869  1  20 73 18        jsr print_hex_nybble
00186C  1  68              pla
00186D  1  29 0F           and #$0F                      ; isolate low nibble
00186F  1  20 73 18        jsr print_hex_nybble
001872  1  60              rts
001873  1               
001873  1               ; print_hex_nybble — print lower 4 bits of .A as one hex digit
001873  1               ;   Relies on carry state from CMP to select digit vs. letter range
001873  1               print_hex_nybble:
001873  1  C9 0A           cmp #10
001875  1  90 06           bcc @digit                    ; carry clear → 0-9
001877  1  69 36           adc #($41 - 10 - 1)          ; A-F: 'A'=65; carry set adds 1
001879  1  20 D2 FF        jsr CHROUT
00187C  1  60              rts
00187D  1               @digit:
00187D  1  69 30           adc #$30                      ; 0-9: '0'=48; carry clear adds 0
00187F  1  20 D2 FF        jsr CHROUT
001882  1  60              rts
