001573  1  8D 23 9F        sta VERA_data0
001576  1  A9 00           lda #0
001578  1  8D 23 9F        sta VERA_data0
00157B  1  A9 0C           lda #SPR_Z_FRONT
00157D  1  8D 23 9F        sta VERA_data0
001580  1  A9 50           lda #SPR_16x16_PAL0
001582  1  8D 23 9F        sta VERA_data0
001585  1               
001585  1  A2 15           ldx #21
001587  1  A0 0F           ldy #15
001589  1  18              clc
00158A  1  20 F0 FF        jsr PLOT
00158D  1  A2 00           ldx #0
00158F  1  BD 80 1D     @lp_b: lda str_score_b, x
001592  1  F0 06           beq @lp_b_done
