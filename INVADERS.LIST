000000r 1               .segment "ZEROPAGE"
000000r 1               ; Zero Page variables ($22-$7F available)
000000r 1               
000000r 1  xx           key_last:       .res 1           ; most recent PETSCII key from GETIN ($00 = none)
000001r 1  xx           frame_count:    .res 1           ; wrapping frame counter (increments each VSYNC)
000002r 1  xx           rand_seed_lo:   .res 1           ; PRNG state - low byte
000003r 1  xx           rand_seed_hi:   .res 1           ; PRNG state - high byte
000004r 1  xx           player_x_lo:    .res 1           ; player X position, low byte  (VERA 640x480 space)
000005r 1  xx           player_x_hi:    .res 1           ; player X position, high byte (bits 1-0 only)
000006r 1  xx           key_flags:      .res 1           ; input flags this frame (see KEY_* constants)
000007r 1               
000007r 1               ; --- Invader grid state ---
000007r 1  xx           inv_grid_x_lo:  .res 1           ; invader grid left-column X, low byte (VERA coords)
000008r 1  xx           inv_grid_x_hi:  .res 1           ; invader grid left-column X, high byte
000009r 1  xx           inv_offset_y:   .res 1           ; cumulative Y drop applied to grid (VERA pixels)
00000Ar 1  xx           inv_direction:  .res 1           ; 0 = moving right, 1 = moving left
00000Br 1  xx xx xx xx  inv_alive:      .res 7           ; 55-bit alive bitmap; bit N = invader N alive
00000Fr 1  xx xx xx     
000012r 1  xx           inv_count:      .res 1           ; number of invaders still alive
000013r 1  xx           inv_move_timer: .res 1           ; frames until next march step
000014r 1  xx           inv_move_speed: .res 1           ; frames per march step (decreases as invaders die)
000015r 1  xx           inv_drop_flag:  .res 1           ; 1 = drop grid on next step instead of marching
000016r 1  xx           inv_anim_frame: .res 1           ; animation frame index: 0 or 1
000017r 1               
000017r 1               ; --- Scratch for invader sprite update loop ---
000017r 1  xx           zp_row:         .res 1
000018r 1  xx           zp_col:         .res 1
000019r 1  xx           zp_x_lo:        .res 1
00001Ar 1  xx           zp_x_hi:        .res 1
00001Br 1  xx           zp_y_base_lo:   .res 1           ; grid Y base + cumulative drop
00001Cr 1  xx           zp_y_base_hi:   .res 1
00001Dr 1  xx           zp_row_y_lo:    .res 1           ; row Y = y_base + row spacing offset
00001Er 1  xx           zp_row_y_hi:    .res 1
00001Fr 1  xx           zp_addr_b0:     .res 1           ; VERA sprite data addr[12:5] for current row+frame
000020r 1               
000020r 1               ; --- Player bullet state ---
000020r 1  xx           bullet_active:  .res 1           ; 0=inactive, 1=active
000021r 1  xx           bullet_x_lo:    .res 1           ; bullet X low byte (VERA coords)
000022r 1  xx           bullet_x_hi:    .res 1           ; bullet X high byte
000023r 1  xx           bullet_y_lo:    .res 1           ; bullet Y low byte (VERA coords)
000024r 1  xx           bullet_y_hi:    .res 1           ; bullet Y high byte
000025r 1               
000025r 1               ; --- Score ---
000025r 1  xx           score_lo:       .res 1           ; score BCD byte 0 (digits 1-2)
000026r 1  xx           score_mid:      .res 1           ; score BCD byte 1 (digits 3-4)
000027r 1  xx           score_hi:       .res 1           ; score BCD byte 2 (digits 5-6)
000028r 1               
000028r 1               ; --- Scratch for 16-bit math (collision etc.) ---
000028r 1  xx           zp_scratch_lo:  .res 1
000029r 1  xx           zp_scratch_hi:  .res 1
00002Ar 1               
00002Ar 1               ; --- Explosion ---
00002Ar 1  xx           exp_timer:      .res 1           ; frames remaining for explosion display (0=inactive)
00002Br 1               
00002Br 1               ; --- Invader bullets (3 slots, parallel arrays) ---
00002Br 1  xx xx xx     ibul_active:    .res 3           ; 0=inactive, 1=active (one per slot)
00002Er 1  xx xx xx     ibul_x_lo:      .res 3           ; X position low byte (VERA coords)
000031r 1  xx xx xx     ibul_x_hi:      .res 3           ; X position high byte
000034r 1  xx xx xx     ibul_y_lo:      .res 3           ; Y position low byte (VERA coords)
000037r 1  xx xx xx     ibul_y_hi:      .res 3           ; Y position high byte
00003Ar 1  xx           inv_fire_timer: .res 1           ; frames until next fire attempt
00003Br 1               
00003Br 1               ; --- Player lives & invincibility ---
00003Br 1  xx           lives:          .res 1           ; remaining lives (0-3)
00003Cr 1  xx           inv_hit_timer:  .res 1           ; invincibility frames remaining after being hit (0=vulnerable)
00003Dr 1  xx           hi_score_lo:    .res 1           ; hi-score BCD byte 0 (digits 1-2)
00003Er 1  xx           hi_score_mid:   .res 1           ; hi-score BCD byte 1 (digits 3-4)
00003Fr 1  xx           hi_score_hi:    .res 1           ; hi-score BCD byte 2 (digits 5-6)
000040r 1               
000040r 1               ; --- Shield state ---
000040r 1  xx xx xx xx  shield_damage:  .res 4           ; damage level per shield: 0=intact … 7=dmg7, 8=destroyed
000044r 1               
000044r 1               ; --- Wave progression ---
000044r 1  xx           wave:           .res 1           ; current wave number (1-based)
000045r 1  xx           wave_init_speed: .res 1          ; starting inv_move_speed for current wave
000046r 1               
000046r 1               ; --- UFO state ---
000046r 1  xx           ufo_active:     .res 1           ; 0=inactive, 1=active
000047r 1  xx           ufo_x_lo:       .res 1           ; UFO X position low byte (VERA coords)
000048r 1  xx           ufo_x_hi:       .res 1           ; UFO X position high byte
000049r 1  xx           ufo_timer_lo:   .res 1           ; countdown to next UFO appearance (frames, low byte)
00004Ar 1  xx           ufo_timer_hi:   .res 1           ; countdown to next UFO appearance (frames, high byte)
00004Br 1  xx           shot_count:     .res 1           ; player bullets fired mod 8 → UFO score table index
00004Cr 1  xx           march_beat:     .res 1           ; current march note index (0-3, cycles)
00004Dr 1  xx           march_snd_timer:.res 1           ; frames remaining for current march note (0=silent)
00004Er 1  xx           fire_snd_timer: .res 1           ; frames remaining for fire sound (0=silent)
00004Fr 1  xx           exp_snd_timer:  .res 1           ; frames remaining for explosion sound (0=silent)
000050r 1               
000050r 1  xx xx        UFO_DRONE_FREQ: .res 2           ; store the current UFO Drone Frequency (will oscillate high-low)
000052r 1  xx           UFO_FREQ_DIR:   .res 1           ; direction of ascending/descending ufo tone (00=down, ff=up)
000053r 1               
