0015EC  1               ;******************************************************************
0015EC  1               ; hide_all_inv_sprites — set z-depth=0 for all 55 invader sprites
0015EC  1               ;   Uses VERA stride=8 to write only byte 6 (z-depth) of each block.
0015EC  1               ;   First invader sprite byte 6: $1FC00 + 11*8 + 6 = $1FC5E
0015EC  1               ;******************************************************************
0015EC  1               hide_all_inv_sprites:
0015EC  1  9C 25 9F        stz VERA_ctrl
0015EF  1  A9 41           lda #$41               ; stride=8 (code $4 in high nibble), bank=1
0015F1  1  8D 22 9F        sta VERA_addr_bank
0015F4  1  A9 FC           lda #$FC
0015F6  1  8D 21 9F        sta VERA_addr_high
0015F9  1  A9 5E           lda #$5E               ; low byte of $1FC5E  ($1FC58+6)
0015FB  1  8D 20 9F        sta VERA_addr_low
0015FE  1  A9 00           lda #0                 ; z-depth=0 → disabled
001600  1  A2 37           ldx #55
001602  1               @loop:
001602  1  8D 23 9F        sta VERA_data0         ; writes byte 6; addr auto-advances by 8
001605  1  CA              dex
001606  1  D0 FA           bne @loop
001608  1  60              rts
001609  1               
001609  1               ;******************************************************************
001609  1               ; hide_all_sprites — set z-depth=0 for all 128 VERA sprite slots.
001609  1               ;   Writes 0 to byte 6 of every slot starting at $1FC06, stride=8.
001609  1               ;   Call before returning to BASIC so no sprites linger on screen.
001609  1               ;******************************************************************
001609  1               hide_all_sprites:
001609  1  9C 25 9F        stz VERA_ctrl
00160C  1  A9 41           lda #$41               ; stride=8, bank=1
00160E  1  8D 22 9F        sta VERA_addr_bank
001611  1  A9 FC           lda #$FC
001613  1  8D 21 9F        sta VERA_addr_high
001616  1  A9 06           lda #$06               ; byte 6 of sprite 0 ($1FC06)
001618  1  8D 20 9F        sta VERA_addr_low
00161B  1  A9 00           lda #0                 ; z-depth=0 → disabled
00161D  1  A2 80           ldx #128
00161F  1               @loop:
00161F  1  8D 23 9F        sta VERA_data0         ; writes byte 6; addr auto-advances by 8
001622  1  CA              dex
001623  1  D0 FA           bne @loop
001625  1  60              rts
