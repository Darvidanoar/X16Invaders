0011AC  1               
0011AC  1                  ; decrement lives
0011AC  1  C6 rr           dec lives
0011AE  1  F0 0D           beq @game_over            ; lives hit 0 → end game (Phase 6 will handle this properly)
0011B0  1               
0011B0  1                  ; grant invincibility and re-centre the ship
0011B0  1  A9 78           lda #INV_HIT_FRAMES
0011B2  1  85 rr           sta inv_hit_timer
0011B4  1  A9 38           lda #<PLAYER_X_INIT
0011B6  1  85 rr           sta player_x_lo
0011B8  1  A9 01           lda #>PLAYER_X_INIT
0011BA  1  85 rr           sta player_x_hi
0011BC  1  60              rts
