00135C  1               ;******************************************************************
00135C  1               ; next_wave — advance wave counter, reduce speed, reset grid, resume play
00135C  1               ;   Keeps: player X, lives, score, shields.
00135C  1               ;   Clears: bullets, invaders, explosion, UFO.
00135C  1               ;******************************************************************
00135C  1               next_wave:
00135C  1  E6 rr           inc wave
00135E  1               
00135E  1                  ; new wave_init_speed = max(current - WAVE_SPEED_STEP, INV_MOVE_SPEED_MIN)
00135E  1  A5 rr           lda wave_init_speed
001360  1  38              sec
001361  1  E9 05           sbc #WAVE_SPEED_STEP
001363  1  C9 05           cmp #INV_MOVE_SPEED_MIN
001365  1  B0 02           bcs @speed_ok
001367  1  A9 05           lda #INV_MOVE_SPEED_MIN
001369  1               @speed_ok:
001369  1  85 rr           sta wave_init_speed
00136B  1               
00136B  1                  ; deactivate player bullet
00136B  1  64 rr           stz bullet_active
00136D  1  20 3A 0E        jsr update_bullet_sprite
001370  1               
001370  1                  ; reset explosion
001370  1  64 rr           stz exp_timer
001372  1  9C 25 9F        stz VERA_ctrl
001375  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1
001379  1  9F A9 FC 8D  
00137D  1  21 9F A9 26  
001384  1  A9 00           lda #$00
001386  1  8D 23 9F        sta VERA_data0
001389  1               
001389  1                  ; deactivate invader bullets
001389  1  64 rr           stz ibul_active+0
00138B  1  64 rr           stz ibul_active+1
00138D  1  64 rr           stz ibul_active+2
00138F  1  A2 00           ldx #0
001391  1               @nw_ibul:
001391  1  20 2B 10        jsr update_inv_bullet_sprite
001394  1  E8              inx
001395  1  E0 03           cpx #3
001397  1  D0 F8           bne @nw_ibul
001399  1  A9 5A           lda #INV_FIRE_TIMER_INIT
00139B  1  85 rr           sta inv_fire_timer
00139D  1               
00139D  1                  ; reset UFO timer (UFO already inactive from wave_clear_screen)
00139D  1  A9 58           lda #<UFO_TIMER_INIT
00139F  1  85 rr           sta ufo_timer_lo
0013A1  1  A9 02           lda #>UFO_TIMER_INIT
0013A3  1  85 rr           sta ufo_timer_hi
0013A5  1               
0013A5  1                  ; reset invader grid to full, using new wave_init_speed
0013A5  1  20 86 0B        jsr init_invaders
0013A8  1               
0013A8  1  A9 93           lda #PETSCII_CLR
0013AA  1  20 D2 FF        jsr CHROUT
0013AD  1  4C C5 08        jmp main_loop
0013B0  1               
0013B0  1               ;******************************************************************
0013B0  1               ; print_dec_byte — print .A as 1 or 2 decimal digits (values 0-99)
0013B0  1               ;   Suppresses leading zero for single-digit numbers.
0013B0  1               ;   Clobbers: A, X.  Carry is cleared on exit.
0013B0  1               ;******************************************************************
0013B0  1               print_dec_byte:
0013B0  1  A2 00           ldx #0
0013B2  1               @pdb_loop:
0013B2  1  C9 0A           cmp #10
0013B4  1  90 05           bcc @pdb_units            ; A < 10 → done dividing
0013B6  1  E8              inx
0013B7  1  E9 0A           sbc #10                   ; carry is set by cmp, so sbc = A - 10
0013B9  1  80 F7           bra @pdb_loop
0013BB  1               @pdb_units:
0013BB  1  48              pha                       ; save units digit
0013BC  1  8A              txa                       ; tens digit count
0013BD  1  F0 05           beq @pdb_skip_tens        ; zero → suppress leading zero
0013BF  1  69 30           adc #$30                  ; carry=0 here (from last bcc), so adc = X + $30
0013C1  1  20 D2 FF        jsr CHROUT
0013C4  1               @pdb_skip_tens:
0013C4  1  68              pla                       ; units digit (0-9; carry=0)
0013C5  1  69 30           adc #$30
0013C7  1  20 D2 FF        jsr CHROUT
0013CA  1  60              rts
0013CB  1               
0013CB  1               ;******************************************************************
0013CB  1               ; draw_title_screen — paint the title screen; called once before title_loop
0013CB  1               ;
0013CB  1               ;   Layout (40-col text, VERA Y=row*16):
0013CB  1               ;     Row  1, col 14: "X16 INVADERS"      (12 chars, centred)
0013CB  1               ;     Row  3, col 16: "HI-SCORE"          (8 chars, centred)
0013CB  1               ;     Row  4, col 17: 000000              (6-digit BCD hi-score)
0013CB  1               ;     Row  5, col  5: "?UFO? = ??? PTS"
0013CB  1               ;     Row  7, col  9: "= 30 PTS"          + Type C sprite at X=96,Y=112
0013CB  1               ;     Row 10, col  9: "= 20 PTS"          + Type B sprite at X=96,Y=160
0013CB  1               ;     Row 13, col  9: "= 10 PTS"          + Type A sprite at X=96,Y=208
0013CB  1               ;     Row 17, col 10: (PRESS SPACE TO START — blinked by title_loop)
0013CB  1               ;     Row 19, col 12: "RUN/STOP TO QUIT"
0013CB  1               ;******************************************************************
0013CB  1               draw_title_screen:
0013CB  1                  ; Row 1, col 14: "X16 INVADERS"
0013CB  1  A9 01           lda #1
0013CD  1  A0 0E           ldy #14
0013CF  1  18              clc
0013D0  1  20 F0 FF        jsr PLOT
0013D3  1  A2 00           ldx #0
0013D5  1  BD D6 1A     @lp1: lda str_title_main, x
0013D8  1  F0 06           beq @lp1_done
0013DA  1  20 D2 FF        jsr CHROUT
0013DD  1  E8              inx
0013DE  1  80 F5           bra @lp1
0013E0  1               @lp1_done:
0013E0  1               
0013E0  1                  ; Row 3, col 16: "HI-SCORE"
0013E0  1  A9 03           lda #3
0013E2  1  A0 10           ldy #16
0013E4  1  18              clc
0013E5  1  20 F0 FF        jsr PLOT
0013E8  1  A2 00           ldx #0
0013EA  1  BD E3 1A     @lp2: lda str_hi_score_lbl, x
0013ED  1  F0 06           beq @lp2_done
0013EF  1  20 D2 FF        jsr CHROUT
0013F2  1  E8              inx
0013F3  1  80 F5           bra @lp2
0013F5  1               @lp2_done:
0013F5  1               
0013F5  1                  ; Row 4, col 17: hi-score 6 BCD digits (000000 at start)
0013F5  1  A9 04           lda #4
0013F7  1  A0 11           ldy #17
0013F9  1  18              clc
0013FA  1  20 F0 FF        jsr PLOT
0013FD  1  A5 rr           lda hi_score_hi
0013FF  1  20 B7 1A        jsr print_hex_byte
001402  1  A5 rr           lda hi_score_mid
001404  1  20 B7 1A        jsr print_hex_byte
001407  1  A5 rr           lda hi_score_lo
001409  1  20 B7 1A        jsr print_hex_byte
00140C  1               
00140C  1                  ; Row 5, col 5: "?UFO? = ??? PTS"
00140C  1  A9 05           lda #5
00140E  1  A0 05           ldy #5
001410  1  18              clc
001411  1  20 F0 FF        jsr PLOT
001414  1  A2 00           ldx #0
001416  1  BD EC 1A     @lp3: lda str_ufo_score, x
001419  1  F0 06           beq @lp3_done
00141B  1  20 D2 FF        jsr CHROUT
00141E  1  E8              inx
00141F  1  80 F5           bra @lp3
001421  1               @lp3_done:
001421  1               
001421  1                  ; Sample invader sprites (Types C, B, A) + score labels
001421  1  20 3A 14        jsr show_title_sprites
001424  1               
001424  1                  ; Row 19, col 12: "RUN/STOP TO QUIT"
001424  1  A9 13           lda #19
001426  1  A0 0C           ldy #12
001428  1  18              clc
001429  1  20 F0 FF        jsr PLOT
00142C  1  A2 00           ldx #0
00142E  1  BD 86 1B     @lp4: lda str_run_stop_hint, x
001431  1  F0 06           beq @lp4_done
001433  1  20 D2 FF        jsr CHROUT
001436  1  E8              inx
001437  1  80 F5           bra @lp4
001439  1               @lp4_done:
001439  1               
001439  1  60              rts
00143A  1               
00143A  1               ;******************************************************************
00143A  1               ; show_title_sprites — enable one sprite of each type at fixed
00143A  1               ;   title-screen positions and print score labels beside them.
00143A  1               ;
00143A  1               ;   In VERA 640x480 space, 1 text row/col = 16 VERA pixels.
00143A  1               ;   Sprites: X=96 (col 6), score labels at col 9.
00143A  1               ;   Sprite 11 (Type C): Y=112 → text row 7,  "= 30 PTS"
00143A  1               ;   Sprite 22 (Type B): Y=160 → text row 10, "= 20 PTS"
00143A  1               ;   Sprite 44 (Type A): Y=208 → text row 13, "= 10 PTS"
00143A  1               ;******************************************************************
00143A  1               show_title_sprites:
00143A  1  9C 25 9F        stz VERA_ctrl
00143D  1                  ; --- sprite 11 (Type C, squid/cyan): attr $1FC00+11*8=$1FC58 ---
00143D  1                  ; addr[12:5] = VRAM_INV_C_F0>>5 = $00300>>5 = $18
00143D  1  A9 11           lda #$11               ; stride=1, bank=1
00143F  1  8D 22 9F        sta VERA_addr_bank
001442  1  A9 FC           lda #$FC
001444  1  8D 21 9F        sta VERA_addr_high
001447  1  A9 58           lda #$58               ; low byte of $1FC58
001449  1  8D 20 9F        sta VERA_addr_low
00144C  1  A9 18           lda #$18               ; byte 0: data addr[12:5]
00144E  1  8D 23 9F        sta VERA_data0
001451  1  A9 00           lda #$00               ; byte 1: 4bpp, addr[16:13]=0
001453  1  8D 23 9F        sta VERA_data0
001456  1  A9 60           lda #96                ; byte 2: X lo
001458  1  8D 23 9F        sta VERA_data0
00145B  1  A9 00           lda #0                 ; byte 3: X hi
00145D  1  8D 23 9F        sta VERA_data0
001460  1  A9 70           lda #112               ; byte 4: Y lo (row 7: 7*16=112)
001462  1  8D 23 9F        sta VERA_data0
001465  1  A9 00           lda #0                 ; byte 5: Y hi
001467  1  8D 23 9F        sta VERA_data0
00146A  1  A9 0C           lda #SPR_Z_FRONT       ; byte 6: z-depth=3
