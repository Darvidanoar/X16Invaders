001A84  1               ;******************************************************************
001A84  1               ; player_spr_data — 16x16 4bpp sprite, 128 bytes
001A84  1               ;
001A84  1               ;   Color 0 = transparent, Color 1 = white (default palette index 1)
001A84  1               ;   Design: classic upward-pointing triangular ship with engine notches
001A84  1               ;
001A84  1               ;   Each byte encodes 2 pixels: high nibble = left, low nibble = right
001A84  1               ;   Columns: 0123456789ABCDEF
001A84  1               ;
001A84  1               ;   Row  0:  .......1........   cannon tip
001A84  1               ;   Row  1:  .......11.......
001A84  1               ;   Row  2:  ......111.......
001A84  1               ;   Row  3:  ......111.......
