0013B9  1               ;******************************************************************
0013B9  1               ; print_dec_byte — print .A as 1 or 2 decimal digits (values 0-99)
0013B9  1               ;   Suppresses leading zero for single-digit numbers.
0013B9  1               ;   Clobbers: A, X.  Carry is cleared on exit.
0013B9  1               ;******************************************************************
0013B9  1               print_dec_byte:
0013B9  1  A2 00           ldx #0
0013BB  1               @pdb_loop:
0013BB  1  C9 0A           cmp #10
0013BD  1  90 05           bcc @pdb_units            ; A < 10 → done dividing
0013BF  1  E8              inx
0013C0  1  E9 0A           sbc #10                   ; carry is set by cmp, so sbc = A - 10
0013C2  1  80 F7           bra @pdb_loop
0013C4  1               @pdb_units:
0013C4  1  48              pha                       ; save units digit
0013C5  1  8A              txa                       ; tens digit count
0013C6  1  F0 05           beq @pdb_skip_tens        ; zero → suppress leading zero
0013C8  1  69 30           adc #$30                  ; carry=0 here (from last bcc), so adc = X + $30
0013CA  1  20 D2 FF        jsr CHROUT
0013CD  1               @pdb_skip_tens:
0013CD  1  68              pla                       ; units digit (0-9; carry=0)
0013CE  1  69 30           adc #$30
0013D0  1  20 D2 FF        jsr CHROUT
0013D3  1  60              rts
0013D4  1               
0013D4  1               ;******************************************************************
