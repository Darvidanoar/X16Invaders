00121E  1  D0 3B           bne @go_restart
001220  1               
001220  1  A5 rr           lda frame_count
001222  1  29 20           and #$20                  ; bit 5: flips every 32 frames ≈ 2 Hz blink
001224  1  D0 15           bne @go_show
001226  1               @go_hide:
001226  1  A9 0F           lda #15
001228  1  A0 0B           ldy #11
00122A  1  18              clc
00122B  1  20 F0 FF        jsr PLOT
00122E  1  A2 12           ldx #18
001230  1  A9 20        @go_erase: lda #' '
001232  1  20 D2 FF        jsr CHROUT
001235  1  CA              dex
001236  1  D0 F8           bne @go_erase
001238  1  4C 0C 12        jmp game_over_loop
00123B  1               @go_show:
00123B  1  A9 0F           lda #15
00123D  1  A0 0B           ldy #11
00123F  1  18              clc
001240  1  20 F0 FF        jsr PLOT
