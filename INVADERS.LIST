0011E7  1  E9 01           sbc #1
0011E9  1  85 rr           sta zp_scratch_lo
0011EB  1  A5 rr           lda zp_scratch_hi
0011ED  1  E9 00           sbc #0
0011EF  1  85 rr           sta zp_scratch_hi
0011F1  1  05 rr           ora zp_scratch_lo
0011F3  1  D0 EC           bne @go_pause
0011F5  1               
0011F5  1  A9 13           lda #$13
0011F7  1  20 AB FE        jsr EXTAPI  ; Clear the keyboard buffer
0011FA  1               
