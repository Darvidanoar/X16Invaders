001343  1               @wc1d:
001343  1               
001343  1  A9 0B           lda #11
001345  1  A0 0F           ldy #15
001347  1  18              clc
001348  1  20 F0 FF        jsr PLOT
00134B  1  A2 00           ldx #0
00134D  1  BD 3D 1D     @wc2: lda str_wave_lbl, x
001350  1  F0 06           beq @wc2d
001352  1  20 D2 FF        jsr CHROUT
001355  1  E8              inx
001356  1  80 F5           bra @wc2
001358  1               @wc2d:
