000C8E  1  C5 20 33 20  
000C92  1  2D 20 C9 CE  
000CA1  1               str_status_vsync:
000CA1  1  D6 D3 D9 CE     .byte "VSYNC : WAI (60HZ IRQ)", 0
000CA5  1  C3 20 3A 20  
000CA9  1  D7 C1 C9 20  
000CB8  1               str_status_kbd:
000CB8  1  CB C5 D9 C2     .byte "KEYBOARD: JOYSTICK + GETIN", 0
000CBC  1  CF C1 D2 C4  
000CC0  1  3A 20 CA CF  
000CD3  1               str_status_spr:
000CD3  1  D3 D0 D2 C9     .byte "SPRITES : ENABLED", 0
000CD7  1  D4 C5 D3 20  
000CDB  1  3A 20 C5 CE  
