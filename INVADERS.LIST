00120F  1               ; game_over_loop — blink "SPACE = PLAY AGAIN"; wait for input
00120F  1               ;------------------------------------------------------------------
00120F  1               game_over_loop:
00120F  1  20 2E 09        jsr wait_vsync
001212  1  E6 rr           inc frame_count
001214  1  20 30 09        jsr update_input
001217  1               
