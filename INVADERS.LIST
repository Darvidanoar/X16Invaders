0015E7  1               ;******************************************************************
0015E7  1               ; hide_all_inv_sprites — set z-depth=0 for all 55 invader sprites
0015E7  1               ;   Uses VERA stride=8 to write only byte 6 (z-depth) of each block.
0015E7  1               ;   First invader sprite byte 6: $1FC00 + 11*8 + 6 = $1FC5E
0015E7  1               ;******************************************************************
0015E7  1               hide_all_inv_sprites:
0015E7  1  9C 25 9F        stz VERA_ctrl
0015EA  1  A9 41           lda #$41               ; stride=8 (code $4 in high nibble), bank=1
0015EC  1  8D 22 9F        sta VERA_addr_bank
0015EF  1  A9 FC           lda #$FC
0015F1  1  8D 21 9F        sta VERA_addr_high
0015F4  1  A9 5E           lda #$5E               ; low byte of $1FC5E  ($1FC58+6)
0015F6  1  8D 20 9F        sta VERA_addr_low
0015F9  1  A9 00           lda #0                 ; z-depth=0 → disabled
0015FB  1  A2 37           ldx #55
0015FD  1               @loop:
0015FD  1  8D 23 9F        sta VERA_data0         ; writes byte 6; addr auto-advances by 8
001600  1  CA              dex
001601  1  D0 FA           bne @loop
001603  1  60              rts
001604  1               
001604  1               ;******************************************************************
001604  1               ; hide_all_sprites — set z-depth=0 for all 128 VERA sprite slots.
001604  1               ;   Writes 0 to byte 6 of every slot starting at $1FC06, stride=8.
001604  1               ;   Call before returning to BASIC so no sprites linger on screen.
001604  1               ;******************************************************************
001604  1               hide_all_sprites:
001604  1  9C 25 9F        stz VERA_ctrl
001607  1  A9 41           lda #$41               ; stride=8, bank=1
001609  1  8D 22 9F        sta VERA_addr_bank
00160C  1  A9 FC           lda #$FC
00160E  1  8D 21 9F        sta VERA_addr_high
001611  1  A9 06           lda #$06               ; byte 6 of sprite 0 ($1FC06)
001613  1  8D 20 9F        sta VERA_addr_low
001616  1  A9 00           lda #0                 ; z-depth=0 → disabled
001618  1  A2 80           ldx #128
00161A  1               @loop:
00161A  1  8D 23 9F        sta VERA_data0         ; writes byte 6; addr auto-advances by 8
00161D  1  CA              dex
00161E  1  D0 FA           bne @loop
001620  1  60              rts
001621  1               
001621  1               ;******************************************************************
001621  1               ; init_shields — upload 8 damage tiles, set palette entry 7 to dark
001621  1               ;   green, init shield_damage counters, write sprite attributes for
001621  1               ;   all 4 shields (slots 66–69, base $1FE10).
001621  1               ;
001621  1               ;   Sprite positions: X = shield_x_lo/hi[n], Y = SHIELD_Y (352)
001621  1               ;   Each shield sprite: 32x32, palette 0 (entry 7 = dark green).
001621  1               ;******************************************************************
001621  1               init_shields:
001621  1  9C 25 9F        stz VERA_ctrl
001624  1               
001624  1                  ; --- palette entry 7 → dark green (R=0, G=$A, B=0) ---
001624  1                  ; Palette byte 0: G[3:0] B[3:0] = $A0;  byte 1: R[3:0] = $00
001624  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_palette + 14), 1   ; entry 7 = offset 14 bytes
001628  1  9F A9 FA 8D  
00162C  1  21 9F A9 0E  
001633  1  A9 A0           lda #$A0
001635  1  8D 23 9F        sta VERA_data0
001638  1  A9 00           lda #$00
00163A  1  8D 23 9F        sta VERA_data0
00163D  1               
00163D  1                  ; --- upload shield_tile_full → $00500 (512 bytes: four 128-byte passes) ---
00163D  1  A9 10 8D 22     VERA_SET_ADDR VRAM_SHIELD_FULL, 1
001641  1  9F A9 05 8D  
001645  1  21 9F A9 00  
00164C  1  A2 80           ldx #128
00164E  1  BD EC 22     @up_s0a: lda shield_tile_full - 128, x
001651  1  8D 23 9F        sta VERA_data0
001654  1  E8              inx
001655  1  D0 F7           bne @up_s0a
001657  1  A2 80           ldx #128
001659  1  BD 6C 23     @up_s0b: lda shield_tile_full, x
00165C  1  8D 23 9F        sta VERA_data0
00165F  1  E8              inx
001660  1  D0 F7           bne @up_s0b
001662  1  A2 80           ldx #128
001664  1  BD EC 23     @up_s0c: lda shield_tile_full + 128, x
001667  1  8D 23 9F        sta VERA_data0
00166A  1  E8              inx
00166B  1  D0 F7           bne @up_s0c
00166D  1  A2 80           ldx #128
00166F  1  BD 6C 24     @up_s0d: lda shield_tile_full + 256, x
001672  1  8D 23 9F        sta VERA_data0
001675  1  E8              inx
001676  1  D0 F7           bne @up_s0d
001678  1               
001678  1                  ; --- upload shield_tile_dmg1 → $00700 ---
