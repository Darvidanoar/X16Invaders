0013D4  1               ; Called once after screen clear, before main_loop.
0013D4  1               ;******************************************************************
0013D4  1               draw_score_labels:
0013D4  1  A9 00           lda #0
0013D6  1  A0 00           ldy #0
0013D8  1  18              clc
0013D9  1  20 F0 FF        jsr PLOT
0013DC  1  A2 00           ldx #0
0013DE  1  BD 45 1B     @sl1: lda str_score_title, x
0013E1  1  F0 06           beq @sl1d
0013E3  1  20 D2 FF        jsr CHROUT
0013E6  1  E8              inx
