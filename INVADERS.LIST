0012B3  1               ;******************************************************************
0012B3  1               ; print_hex_byte — print .A as two uppercase hex digits via CHROUT
0012B3  1               ;******************************************************************
0012B3  1               print_hex_byte:
0012B3  1  48              pha
0012B4  1  4A              lsr                           ; shift high nibble down
0012B5  1  4A              lsr
0012B6  1  4A              lsr
0012B7  1  4A              lsr
0012B8  1  20 C2 12        jsr print_hex_nybble
0012BB  1  68              pla
0012BC  1  29 0F           and #$0F                      ; isolate low nibble
0012BE  1  20 C2 12        jsr print_hex_nybble
0012C1  1  60              rts
0012C2  1               
0012C2  1               ; print_hex_nybble — print lower 4 bits of .A as one hex digit
0012C2  1               ;   Relies on carry state from CMP to select digit vs. letter range
0012C2  1               print_hex_nybble:
0012C2  1  C9 0A           cmp #10
0012C4  1  90 06           bcc @digit                    ; carry clear → 0-9
0012C6  1  69 36           adc #($41 - 10 - 1)          ; A-F: 'A'=65; carry set adds 1
0012C8  1  20 D2 FF        jsr CHROUT
0012CB  1  60              rts
0012CC  1               @digit:
0012CC  1  69 30           adc #$30                      ; 0-9: '0'=48; carry clear adds 0
0012CE  1  20 D2 FF        jsr CHROUT
0012D1  1  60              rts
