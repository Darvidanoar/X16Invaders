000810  1               ;******************************************************************
000810  1               ; Constants
000810  1               ;******************************************************************
000810  1               
000810  1               ; VERA display control
000810  1               VERA_SPRITE_EN  = %01000000      ; VERA_dc_video bit 6: enable sprites
000810  1               
000810  1               ; PETSCII control codes
000810  1               PETSCII_WHITE   = $05            ; set text color to white
000810  1               PETSCII_CLR     = $93            ; clear screen and home cursor
000810  1               PETSCII_HOME    = $13            ; home cursor (no clear)
000810  1               PETSCII_RETURN  = $0D            ; carriage return
000810  1               
000810  1               ; SCREEN_SET_CHARSET font numbers (call address $FF62)
000810  1               CHARSET_UPPER   = 1              ; Commodore upper/graphics: $41-$5A = A-Z
000810  1               CHARSET_LOWER   = 2              ; Commodore lower/upper:    $41-$5A = a-z (lowercase)
000810  1               
000810  1               ; Key codes (PETSCII)
000810  1               KEY_RUN_STOP    = $03            ; RUN/STOP — exit game
000810  1               
000810  1               ; Input flag bits (key_flags)
000810  1               KEY_LEFT        = %00000001
000810  1               KEY_RIGHT       = %00000010
000810  1               KEY_FIRE        = %00000100
000810  1               
000810  1               ; JOYSTICK_GET .A return: {B,Y,Sel,Sta,Up,Dn,Left,Right} active low
000810  1               JOY_RIGHT       = %00000001     ; bit 0
000810  1               JOY_LEFT        = %00000010     ; bit 1
000810  1               
000810  1               ; Player ship — all positions in VERA 640x480 coordinate space
000810  1               PLAYER_Y        = 420            ; fixed Y, near bottom (479 = bottom edge)
000810  1               PLAYER_X_INIT   = 312            ; starting X, centred  ((640-16)/2)
000810  1               PLAYER_X_MIN    = 8              ; left  boundary (sprite left edge)
000810  1               PLAYER_X_MAX    = 616            ; right boundary (640 - 16px sprite - 8px margin)
000810  1               PLAYER_SPEED    = 4              ; pixels per frame
000810  1               
000810  1               ; Sprite attribute encoding helpers
000810  1               SPRITE1_ATTR    = $1FC08 ; sprite 1 attribute base ($1FC00=sprite 0, reserved for KERNAL mouse)
000810  1               SPR_Z_FRONT     = %00001100     ; byte 6: z-depth = %11 in bits 3-2 (in front of all layers)
000810  1               SPR_16x16_PAL0  = %01010000     ; byte 7: width=1(16px), height=1(16px), palette_off=0
000810  1               SPR_32x16_PAL0  = %10010000     ; byte 7: width=2(32px), height=1(16px), palette_off=0
000810  1               SPR_32x32_PAL0  = %10100000     ; byte 7: width=2(32px), height=2(32px), palette_off=0
000810  1               SPR_8x8_PAL0    = %00000000     ; byte 7: width=0(8px),  height=0(8px),  palette_off=0
000810  1               
000810  1               ; Explosion sprite (slot 4)
000810  1               VRAM_EXPLOSION     = $00440     ; explosion pixel data (128 bytes, 16x16 4bpp)
000810  1               EXPLODE_SPRITE_ATTR = $1FC20    ; sprite 4 attribute base (explosion)
000810  1               EXPLODE_FRAMES     = 30         ; display duration in frames (~0.5 sec at 60 Hz)
000810  1               
000810  1               ; Invader bullets (sprite slots 5-7)
000810  1               VRAM_INV_BULLET    = $00420     ; invader bullet pixel data (32 bytes, 8x8 4bpp)
000810  1               INV_BULLET_SPR_BASE = $1FC28    ; sprite 5 attribute base (first invader bullet)
000810  1               INV_BULLET_SPEED   = 6          ; VERA pixels per frame downward (=3 game pixels)
000810  1               INV_FIRE_TIMER_MIN = 10         ; minimum frames between fire attempts
000810  1               INV_FIRE_TIMER_INIT = 90        ; frames before first shot
000810  1               
000810  1               ; Player lives
000810  1               LIVES_INIT         = 3          ; starting lives
000810  1               INV_HIT_FRAMES     = 120        ; invincibility duration after being hit (2 sec at 60 Hz)
000810  1               
000810  1               ; UFO saucer (sprite slot 3)
000810  1               UFO_SPRITE_ATTR    = $1FC18      ; sprite 3 attribute base ($1FC00 + 3*8)
000810  1               VRAM_UFO           = $01500      ; UFO pixel data (128 bytes, 16x16 4bpp, after shield tiles)
000810  1               UFO_Y              = 32          ; VERA Y coord (= display pixel 16, top of play field)
000810  1               UFO_SPEED          = 2           ; VERA pixels per frame rightward (1 display pixel/frame)
000810  1               UFO_TIMER_INIT     = 600         ; frames between UFO appearances (≈10 sec at 60 Hz)
000810  1               
000810  1               ; VERA PSG voice 3 — UFO drone (base addr $1F9C0 + 3*4 = $1F9CC)
000810  1               ; PSG byte layout: 0=FREQ_L, 1=FREQ_H, 2=volume([7]=R,[6]=L,[5:0]=vol 0-63), 3=waveform([7:6])
000810  1               ; Waveform codes: 00=pulse, 01=sawtooth, 10=triangle, 11=noise
000810  1               ; freq_hz ≈ freq_reg * 25000000 / (512 * 131072)  →  freq_reg ≈ freq_hz * 2.684
000810  1               VRAM_PSG_VOICE3    = VRAM_psg + 12   ; $1F9CC — voice 3 registers
000810  1               PSG_VOL_FULL       = $FF             ; R enable + L enable + volume 63
000810  1               PSG_WAVE_SAW       = %01000000       ; sawtooth waveform (bits 7:6 = 01)
000810  1               UFO_DRONE_FREQ1    = 1074            ; ≈400 Hz  ($0432)
000810  1               UFO_DRONE_FREQ2    = 1611            ; ≈600 Hz  ($064B)
000810  1               
000810  1               ; Shields
000810  1               SHIELD_Y           = 352        ; VERA Y coordinate for all 4 shields (176 display pixels)
000810  1               SHIELD_SPR_BASE    = $1FE10     ; sprite slot 66 attr ($1FC00 + 66*8); slots 8-65 in use
000810  1               VRAM_SHIELD_FULL   = $00500     ; 512-byte 32x32 4bpp tile: intact
000810  1               VRAM_SHIELD_DMG1   = $00700     ; 12% damaged
000810  1               VRAM_SHIELD_DMG2   = $00900     ; 25% damaged
000810  1               VRAM_SHIELD_DMG3   = $00B00     ; 37% damaged
000810  1               VRAM_SHIELD_DMG4   = $00D00     ; 50% damaged
000810  1               VRAM_SHIELD_DMG5   = $00F00     ; 62% damaged
000810  1               VRAM_SHIELD_DMG6   = $01100     ; 75% damaged
000810  1               VRAM_SHIELD_DMG7   = $01300     ; nearly destroyed
000810  1               
000810  1               ; Player bullet
000810  1               BULLET_SPRITE_ATTR = $1FC10     ; sprite 2 attribute base (player bullet)
000810  1               VRAM_BULLET     = $00400        ; player bullet pixel data (32 bytes, 8x8 4bpp)
000810  1               BULLET_SPEED    = 12            ; VERA pixels per frame upward (= 6 game pixels)
000810  1               BULLET_Y_INIT   = PLAYER_Y - 8 ; bullet starts just above player ship top
000810  1               
000810  1               ; Invader grid geometry (VERA 640x480 coordinate space)
000810  1               INV_GRID_X_INIT   = 112         ; left-column X at start (centered: (640 - 10*40 - 16) / 2 = 112)
000810  1               INV_GRID_Y_BASE   = 80          ; top-row Y, fixed base (drops added via inv_offset_y)
000810  1               INV_SPACING_X     = 40          ; VERA pixels between invader column origins
000810  1               INV_SPACING_Y     = 48          ; VERA pixels between invader row origins
000810  1               INV_STEP_X        = 4           ; VERA pixels per march step
000810  1               INV_DROP_Y        = 16          ; VERA pixels per grid drop
000810  1               INV_MOVE_SPEED_INIT = 50        ; frames between march steps (initial)
000810  1               INV_COUNT_INIT    = 55
000810  1               INV_MOVE_SPEED_MIN = 5           ; minimum frames per march step
000810  1               
000810  1               ; Grid boundary: when grid_x reaches these values, reverse and drop
000810  1               ; Rightmost invader base X = grid_x + 10*INV_SPACING_X (=400). Right wall = 624 (640-16px).
000810  1               ; So right limit = 624 - 400 - 16 = 208
000810  1               INV_X_RIGHT_LIM   = 208
000810  1               INV_X_LEFT_LIM    = 16          ; leftmost sprite at x=grid_x must stay >= 16
000810  1               
000810  1               ; VRAM addresses for invader sprite pixel data (128 bytes each, 16x16 4bpp)
000810  1               VRAM_INV_A_F0   = $00100        ; Type A (crab,   bottom rows 3-4), frame 0
000810  1               VRAM_INV_A_F1   = $00180        ; Type A frame 1
000810  1               VRAM_INV_B_F0   = $00200        ; Type B (octopus, middle rows 1-2), frame 0
000810  1               VRAM_INV_B_F1   = $00280        ; Type B frame 1
000810  1               VRAM_INV_C_F0   = $00300        ; Type C (squid,   top row 0), frame 0
000810  1               VRAM_INV_C_F1   = $00380        ; Type C frame 1
000810  1               
000810  1               ; Sprite addr[12:5] byte values for each type/frame (= VRAM_addr >> 5)
000810  1               ;   VRAM $00100>>5=$08  $00180>>5=$0C  $00200>>5=$10  $00280>>5=$14  $00300>>5=$18  $00380>>5=$1C
000810  1               INV_ATTR_BASE   = $1FC58        ; sprite slot 11 = first invader ($1FC00 + 11*8)
000810  1               INV_SPRITE_SLOT = 11            ; first invader sprite slot index
000810  1               
000810  1               ;******************************************************************
000810  1               ; start — main program entry point
000810  1               ;******************************************************************
000810  1               start:
000810  1  78              sei                           ; disable interrupts during init
000811  1               
000811  1                  ; Switch to 40-column text mode (mode 0)
000811  1                  ; Carry clear = SET mode (carry set = READ mode)
000811  1  18              clc
000812  1  A9 00           lda #$00
000814  1  20 5F FF        jsr SCREEN_MODE
000817  1               
000817  1                  ; Seed PRNG with hardware entropy
000817  1  20 CF FE        jsr ENTROPY_GET
00081A  1  85 rr           sta rand_seed_lo
00081C  1  86 rr           stx rand_seed_hi
00081E  1               
00081E  1                  ; Enable sprites in VERA display controller
00081E  1  9C 25 9F        stz VERA_ctrl                 ; DCSEL=0, ADDRSEL=0
000821  1  AD 29 9F        lda VERA_dc_video
000824  1  09 40           ora #VERA_SPRITE_EN
000826  1  8D 29 9F        sta VERA_dc_video
000829  1               
000829  1               
000829  1                  ; Clear game variables
000829  1  64 rr           stz key_last
00082B  1  64 rr           stz key_flags
00082D  1  64 rr           stz frame_count
00082F  1  64 rr           stz bullet_active
000831  1  64 rr           stz score_lo
000833  1  64 rr           stz score_mid
000835  1  64 rr           stz score_hi
000837  1  64 rr           stz hi_score_lo
000839  1  64 rr           stz hi_score_mid
00083B  1  64 rr           stz hi_score_hi
00083D  1  64 rr           stz ufo_active
00083F  1  A9 58           lda #<UFO_TIMER_INIT
000841  1  85 rr           sta ufo_timer_lo
000843  1  A9 02           lda #>UFO_TIMER_INIT
000845  1  85 rr           sta ufo_timer_hi
000847  1  64 rr           stz shot_count
000849  1               
000849  1                  ; Set initial player position before sprite init reads it
000849  1  20 69 09        jsr init_player
00084C  1               
00084C  1  58              cli                           ; re-enable interrupts
00084D  1               
00084D  1                  ; Switch to Commodore uppercase/graphics charset: $41-$5A = A-Z
00084D  1                  ; Must be called AFTER SCREEN_MODE (which resets to lowercase by default)
00084D  1  A9 01           lda #CHARSET_UPPER
00084F  1  20 62 FF        jsr SCREEN_SET_CHARSET
000852  1               
000852  1                  ; Clear screen and set text color
000852  1  A9 05           lda #PETSCII_WHITE
000854  1  20 D2 FF        jsr CHROUT
000857  1  A9 93           lda #PETSCII_CLR
000859  1  20 D2 FF        jsr CHROUT
00085C  1               
00085C  1                  ; Upload sprite pixel data and configure sprite 1 attributes
00085C  1  20 78 09        jsr init_sprites
00085F  1               
00085F  1                  ; Upload invader sprite data, set palette, init grid state, place sprites
00085F  1  20 77 0B        jsr init_invaders
000862  1  20 26 14        jsr hide_all_inv_sprites     ; hide all 55 during title screen
000865  1               
000865  1  20 CF 12        jsr draw_title_screen
000868  1               
000868  1               ;------------------------------------------------------------------
000868  1               ; title_loop — wait for SPACE; blink "PRESS SPACE TO START"
000868  1               ;------------------------------------------------------------------
000868  1               title_loop:
000868  1  20 1C 09        jsr wait_vsync
00086B  1  E6 rr           inc frame_count
00086D  1  20 1E 09        jsr update_input
000870  1               
000870  1  A5 rr           lda key_last
000872  1  C9 03           cmp #KEY_RUN_STOP
000874  1  D0 03           bne @tl_no_exit
000876  1  4C 14 09        jmp exit_game
000879  1               @tl_no_exit:
000879  1               
000879  1  A5 rr           lda key_flags
00087B  1  29 04           and #KEY_FIRE
00087D  1  D0 33           bne start_game
00087F  1               
00087F  1                  ; blink using frame_count bit 5 (~2 Hz)
00087F  1  A5 rr           lda frame_count
000881  1  29 20           and #$20
000883  1  D0 15           bne @tl_on
000885  1               @tl_off:
000885  1  A9 11           lda #17
000887  1  A0 0A           ldy #10
000889  1  18              clc
00088A  1  20 F0 FF        jsr PLOT
00088D  1  A2 14           ldx #20                      ; erase 20 chars of "PRESS SPACE TO START"
00088F  1  A9 20        @tl_erase: lda #' '
000891  1  20 D2 FF        jsr CHROUT
000894  1  CA              dex
000895  1  D0 F8           bne @tl_erase
000897  1  4C 68 08        jmp title_loop
00089A  1               @tl_on:
00089A  1  A9 11           lda #17
00089C  1  A0 0A           ldy #10
00089E  1  18              clc
00089F  1  20 F0 FF        jsr PLOT
0008A2  1  A2 00           ldx #0
0008A4  1  BD 16 1A     @tl_print: lda str_press_space, x
0008A7  1  F0 06           beq @tl_print_done
0008A9  1  20 D2 FF        jsr CHROUT
0008AC  1  E8              inx
0008AD  1  80 F5           bra @tl_print
0008AF  1               @tl_print_done:
0008AF  1  4C 68 08        jmp title_loop
0008B2  1               
0008B2  1               start_game:
0008B2  1  20 AB 0C        jsr update_invader_sprites   ; re-enable all 55 invaders at grid positions
0008B5  1  20 43 14        jsr init_shields             ; upload shield tiles, init damage counters, place sprites
0008B8  1  A9 93           lda #PETSCII_CLR
0008BA  1  20 D2 FF        jsr CHROUT                   ; clear title text, leave sprites visible
0008BD  1               
0008BD  1               ;******************************************************************
0008BD  1               ; main_loop — one iteration per video frame (60 Hz)
0008BD  1               ;******************************************************************
0008BD  1               main_loop:
0008BD  1  20 1C 09        jsr wait_vsync
0008C0  1               
0008C0  1  E6 rr           inc frame_count
0008C2  1               
0008C2  1  20 1E 09        jsr update_input              ; fills key_flags (joystick) + key_last (GETIN)
0008C5  1               
0008C5  1  A5 rr           lda key_last
0008C7  1  C9 03           cmp #KEY_RUN_STOP
0008C9  1  F0 49           beq exit_game
0008CB  1               
0008CB  1                  ; --- invincibility timer ---
0008CB  1  A5 rr           lda inv_hit_timer
0008CD  1  F0 02           beq @no_inv_dec
0008CF  1  C6 rr           dec inv_hit_timer
0008D1  1               @no_inv_dec:
0008D1  1               
0008D1  1  20 61 0D        jsr move_player               ; apply movement, clamp to boundaries
0008D4  1  20 B0 0D        jsr update_player_sprite      ; write new X to VERA sprite 1
0008D7  1               
0008D7  1                  ; --- fire player bullet (SPACE pressed and bullet not already active) ---
0008D7  1  A5 rr           lda key_flags
0008D9  1  29 04           and #KEY_FIRE
0008DB  1  F0 07           beq @skip_fire
0008DD  1  A5 rr           lda bullet_active
0008DF  1  D0 03           bne @skip_fire
0008E1  1  20 F3 0D        jsr fire_bullet
0008E4  1               @skip_fire:
0008E4  1               
0008E4  1                  ; --- move bullet if active ---
0008E4  1  A5 rr           lda bullet_active
0008E6  1  F0 03           beq @skip_bullet_move
0008E8  1  20 12 0E        jsr move_bullet
0008EB  1               @skip_bullet_move:
0008EB  1               
0008EB  1                  ; --- check player bullet vs invader collision ---
0008EB  1  20 63 0E        jsr check_bullet_invader
0008EE  1               
0008EE  1                  ; --- check player bullet vs shield collision ---
0008EE  1  20 CF 16        jsr check_bullet_shields
0008F1  1               
0008F1  1                  ; --- explosion timer ---
0008F1  1  20 B2 0F        jsr update_explosion
0008F4  1               
0008F4  1                  ; --- invader bullets: move, spawn, boundary check ---
0008F4  1  20 E1 0F        jsr update_inv_bullets
0008F7  1               
0008F7  1                  ; --- invader bullet vs player collision ---
0008F7  1  20 EF 10        jsr check_inv_bullet_player
0008FA  1               
0008FA  1                  ; --- invader bullet vs shield collision ---
0008FA  1  20 41 17        jsr check_invbullet_shields
0008FD  1               
0008FD  1                  ; --- UFO spawn/move and player bullet collision ---
0008FD  1  20 E2 17        jsr update_ufo
000900  1  20 7B 18        jsr check_bullet_ufo
000903  1               
000903  1                  ; --- Invader march timer ---
000903  1  C6 rr           dec inv_move_timer
000905  1  D0 07           bne @skip_inv_step
000907  1  20 46 0C        jsr step_invaders             ; move grid, check bounds, update sprites
00090A  1  A5 rr           lda inv_move_speed
00090C  1  85 rr           sta inv_move_timer
00090E  1               @skip_inv_step:
00090E  1               
00090E  1  20 7C 19        jsr update_hud                ; refresh text readouts
000911  1               
000911  1  4C BD 08        jmp main_loop
000914  1               
000914  1               ;------------------------------------------------------------------
000914  1               exit_game:
000914  1  A9 93           lda #PETSCII_CLR
000916  1  20 D2 FF        jsr CHROUT
000919  1  4C 47 FF        jmp ENTER_BASIC
00091C  1               
00091C  1               ;******************************************************************
00091C  1               ; wait_vsync — busy-poll VERA_isr until VSYNC, then clear flag
00091C  1               ;******************************************************************
00091C  1               wait_vsync:
00091C  1                  ; WAI sleeps the CPU until any IRQ fires.  The KERNAL's VSYNC IRQ
00091C  1                  ; handler (60 Hz) wakes us up and has already cleared VERA_isr bit 0
00091C  1                  ; by the time execution returns here, so polling VERA_isr would loop
00091C  1                  ; forever.  Just return — one WAI ≈ one frame.
00091C  1  CB              wai
00091D  1  60              rts
00091E  1               
00091E  1               ;******************************************************************
00091E  1               ; update_input — joystick + GETIN keyboard input each frame
00091E  1               ;
00091E  1               ;   key_flags bits set this frame:
00091E  1               ;     KEY_LEFT  — left arrow held
00091E  1               ;     KEY_RIGHT — right arrow held
00091E  1               ;     KEY_FIRE  — space bar pressed
00091E  1               ;   key_last   — raw PETSCII from GETIN (RUN/STOP etc.)
00091E  1               ;
00091E  1               ;   JOYSTICK_GET(0) = keyboard-as-joystick; gives smooth held-key
00091E  1               ;   movement with no repeat delay.  GETIN handles space and RUN/STOP.
00091E  1               ;******************************************************************
00091E  1               update_input:
00091E  1  64 rr           stz key_flags
000920  1  64 rr           stz key_last
000922  1               
000922  1                  ; --- joystick 0 = keyboard d-pad (active low: 0 = pressed) ---
000922  1                  ; Byte returned: {B,Y,Sel,Sta,Up,Dn,Left,Right} bits 7–0
000922  1  A9 00           lda #0
000924  1  20 56 FF        jsr JOYSTICK_GET
000927  1  48              pha                           ; save — AND destroys .A
000928  1               
000928  1  29 01           and #JOY_RIGHT                ; bit 0: right arrow
00092A  1  D0 06           bne @not_right
00092C  1  A5 rr           lda key_flags
00092E  1  09 02           ora #KEY_RIGHT
000930  1  85 rr           sta key_flags
000932  1               @not_right:
000932  1  68              pla
000933  1  29 02           and #JOY_LEFT                 ; bit 1: left arrow
000935  1  D0 06           bne @not_left
000937  1  A5 rr           lda key_flags
000939  1  09 01           ora #KEY_LEFT
00093B  1  85 rr           sta key_flags
00093D  1               @not_left:
00093D  1               
00093D  1                  ; --- GETIN — discrete events: fire, RUN/STOP, arrow fallback ---
00093D  1               @getin_drain:
00093D  1  20 E4 FF        jsr GETIN
000940  1  F0 26           beq @getin_done               ; buffer empty
000942  1  85 rr           sta key_last
000944  1  C9 9D           cmp #$9D                      ; cursor left (PETSCII)
000946  1  D0 08           bne @chk_right_getin
000948  1  A5 rr           lda key_flags
00094A  1  09 01           ora #KEY_LEFT
00094C  1  85 rr           sta key_flags
00094E  1  80 ED           bra @getin_drain
000950  1               @chk_right_getin:
000950  1  C9 1D           cmp #$1D                      ; cursor right (PETSCII)
000952  1  D0 08           bne @chk_fire_getin
000954  1  A5 rr           lda key_flags
000956  1  09 02           ora #KEY_RIGHT
000958  1  85 rr           sta key_flags
00095A  1  80 E1           bra @getin_drain
00095C  1               @chk_fire_getin:
00095C  1  C9 20           cmp #$20                      ; space = fire
00095E  1  D0 DD           bne @getin_drain
000960  1  A5 rr           lda key_flags
000962  1  09 04           ora #KEY_FIRE
000964  1  85 rr           sta key_flags
000966  1  80 D5           bra @getin_drain
000968  1               @getin_done:
000968  1  60              rts
000969  1               
000969  1               ;******************************************************************
000969  1               ; init_player — set player_x to starting position
000969  1               ;******************************************************************
000969  1               init_player:
000969  1  A9 38           lda #<PLAYER_X_INIT
00096B  1  85 rr           sta player_x_lo
00096D  1  A9 01           lda #>PLAYER_X_INIT
00096F  1  85 rr           sta player_x_hi
000971  1  A9 03           lda #LIVES_INIT
000973  1  85 rr           sta lives
000975  1  64 rr           stz inv_hit_timer
000977  1  60              rts
000978  1               
000978  1               ;******************************************************************
000978  1               ; init_sprites — upload pixel data + write sprite 1 attributes
000978  1               ;
000978  1               ;   Sprite 0 ($1FC00) is reserved by the KERNAL mouse cursor —
000978  1               ;   we disable it and keep clear of $1FC00.
000978  1               ;
000978  1               ;   Sprite 1 ($1FC08) = player ship
000978  1               ;   Pixel data at VRAM $00080 (128 bytes, 16x16 4bpp)
000978  1               ;   Address encoding:  addr[12:5] = $00080>>5 = $04  → byte 0 = $04
000978  1               ;                      4bpp, addr[16:13] = 0          → byte 1 = $00
000978  1               ;******************************************************************
000978  1               init_sprites:
000978  1  9C 25 9F        stz VERA_ctrl
00097B  1               
00097B  1                  ; --- set palette entries 1-4 ---
00097B  1                  ; VERA palette entry N is 2 bytes at VRAM_palette + N*2
00097B  1                  ; Byte 0: [7:4]=Green [3:0]=Blue   Byte 1: [3:0]=Red (bits 7-4 unused)
00097B  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_palette + 2), 1   ; entry 1 (player white); stride=1 auto-advances
00097F  1  9F A9 FA 8D  
000983  1  21 9F A9 02  
00098A  1  A9 FF           lda #$FF                               ; G=$F, B=$F
00098C  1  8D 23 9F        sta VERA_data0
00098F  1  A9 0F           lda #$0F                               ; R=$F  → white
000991  1  8D 23 9F        sta VERA_data0
000994  1                  ; entry 2 = cyan  (R=0, G=$F, B=$F)
000994  1  A9 FF           lda #$FF                               ; G=$F, B=$F
000996  1  8D 23 9F        sta VERA_data0
000999  1  A9 00           lda #$00                               ; R=$0
00099B  1  8D 23 9F        sta VERA_data0
00099E  1                  ; entry 3 = magenta (R=$F, G=0, B=$F)
00099E  1  A9 0F           lda #$0F                               ; G=$0, B=$F
0009A0  1  8D 23 9F        sta VERA_data0
0009A3  1  A9 0F           lda #$0F                               ; R=$F
0009A5  1  8D 23 9F        sta VERA_data0
0009A8  1                  ; entry 4 = green  (R=0, G=$F, B=0)
0009A8  1  A9 F0           lda #$F0                               ; G=$F, B=$0
0009AA  1  8D 23 9F        sta VERA_data0
0009AD  1  A9 00           lda #$00                               ; R=$0
0009AF  1  8D 23 9F        sta VERA_data0
0009B2  1                  ; entry 5 = red    (R=$F, G=0, B=0)
0009B2  1  A9 00           lda #$00                               ; G=$0, B=$0
0009B4  1  8D 23 9F        sta VERA_data0
0009B7  1  A9 0F           lda #$0F                               ; R=$F
0009B9  1  8D 23 9F        sta VERA_data0
0009BC  1                  ; --- disable sprite 0 (KERNAL mouse cursor) ---
0009BC  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_sprattr + 6), 1   ; sprite 0 byte 6 = z-depth
0009C0  1  9F A9 FC 8D  
0009C4  1  21 9F A9 06  
0009CB  1  A9 00           lda #$00                               ; z-depth=0 → disabled
0009CD  1  8D 23 9F        sta VERA_data0
0009D0  1               
0009D0  1                  ; --- upload player sprite pixel data to VRAM $00080 ---
0009D0  1  A9 10 8D 22     VERA_SET_ADDR $00080, 1
0009D4  1  9F A9 00 8D  
0009D8  1  21 9F A9 80  
0009DF  1  A2 00           ldx #0
0009E1  1               @upload:
0009E1  1  BD 84 1A        lda player_spr_data,x
0009E4  1  8D 23 9F        sta VERA_data0
0009E7  1  E8              inx
0009E8  1  E0 80           cpx #128
0009EA  1  D0 F5           bne @upload
0009EC  1               
0009EC  1                  ; --- write sprite 1 attribute bytes ---
0009EC  1  A9 11 8D 22     VERA_SET_ADDR SPRITE1_ATTR, 1
0009F0  1  9F A9 FC 8D  
0009F4  1  21 9F A9 08  
0009FB  1  A9 04           lda #$04
0009FD  1  8D 23 9F        sta VERA_data0               ; byte 0: addr[12:5] = $00080>>5 = $04
000A00  1  A9 00           lda #$00
000A02  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, addr[16:13] = 0
000A05  1  A5 rr           lda player_x_lo
000A07  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000A0A  1  A5 rr           lda player_x_hi
000A0C  1  29 03           and #$03
000A0E  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000A11  1  A9 A4           lda #<PLAYER_Y
000A13  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000A16  1  A9 01           lda #>PLAYER_Y
000A18  1  29 03           and #$03
000A1A  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000A1D  1  A9 0C           lda #SPR_Z_FRONT
000A1F  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3, no collision, no flip
000A22  1  A9 50           lda #SPR_16x16_PAL0
000A24  1  8D 23 9F        sta VERA_data0               ; byte 7: palette 0, 16x16
000A27  1               
000A27  1                  ; --- upload player bullet pixel data to VRAM $00400 ---
000A27  1  A9 10 8D 22     VERA_SET_ADDR VRAM_BULLET, 1
000A2B  1  9F A9 04 8D  
000A2F  1  21 9F A9 00  
000A36  1  A2 00           ldx #0
000A38  1               @up_bullet:
000A38  1  BD 04 1B        lda bullet_spr_data,x
000A3B  1  8D 23 9F        sta VERA_data0
000A3E  1  E8              inx
000A3F  1  E0 20           cpx #32
000A41  1  D0 F5           bne @up_bullet
000A43  1               
000A43  1                  ; --- write sprite 2 attributes (initially disabled, z-depth=0) ---
000A43  1  A9 11 8D 22     VERA_SET_ADDR BULLET_SPRITE_ATTR, 1
000A47  1  9F A9 FC 8D  
000A4B  1  21 9F A9 10  
000A52  1  A9 20           lda #$20                     ; byte 0: addr[12:5] = $00400>>5 = $20
000A54  1  8D 23 9F        sta VERA_data0
000A57  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000A59  1  8D 23 9F        sta VERA_data0
000A5C  1  A9 00           lda #$00                     ; byte 2: X lo (arbitrary; sprite disabled)
000A5E  1  8D 23 9F        sta VERA_data0
000A61  1  A9 00           lda #$00                     ; byte 3: X hi
000A63  1  8D 23 9F        sta VERA_data0
000A66  1  A9 00           lda #$00                     ; byte 4: Y lo
000A68  1  8D 23 9F        sta VERA_data0
000A6B  1  A9 00           lda #$00                     ; byte 5: Y hi
000A6D  1  8D 23 9F        sta VERA_data0
000A70  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000A72  1  8D 23 9F        sta VERA_data0
000A75  1  A9 00           lda #SPR_8x8_PAL0            ; byte 7: 8x8, palette 0
000A77  1  8D 23 9F        sta VERA_data0
000A7A  1               
000A7A  1                  ; --- upload explosion pixel data to VRAM $00440 ---
000A7A  1  A9 10 8D 22     VERA_SET_ADDR VRAM_EXPLOSION, 1
000A7E  1  9F A9 04 8D  
000A82  1  21 9F A9 40  
000A89  1  A2 00           ldx #0
000A8B  1               @up_exp:
000A8B  1  BD D6 1B        lda explosion_pixels,x
000A8E  1  8D 23 9F        sta VERA_data0
000A91  1  E8              inx
000A92  1  E0 80           cpx #128
000A94  1  D0 F5           bne @up_exp
000A96  1               
000A96  1                  ; --- write sprite 4 attributes (initially disabled) ---
000A96  1                  ; addr[12:5] = VRAM_EXPLOSION>>5 = $00440>>5 = $22
000A96  1  A9 11 8D 22     VERA_SET_ADDR EXPLODE_SPRITE_ATTR, 1
000A9A  1  9F A9 FC 8D  
000A9E  1  21 9F A9 20  
000AA5  1  A9 22           lda #$22                     ; byte 0: addr[12:5]
000AA7  1  8D 23 9F        sta VERA_data0
000AAA  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000AAC  1  8D 23 9F        sta VERA_data0
000AAF  1  A9 00           lda #$00                     ; byte 2: X lo (placeholder)
000AB1  1  8D 23 9F        sta VERA_data0
000AB4  1  A9 00           lda #$00                     ; byte 3: X hi
000AB6  1  8D 23 9F        sta VERA_data0
000AB9  1  A9 00           lda #$00                     ; byte 4: Y lo (placeholder)
000ABB  1  8D 23 9F        sta VERA_data0
000ABE  1  A9 00           lda #$00                     ; byte 5: Y hi
000AC0  1  8D 23 9F        sta VERA_data0
000AC3  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000AC5  1  8D 23 9F        sta VERA_data0
000AC8  1  A9 50           lda #SPR_16x16_PAL0          ; byte 7: 16x16, palette 0
000ACA  1  8D 23 9F        sta VERA_data0
000ACD  1               
000ACD  1  64 rr           stz exp_timer
000ACF  1               
000ACF  1                  ; --- upload invader bullet pixel data to VRAM $00420 ---
000ACF  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_BULLET, 1
000AD3  1  9F A9 04 8D  
000AD7  1  21 9F A9 20  
000ADE  1  A2 00           ldx #0
000AE0  1               @up_ibul:
000AE0  1  BD B6 1B        lda inv_bullet_spr_data,x
000AE3  1  8D 23 9F        sta VERA_data0
000AE6  1  E8              inx
000AE7  1  E0 20           cpx #32
000AE9  1  D0 F5           bne @up_ibul
000AEB  1               
000AEB  1                  ; --- init 3 invader bullet sprites (slots 5-7, base $1FC28), all disabled ---
000AEB  1                  ; addr[12:5] = VRAM_INV_BULLET>>5 = $00420>>5 = $21
000AEB  1  A9 11 8D 22     VERA_SET_ADDR INV_BULLET_SPR_BASE, 1
000AEF  1  9F A9 FC 8D  
000AF3  1  21 9F A9 28  
000AFA  1  A2 03           ldx #3                       ; 3 sprites
000AFC  1               @init_ibspr:
000AFC  1  A9 21           lda #$21                     ; byte 0: addr[12:5] = $21
000AFE  1  8D 23 9F        sta VERA_data0
000B01  1  A9 00           lda #$00
000B03  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, bank 0
000B06  1  8D 23 9F        sta VERA_data0               ; byte 2: X lo
000B09  1  8D 23 9F        sta VERA_data0               ; byte 3: X hi
000B0C  1  8D 23 9F        sta VERA_data0               ; byte 4: Y lo
000B0F  1  8D 23 9F        sta VERA_data0               ; byte 5: Y hi
000B12  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=0 → disabled
000B15  1  8D 23 9F        sta VERA_data0               ; byte 7: 8x8, palette 0
000B18  1  CA              dex
000B19  1  D0 E1           bne @init_ibspr
000B1B  1               
000B1B  1                  ; --- clear invader bullet state ---
000B1B  1  64 rr           stz ibul_active+0
000B1D  1  64 rr           stz ibul_active+1
000B1F  1  64 rr           stz ibul_active+2
000B21  1  A9 5A           lda #INV_FIRE_TIMER_INIT
000B23  1  85 rr           sta inv_fire_timer
000B25  1               
000B25  1                  ; --- upload UFO pixel data → VRAM $01500 ---
000B25  1  A9 10 8D 22     VERA_SET_ADDR VRAM_UFO, 1
000B29  1  9F A9 15 8D  
000B2D  1  21 9F A9 00  
000B34  1  A2 80           ldx #128
000B36  1  BD D6 1B     @up_ufo: lda ufo_spr_data-128,x
000B39  1  8D 23 9F        sta VERA_data0
000B3C  1  E8              inx
000B3D  1  D0 F7           bne @up_ufo
000B3F  1               
000B3F  1                  ; --- write sprite 3 (UFO) attributes (initially disabled) ---
000B3F  1                  ; addr[12:5] = VRAM_UFO>>5 = $01500>>5 = $A8
000B3F  1  A9 11 8D 22     VERA_SET_ADDR UFO_SPRITE_ATTR, 1
000B43  1  9F A9 FC 8D  
000B47  1  21 9F A9 18  
000B4E  1  A9 A8           lda #$A8                     ; byte 0: addr[12:5]
000B50  1  8D 23 9F        sta VERA_data0
000B53  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000B55  1  8D 23 9F        sta VERA_data0
000B58  1  A9 00           lda #$00                     ; byte 2: X lo
000B5A  1  8D 23 9F        sta VERA_data0
000B5D  1  A9 00           lda #$00                     ; byte 3: X hi
000B5F  1  8D 23 9F        sta VERA_data0
000B62  1  A9 20           lda #<UFO_Y                  ; byte 4: Y lo
000B64  1  8D 23 9F        sta VERA_data0
000B67  1  A9 00           lda #>UFO_Y                  ; byte 5: Y hi
000B69  1  8D 23 9F        sta VERA_data0
000B6C  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000B6E  1  8D 23 9F        sta VERA_data0
000B71  1  A9 50           lda #SPR_16x16_PAL0          ; byte 7: 16x16, palette 0
000B73  1  8D 23 9F        sta VERA_data0
000B76  1               
000B76  1  60              rts
000B77  1               
000B77  1               ;******************************************************************
000B77  1               ; init_invaders — upload invader pixel data, init grid state, place sprites
000B77  1               ;******************************************************************
000B77  1               init_invaders:
000B77  1  9C 25 9F        stz VERA_ctrl
000B7A  1               
000B7A  1                  ; --- upload Type A frame 0 → VRAM $00100 ---
000B7A  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F0, 1
000B7E  1  9F A9 01 8D  
000B82  1  21 9F A9 00  
000B89  1  A2 80           ldx #128
000B8B  1  BD 56 1C     @up_af0: lda inv_a_spr_f0-128,x
000B8E  1  8D 23 9F        sta VERA_data0
000B91  1  E8              inx
000B92  1  D0 F7           bne @up_af0
000B94  1               
000B94  1                  ; --- upload Type A frame 1 → VRAM $00180 ---
000B94  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F1, 1
000B98  1  9F A9 01 8D  
000B9C  1  21 9F A9 80  
000BA3  1  A2 80           ldx #128
000BA5  1  BD D6 1C     @up_af1: lda inv_a_spr_f1-128,x
000BA8  1  8D 23 9F        sta VERA_data0
000BAB  1  E8              inx
000BAC  1  D0 F7           bne @up_af1
000BAE  1               
000BAE  1                  ; --- upload Type B frame 0 → VRAM $00200 ---
000BAE  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F0, 1
000BB2  1  9F A9 02 8D  
000BB6  1  21 9F A9 00  
000BBD  1  A2 80           ldx #128
000BBF  1  BD 56 1D     @up_bf0: lda inv_b_spr_f0-128,x
000BC2  1  8D 23 9F        sta VERA_data0
000BC5  1  E8              inx
000BC6  1  D0 F7           bne @up_bf0
000BC8  1               
000BC8  1                  ; --- upload Type B frame 1 → VRAM $00280 ---
000BC8  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F1, 1
000BCC  1  9F A9 02 8D  
000BD0  1  21 9F A9 80  
000BD7  1  A2 80           ldx #128
000BD9  1  BD D6 1D     @up_bf1: lda inv_b_spr_f1-128,x
000BDC  1  8D 23 9F        sta VERA_data0
000BDF  1  E8              inx
000BE0  1  D0 F7           bne @up_bf1
000BE2  1               
000BE2  1                  ; --- upload Type C frame 0 → VRAM $00300 ---
000BE2  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F0, 1
000BE6  1  9F A9 03 8D  
000BEA  1  21 9F A9 00  
000BF1  1  A2 80           ldx #128
000BF3  1  BD 56 1E     @up_cf0: lda inv_c_spr_f0-128,x
000BF6  1  8D 23 9F        sta VERA_data0
000BF9  1  E8              inx
000BFA  1  D0 F7           bne @up_cf0
000BFC  1               
000BFC  1                  ; --- upload Type C frame 1 → VRAM $00380 ---
000BFC  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F1, 1
000C00  1  9F A9 03 8D  
000C04  1  21 9F A9 80  
000C0B  1  A2 80           ldx #128
000C0D  1  BD D6 1E     @up_cf1: lda inv_c_spr_f1-128,x
000C10  1  8D 23 9F        sta VERA_data0
000C13  1  E8              inx
000C14  1  D0 F7           bne @up_cf1
000C16  1               
000C16  1                  ; --- initialize zero-page grid variables ---
000C16  1  A9 70           lda #<INV_GRID_X_INIT
000C18  1  85 rr           sta inv_grid_x_lo
000C1A  1  A9 00           lda #>INV_GRID_X_INIT
000C1C  1  85 rr           sta inv_grid_x_hi
000C1E  1  64 rr           stz inv_offset_y
000C20  1  64 rr           stz inv_direction
000C22  1  64 rr           stz inv_anim_frame
000C24  1  64 rr           stz inv_drop_flag
000C26  1               
000C26  1                  ; all 55 invaders alive: bytes 0-5 = $FF, byte 6 = $7F (55 bits)
000C26  1  A9 FF           lda #$FF
000C28  1  85 rr           sta inv_alive+0
000C2A  1  85 rr           sta inv_alive+1
000C2C  1  85 rr           sta inv_alive+2
000C2E  1  85 rr           sta inv_alive+3
000C30  1  85 rr           sta inv_alive+4
000C32  1  85 rr           sta inv_alive+5
000C34  1  A9 7F           lda #$7F
000C36  1  85 rr           sta inv_alive+6
000C38  1               
000C38  1  A9 37           lda #INV_COUNT_INIT
000C3A  1  85 rr           sta inv_count
000C3C  1  A9 32           lda #INV_MOVE_SPEED_INIT
000C3E  1  85 rr           sta inv_move_speed
000C40  1  85 rr           sta inv_move_timer
000C42  1               
000C42  1                  ; --- write initial sprite attributes for all 55 invaders ---
000C42  1  20 AB 0C        jsr update_invader_sprites
000C45  1  60              rts
000C46  1               
000C46  1               ;******************************************************************
000C46  1               ; step_invaders — one march step: move or drop grid, toggle anim frame
000C46  1               ;   Called when inv_move_timer reaches 0.
000C46  1               ;   Updates inv_grid_x / inv_offset_y, sets inv_drop_flag as needed,
000C46  1               ;   then refreshes all VERA sprite positions.
000C46  1               ;******************************************************************
000C46  1               step_invaders:
000C46  1                  ; toggle animation frame
000C46  1  A5 rr           lda inv_anim_frame
000C48  1  49 01           eor #1
000C4A  1  85 rr           sta inv_anim_frame
000C4C  1               
000C4C  1                  ; if drop flag is set: drop grid this step, skip march
000C4C  1  A5 rr           lda inv_drop_flag
000C4E  1  F0 0B           beq @do_march
000C50  1  64 rr           stz inv_drop_flag
000C52  1  A5 rr           lda inv_offset_y
000C54  1  18              clc
000C55  1  69 10           adc #INV_DROP_Y
000C57  1  85 rr           sta inv_offset_y
000C59  1  80 4C           bra @sprites_done
000C5B  1               
000C5B  1               @do_march:
000C5B  1  A5 rr           lda inv_direction
000C5D  1  D0 25           bne @march_left
000C5F  1               
000C5F  1                  ; --- march right ---
000C5F  1  A5 rr           lda inv_grid_x_lo
000C61  1  18              clc
000C62  1  69 04           adc #INV_STEP_X
000C64  1  85 rr           sta inv_grid_x_lo
000C66  1  90 02           bcc @chk_right
000C68  1  E6 rr           inc inv_grid_x_hi
000C6A  1               @chk_right:
000C6A  1                  ; hit right if grid_x > INV_X_RIGHT_LIM (208, fits in 1 byte, hi always 0)
000C6A  1  A5 rr           lda inv_grid_x_hi
000C6C  1  D0 06           bne @clamp_right          ; hi > 0 → definitely over limit
000C6E  1  A5 rr           lda inv_grid_x_lo
000C70  1  C9 D1           cmp #INV_X_RIGHT_LIM + 1  ; C set if lo > limit
000C72  1  90 33           bcc @sprites_done
000C74  1               @clamp_right:
000C74  1  A9 D0           lda #<INV_X_RIGHT_LIM
000C76  1  85 rr           sta inv_grid_x_lo
000C78  1  A9 00           lda #>INV_X_RIGHT_LIM
000C7A  1  85 rr           sta inv_grid_x_hi
000C7C  1  A9 01           lda #1
000C7E  1  85 rr           sta inv_direction
000C80  1  85 rr           sta inv_drop_flag
000C82  1  80 23           bra @sprites_done
000C84  1               
000C84  1                  ; --- march left ---
000C84  1               @march_left:
000C84  1  A5 rr           lda inv_grid_x_lo
000C86  1  38              sec
000C87  1  E9 04           sbc #INV_STEP_X
000C89  1  85 rr           sta inv_grid_x_lo
000C8B  1  B0 02           bcs @chk_left             ; no borrow
000C8D  1  C6 rr           dec inv_grid_x_hi
000C8F  1               @chk_left:
000C8F  1                  ; hit left if hi went negative OR lo < INV_X_LEFT_LIM
000C8F  1  A5 rr           lda inv_grid_x_hi
000C91  1  30 06           bmi @clamp_left
000C93  1  A5 rr           lda inv_grid_x_lo
000C95  1  C9 10           cmp #INV_X_LEFT_LIM
000C97  1  B0 0E           bcs @sprites_done         ; lo >= left limit → ok
000C99  1               @clamp_left:
000C99  1  A9 10           lda #<INV_X_LEFT_LIM
000C9B  1  85 rr           sta inv_grid_x_lo
000C9D  1  A9 00           lda #>INV_X_LEFT_LIM
000C9F  1  85 rr           sta inv_grid_x_hi
000CA1  1  64 rr           stz inv_direction
000CA3  1  A9 01           lda #1
000CA5  1  85 rr           sta inv_drop_flag
000CA7  1               
000CA7  1               @sprites_done:
000CA7  1  20 AB 0C        jsr update_invader_sprites
000CAA  1  60              rts
000CAB  1               
000CAB  1               ;******************************************************************
000CAB  1               ; update_invader_sprites — write all 55 invader sprite attributes to VERA
000CAB  1               ;
000CAB  1               ;   VERA sprite slots 11-65 hold the 55 invaders.
000CAB  1               ;   Attributes base: $1FC58 ($1FC00 + 11*8).
000CAB  1               ;   With stride=1 the VERA address auto-increments, so we set it
000CAB  1               ;   once and write all 440 bytes sequentially.
000CAB  1               ;
000CAB  1               ;   Byte layout per sprite:
000CAB  1               ;     0: data addr[12:5]   (encodes VRAM pixel data address + frame)
000CAB  1               ;     1: $00               (4bpp, addr[16:13]=0)
000CAB  1               ;     2: X[7:0]
000CAB  1               ;     3: X[9:8]
000CAB  1               ;     4: Y[7:0]
000CAB  1               ;     5: Y[9:8]
000CAB  1               ;     6: z-depth/collision
000CAB  1               ;     7: palette / size
000CAB  1               ;
000CAB  1               ;   Invader index i = row*11 + col; alive bit i in inv_alive bitmap.
000CAB  1               ;   For Phase 3 all invaders are alive; alive check will be added Phase 4.
000CAB  1               ;******************************************************************
000CAB  1               update_invader_sprites:
000CAB  1  9C 25 9F        stz VERA_ctrl
000CAE  1  A9 11           lda #$11              ; stride=1, VRAM bank bit=1 (addr $1Fxxxx)
000CB0  1  8D 22 9F        sta VERA_addr_bank
000CB3  1  A9 FC           lda #$FC
000CB5  1  8D 21 9F        sta VERA_addr_high
000CB8  1  A9 58           lda #$58
000CBA  1  8D 20 9F        sta VERA_addr_low     ; VERA now at $1FC58, auto-increments by 1
000CBD  1               
000CBD  1                  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000CBD  1  A9 50           lda #<INV_GRID_Y_BASE
000CBF  1  18              clc
000CC0  1  65 rr           adc inv_offset_y
000CC2  1  85 rr           sta zp_y_base_lo
000CC4  1  A9 00           lda #>INV_GRID_Y_BASE
000CC6  1  69 00           adc #0
000CC8  1  85 rr           sta zp_y_base_hi
000CCA  1               
000CCA  1  64 rr           stz zp_row
000CCC  1               @row_loop:
000CCC  1                  ; compute row Y: zp_row_y = zp_y_base + row_y_offsets[row]
000CCC  1  A4 rr           ldy zp_row
000CCE  1  B9 44 1B        lda row_y_offsets,y
000CD1  1  18              clc
000CD2  1  65 rr           adc zp_y_base_lo
000CD4  1  85 rr           sta zp_row_y_lo
000CD6  1  A9 00           lda #0
000CD8  1  65 rr           adc zp_y_base_hi
000CDA  1  85 rr           sta zp_row_y_hi
000CDC  1               
000CDC  1                  ; select addr byte0 based on row type and animation frame
000CDC  1  A4 rr           ldy zp_row
000CDE  1  A5 rr           lda inv_anim_frame
000CE0  1  F0 05           beq @use_f0
000CE2  1  B9 29 1B        lda inv_addr_b0_f1,y
000CE5  1  80 03           bra @got_b0
000CE7  1               @use_f0:
000CE7  1  B9 24 1B        lda inv_addr_b0_f0,y
000CEA  1               @got_b0:
000CEA  1  85 rr           sta zp_addr_b0
000CEC  1               
000CEC  1  20 F8 0C        jsr update_invader_row
000CEF  1               
000CEF  1  E6 rr           inc zp_row
000CF1  1  A5 rr           lda zp_row
000CF3  1  C9 05           cmp #5
000CF5  1  D0 D5           bne @row_loop
000CF7  1               
000CF7  1  60              rts
000CF8  1               
000CF8  1               ;******************************************************************
000CF8  1               ; update_invader_row — write 11 sprite attribute blocks for one row
000CF8  1               ;
000CF8  1               ;   Inputs (ZP): zp_row, zp_addr_b0, zp_row_y_lo/hi, inv_grid_x_lo/hi
000CF8  1               ;   VERA address register must already be set to the first sprite slot
000CF8  1               ;   for this row on entry (maintained by the sequential write stream).
000CF8  1               ;******************************************************************
000CF8  1               update_invader_row:
000CF8  1  64 rr           stz zp_col
000CFA  1               @col_loop:
000CFA  1                  ; --- determine z-depth from alive bitmap ---
000CFA  1                  ; index = inv_row_base[row] + col; byte = index>>3; bit = index&7
000CFA  1  A4 rr           ldy zp_row
000CFC  1  B9 49 1B        lda inv_row_base,y
000CFF  1  18              clc
000D00  1  65 rr           adc zp_col
000D02  1  A8              tay                   ; Y = invader index
000D03  1  29 07           and #$07
000D05  1  AA              tax                   ; X = bit index
000D06  1  BD 4E 1B        lda bit_masks,x
000D09  1  48              pha                   ; save bit mask
000D0A  1  98              tya
000D0B  1  4A              lsr
000D0C  1  4A              lsr
000D0D  1  4A              lsr
000D0E  1  A8              tay                   ; Y = byte index into inv_alive
000D0F  1  68              pla                   ; A = bit mask
000D10  1  39 rr rr        and inv_alive,y
000D13  1  F0 04           beq @zdepth_off
000D15  1  A9 0C           lda #SPR_Z_FRONT
000D17  1  80 02           bra @zdepth_done
000D19  1               @zdepth_off:
000D19  1  A9 00           lda #0
000D1B  1               @zdepth_done:
000D1B  1  85 rr           sta zp_scratch_lo     ; save z-depth before VERA stream starts
000D1D  1               
000D1D  1                  ; --- compute sprite X = inv_grid_x + col_x_offsets[col] ---
000D1D  1  A4 rr           ldy zp_col
000D1F  1  B9 2E 1B        lda col_x_lo,y
000D22  1  18              clc
000D23  1  65 rr           adc inv_grid_x_lo
000D25  1  85 rr           sta zp_x_lo
000D27  1  B9 39 1B        lda col_x_hi,y
000D2A  1  65 rr           adc inv_grid_x_hi
000D2C  1  85 rr           sta zp_x_hi
000D2E  1               
000D2E  1                  ; --- write 8 attribute bytes (VERA auto-increments) ---
000D2E  1  A5 rr           lda zp_addr_b0
000D30  1  8D 23 9F        sta VERA_data0        ; byte 0: data addr[12:5]
000D33  1  9C 23 9F        stz VERA_data0        ; byte 1: 4bpp, addr[16:13]=0
000D36  1  A5 rr           lda zp_x_lo
000D38  1  8D 23 9F        sta VERA_data0        ; byte 2: X[7:0]
000D3B  1  A5 rr           lda zp_x_hi
000D3D  1  29 03           and #$03
000D3F  1  8D 23 9F        sta VERA_data0        ; byte 3: X[9:8]
000D42  1  A5 rr           lda zp_row_y_lo
000D44  1  8D 23 9F        sta VERA_data0        ; byte 4: Y[7:0]
000D47  1  A5 rr           lda zp_row_y_hi
000D49  1  29 03           and #$03
000D4B  1  8D 23 9F        sta VERA_data0        ; byte 5: Y[9:8]
000D4E  1  A5 rr           lda zp_scratch_lo
000D50  1  8D 23 9F        sta VERA_data0        ; byte 6: z-depth (SPR_Z_FRONT if alive, 0 if dead)
000D53  1  A9 50           lda #SPR_16x16_PAL0
000D55  1  8D 23 9F        sta VERA_data0        ; byte 7: 16x16, palette offset 0
000D58  1               
000D58  1  E6 rr           inc zp_col
000D5A  1  A5 rr           lda zp_col
000D5C  1  C9 0B           cmp #11
000D5E  1  D0 9A           bne @col_loop
000D60  1               
000D60  1  60              rts
000D61  1               
000D61  1               ;******************************************************************
000D61  1               ; move_player — apply key_flags movement and clamp to screen edges
000D61  1               ;******************************************************************
000D61  1               move_player:
000D61  1  A5 rr           lda key_flags
000D63  1               
000D63  1                  ; --- move left ---
000D63  1  29 01           and #KEY_LEFT
000D65  1  F0 1F           beq @check_right
000D67  1  A5 rr           lda player_x_lo
000D69  1  38              sec
000D6A  1  E9 04           sbc #PLAYER_SPEED
000D6C  1  85 rr           sta player_x_lo
000D6E  1  B0 02           bcs @clamp_left              ; no borrow → hi unchanged
000D70  1  C6 rr           dec player_x_hi
000D72  1               @clamp_left:
000D72  1                  ; Clamp: if hi went negative ($FF) or (hi=0 AND lo < min) → set to min
000D72  1  A5 rr           lda player_x_hi
000D74  1  30 08           bmi @set_min                 ; $80–$FF = underflowed
000D76  1  D0 0E           bne @check_right             ; hi > 0 → still above minimum
000D78  1  A5 rr           lda player_x_lo
000D7A  1  C9 08           cmp #PLAYER_X_MIN
000D7C  1  B0 08           bcs @check_right             ; lo >= min → ok
000D7E  1               @set_min:
000D7E  1  A9 08           lda #<PLAYER_X_MIN
000D80  1  85 rr           sta player_x_lo
000D82  1  A9 00           lda #>PLAYER_X_MIN
000D84  1  85 rr           sta player_x_hi
000D86  1               
000D86  1                  ; --- move right ---
000D86  1               @check_right:
000D86  1  A5 rr           lda key_flags
000D88  1  29 02           and #KEY_RIGHT
000D8A  1  F0 23           beq @move_done
000D8C  1  A5 rr           lda player_x_lo
000D8E  1  18              clc
000D8F  1  69 04           adc #PLAYER_SPEED
000D91  1  85 rr           sta player_x_lo
000D93  1  90 02           bcc @clamp_right             ; no carry → hi unchanged
000D95  1  E6 rr           inc player_x_hi
000D97  1               @clamp_right:
000D97  1                  ; Clamp: if hi > max_hi, OR (hi == max_hi AND lo > max_lo) → set to max
000D97  1  A5 rr           lda player_x_hi
000D99  1  C9 02           cmp #>PLAYER_X_MAX
000D9B  1  90 12           bcc @move_done               ; hi < max_hi → definitely ok
000D9D  1  D0 08           bne @set_max                 ; hi > max_hi → over limit
000D9F  1  A5 rr           lda player_x_lo
000DA1  1  C9 68           cmp #<PLAYER_X_MAX
000DA3  1  90 0A           bcc @move_done               ; lo < max_lo when hi == max_hi → ok
000DA5  1  F0 08           beq @move_done               ; lo == max_lo → exactly at max, ok
000DA7  1               @set_max:
000DA7  1  A9 68           lda #<PLAYER_X_MAX
000DA9  1  85 rr           sta player_x_lo
000DAB  1  A9 02           lda #>PLAYER_X_MAX
000DAD  1  85 rr           sta player_x_hi
000DAF  1               
000DAF  1               @move_done:
000DAF  1  60              rts
000DB0  1               
000DB0  1               ;******************************************************************
000DB0  1               ; update_player_sprite — write current X position to sprite 1 in VERA
000DB0  1               ;   Only X needs updating (Y is fixed)
000DB0  1               ;******************************************************************
000DB0  1               update_player_sprite:
000DB0  1  9C 25 9F        stz VERA_ctrl
000DB3  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 2), 1
000DB7  1  9F A9 FC 8D  
000DBB  1  21 9F A9 0A  
000DC2  1  A5 rr           lda player_x_lo
000DC4  1  8D 23 9F        sta VERA_data0               ; sprite byte 2: X[7:0]
000DC7  1  A5 rr           lda player_x_hi
000DC9  1  29 03           and #$03
000DCB  1  8D 23 9F        sta VERA_data0               ; sprite byte 3: X[9:8]
000DCE  1                  ; update z-depth based on inv_hit_timer:
000DCE  1                  ;   timer = 0        → show solid (not hit)
000DCE  1                  ;   timer = 61-120   → hidden solid (1-second respawn delay)
000DCE  1                  ;   timer = 1-60     → flashing (invincible, visible warning)
000DCE  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 6), 1
000DD2  1  9F A9 FC 8D  
000DD6  1  21 9F A9 0E  
000DDD  1  A5 rr           lda inv_hit_timer
000DDF  1  F0 08           beq @show                    ; timer=0 → show solid
000DE1  1  C9 3D           cmp #61
000DE3  1  B0 08           bcs @hide                    ; timer>=61 → first second: fully hidden
000DE5  1  29 08           and #$08                     ; timer 1-60: bit 3 flips every 8 frames → ~4 Hz flash
000DE7  1  D0 04           bne @hide
000DE9  1               @show:
000DE9  1  A9 0C           lda #SPR_Z_FRONT
000DEB  1  80 02           bra @write_z
000DED  1               @hide:
000DED  1  A9 00           lda #0
000DEF  1               @write_z:
000DEF  1  8D 23 9F        sta VERA_data0               ; sprite byte 6: z-depth
000DF2  1  60              rts
000DF3  1               
000DF3  1               ;******************************************************************
000DF3  1               ; fire_bullet — activate player bullet at cannon tip, update sprite
000DF3  1               ;   Bullet X centers the 8-px bullet over the 16-px player ship:
000DF3  1               ;     bullet_x = player_x + 4
000DF3  1               ;   Bullet Y starts 8 VERA pixels above the player sprite top.
000DF3  1               ;   Caller must check bullet_active == 0 before calling.
000DF3  1               ;******************************************************************
000DF3  1               fire_bullet:
000DF3  1  A5 rr           lda player_x_lo
000DF5  1  18              clc
000DF6  1  69 04           adc #4
000DF8  1  85 rr           sta bullet_x_lo
000DFA  1  A5 rr           lda player_x_hi
000DFC  1  69 00           adc #0
000DFE  1  85 rr           sta bullet_x_hi
000E00  1               
000E00  1  A9 9C           lda #<BULLET_Y_INIT
000E02  1  85 rr           sta bullet_y_lo
000E04  1  A9 01           lda #>BULLET_Y_INIT
000E06  1  85 rr           sta bullet_y_hi
000E08  1               
000E08  1  A9 01           lda #1
000E0A  1  85 rr           sta bullet_active
000E0C  1  E6 rr           inc shot_count
000E0E  1  20 2B 0E        jsr update_bullet_sprite
000E11  1  60              rts
000E12  1               
000E12  1               ;******************************************************************
000E12  1               ; move_bullet — move bullet upward by BULLET_SPEED each frame;
000E12  1               ;   deactivate when it reaches the top of the screen (Y underflows 0)
000E12  1               ;******************************************************************
000E12  1               move_bullet:
000E12  1  A5 rr           lda bullet_y_lo
000E14  1  38              sec
000E15  1  E9 0C           sbc #BULLET_SPEED
000E17  1  85 rr           sta bullet_y_lo
000E19  1  A5 rr           lda bullet_y_hi
000E1B  1  E9 00           sbc #0
000E1D  1  85 rr           sta bullet_y_hi
000E1F  1  30 04           bmi @deactivate              ; 16-bit underflow past 0 → off screen
000E21  1               
000E21  1  20 2B 0E        jsr update_bullet_sprite
000E24  1  60              rts
000E25  1               
000E25  1               @deactivate:
000E25  1  64 rr           stz bullet_active
000E27  1  20 2B 0E        jsr update_bullet_sprite     ; disables sprite (z-depth=0)
000E2A  1  60              rts
000E2B  1               
000E2B  1               ;******************************************************************
000E2B  1               ; update_bullet_sprite — write bullet position and enable/disable
000E2B  1               ;   to VERA sprite 2 (bytes 2-6); byte 7 set once at init.
000E2B  1               ;   z-depth = SPR_Z_FRONT when active, 0 when inactive.
000E2B  1               ;******************************************************************
000E2B  1               update_bullet_sprite:
000E2B  1  9C 25 9F        stz VERA_ctrl
000E2E  1  A9 11 8D 22     VERA_SET_ADDR (BULLET_SPRITE_ATTR + 2), 1
000E32  1  9F A9 FC 8D  
000E36  1  21 9F A9 12  
000E3D  1  A5 rr           lda bullet_x_lo
000E3F  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000E42  1  A5 rr           lda bullet_x_hi
000E44  1  29 03           and #$03
000E46  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000E49  1  A5 rr           lda bullet_y_lo
000E4B  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000E4E  1  A5 rr           lda bullet_y_hi
000E50  1  29 03           and #$03
000E52  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000E55  1  A5 rr           lda bullet_active
000E57  1  F0 04           beq @z_off
000E59  1  A9 0C           lda #SPR_Z_FRONT
000E5B  1  80 02           bra @write_z
000E5D  1               @z_off:
000E5D  1  A9 00           lda #$00
000E5F  1               @write_z:
000E5F  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
000E62  1  60              rts
000E63  1               
000E63  1               ;******************************************************************
000E63  1               ; check_bullet_invader — scan all 55 invaders for a hit with the player bullet
000E63  1               ;
000E63  1               ;   Iterates rows 0-4, columns 0-10.  Skips dead invaders.
000E63  1               ;   For each live invader checks 16-bit AABB overlap:
000E63  1               ;     X: bullet_x+8 > inv_x  AND  bullet_x < inv_x+16
000E63  1               ;     Y: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000E63  1               ;   On hit: calls kill_invader_hit and returns immediately.
000E63  1               ;
000E63  1               ;   Scratch used: zp_y_base_lo/hi, zp_row_y_lo/hi, zp_x_lo/hi,
000E63  1               ;                 zp_scratch_lo/hi, zp_row, zp_col
000E63  1               ;******************************************************************
000E63  1               check_bullet_invader:
000E63  1  A5 rr           lda bullet_active
000E65  1  D0 01           bne :+
000E67  1  60              rts
000E68  1               :  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000E68  1  A9 50           lda #<INV_GRID_Y_BASE
000E6A  1  18              clc
000E6B  1  65 rr           adc inv_offset_y
000E6D  1  85 rr           sta zp_y_base_lo
000E6F  1  A9 00           lda #>INV_GRID_Y_BASE
000E71  1  69 00           adc #0
000E73  1  85 rr           sta zp_y_base_hi
000E75  1               
000E75  1  64 rr           stz zp_row
000E77  1               @row_loop:
000E77  1                  ; row Y = y_base + row_y_offsets[row]
000E77  1  A4 rr           ldy zp_row
000E79  1  B9 44 1B        lda row_y_offsets,y
000E7C  1  18              clc
000E7D  1  65 rr           adc zp_y_base_lo
000E7F  1  85 rr           sta zp_row_y_lo
000E81  1  A9 00           lda #0
000E83  1  65 rr           adc zp_y_base_hi
000E85  1  85 rr           sta zp_row_y_hi
000E87  1               
000E87  1                  ; --- Quick Y range check for whole row ---
000E87  1                  ; Need: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000E87  1               
000E87  1                  ; (1) bullet_y+8 > inv_y  →  (bullet_y+8) - inv_y > 0
000E87  1                  ;     result negative (bmi) means bullet above this row
000E87  1  A5 rr           lda bullet_y_lo
000E89  1  18              clc
000E8A  1  69 08           adc #8
000E8C  1  85 rr           sta zp_scratch_lo
000E8E  1  A5 rr           lda bullet_y_hi
000E90  1  69 00           adc #0
000E92  1  85 rr           sta zp_scratch_hi
000E94  1  A5 rr           lda zp_scratch_lo
000E96  1  38              sec
000E97  1  E5 rr           sbc zp_row_y_lo
000E99  1  A5 rr           lda zp_scratch_hi
000E9B  1  E5 rr           sbc zp_row_y_hi
000E9D  1  30 1D           bmi @next_row         ; bullet bottom above invader top → no hit in this row
000E9F  1               
000E9F  1                  ; (2) bullet_y < inv_y+16  →  bullet_y - (inv_y+16) < 0
000E9F  1                  ;     result >= 0 (bpl) means bullet below this row
000E9F  1  A5 rr           lda zp_row_y_lo
000EA1  1  18              clc
000EA2  1  69 10           adc #16
000EA4  1  85 rr           sta zp_scratch_lo
000EA6  1  A5 rr           lda zp_row_y_hi
000EA8  1  69 00           adc #0
000EAA  1  85 rr           sta zp_scratch_hi
000EAC  1  A5 rr           lda bullet_y_lo
000EAE  1  38              sec
000EAF  1  E5 rr           sbc zp_scratch_lo
000EB1  1  A5 rr           lda bullet_y_hi
000EB3  1  E5 rr           sbc zp_scratch_hi
000EB5  1  10 05           bpl @next_row         ; bullet top at or below invader bottom → no hit
000EB7  1               
000EB7  1                  ; Y overlaps this row — check each column
000EB7  1  20 C5 0E        jsr cbi_check_cols
000EBA  1  B0 08           bcs @done             ; hit found; bullet already handled
000EBC  1               
000EBC  1               @next_row:
000EBC  1  E6 rr           inc zp_row
000EBE  1  A5 rr           lda zp_row
000EC0  1  C9 05           cmp #5
000EC2  1  D0 B3           bne @row_loop
000EC4  1               
000EC4  1               @done:
000EC4  1  60              rts
000EC5  1               
000EC5  1               ;******************************************************************
000EC5  1               ; cbi_check_cols — column scan for check_bullet_invader
000EC5  1               ;
000EC5  1               ;   Scans all 11 columns of zp_row for an X overlap with the bullet.
000EC5  1               ;   Assumes Y overlap for this row has already been confirmed.
000EC5  1               ;   Returns: C set if hit (kill_invader_hit already called),
000EC5  1               ;            C clear if no hit.
000EC5  1               ;   Scratch used: zp_col, zp_x_lo/hi, zp_scratch_lo/hi
000EC5  1               ;******************************************************************
000EC5  1               cbi_check_cols:
000EC5  1  64 rr           stz zp_col
000EC7  1               @col_loop:
000EC7  1                  ; skip if invader is dead
000EC7  1  A4 rr           ldy zp_row
000EC9  1  B9 49 1B        lda inv_row_base,y
000ECC  1  18              clc
000ECD  1  65 rr           adc zp_col
000ECF  1  A8              tay                   ; Y = invader index
000ED0  1  29 07           and #$07
000ED2  1  AA              tax
000ED3  1  BD 4E 1B        lda bit_masks,x
000ED6  1  48              pha
000ED7  1  98              tya
000ED8  1  4A              lsr
000ED9  1  4A              lsr
000EDA  1  4A              lsr
000EDB  1  A8              tay                   ; Y = byte index into inv_alive
000EDC  1  68              pla
000EDD  1  39 rr rr        and inv_alive,y
000EE0  1  F0 46           beq @next_col         ; dead
000EE2  1               
000EE2  1                  ; compute inv_x = inv_grid_x + col_x_offsets[col]
000EE2  1  A4 rr           ldy zp_col
000EE4  1  B9 2E 1B        lda col_x_lo,y
000EE7  1  18              clc
000EE8  1  65 rr           adc inv_grid_x_lo
000EEA  1  85 rr           sta zp_x_lo
000EEC  1  B9 39 1B        lda col_x_hi,y
000EEF  1  65 rr           adc inv_grid_x_hi
000EF1  1  85 rr           sta zp_x_hi
000EF3  1               
000EF3  1                  ; X check (1): bullet_x+8 > inv_x
000EF3  1  A5 rr           lda bullet_x_lo
000EF5  1  18              clc
000EF6  1  69 08           adc #8
000EF8  1  85 rr           sta zp_scratch_lo
000EFA  1  A5 rr           lda bullet_x_hi
000EFC  1  69 00           adc #0
000EFE  1  85 rr           sta zp_scratch_hi
000F00  1  A5 rr           lda zp_scratch_lo
000F02  1  38              sec
000F03  1  E5 rr           sbc zp_x_lo
000F05  1  A5 rr           lda zp_scratch_hi
000F07  1  E5 rr           sbc zp_x_hi
000F09  1  30 1D           bmi @next_col         ; bullet right edge left of invader → no hit
000F0B  1               
000F0B  1                  ; X check (2): bullet_x < inv_x+16
000F0B  1  A5 rr           lda zp_x_lo
000F0D  1  18              clc
000F0E  1  69 10           adc #16
000F10  1  85 rr           sta zp_scratch_lo
000F12  1  A5 rr           lda zp_x_hi
000F14  1  69 00           adc #0
000F16  1  85 rr           sta zp_scratch_hi
000F18  1  A5 rr           lda bullet_x_lo
000F1A  1  38              sec
000F1B  1  E5 rr           sbc zp_scratch_lo
000F1D  1  A5 rr           lda bullet_x_hi
000F1F  1  E5 rr           sbc zp_scratch_hi
000F21  1  10 05           bpl @next_col         ; bullet left edge at or right of invader → no hit
000F23  1               
000F23  1                  ; --- HIT ---
000F23  1  20 32 0F        jsr kill_invader_hit
000F26  1  38              sec                   ; signal hit to caller
000F27  1  60              rts
000F28  1               
000F28  1               @next_col:
000F28  1  E6 rr           inc zp_col
000F2A  1  A5 rr           lda zp_col
000F2C  1  C9 0B           cmp #11
000F2E  1  D0 97           bne @col_loop
000F30  1               
000F30  1  18              clc                   ; no hit
000F31  1  60              rts
000F32  1               
000F32  1               ;******************************************************************
000F32  1               ; kill_invader_hit — clear alive bit, deactivate bullet, update score & speed
000F32  1               ;   Expects zp_row, zp_col to identify the hit invader.
000F32  1               ;******************************************************************
000F32  1               kill_invader_hit:
000F32  1                  ; --- clear alive bit ---
000F32  1  A4 rr           ldy zp_row
000F34  1  B9 49 1B        lda inv_row_base,y
000F37  1  18              clc
000F38  1  65 rr           adc zp_col
000F3A  1  A8              tay                   ; Y = invader index
000F3B  1  29 07           and #$07
000F3D  1  AA              tax
000F3E  1  BD 4E 1B        lda bit_masks,x       ; bit mask for this invader
000F41  1  48              pha
000F42  1  98              tya
000F43  1  4A              lsr
000F44  1  4A              lsr
000F45  1  4A              lsr
000F46  1  A8              tay                   ; Y = byte index into inv_alive
000F47  1  68              pla
000F48  1  49 FF           eor #$FF              ; invert → clear mask
000F4A  1  39 rr rr        and inv_alive,y
000F4D  1  99 rr rr        sta inv_alive,y
000F50  1               
000F50  1                  ; --- start explosion at the hit invader's position ---
000F50  1                  ; zp_x_lo/hi and zp_row_y_lo/hi still hold the invader coords from collision detection
000F50  1  20 7E 0F        jsr start_explosion
000F53  1               
000F53  1                  ; --- deactivate bullet ---
000F53  1  64 rr           stz bullet_active
000F55  1  20 2B 0E        jsr update_bullet_sprite
000F58  1               
000F58  1                  ; --- decrement inv_count ---
000F58  1  C6 rr           dec inv_count
000F5A  1               
000F5A  1                  ; --- update inv_move_speed: proportional to remaining count ---
000F5A  1  A6 rr           ldx inv_count
000F5C  1  BD 5B 1B        lda inv_speed_table,x
000F5F  1  85 rr           sta inv_move_speed
000F61  1               
000F61  1                  ; --- add score for this row's invader type ---
000F61  1  A4 rr           ldy zp_row
000F63  1  B9 56 1B        lda score_by_row_bcd,y
000F66  1  20 6A 0F        jsr add_score
000F69  1  60              rts
000F6A  1               
000F6A  1               ;******************************************************************
000F6A  1               ; add_score — add BCD value in A to score_lo/mid/hi
000F6A  1               ;******************************************************************
000F6A  1               add_score:
000F6A  1  F8              sed
000F6B  1  18              clc
000F6C  1  65 rr           adc score_lo
000F6E  1  85 rr           sta score_lo
000F70  1  A5 rr           lda score_mid
000F72  1  69 00           adc #0
000F74  1  85 rr           sta score_mid
000F76  1  A5 rr           lda score_hi
000F78  1  69 00           adc #0
000F7A  1  85 rr           sta score_hi
000F7C  1  D8              cld
000F7D  1  60              rts
000F7E  1               
000F7E  1               ;******************************************************************
000F7E  1               ; start_explosion — position sprite 4 at the hit invader and start timer
000F7E  1               ;
000F7E  1               ;   Inputs: zp_x_lo/hi     — invader X (VERA coords)
000F7E  1               ;           zp_row_y_lo/hi — invader Y (VERA coords)
000F7E  1               ;   Sets exp_timer = EXPLODE_FRAMES and enables sprite 4.
000F7E  1               ;******************************************************************
000F7E  1               start_explosion:
000F7E  1  9C 25 9F        stz VERA_ctrl
000F81  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 2), 1  ; start at byte 2 (X lo)
000F85  1  9F A9 FC 8D  
000F89  1  21 9F A9 22  
000F90  1  A5 rr           lda zp_x_lo
000F92  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000F95  1  A5 rr           lda zp_x_hi
000F97  1  29 03           and #$03
000F99  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000F9C  1  A5 rr           lda zp_row_y_lo
000F9E  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000FA1  1  A5 rr           lda zp_row_y_hi
000FA3  1  29 03           and #$03
000FA5  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000FA8  1  A9 0C           lda #SPR_Z_FRONT
000FAA  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3 → enabled, in front
000FAD  1  A9 1E           lda #EXPLODE_FRAMES
000FAF  1  85 rr           sta exp_timer
000FB1  1  60              rts
000FB2  1               
000FB2  1               ;******************************************************************
000FB2  1               ; update_explosion — decrement exp_timer; disable sprite when it hits 0
000FB2  1               ;******************************************************************
000FB2  1               update_explosion:
000FB2  1  A5 rr           lda exp_timer
000FB4  1  F0 1B           beq @inactive
000FB6  1  C6 rr           dec exp_timer
000FB8  1  D0 17           bne @inactive
000FBA  1                  ; timer just expired — disable sprite 4
000FBA  1  9C 25 9F        stz VERA_ctrl
000FBD  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1  ; byte 6 = z-depth
000FC1  1  9F A9 FC 8D  
000FC5  1  21 9F A9 26  
000FCC  1  A9 00           lda #$00
000FCE  1  8D 23 9F        sta VERA_data0               ; z-depth=0 → disabled
000FD1  1               @inactive:
000FD1  1  60              rts
000FD2  1               
000FD2  1               ;******************************************************************
000FD2  1               ; prng — 16-bit Galois LFSR, feedback polynomial $B400
000FD2  1               ;   Updates rand_seed_lo/hi; returns pseudo-random byte in A.
000FD2  1               ;******************************************************************
000FD2  1               prng:
000FD2  1  46 rr           lsr rand_seed_hi          ; shift 16-bit state right; carry = old hi[0]
000FD4  1  66 rr           ror rand_seed_lo          ; lo[7] = old hi[0]; carry = old lo[0] (feedback bit)
000FD6  1  90 06           bcc @done                 ; feedback bit=0: no XOR
000FD8  1  A5 rr           lda rand_seed_hi
000FDA  1  49 B4           eor #$B4                  ; XOR hi byte with feedback poly ($B400 >> 8)
000FDC  1  85 rr           sta rand_seed_hi
000FDE  1               @done:
000FDE  1  A5 rr           lda rand_seed_lo
000FE0  1  60              rts
000FE1  1               
000FE1  1               ;******************************************************************
000FE1  1               ; update_inv_bullets — fire timer, move active bullets, boundary check,
000FE1  1               ;   update VERA sprites for all 3 invader bullet slots.
000FE1  1               ;******************************************************************
000FE1  1               update_inv_bullets:
000FE1  1                  ; --- fire timer ---
000FE1  1  C6 rr           dec inv_fire_timer
000FE3  1  D0 0D           bne @move_loop
000FE5  1                  ; reset timer = max(inv_move_speed, INV_FIRE_TIMER_MIN)
000FE5  1  A5 rr           lda inv_move_speed
000FE7  1  C9 0A           cmp #INV_FIRE_TIMER_MIN
000FE9  1  B0 02           bcs @set_timer
000FEB  1  A9 0A           lda #INV_FIRE_TIMER_MIN
000FED  1               @set_timer:
000FED  1  85 rr           sta inv_fire_timer
000FEF  1  20 5C 10        jsr try_fire_inv_bullet
000FF2  1               
000FF2  1               @move_loop:
000FF2  1  A2 00           ldx #0
000FF4  1               @slot_loop:
000FF4  1  B5 rr           lda ibul_active,x
000FF6  1  F0 1B           beq @update_spr           ; inactive: just hide sprite
000FF8  1               
000FF8  1                  ; move bullet down by INV_BULLET_SPEED
000FF8  1  B5 rr           lda ibul_y_lo,x
000FFA  1  18              clc
000FFB  1  69 06           adc #INV_BULLET_SPEED
000FFD  1  95 rr           sta ibul_y_lo,x
000FFF  1  B5 rr           lda ibul_y_hi,x
001001  1  69 00           adc #0
001003  1  95 rr           sta ibul_y_hi,x
001005  1               
001005  1                  ; boundary: deactivate if Y >= 480 ($01E0)
001005  1  C9 01           cmp #>480                 ; A = new hi byte; compare with 1
001007  1  90 0A           bcc @update_spr           ; hi < 1: still on screen
001009  1  D0 06           bne @deactivate           ; hi > 1: off screen
00100B  1  B5 rr           lda ibul_y_lo,x
00100D  1  C9 E0           cmp #<480                 ; compare lo with $E0
00100F  1  90 02           bcc @update_spr           ; lo < $E0: still on screen
001011  1               @deactivate:
001011  1  74 rr           stz ibul_active,x
001013  1               
001013  1               @update_spr:
001013  1  20 1C 10        jsr update_inv_bullet_sprite   ; preserves X
001016  1  E8              inx
001017  1  E0 03           cpx #3
001019  1  D0 D9           bne @slot_loop
00101B  1  60              rts
00101C  1               
00101C  1               ;******************************************************************
00101C  1               ; update_inv_bullet_sprite — write VERA sprite attrs bytes 2-6 for slot X
00101C  1               ;   X = slot index (0-2).  Preserves X.
00101C  1               ;******************************************************************
00101C  1               update_inv_bullet_sprite:
00101C  1  86 rr           stx zp_scratch_lo              ; preserve slot index
00101E  1  9C 25 9F        stz VERA_ctrl
001021  1  A9 11           lda #$11                       ; stride=1, bank bit=1
001023  1  8D 22 9F        sta VERA_addr_bank
001026  1  A9 FC           lda #$FC
001028  1  8D 21 9F        sta VERA_addr_high
00102B  1  BD 93 1B        lda ibul_spr_lo,x
00102E  1  18              clc
00102F  1  69 02           adc #2                         ; point to byte 2 (X position)
001031  1  8D 20 9F        sta VERA_addr_low
001034  1  B5 rr           lda ibul_x_lo,x
001036  1  8D 23 9F        sta VERA_data0                 ; byte 2: X lo
001039  1  B5 rr           lda ibul_x_hi,x
00103B  1  29 03           and #$03
00103D  1  8D 23 9F        sta VERA_data0                 ; byte 3: X hi
001040  1  B5 rr           lda ibul_y_lo,x
001042  1  8D 23 9F        sta VERA_data0                 ; byte 4: Y lo
001045  1  B5 rr           lda ibul_y_hi,x
001047  1  29 03           and #$03
001049  1  8D 23 9F        sta VERA_data0                 ; byte 5: Y hi
00104C  1  B5 rr           lda ibul_active,x
00104E  1  F0 04           beq @disabled
001050  1  A9 0C           lda #SPR_Z_FRONT
001052  1  80 02           bra @write_z
001054  1               @disabled:
001054  1  A9 00           lda #0
001056  1               @write_z:
001056  1  8D 23 9F        sta VERA_data0                 ; byte 6: z-depth
001059  1  A6 rr           ldx zp_scratch_lo
00105B  1  60              rts
00105C  1               
00105C  1               ;******************************************************************
00105C  1               ; try_fire_inv_bullet — find a free slot and spawn a bullet from the
00105C  1               ;   bottommost live invader in a randomly chosen column.
00105C  1               ;   Returns immediately if all slots busy or chosen column is empty.
00105C  1               ;   Scratch used: zp_row, zp_col, zp_scratch_lo (slot index)
00105C  1               ;******************************************************************
00105C  1               try_fire_inv_bullet:
00105C  1                  ; find a free bullet slot
00105C  1  A2 00           ldx #0
00105E  1               @find_slot:
00105E  1  B5 rr           lda ibul_active,x
001060  1  F0 06           beq @slot_found
001062  1  E8              inx
001063  1  E0 03           cpx #3
001065  1  D0 F7           bne @find_slot
001067  1  60              rts                            ; all slots busy
001068  1               
001068  1               @slot_found:
001068  1  86 rr           stx zp_scratch_lo              ; save free slot index
00106A  1               
00106A  1                  ; pick a random column 0-10
00106A  1  20 D2 0F        jsr prng
00106D  1  29 0F           and #$0F                       ; 0-15
00106F  1  C9 0B           cmp #11
001071  1  90 03           bcc @col_ok
001073  1  38              sec
001074  1  E9 0B           sbc #11                        ; wrap 11-15 → 0-4 (slight bias, acceptable)
001076  1               @col_ok:
001076  1  85 rr           sta zp_col
001078  1               
001078  1                  ; scan rows 4 down to 0 for bottommost live invader in this column
001078  1  A9 04           lda #4
00107A  1  85 rr           sta zp_row
00107C  1               @row_scan:
00107C  1  A4 rr           ldy zp_row
00107E  1  B9 49 1B        lda inv_row_base,y
001081  1  18              clc
001082  1  65 rr           adc zp_col
001084  1  A8              tay                            ; Y = invader index
001085  1  29 07           and #$07
001087  1  AA              tax                            ; X = bit position
001088  1  BD 4E 1B        lda bit_masks,x
00108B  1  48              pha
00108C  1  98              tya
00108D  1  4A              lsr
00108E  1  4A              lsr
00108F  1  4A              lsr
001090  1  A8              tay                            ; Y = byte index into inv_alive
001091  1  68              pla
001092  1  39 rr rr        and inv_alive,y
001095  1  D0 09           bne @found_invader
001097  1  A5 rr           lda zp_row
001099  1  F0 04           beq @no_invader                ; checked row 0, nothing alive
00109B  1  C6 rr           dec zp_row
00109D  1  80 DD           bra @row_scan
00109F  1               
00109F  1               @no_invader:
00109F  1  60              rts                            ; column empty, skip fire
0010A0  1               
0010A0  1               @found_invader:
0010A0  1  A6 rr           ldx zp_scratch_lo              ; restore free slot index
0010A2  1  A9 01           lda #1
0010A4  1  95 rr           sta ibul_active,x
0010A6  1               
0010A6  1                  ; spawn X = inv_grid_x + col_x_offsets[col]  (16-bit, matching update_invader_sprites)
0010A6  1  A4 rr           ldy zp_col
0010A8  1  B9 2E 1B        lda col_x_lo,y
0010AB  1  18              clc
0010AC  1  65 rr           adc inv_grid_x_lo
0010AE  1  95 rr           sta ibul_x_lo,x
0010B0  1  B9 39 1B        lda col_x_hi,y
0010B3  1  65 rr           adc inv_grid_x_hi
0010B5  1  95 rr           sta ibul_x_hi,x
0010B7  1                  ; add +4 as a separate 16-bit step to centre the 8px bullet in the 16px invader
0010B7  1  B5 rr           lda ibul_x_lo,x
0010B9  1  18              clc
0010BA  1  69 04           adc #4
0010BC  1  95 rr           sta ibul_x_lo,x
0010BE  1  B5 rr           lda ibul_x_hi,x
0010C0  1  69 00           adc #0
0010C2  1  95 rr           sta ibul_x_hi,x
0010C4  1               
0010C4  1                  ; spawn Y: compute y_base first (same two-step pattern as update_invader_sprites)
0010C4  1                  ; step 1: y_base = INV_GRID_Y_BASE + inv_offset_y  (16-bit)
0010C4  1  A9 50           lda #<INV_GRID_Y_BASE
0010C6  1  18              clc
0010C7  1  65 rr           adc inv_offset_y
0010C9  1  85 rr           sta zp_y_base_lo
0010CB  1  A9 00           lda #>INV_GRID_Y_BASE
0010CD  1  69 00           adc #0
0010CF  1  85 rr           sta zp_y_base_hi
0010D1  1                  ; step 2: spawn_y = y_base + row_y_offsets[row]
0010D1  1  A4 rr           ldy zp_row
0010D3  1  B9 44 1B        lda row_y_offsets,y
0010D6  1  18              clc
0010D7  1  65 rr           adc zp_y_base_lo
0010D9  1  95 rr           sta ibul_y_lo,x
0010DB  1  A9 00           lda #0
0010DD  1  65 rr           adc zp_y_base_hi
0010DF  1  95 rr           sta ibul_y_hi,x
0010E1  1                  ; step 3: +16 to place bullet at the bottom edge of the 16px invader
0010E1  1  B5 rr           lda ibul_y_lo,x
0010E3  1  18              clc
0010E4  1  69 10           adc #16
0010E6  1  95 rr           sta ibul_y_lo,x
0010E8  1  B5 rr           lda ibul_y_hi,x
0010EA  1  69 00           adc #0
0010EC  1  95 rr           sta ibul_y_hi,x
0010EE  1               
0010EE  1  60              rts
0010EF  1               
0010EF  1               ;******************************************************************
0010EF  1               ; check_inv_bullet_player — AABB test each active invader bullet vs. player
0010EF  1               ;
0010EF  1               ;   Player rect: (player_x, PLAYER_Y) to (player_x+15, PLAYER_Y+15), 16x16
0010EF  1               ;   Bullet rect: (ibul_x,   ibul_y)   to (ibul_x+7,   ibul_y+7),     8x8
0010EF  1               ;
0010EF  1               ;   On hit: bullet deactivated, jsr player_hit called, loop continues
0010EF  1               ;   (remaining bullets checked — at most one hit landing per frame).
0010EF  1               ;   Scratch: zp_scratch_lo/hi, X (slot index)
0010EF  1               ;******************************************************************
0010EF  1               check_inv_bullet_player:
0010EF  1  A2 00           ldx #0
0010F1  1               @slot_loop:
0010F1  1  B5 rr           lda ibul_active,x
0010F3  1  F0 5B           beq @next_slot
0010F5  1               
0010F5  1                  ; --- Y check 1: (bullet_y + 8) > PLAYER_Y  →  bullet_y + 8 - PLAYER_Y > 0 ---
0010F5  1  B5 rr           lda ibul_y_lo,x
0010F7  1  18              clc
0010F8  1  69 08           adc #8
0010FA  1  85 rr           sta zp_scratch_lo
0010FC  1  B5 rr           lda ibul_y_hi,x
0010FE  1  69 00           adc #0
001100  1  85 rr           sta zp_scratch_hi
001102  1  A5 rr           lda zp_scratch_lo
001104  1  38              sec
001105  1  E9 A4           sbc #<PLAYER_Y
001107  1  A5 rr           lda zp_scratch_hi
001109  1  E9 01           sbc #>PLAYER_Y
00110B  1  30 43           bmi @next_slot            ; bullet bottom above player top → no hit
00110D  1               
00110D  1                  ; --- Y check 2: bullet_y < PLAYER_Y + 16 → bullet_y - (PLAYER_Y+16) < 0 ---
00110D  1  B5 rr           lda ibul_y_lo,x
00110F  1  38              sec
001110  1  E9 B4           sbc #<(PLAYER_Y+16)
001112  1  B5 rr           lda ibul_y_hi,x
001114  1  E9 01           sbc #>(PLAYER_Y+16)
001116  1  10 38           bpl @next_slot            ; bullet top at or below player bottom → no hit
001118  1               
001118  1                  ; --- X check 1: (bullet_x + 8) > player_x ---
001118  1  B5 rr           lda ibul_x_lo,x
00111A  1  18              clc
00111B  1  69 08           adc #8
00111D  1  85 rr           sta zp_scratch_lo
00111F  1  B5 rr           lda ibul_x_hi,x
001121  1  69 00           adc #0
001123  1  85 rr           sta zp_scratch_hi
001125  1  A5 rr           lda zp_scratch_lo
001127  1  38              sec
001128  1  E5 rr           sbc player_x_lo
00112A  1  A5 rr           lda zp_scratch_hi
00112C  1  E5 rr           sbc player_x_hi
00112E  1  30 20           bmi @next_slot            ; bullet right edge left of player → no hit
001130  1               
001130  1                  ; --- X check 2: bullet_x < player_x + 16 ---
001130  1  A5 rr           lda player_x_lo
001132  1  18              clc
001133  1  69 10           adc #16
001135  1  85 rr           sta zp_scratch_lo
001137  1  A5 rr           lda player_x_hi
001139  1  69 00           adc #0
00113B  1  85 rr           sta zp_scratch_hi
00113D  1  B5 rr           lda ibul_x_lo,x
00113F  1  38              sec
001140  1  E5 rr           sbc zp_scratch_lo
001142  1  B5 rr           lda ibul_x_hi,x
001144  1  E5 rr           sbc zp_scratch_hi
001146  1  10 08           bpl @next_slot            ; bullet left edge at or right of player → no hit
001148  1               
001148  1                  ; --- HIT ---
001148  1  74 rr           stz ibul_active,x         ; deactivate this bullet
00114A  1  20 1C 10        jsr update_inv_bullet_sprite
00114D  1  20 56 11        jsr player_hit
001150  1               
001150  1               @next_slot:
001150  1  E8              inx
001151  1  E0 03           cpx #3
001153  1  D0 9C           bne @slot_loop
001155  1  60              rts
001156  1               
001156  1               ;******************************************************************
001156  1               ; player_hit — handle a bullet-player collision:
001156  1               ;   explosion at player position, decrement lives, respawn, invincibility
001156  1               ;******************************************************************
001156  1               player_hit:
001156  1                  ; start explosion at player position
001156  1  A5 rr           lda player_x_lo
001158  1  85 rr           sta zp_x_lo
00115A  1  A5 rr           lda player_x_hi
00115C  1  85 rr           sta zp_x_hi
00115E  1  A9 A4           lda #<PLAYER_Y
001160  1  85 rr           sta zp_row_y_lo
001162  1  A9 01           lda #>PLAYER_Y
001164  1  85 rr           sta zp_row_y_hi
001166  1  20 7E 0F        jsr start_explosion
001169  1               
001169  1                  ; decrement lives
001169  1  C6 rr           dec lives
00116B  1  F0 0D           beq @game_over            ; lives hit 0 → end game (Phase 6 will handle this properly)
00116D  1               
00116D  1                  ; grant invincibility and re-centre the ship
00116D  1  A9 78           lda #INV_HIT_FRAMES
00116F  1  85 rr           sta inv_hit_timer
001171  1  A9 38           lda #<PLAYER_X_INIT
001173  1  85 rr           sta player_x_lo
001175  1  A9 01           lda #>PLAYER_X_INIT
001177  1  85 rr           sta player_x_hi
001179  1  60              rts
00117A  1               
00117A  1               @game_over:
00117A  1  4C 7D 11        jmp game_over_screen
00117D  1               
00117D  1               ;******************************************************************
00117D  1               ; game_over_screen — update hi-score, draw GAME OVER, wait for input
00117D  1               ;   SPACE     → restart_game (full state reset + main_loop)
00117D  1               ;   RUN/STOP  → exit to BASIC
00117D  1               ;
00117D  1               ;   Layout (40-col text):
00117D  1               ;     Row  9, col 15: "GAME OVER"
00117D  1               ;     Row 11, col 13: "SCORE: " + 6 BCD digits
00117D  1               ;     Row 12, col 12: "HI-SCORE: " + 6 BCD digits
00117D  1               ;     Row 15, col 11: "SPACE = PLAY AGAIN"  (blinks)
00117D  1               ;     Row 17, col 12: "RUN/STOP TO QUIT"
00117D  1               ;******************************************************************
00117D  1               game_over_screen:
00117D  1  20 2E 19        jsr snd_stop_ufo_drone    ; silence drone if UFO was active
001180  1               
001180  1  20 4F 12        jsr update_hi_score       ; copy score → hi_score if score is higher
001183  1               
001183  1  20 26 14        jsr hide_all_inv_sprites  ; clear play field sprites
001186  1               
001186  1  A9 93           lda #PETSCII_CLR
001188  1  20 D2 FF        jsr CHROUT
00118B  1               
00118B  1  A9 09           lda #9
00118D  1  A0 0F           ldy #15
00118F  1  18              clc
001190  1  20 F0 FF        jsr PLOT
001193  1  A2 00           ldx #0
001195  1  BD 2B 1A     @go1: lda str_game_over, x
001198  1  F0 06           beq @go1d
00119A  1  20 D2 FF        jsr CHROUT
00119D  1  E8              inx
00119E  1  80 F5           bra @go1
0011A0  1               @go1d:
0011A0  1               
0011A0  1  A9 0B           lda #11
0011A2  1  A0 0D           ldy #13
0011A4  1  18              clc
0011A5  1  20 F0 FF        jsr PLOT
0011A8  1  A2 00           ldx #0
0011AA  1  BD 35 1A     @go2: lda str_score_lbl, x
0011AD  1  F0 06           beq @go2d
0011AF  1  20 D2 FF        jsr CHROUT
0011B2  1  E8              inx
0011B3  1  80 F5           bra @go2
0011B5  1               @go2d:
0011B5  1  A5 rr           lda score_hi
0011B7  1  20 B6 19        jsr print_hex_byte
0011BA  1  A5 rr           lda score_mid
0011BC  1  20 B6 19        jsr print_hex_byte
0011BF  1  A5 rr           lda score_lo
