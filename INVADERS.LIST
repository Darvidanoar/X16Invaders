0017A4  1                  ; --- write sprite attributes for 4 shields (sequential VERA write) ---
0017A4  1                  ; Slots 66–69: $1FE10, $1FE18, $1FE20, $1FE28  (high=$FE, bank=1)
0017A4  1  A9 11           lda #$11               ; stride=1, bank=1
0017A6  1  8D 22 9F        sta VERA_addr_bank
0017A9  1  A9 FE           lda #$FE
0017AB  1  8D 21 9F        sta VERA_addr_high
0017AE  1  A9 10           lda #$10               ; low byte of $1FE10
0017B0  1  8D 20 9F        sta VERA_addr_low
0017B3  1               
0017B3  1  A2 00           ldx #0
0017B5  1               @spr_init:
0017B5  1  A9 28           lda #$28               ; byte 0: addr[12:5] = VRAM_SHIELD_FULL>>5 = $00500>>5 = $28
0017B7  1  8D 23 9F        sta VERA_data0
0017BA  1  A9 00           lda #$00               ; byte 1: 4bpp, addr[16:13]=0
0017BC  1  8D 23 9F        sta VERA_data0
0017BF  1  BD 9F 1E        lda shield_x_lo, x     ; byte 2: X lo
0017C2  1  8D 23 9F        sta VERA_data0
0017C5  1  BD A3 1E        lda shield_x_hi, x     ; byte 3: X hi
0017C8  1  8D 23 9F        sta VERA_data0
0017CB  1  A9 60           lda #<SHIELD_Y         ; byte 4: Y lo
0017CD  1  8D 23 9F        sta VERA_data0
0017D0  1  A9 01           lda #>SHIELD_Y         ; byte 5: Y hi
0017D2  1  8D 23 9F        sta VERA_data0
0017D5  1  A9 0C           lda #SPR_Z_FRONT       ; byte 6: z-depth=3 (in front of all layers)
0017D7  1  8D 23 9F        sta VERA_data0
0017DA  1  A9 A0           lda #SPR_32x32_PAL0    ; byte 7: 32x32, palette 0
0017DC  1  8D 23 9F        sta VERA_data0
0017DF  1  E8              inx
0017E0  1  E0 04           cpx #4
0017E2  1  D0 D1           bne @spr_init
0017E4  1               
0017E4  1  60              rts
0017E5  1               
0017E5  1               ;******************************************************************
0017E5  1               ; update_shield_sprite — write new data-addr byte to shield sprite N
0017E5  1               ;   Input:  X = shield index (0–3)
0017E5  1               ;           shield_damage[X] = current damage level (1–7)
0017E5  1               ;   Writes sprite byte 0 (addr[12:5]) using shield_addr_b0 lookup.
0017E5  1               ;   VERA addr for byte 0 of sprite N: $1FE10 + N*8
0017E5  1               ;******************************************************************
0017E5  1               update_shield_sprite:
0017E5  1  9C 25 9F        stz VERA_ctrl
0017E8  1  A9 11           lda #$11               ; stride=1, bank=1
0017EA  1  8D 22 9F        sta VERA_addr_bank
0017ED  1  A9 FE           lda #$FE
0017EF  1  8D 21 9F        sta VERA_addr_high
0017F2  1  8A              txa                    ; A = shield index
0017F3  1  0A              asl                    ; ×2
0017F4  1  0A              asl                    ; ×4
0017F5  1  0A              asl                    ; ×8
0017F6  1  18              clc
0017F7  1  69 10           adc #$10               ; + low byte of $1FE10
0017F9  1  8D 20 9F        sta VERA_addr_low
0017FC  1  B4 rr           ldy shield_damage, x   ; Y = damage level (1-3)
0017FE  1  B9 A7 1E        lda shield_addr_b0, y  ; addr[12:5] for this tile
001801  1  8D 23 9F        sta VERA_data0
001804  1  60              rts
001805  1               
001805  1               ;******************************************************************
001805  1               ; hide_shield_sprite — disable sprite for shield N (z-depth=0)
001805  1               ;   Input: X = shield index (0–3)
001805  1               ;   Writes sprite byte 6 at $1FE10 + N*8 + 6 = $1FE16 + N*8
001805  1               ;******************************************************************
001805  1               hide_shield_sprite:
001805  1  9C 25 9F        stz VERA_ctrl
001808  1  A9 11           lda #$11
00180A  1  8D 22 9F        sta VERA_addr_bank
00180D  1  A9 FE           lda #$FE
00180F  1  8D 21 9F        sta VERA_addr_high
001812  1  8A              txa
001813  1  0A              asl
001814  1  0A              asl
001815  1  0A              asl
001816  1  18              clc
001817  1  69 16           adc #$16               ; low($1FE10) + 6 = $16, + N*8
001819  1  8D 20 9F        sta VERA_addr_low
00181C  1  A9 00           lda #0                 ; z-depth=0 → sprite disabled
00181E  1  8D 23 9F        sta VERA_data0
001821  1  60              rts
001822  1               
001822  1               ;******************************************************************
001822  1               ; damage_shield — increment damage counter for shield X and update
001822  1               ;   sprite (or disable it when counter reaches 8 = destroyed).
001822  1               ;   Input:  X = shield index (0–3)
001822  1               ;   Clobbers: A, Y, VERA registers.  Preserves X.
001822  1               ;******************************************************************
001822  1               damage_shield:
001822  1  F6 rr           inc shield_damage, x
001824  1  B5 rr           lda shield_damage, x
001826  1  C9 08           cmp #8
001828  1  F0 06           beq @destroy
00182A  1  B0 07           bcs @done              ; already at 8 (safety guard)
00182C  1  20 E5 17        jsr update_shield_sprite
00182F  1  60              rts
001830  1               @destroy:
001830  1  20 05 18        jsr hide_shield_sprite
001833  1               @done:
001833  1  60              rts
001834  1               
001834  1               ;******************************************************************
001834  1               ; check_bullet_shields — test active player bullet vs all 4 shields
001834  1               ;
001834  1               ;   Overlap condition (AABB, all values VERA 16-bit):
001834  1               ;     X: bullet_x+8 > shield_x  AND  bullet_x < shield_x+16
001834  1               ;     Y: bullet_y+8 > SHIELD_Y  AND  bullet_y < SHIELD_Y+16
001834  1               ;
001834  1               ;   On hit: calls damage_shield, deactivates bullet, returns.
001834  1               ;   Scratch used: zp_scratch_lo/hi.  Preserves nothing.
001834  1               ;******************************************************************
001834  1               check_bullet_shields:
001834  1  A5 rr           lda bullet_active
001836  1  F0 6D           beq @done
001838  1               
001838  1                  ; --- Y quick check (same band for all shields) ---
001838  1                  ; (1) bullet_y+8 > SHIELD_Y
001838  1  A5 rr           lda bullet_y_lo
00183A  1  18              clc
00183B  1  69 08           adc #8
00183D  1  85 rr           sta zp_scratch_lo
00183F  1  A5 rr           lda bullet_y_hi
001841  1  69 00           adc #0
001843  1  85 rr           sta zp_scratch_hi
001845  1  A5 rr           lda zp_scratch_lo
001847  1  38              sec
001848  1  E9 60           sbc #<SHIELD_Y
00184A  1  A5 rr           lda zp_scratch_hi
00184C  1  E9 01           sbc #>SHIELD_Y
00184E  1  30 55           bmi @done              ; bullet bottom above shield top
001850  1               
001850  1                  ; (2) bullet_y < SHIELD_Y+32
001850  1  A5 rr           lda bullet_y_lo
001852  1  38              sec
001853  1  E9 80           sbc #<(SHIELD_Y + 32)
001855  1  A5 rr           lda bullet_y_hi
001857  1  E9 01           sbc #>(SHIELD_Y + 32)
001859  1  10 4A           bpl @done              ; bullet top at or below shield bottom
00185B  1               
00185B  1                  ; --- Y overlaps: scan each shield ---
00185B  1  A2 00           ldx #0
00185D  1               @sld_loop:
00185D  1  B5 rr           lda shield_damage, x
00185F  1  C9 08           cmp #8
001861  1  B0 3D           bcs @next_sld          ; destroyed, skip
001863  1               
001863  1                  ; X check (1): bullet_x+8 > shield_x[x]
001863  1  A5 rr           lda bullet_x_lo
001865  1  18              clc
001866  1  69 08           adc #8
001868  1  85 rr           sta zp_scratch_lo
00186A  1  A5 rr           lda bullet_x_hi
00186C  1  69 00           adc #0
00186E  1  85 rr           sta zp_scratch_hi
001870  1  A5 rr           lda zp_scratch_lo
001872  1  38              sec
001873  1  FD 9F 1E        sbc shield_x_lo, x
001876  1  A5 rr           lda zp_scratch_hi
001878  1  FD A3 1E        sbc shield_x_hi, x
00187B  1  30 23           bmi @next_sld
00187D  1               
00187D  1                  ; X check (2): bullet_x < shield_x[x]+32
00187D  1  BD 9F 1E        lda shield_x_lo, x
001880  1  18              clc
001881  1  69 20           adc #32
001883  1  85 rr           sta zp_scratch_lo
001885  1  BD A3 1E        lda shield_x_hi, x
001888  1  69 00           adc #0
00188A  1  85 rr           sta zp_scratch_hi
00188C  1  A5 rr           lda bullet_x_lo
00188E  1  38              sec
00188F  1  E5 rr           sbc zp_scratch_lo
001891  1  A5 rr           lda bullet_x_hi
001893  1  E5 rr           sbc zp_scratch_hi
001895  1  10 09           bpl @next_sld
001897  1               
001897  1                  ; --- HIT ---
001897  1  20 22 18        jsr damage_shield      ; X = shield index
00189A  1  64 rr           stz bullet_active
00189C  1  20 54 0E        jsr update_bullet_sprite
00189F  1  60              rts
0018A0  1               
0018A0  1               @next_sld:
0018A0  1  E8              inx
0018A1  1  E0 04           cpx #4
0018A3  1  D0 B8           bne @sld_loop
0018A5  1               @done:
0018A5  1  60              rts
0018A6  1               
0018A6  1               ;******************************************************************
0018A6  1               ; check_invbullet_shields — test each active invader bullet vs all
0018A6  1               ;   4 shields.  Same AABB logic as check_bullet_shields but loops
0018A6  1               ;   over 3 bullet slots (ibul_active / ibul_x / ibul_y arrays).
0018A6  1               ;
0018A6  1               ;   Scratch: zp_scratch_lo/hi, zp_row (bullet slot index),
0018A6  1               ;            zp_col (shield index during inner scan).
0018A6  1               ;******************************************************************
0018A6  1               check_invbullet_shields:
0018A6  1  A2 00           ldx #0                 ; outer loop: invader bullet slot
0018A8  1               @ibul_loop:
0018A8  1  86 rr           stx zp_row             ; save slot before any branch
0018AA  1  B5 rr           lda ibul_active, x
0018AC  1  F0 7B           beq @next_ibul
0018AE  1               
0018AE  1                  ; --- Y quick check ---
0018AE  1                  ; (1) ibul_y+8 > SHIELD_Y
0018AE  1  B5 rr           lda ibul_y_lo, x
0018B0  1  18              clc
0018B1  1  69 08           adc #8
0018B3  1  85 rr           sta zp_scratch_lo
0018B5  1  B5 rr           lda ibul_y_hi, x
0018B7  1  69 00           adc #0
0018B9  1  85 rr           sta zp_scratch_hi
0018BB  1  A5 rr           lda zp_scratch_lo
0018BD  1  38              sec
0018BE  1  E9 60           sbc #<SHIELD_Y
0018C0  1  A5 rr           lda zp_scratch_hi
0018C2  1  E9 01           sbc #>SHIELD_Y
0018C4  1  30 63           bmi @next_ibul
0018C6  1               
0018C6  1                  ; (2) ibul_y < SHIELD_Y+32
0018C6  1  A6 rr           ldx zp_row
0018C8  1  B5 rr           lda ibul_y_lo, x
0018CA  1  38              sec
0018CB  1  E9 80           sbc #<(SHIELD_Y + 32)
0018CD  1  B5 rr           lda ibul_y_hi, x
0018CF  1  E9 01           sbc #>(SHIELD_Y + 32)
0018D1  1  10 56           bpl @next_ibul
0018D3  1               
0018D3  1                  ; --- Y overlaps: scan shields with Y register ---
0018D3  1  A0 00           ldy #0
0018D5  1               @sld_scan:
0018D5  1  B9 rr rr        lda shield_damage, y
0018D8  1  C9 08           cmp #8
0018DA  1  B0 48           bcs @next_sld_y        ; destroyed
0018DC  1               
0018DC  1                  ; X check (1): ibul_x+8 > shield_x[y]
0018DC  1  A6 rr           ldx zp_row
0018DE  1  B5 rr           lda ibul_x_lo, x
0018E0  1  18              clc
0018E1  1  69 08           adc #8
0018E3  1  85 rr           sta zp_scratch_lo
0018E5  1  B5 rr           lda ibul_x_hi, x
0018E7  1  69 00           adc #0
0018E9  1  85 rr           sta zp_scratch_hi
0018EB  1  A5 rr           lda zp_scratch_lo
0018ED  1  38              sec
0018EE  1  F9 9F 1E        sbc shield_x_lo, y
0018F1  1  A5 rr           lda zp_scratch_hi
0018F3  1  F9 A3 1E        sbc shield_x_hi, y
0018F6  1  30 2C           bmi @next_sld_y
0018F8  1               
0018F8  1                  ; X check (2): ibul_x < shield_x[y]+32
0018F8  1  B9 9F 1E        lda shield_x_lo, y
0018FB  1  18              clc
0018FC  1  69 20           adc #32
0018FE  1  85 rr           sta zp_scratch_lo
001900  1  B9 A3 1E        lda shield_x_hi, y
001903  1  69 00           adc #0
001905  1  85 rr           sta zp_scratch_hi
001907  1  A6 rr           ldx zp_row
001909  1  B5 rr           lda ibul_x_lo, x
00190B  1  38              sec
00190C  1  E5 rr           sbc zp_scratch_lo
00190E  1  B5 rr           lda ibul_x_hi, x
001910  1  E5 rr           sbc zp_scratch_hi
001912  1  10 10           bpl @next_sld_y
001914  1               
001914  1                  ; --- HIT ---
001914  1  98              tya                    ; shield index → A → X for damage_shield
001915  1  AA              tax
001916  1  20 22 18        jsr damage_shield
001919  1  A6 rr           ldx zp_row             ; restore bullet slot
00191B  1  74 rr           stz ibul_active, x
00191D  1  20 48 10        jsr update_inv_bullet_sprite
001920  1  A6 rr           ldx zp_row
001922  1  80 05           bra @next_ibul         ; done with this bullet
001924  1               
001924  1               @next_sld_y:
001924  1  C8              iny
001925  1  C0 04           cpy #4
001927  1  D0 AC           bne @sld_scan
001929  1               
001929  1               @next_ibul:
001929  1  A6 rr           ldx zp_row
00192B  1  E8              inx
00192C  1  E0 03           cpx #3
00192E  1  F0 03           beq @cis_done
001930  1  4C A8 18        jmp @ibul_loop
001933  1               @cis_done:
001933  1  60              rts
