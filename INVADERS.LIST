001912  1               ;******************************************************************
001912  1               ; add_score_bcd — add a 2-byte BCD pair to the score
001912  1               ;   A = BCD low byte (units/tens), Y = BCD mid byte (hundreds/thousands)
001912  1               ;******************************************************************
001912  1               add_score_bcd:
001912  1  F8              sed
001913  1  18              clc
001914  1  65 rr           adc score_lo
001916  1  85 rr           sta score_lo
001918  1  98              tya
001919  1  65 rr           adc score_mid
00191B  1  85 rr           sta score_mid
00191D  1  A5 rr           lda score_hi
00191F  1  69 00           adc #0
001921  1  85 rr           sta score_hi
001923  1  D8              cld
001924  1  60              rts
001925  1               
001925  1               ;******************************************************************
001925  1               ; update_ufo — per-frame UFO logic: spawn timer + movement
001925  1               ;
001925  1               ;   Inactive: 16-bit ufo_timer counts down each frame.
001925  1               ;   On zero: UFO spawns at left edge (X=0), timer reset to
001925  1               ;             UFO_TIMER_INIT + (prng() & $7F) for next cycle.
001925  1               ;   Active: move right UFO_SPEED VERA pixels/frame.
001925  1               ;           Deactivate when X >= 640 (off right edge).
001925  1               ;   Updates VERA sprite 3 after any state change.
001925  1               ;******************************************************************
001925  1               update_ufo:
001925  1  A5 rr           lda ufo_active
001927  1  D0 36           bne @move_ufo
001929  1               
001929  1                  ; --- timer countdown (16-bit decrement) ---
001929  1  A5 rr           lda ufo_timer_lo
00192B  1  D0 0B           bne @dec_lo
00192D  1  A5 rr           lda ufo_timer_hi
00192F  1  F0 0F           beq @spawn                   ; both zero → spawn (guard against stuck state)
001931  1  C6 rr           dec ufo_timer_hi
001933  1  A9 FF           lda #$FF
001935  1  85 rr           sta ufo_timer_lo
001937  1  60              rts
001938  1               @dec_lo:
001938  1  C6 rr           dec ufo_timer_lo
00193A  1  A5 rr           lda ufo_timer_lo
00193C  1  05 rr           ora ufo_timer_hi
00193E  1  D0 47           bne @ufo_done                ; timer not yet zero
001940  1               
001940  1               @spawn:
001940  1  A9 01           lda #1
001942  1  85 rr           sta ufo_active
001944  1  64 rr           stz ufo_x_lo
001946  1  64 rr           stz ufo_x_hi
001948  1                  ; next timer = UFO_TIMER_INIT + (prng() & $7F) so interval varies by 0-127 frames
001948  1  20 EE 0F        jsr prng
00194B  1  29 7F           and #$7F
00194D  1  18              clc
00194E  1  69 58           adc #<UFO_TIMER_INIT
001950  1  85 rr           sta ufo_timer_lo
001952  1  A9 02           lda #>UFO_TIMER_INIT
001954  1  69 00           adc #0
001956  1  85 rr           sta ufo_timer_hi
001958  1  20 88 19        jsr update_ufo_sprite
00195B  1  20 4A 1A        jsr snd_start_ufo_drone
00195E  1  60              rts
00195F  1               
00195F  1                  ; --- move UFO right ---
00195F  1               @move_ufo:
00195F  1  A5 rr           lda ufo_x_lo
001961  1  18              clc
001962  1  69 02           adc #UFO_SPEED
001964  1  85 rr           sta ufo_x_lo
001966  1  A5 rr           lda ufo_x_hi
001968  1  69 00           adc #0
00196A  1  85 rr           sta ufo_x_hi
00196C  1                  ; deactivate if X high byte >= 3 (≥ 768, safely off the 640-wide screen)
00196C  1                  ; simpler guard: X hi > 0 means X >= 256; combined with lo check
00196C  1  C9 02           cmp #>640                    ; A = new hi; >640 = 2
00196E  1  90 11           bcc @ufo_on_screen           ; hi < 2 → still visible
001970  1  D0 06           bne @ufo_off_screen          ; hi > 2 → gone
001972  1  A5 rr           lda ufo_x_lo
001974  1  C9 80           cmp #<640
001976  1  90 09           bcc @ufo_on_screen           ; hi=2, lo < 128 → past edge but close; still off
001978  1               @ufo_off_screen:
001978  1  64 rr           stz ufo_active
00197A  1  20 88 19        jsr update_ufo_sprite
00197D  1  20 71 1A        jsr snd_stop_ufo_drone
001980  1  60              rts
001981  1               @ufo_on_screen:
001981  1  20 88 19        jsr update_ufo_sprite
001984  1  20 89 1A        jsr snd_update_ufo_drone
001987  1               @ufo_done:
001987  1  60              rts
001988  1               
001988  1               ;******************************************************************
001988  1               ; update_ufo_sprite — write sprite 3 (UFO) position + enable/disable
001988  1               ;   addr[12:5] = VRAM_UFO>>5 = $01500>>5 = $A8
001988  1               ;   Writes bytes 2-6; bytes 0-1 and 7 set once at init.
001988  1               ;******************************************************************
001988  1               update_ufo_sprite:
001988  1  9C 25 9F        stz VERA_ctrl
00198B  1  A9 11 8D 22     VERA_SET_ADDR (UFO_SPRITE_ATTR + 2), 1
00198F  1  9F A9 FC 8D  
001993  1  21 9F A9 1A  
00199A  1  A5 rr           lda ufo_x_lo
00199C  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
00199F  1  A5 rr           lda ufo_x_hi
0019A1  1  29 03           and #$03
0019A3  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
0019A6  1  A9 20           lda #<UFO_Y
0019A8  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
0019AB  1  A9 00           lda #>UFO_Y
0019AD  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
0019B0  1  A5 rr           lda ufo_active
0019B2  1  F0 04           beq @z_off
0019B4  1  A9 0C           lda #SPR_Z_FRONT
0019B6  1  80 02           bra @write_z
0019B8  1               @z_off:
0019B8  1  A9 00           lda #0
0019BA  1               @write_z:
0019BA  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
0019BD  1  60              rts
0019BE  1               
0019BE  1               ;******************************************************************
0019BE  1               ; check_bullet_ufo — AABB test: player bullet vs. UFO sprite (16x16)
0019BE  1               ;   Bullet rect: (bullet_x, bullet_y)+(7,7);  UFO rect: (ufo_x, UFO_Y)+(15,15)
0019BE  1               ;   On hit: bullet deactivated, UFO killed, score added, explosion started.
0019BE  1               ;   Scratch: zp_scratch_lo/hi, zp_x_lo/hi, zp_row_y_lo/hi
0019BE  1               ;******************************************************************
0019BE  1               check_bullet_ufo:
0019BE  1  A5 rr           lda bullet_active
0019C0  1  D0 01           bne :+
0019C2  1  60              rts
0019C3  1  A5 rr        :  lda ufo_active
0019C5  1  D0 01           bne :+
0019C7  1  60              rts
0019C8  1               :
0019C8  1               
0019C8  1                  ; --- Y check 1: bullet_y+8 > UFO_Y ---
0019C8  1  A5 rr           lda bullet_y_lo
0019CA  1  18              clc
0019CB  1  69 08           adc #8
0019CD  1  85 rr           sta zp_scratch_lo
0019CF  1  A5 rr           lda bullet_y_hi
0019D1  1  69 00           adc #0
0019D3  1  85 rr           sta zp_scratch_hi
0019D5  1  A5 rr           lda zp_scratch_lo
0019D7  1  38              sec
0019D8  1  E9 20           sbc #<UFO_Y
0019DA  1  A5 rr           lda zp_scratch_hi
0019DC  1  E9 00           sbc #>UFO_Y
0019DE  1  30 69           bmi @done                    ; bullet bottom above UFO top → no hit
0019E0  1               
0019E0  1                  ; --- Y check 2: bullet_y < UFO_Y+16 ---
0019E0  1  A5 rr           lda bullet_y_lo
0019E2  1  38              sec
0019E3  1  E9 30           sbc #<(UFO_Y + 16)
0019E5  1  A5 rr           lda bullet_y_hi
0019E7  1  E9 00           sbc #>(UFO_Y + 16)
0019E9  1  10 5E           bpl @done                    ; bullet top at or below UFO bottom → no hit
0019EB  1               
0019EB  1                  ; --- X check 1: bullet_x+8 > ufo_x ---
0019EB  1  A5 rr           lda bullet_x_lo
0019ED  1  18              clc
0019EE  1  69 08           adc #8
0019F0  1  85 rr           sta zp_scratch_lo
0019F2  1  A5 rr           lda bullet_x_hi
0019F4  1  69 00           adc #0
0019F6  1  85 rr           sta zp_scratch_hi
0019F8  1  A5 rr           lda zp_scratch_lo
0019FA  1  38              sec
0019FB  1  E5 rr           sbc ufo_x_lo
0019FD  1  A5 rr           lda zp_scratch_hi
0019FF  1  E5 rr           sbc ufo_x_hi
001A01  1  30 46           bmi @done                    ; bullet right edge left of UFO left edge → no hit
001A03  1               
001A03  1                  ; --- X check 2: bullet_x < ufo_x+16 ---
001A03  1  A5 rr           lda ufo_x_lo
001A05  1  18              clc
001A06  1  69 10           adc #16
001A08  1  85 rr           sta zp_scratch_lo
001A0A  1  A5 rr           lda ufo_x_hi
001A0C  1  69 00           adc #0
001A0E  1  85 rr           sta zp_scratch_hi
001A10  1  A5 rr           lda bullet_x_lo
001A12  1  38              sec
001A13  1  E5 rr           sbc zp_scratch_lo
001A15  1  A5 rr           lda bullet_x_hi
001A17  1  E5 rr           sbc zp_scratch_hi
001A19  1  10 2E           bpl @done                    ; bullet left edge at or right of UFO right edge → no hit
001A1B  1               
001A1B  1                  ; --- HIT ---
001A1B  1  A5 rr           lda ufo_x_lo
001A1D  1  85 rr           sta zp_x_lo
001A1F  1  A5 rr           lda ufo_x_hi
001A21  1  85 rr           sta zp_x_hi
001A23  1  A9 20           lda #<UFO_Y
001A25  1  85 rr           sta zp_row_y_lo
001A27  1  A9 00           lda #>UFO_Y
001A29  1  85 rr           sta zp_row_y_hi
001A2B  1  20 9A 0F        jsr start_explosion
001A2E  1               
001A2E  1  64 rr           stz bullet_active
001A30  1  20 47 0E        jsr update_bullet_sprite
001A33  1               
001A33  1  64 rr           stz ufo_active
001A35  1  20 88 19        jsr update_ufo_sprite
001A38  1  20 71 1A        jsr snd_stop_ufo_drone
001A3B  1               
001A3B  1                  ; score: ufo_score table indexed by shot_count & 7
001A3B  1  A5 rr           lda shot_count
001A3D  1  29 07           and #$07
001A3F  1  AA              tax
001A40  1  BD A3 1D        lda ufo_score_lo, x
001A43  1  BC AB 1D        ldy ufo_score_hi, x
001A46  1  20 12 19        jsr add_score_bcd
001A49  1               
001A49  1               @done:
001A49  1  60              rts
001A4A  1               
001A4A  1               ;******************************************************************
001A4A  1               ; snd_start_ufo_drone — enable VERA PSG voice 3 (sawtooth, full vol, freq1)
001A4A  1               ;   Called once when UFO spawns.
001A4A  1               ;******************************************************************
001A4A  1               snd_start_ufo_drone:
001A4A  1  9C 25 9F        stz VERA_ctrl
001A4D  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
001A51  1  9F A9 F9 8D  
001A55  1  21 9F A9 CC  
001A5C  1  A9 32           lda #<UFO_DRONE_FREQ1
001A5E  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L
001A61  1  A9 04           lda #>UFO_DRONE_FREQ1
001A63  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
001A66  1  A9 FF           lda #PSG_VOL_FULL
001A68  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001A6B  1  A9 40           lda #PSG_WAVE_SAW
001A6D  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
001A70  1  60              rts
001A71  1               
001A71  1               ;******************************************************************
001A71  1               ; snd_stop_ufo_drone — silence VERA PSG voice 3
001A71  1               ;   Called when UFO leaves screen or is destroyed.
001A71  1               ;******************************************************************
001A71  1               snd_stop_ufo_drone:
001A71  1  9C 25 9F        stz VERA_ctrl
001A74  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE3 + 2), 1   ; byte 2 = volume/enable
001A78  1  9F A9 F9 8D  
001A7C  1  21 9F A9 CE  
001A83  1  A9 00           lda #$00
001A85  1  8D 23 9F        sta VERA_data0               ; zero volume → silent
001A88  1  60              rts
001A89  1               
001A89  1               ;******************************************************************
001A89  1               ; snd_update_ufo_drone — warble between freq1/freq2 using frame_count
001A89  1               ;   bit 3 (flips every 8 frames ≈ 3.75 Hz wobble rate).
001A89  1               ;   Call every frame while UFO is active.
001A89  1               ;   Rewrites all 4 voice bytes (keeps volume/waveform stable).
001A89  1               ;******************************************************************
001A89  1               snd_update_ufo_drone:
001A89  1  9C 25 9F        stz VERA_ctrl
001A8C  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
001A90  1  9F A9 F9 8D  
001A94  1  21 9F A9 CC  
001A9B  1  A5 rr           lda frame_count
001A9D  1  29 08           and #$08                     ; bit 3: 0 for 8 frames, 1 for 8 frames
001A9F  1  D0 09           bne @freq2
001AA1  1  A9 32           lda #<UFO_DRONE_FREQ1
001AA3  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L (freq1)
001AA6  1  A9 04           lda #>UFO_DRONE_FREQ1
001AA8  1  80 07           bra @rest
001AAA  1               @freq2:
001AAA  1  A9 4B           lda #<UFO_DRONE_FREQ2
001AAC  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L (freq2)
001AAF  1  A9 06           lda #>UFO_DRONE_FREQ2
001AB1  1               @rest:
001AB1  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
001AB4  1  A9 FF           lda #PSG_VOL_FULL
001AB6  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001AB9  1  A9 40           lda #PSG_WAVE_SAW
001ABB  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
001ABE  1  60              rts
001ABF  1               
001ABF  1               ;******************************************************************
001ABF  1               ; snd_march_step — advance march_beat and play next note on PSG voice 0
001ABF  1               ;   Called once per invader march step (from step_invaders).
001ABF  1               ;   Increments beat index mod 4, writes freq/vol/wave to voice 0,
001ABF  1               ;   and arms march_snd_timer so snd_tick_march will silence it.
001ABF  1               ;******************************************************************
001ABF  1               snd_march_step:
001ABF  1  E6 rr           inc march_beat
001AC1  1  A5 rr           lda march_beat
001AC3  1  29 03           and #$03
001AC5  1  85 rr           sta march_beat
001AC7  1  AA              tax                            ; X = note index 0-3
001AC8  1  9C 25 9F        stz VERA_ctrl
001ACB  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE0, 1
001ACF  1  9F A9 F9 8D  
001AD3  1  21 9F A9 C0  
001ADA  1  BD 9B 1D        lda march_freq_lo, x
001ADD  1  8D 23 9F        sta VERA_data0                 ; byte 0: FREQ_L
001AE0  1  BD 9F 1D        lda march_freq_hi, x
001AE3  1  8D 23 9F        sta VERA_data0                 ; byte 1: FREQ_H
001AE6  1  A9 FF           lda #PSG_MARCH_VOL
001AE8  1  8D 23 9F        sta VERA_data0                 ; byte 2: volume (stereo, full)
001AEB  1  A9 00           lda #PSG_WAVE_PULSE
001AED  1  8D 23 9F        sta VERA_data0                 ; byte 3: pulse waveform
001AF0  1  A9 06           lda #MARCH_NOTE_FRAMES
001AF2  1  85 rr           sta march_snd_timer
001AF4  1  60              rts
001AF5  1               
001AF5  1               ;******************************************************************
001AF5  1               ; snd_tick_march — decrement march note timer; silence voice 0 when it expires
001AF5  1               ;   Call once per frame from main_loop.
001AF5  1               ;******************************************************************
001AF5  1               snd_tick_march:
001AF5  1  A5 rr           lda march_snd_timer
001AF7  1  F0 1B           beq @done
001AF9  1  C6 rr           dec march_snd_timer
001AFB  1  D0 17           bne @done
001AFD  1  9C 25 9F        stz VERA_ctrl
001B00  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE0 + 2), 1
001B04  1  9F A9 F9 8D  
001B08  1  21 9F A9 C2  
001B0F  1  A9 00           lda #$00
001B11  1  8D 23 9F        sta VERA_data0                 ; zero volume → silent
001B14  1               @done:
001B14  1  60              rts
001B15  1               
001B15  1               ;******************************************************************
001B15  1               ; snd_stop_march — immediately silence PSG voice 0 and clear timer
001B15  1               ;   Call when leaving gameplay (game over, wave clear, restart).
001B15  1               ;******************************************************************
001B15  1               snd_stop_march:
001B15  1  64 rr           stz march_snd_timer
001B17  1  9C 25 9F        stz VERA_ctrl
001B1A  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE0 + 2), 1
001B1E  1  9F A9 F9 8D  
001B22  1  21 9F A9 C2  
001B29  1  A9 00           lda #$00
001B2B  1  8D 23 9F        sta VERA_data0
001B2E  1  60              rts
001B2F  1               
001B2F  1               ;******************************************************************
001B2F  1               ; update_hud — rewrite dynamic HUD values each frame
001B2F  1               ;   Row  1, col  0: 6-digit BCD score
001B2F  1               ;   Row  1, col 16: 6-digit BCD hi-score
001B2F  1               ;   Row 29, col  1: LIVES: N
001B2F  1               ;   Row 29, col 20: WAVE: N
001B2F  1               ;   Overwrites fixed positions; no full redraw needed.
001B2F  1               ;   Note: KERNAL PLOT convention for X16: A = row, Y = col, CLC.
001B2F  1               ;******************************************************************
001B2F  1               update_hud:
001B2F  1                  ; --- score: row 1, col 0 (Plot: Set X to Row, Set Y to Col) ---
001B2F  1  A2 01           ldx #1
001B31  1  A0 00           ldy #0
001B33  1  18              clc
001B34  1  20 F0 FF        jsr PLOT
001B37  1  A5 rr           lda score_hi
001B39  1  20 9C 1B        jsr print_hex_byte
001B3C  1  A5 rr           lda score_mid
001B3E  1  20 9C 1B        jsr print_hex_byte
001B41  1  A5 rr           lda score_lo
001B43  1  20 9C 1B        jsr print_hex_byte
001B46  1               
001B46  1                  ; --- hi-score: row 1, col 16  (Plot: Set X to Row, Set Y to Col) ---
001B46  1  A2 01           ldx #1
001B48  1  A0 10           ldy #16
001B4A  1  18              clc
001B4B  1  20 F0 FF        jsr PLOT
001B4E  1  A5 rr           lda hi_score_hi
001B50  1  20 9C 1B        jsr print_hex_byte
001B53  1  A5 rr           lda hi_score_mid
001B55  1  20 9C 1B        jsr print_hex_byte
001B58  1  A5 rr           lda hi_score_lo
001B5A  1  20 9C 1B        jsr print_hex_byte
001B5D  1               
001B5D  1                  ; --- lives count: row 58, col 1  (Plot: Set X to Row, Set Y to Col) ---
001B5D  1  A2 3A           ldx #58
001B5F  1  A0 01           ldy #1
001B61  1  18              clc
001B62  1  20 F0 FF        jsr PLOT
001B65  1  A2 00           ldx #0
001B67  1  BD 81 1C     @lv_lbl: lda str_lives_lbl,x
001B6A  1  F0 06           beq @lv_val
001B6C  1  20 D2 FF        jsr CHROUT
001B6F  1  E8              inx
001B70  1  80 F5           bra @lv_lbl
001B72  1               @lv_val:
001B72  1  A5 rr           lda lives
001B74  1  20 CC 13        jsr print_dec_byte
001B77  1  A9 20           lda #' '
001B79  1  20 D2 FF        jsr CHROUT                    ; erase any stale digit
001B7C  1               
001B7C  1                  ; --- wave number: row 58, col 20  (Plot: Set X to Row, Set Y to Col) ---
001B7C  1  A2 3A           ldx #58
001B7E  1  A0 14           ldy #20
001B80  1  18              clc
001B81  1  20 F0 FF        jsr PLOT
001B84  1  A2 00           ldx #0
001B86  1  BD 51 1C     @wv_lbl: lda str_wave_lbl,x
001B89  1  F0 06           beq @wv_val
001B8B  1  20 D2 FF        jsr CHROUT
001B8E  1  E8              inx
001B8F  1  80 F5           bra @wv_lbl
001B91  1               @wv_val:
001B91  1  A5 rr           lda wave
001B93  1  20 CC 13        jsr print_dec_byte
001B96  1  A9 20           lda #' '
001B98  1  20 D2 FF        jsr CHROUT                    ; erase any stale digit
001B9B  1               
001B9B  1  60              rts
001B9C  1               
001B9C  1               ;******************************************************************
001B9C  1               ; print_hex_byte — print .A as two uppercase hex digits via CHROUT
001B9C  1               ;******************************************************************
001B9C  1               print_hex_byte:
001B9C  1  48              pha
001B9D  1  4A              lsr                           ; shift high nibble down
001B9E  1  4A              lsr
001B9F  1  4A              lsr
001BA0  1  4A              lsr
001BA1  1  20 AB 1B        jsr print_hex_nybble
001BA4  1  68              pla
001BA5  1  29 0F           and #$0F                      ; isolate low nibble
001BA7  1  20 AB 1B        jsr print_hex_nybble
001BAA  1  60              rts
001BAB  1               
001BAB  1               ; print_hex_nybble — print lower 4 bits of .A as one hex digit
001BAB  1               ;   Relies on carry state from CMP to select digit vs. letter range
001BAB  1               print_hex_nybble:
001BAB  1  C9 0A           cmp #10
001BAD  1  90 06           bcc @digit                    ; carry clear → 0-9
001BAF  1  69 36           adc #($41 - 10 - 1)          ; A-F: 'A'=65; carry set adds 1
001BB1  1  20 D2 FF        jsr CHROUT
001BB4  1  60              rts
001BB5  1               @digit:
001BB5  1  69 30           adc #$30                      ; 0-9: '0'=48; carry clear adds 0
001BB7  1  20 D2 FF        jsr CHROUT
001BBA  1  60              rts
001BBB  1               
