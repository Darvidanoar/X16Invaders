000810  1               ; Constants
000810  1               ;******************************************************************
000810  1               
000810  1               ; VERA display control
000810  1               VERA_SPRITE_EN  = %01000000      ; VERA_dc_video bit 6: enable sprites
000810  1               VERA_SPRITE_DIS = %10111111      ; VERA_dc_video bit 6: disable sprites
000810  1               
000810  1               ; PETSCII control codes
000810  1               PETSCII_WHITE   = $05            ; set text color to white
000810  1               PETSCII_CLR     = $93            ; clear screen and home cursor
000810  1               PETSCII_HOME    = $13            ; home cursor (no clear)
000810  1               PETSCII_RETURN  = $0D            ; carriage return
000810  1               
000810  1               ; SCREEN_SET_CHARSET font numbers (call address $FF62)
000810  1               CHARSET_UPPER   = 1              ; Commodore upper/graphics: $41-$5A = A-Z
000810  1               CHARSET_LOWER   = 2              ; Commodore lower/upper:    $41-$5A = a-z (lowercase)
000810  1               
000810  1               ; Key codes (PETSCII)
000810  1               ; KEY_RUN_STOP    = $03            ; RUN/STOP — exit game
000810  1               CHAR_Q          = $51            ; Q — exit game
000810  1               
000810  1               ; Input flag bits (key_flags)
000810  1               KEY_LEFT        = %00000001
000810  1               KEY_RIGHT       = %00000010
000810  1               KEY_FIRE        = %00000100
000810  1               
000810  1               ; JOYSTICK_GET .A return: {B,Y,Sel,Sta,Up,Dn,Left,Right} active low
000810  1               JOY_RIGHT       = %00000001     ; bit 0
000810  1               JOY_LEFT        = %00000010     ; bit 1
000810  1               
000810  1               ; Player ship — all positions in VERA 640x480 coordinate space
000810  1               PLAYER_Y        = 420            ; fixed Y, near bottom (479 = bottom edge)
000810  1               PLAYER_X_INIT   = 312            ; starting X, centred  ((640-16)/2)
000810  1               PLAYER_X_MIN    = 8              ; left  boundary (sprite left edge)
000810  1               PLAYER_X_MAX    = 616            ; right boundary (640 - 16px sprite - 8px margin)
000810  1               PLAYER_SPEED    = 4              ; pixels per frame
000810  1               
000810  1               ; Sprite attribute encoding helpers
000810  1               SPRITE1_ATTR    = $1FC08 ; sprite 1 attribute base ($1FC00=sprite 0, reserved for KERNAL mouse)
000810  1               SPR_Z_FRONT     = %00001100     ; byte 6: z-depth = %11 in bits 3-2 (in front of all layers)
000810  1               SPR_16x16_PAL0  = %01010000     ; byte 7: width=1(16px), height=1(16px), palette_off=0
000810  1               SPR_32x16_PAL0  = %10010000     ; byte 7: width=2(32px), height=1(16px), palette_off=0
000810  1               SPR_32x32_PAL0  = %10100000     ; byte 7: width=2(32px), height=2(32px), palette_off=0
000810  1               SPR_8x8_PAL0    = %00000000     ; byte 7: width=0(8px),  height=0(8px),  palette_off=0
000810  1               
000810  1               ; Explosion sprite (slot 4)
000810  1               VRAM_EXPLOSION     = $00440     ; explosion pixel data (128 bytes, 16x16 4bpp)
000810  1               EXPLODE_SPRITE_ATTR = $1FC20    ; sprite 4 attribute base (explosion)
000810  1               EXPLODE_FRAMES     = 30         ; display duration in frames (~0.5 sec at 60 Hz)
000810  1               
000810  1               ; Invader bullets (sprite slots 5-7)
000810  1               VRAM_INV_BULLET    = $00420     ; invader bullet pixel data (32 bytes, 8x8 4bpp)
000810  1               INV_BULLET_SPR_BASE = $1FC28    ; sprite 5 attribute base (first invader bullet)
000810  1               INV_BULLET_SPEED   = 6          ; VERA pixels per frame downward (=3 game pixels)
000810  1               INV_FIRE_TIMER_MIN = 10         ; minimum frames between fire attempts
000810  1               INV_FIRE_TIMER_INIT = 90        ; frames before first shot
000810  1               
000810  1               ; Player lives
000810  1               LIVES_INIT         = 3          ; starting lives
000810  1               INV_HIT_FRAMES     = 120        ; invincibility duration after being hit (2 sec at 60 Hz)
000810  1               
000810  1               ; UFO saucer (sprite slot 3)
000810  1               UFO_SPRITE_ATTR    = $1FC18      ; sprite 3 attribute base ($1FC00 + 3*8)
000810  1               VRAM_UFO           = $01500      ; UFO pixel data (128 bytes, 16x16 4bpp, after shield tiles)
000810  1               UFO_Y              = 32          ; VERA Y coord (= display pixel 16, top of play field)
000810  1               UFO_SPEED          = 2           ; VERA pixels per frame rightward (1 display pixel/frame)
000810  1               UFO_TIMER_INIT     = 600         ; frames between UFO appearances (≈10 sec at 60 Hz)
000810  1               
000810  1               ; Wave progression
000810  1               WAVE_CLEAR_FRAMES  = 180         ; auto-advance delay after wave clear (≈3 sec at 60 Hz)
000810  1               WAVE_SPEED_STEP    = 5           ; inv_move_speed decreases by this each wave
000810  1               
000810  1               ; VERA PSG voice 0 — march beat (base addr $1F9C0)
000810  1               ; 4-note cycle: ~120 Hz, ~100 Hz, ~80 Hz, ~100 Hz
000810  1               ; freq_reg = freq_hz * 25000000 / (512 * 131072) ≈ freq_hz * 2.684
000810  1               VRAM_PSG_VOICE0    = VRAM_psg + 0    ; $1F9C0 — voice 0 registers (march)
000810  1               PSG_MARCH_VOL      = $FF             ; stereo, full volume
000810  1               PSG_WAVE_PULSE     = %11000000       ; pulse waveform (bits 7:6 = 00)
000810  1               MARCH_NOTE_FRAMES  = 6               ; frames to hold each march note (~100ms)
000810  1               ; Note frequencies: 120Hz→322=$0142, 100Hz→268=$010C, 80Hz→215=$00D7
000810  1               MARCH_FREQ0_L      = $42             ; note 0: 120 Hz
000810  1               MARCH_FREQ0_H      = $01
000810  1               MARCH_FREQ1_L      = $0C             ; note 1: 100 Hz
000810  1               MARCH_FREQ1_H      = $01
000810  1               MARCH_FREQ2_L      = $D7             ; note 2:  80 Hz
000810  1               MARCH_FREQ2_H      = $00
000810  1               MARCH_FREQ3_L      = $0C             ; note 3: 100 Hz
000810  1               MARCH_FREQ3_H      = $01
000810  1               
000810  1               ; VERA PSG voice 1 — player fire sound ($1F9C0 + 1*4 = $1F9C4)
000810  1               ; ~800 Hz pulse wave: 800 * 2.684 ≈ 2147 = $0863
000810  1               VRAM_PSG_VOICE1    = VRAM_psg + 4    ; $1F9C4
000810  1               PSG_FIRE_FREQ_L    = $63             ; freq low byte (~900 Hz)
000810  1               PSG_FIRE_FREQ_H    = $7F             ; freq high byte
000810  1               FIRE_NOTE_FRAMES   = 5               ; frames to hold fire tone (~83ms)
000810  1               
000810  1               ; VERA PSG voice 2 — explosion noise burst ($1F9C0 + 2*4 = $1F9C8)
000810  1               VRAM_PSG_VOICE2    = VRAM_psg + 8    ; $1F9C8
000810  1               PSG_WAVE_NOISE     = %11000000       ; noise waveform (bits 7:6 = 11)
000810  1               PSG_EXP_FREQ_L     = $40             ; low noise clock rate → deep rumble
000810  1               PSG_EXP_FREQ_H     = $00
000810  1               EXP_NOTE_FRAMES    = 20              ; frames to hold explosion noise (~333ms)
000810  1               
000810  1               ; VERA PSG voice 3 — UFO drone (base addr $1F9C0 + 3*4 = $1F9CC)
000810  1               ; PSG byte layout: 0=FREQ_L, 1=FREQ_H, 2=volume([7]=R,[6]=L,[5:0]=vol 0-63), 3=waveform([7:6])
000810  1               ; Waveform codes: 00=pulse, 01=sawtooth, 10=triangle, 11=noise
000810  1               ; freq_hz ≈ freq_reg * 25000000 / (512 * 131072)  →  freq_reg ≈ freq_hz * 2.684
000810  1               VRAM_PSG_VOICE3    = VRAM_psg + 12   ; $1F9CC — voice 3 registers
000810  1               PSG_VOL_FULL       = $FF             ; R enable + L enable + volume 63
000810  1               PSG_VOL_HALF       = $DF             ; R enable + L enable + volume 63
000810  1               PSG_WAVE_SAW       = %01000000       ; sawtooth waveform (bits 7:6 = 01)
000810  1               UFO_DRONE_FREQ1    = $0400            ; ≈400 Hz  ($0432)
000810  1               UFO_DRONE_FREQ2    = $0600            ; ≈600 Hz  ($064B)
000810  1               
000810  1               ; Shields
000810  1               SHIELD_Y           = 352        ; VERA Y coordinate for all 4 shields (176 display pixels)
000810  1               SHIELD_SPR_BASE    = $1FE10     ; sprite slot 66 attr ($1FC00 + 66*8); slots 8-65 in use
000810  1               VRAM_SHIELD_FULL   = $00500     ; 512-byte 32x32 4bpp tile: intact
000810  1               VRAM_SHIELD_DMG1   = $00700     ; 12% damaged
000810  1               VRAM_SHIELD_DMG2   = $00900     ; 25% damaged
000810  1               VRAM_SHIELD_DMG3   = $00B00     ; 37% damaged
000810  1               VRAM_SHIELD_DMG4   = $00D00     ; 50% damaged
000810  1               VRAM_SHIELD_DMG5   = $00F00     ; 62% damaged
000810  1               VRAM_SHIELD_DMG6   = $01100     ; 75% damaged
000810  1               VRAM_SHIELD_DMG7   = $01300     ; nearly destroyed
000810  1               
000810  1               ; Player bullet
000810  1               BULLET_SPRITE_ATTR = $1FC10     ; sprite 2 attribute base (player bullet)
000810  1               VRAM_BULLET     = $00400        ; player bullet pixel data (32 bytes, 8x8 4bpp)
000810  1               BULLET_SPEED    = 12            ; VERA pixels per frame upward (= 6 game pixels)
000810  1               BULLET_Y_INIT   = PLAYER_Y - 8 ; bullet starts just above player ship top
000810  1               
000810  1               ; Invader grid geometry (VERA 640x480 coordinate space)
000810  1               INV_GRID_X_INIT   = 112         ; left-column X at start (centered: (640 - 10*40 - 16) / 2 = 112)
000810  1               INV_GRID_Y_BASE   = 80          ; top-row Y, fixed base (drops added via inv_offset_y)
000810  1               INV_SPACING_X     = 40          ; VERA pixels between invader column origins
000810  1               INV_SPACING_Y     = 48          ; VERA pixels between invader row origins
000810  1               INV_STEP_X        = 4           ; VERA pixels per march step
000810  1               INV_DROP_Y        = 16          ; VERA pixels per grid drop
000810  1               INV_MOVE_SPEED_INIT = 50        ; frames between march steps (initial)
000810  1               INV_COUNT_INIT    = 55
000810  1               INV_MOVE_SPEED_MIN = 5           ; minimum frames per march step
000810  1               
000810  1               ; Grid boundary: when grid_x reaches these values, reverse and drop
000810  1               ; Rightmost invader base X = grid_x + 10*INV_SPACING_X (=400). Right wall = 624 (640-16px).
000810  1               ; So right limit = 624 - 400 - 16 = 208
000810  1               INV_X_RIGHT_LIM   = 208
000810  1               INV_X_LEFT_LIM    = 16          ; leftmost sprite at x=grid_x must stay >= 16
000810  1               
000810  1               ; VRAM addresses for invader sprite pixel data (128 bytes each, 16x16 4bpp)
000810  1               VRAM_INV_A_F0   = $00100        ; Type A (crab,   bottom rows 3-4), frame 0
000810  1               VRAM_INV_A_F1   = $00180        ; Type A frame 1
000810  1               VRAM_INV_B_F0   = $00200        ; Type B (octopus, middle rows 1-2), frame 0
000810  1               VRAM_INV_B_F1   = $00280        ; Type B frame 1
000810  1               VRAM_INV_C_F0   = $00300        ; Type C (squid,   top row 0), frame 0
000810  1               VRAM_INV_C_F1   = $00380        ; Type C frame 1
000810  1               
000810  1               ; Sprite addr[12:5] byte values for each type/frame (= VRAM_addr >> 5)
000810  1               ;   VRAM $00100>>5=$08  $00180>>5=$0C  $00200>>5=$10  $00280>>5=$14  $00300>>5=$18  $00380>>5=$1C
000810  1               INV_ATTR_BASE   = $1FC58        ; sprite slot 11 = first invader ($1FC00 + 11*8)
000810  1               INV_SPRITE_SLOT = 11            ; first invader sprite slot index
000810  1               
000810  1               ;******************************************************************
000810  1               ; start — main program entry point
000810  1               ;******************************************************************
000810  1               start:
000810  1  78              sei                           ; disable interrupts during init
000811  1               
000811  1                  ; Switch to 40-column text mode (mode 0)
000811  1                  ; Carry clear = SET mode (carry set = READ mode)
000811  1  18              clc
000812  1  A9 00           lda #$00
000814  1  20 5F FF        jsr SCREEN_MODE
000817  1               
000817  1                  ; Seed PRNG with hardware entropy
000817  1  20 CF FE        jsr ENTROPY_GET
00081A  1  85 rr           sta rand_seed_lo
00081C  1  86 rr           stx rand_seed_hi
00081E  1               
00081E  1                  ; Enable sprites in VERA display controller
00081E  1  9C 25 9F        stz VERA_ctrl                 ; DCSEL=0, ADDRSEL=0
000821  1  AD 29 9F        lda VERA_dc_video
000824  1  09 40           ora #VERA_SPRITE_EN
000826  1  8D 29 9F        sta VERA_dc_video
000829  1               
000829  1               
000829  1                  ; Clear game variables
000829  1  64 rr           stz key_last
00082B  1  64 rr           stz key_flags
00082D  1  64 rr           stz frame_count
00082F  1  64 rr           stz bullet_active
000831  1  64 rr           stz score_lo
000833  1  64 rr           stz score_mid
000835  1  64 rr           stz score_hi
000837  1  64 rr           stz hi_score_lo
000839  1  64 rr           stz hi_score_mid
00083B  1  64 rr           stz hi_score_hi
00083D  1  64 rr           stz ufo_active
00083F  1  A9 58           lda #<UFO_TIMER_INIT
000841  1  85 rr           sta ufo_timer_lo
000843  1  A9 02           lda #>UFO_TIMER_INIT
000845  1  85 rr           sta ufo_timer_hi
000847  1  64 rr           stz shot_count
000849  1  64 rr           stz march_beat
00084B  1  64 rr           stz march_snd_timer
00084D  1  64 rr           stz fire_snd_timer
00084F  1  64 rr           stz exp_snd_timer
000851  1  A9 01           lda #1
000853  1  85 rr           sta wave
000855  1  A9 32           lda #INV_MOVE_SPEED_INIT
000857  1  85 rr           sta wave_init_speed
000859  1               
000859  1                  ; Set initial player position before sprite init reads it
000859  1  20 9E 09        jsr init_player
00085C  1               
00085C  1  58              cli                           ; re-enable interrupts
00085D  1               
00085D  1                  ; Switch to Commodore uppercase/graphics charset: $41-$5A = A-Z
00085D  1                  ; Must be called AFTER SCREEN_MODE (which resets to lowercase by default)
00085D  1  A9 01           lda #CHARSET_UPPER
00085F  1  20 62 FF        jsr SCREEN_SET_CHARSET
000862  1               
000862  1                  ; Clear screen and set text color
000862  1  A9 05           lda #PETSCII_WHITE
000864  1  20 D2 FF        jsr CHROUT
000867  1  A9 93           lda #PETSCII_CLR
000869  1  20 D2 FF        jsr CHROUT
00086C  1               
00086C  1                  ; Upload sprite pixel data and configure sprite 1 attributes
00086C  1  20 AD 09        jsr init_sprites
00086F  1               
00086F  1                  ; Upload invader sprite data, set palette, init grid state, place sprites
00086F  1  20 AC 0B        jsr init_invaders
000872  1  20 ED 15        jsr hide_all_inv_sprites     ; hide all 55 during title screen
000875  1               
000875  1  20 96 14        jsr draw_title_screen
000878  1               
000878  1               ;------------------------------------------------------------------
000878  1               ; title_loop — wait for SPACE; blink "PRESS SPACE TO START"
000878  1               ;------------------------------------------------------------------
000878  1               title_loop:
000878  1  20 51 09        jsr wait_vsync
00087B  1  E6 rr           inc frame_count
00087D  1  20 53 09        jsr update_input
000880  1               
000880  1  A5 rr           lda key_last
000882  1  C9 51           cmp #CHAR_Q
000884  1  D0 03           bne @tl_no_exit
000886  1  4C 3B 09        jmp exit_game
000889  1               @tl_no_exit:
000889  1               
000889  1  A5 rr           lda key_flags
00088B  1  29 04           and #KEY_FIRE
00088D  1  D0 33           bne start_game
00088F  1               
00088F  1                  ; blink using frame_count bit 5 (~2 Hz)
00088F  1  A5 rr           lda frame_count
000891  1  29 20           and #$20
000893  1  D0 15           bne @tl_on
000895  1               @tl_off:
000895  1  A2 21           ldx #33
000897  1  A0 1E           ldy #30
000899  1  18              clc
00089A  1  20 F0 FF        jsr PLOT
00089D  1  A2 14           ldx #20                      ; erase 20 chars of "PRESS SPACE TO START"
00089F  1  A9 20        @tl_erase: lda #' '
0008A1  1  20 D2 FF        jsr CHROUT
0008A4  1  CA              dex
0008A5  1  D0 F8           bne @tl_erase
0008A7  1  4C 78 08        jmp title_loop
0008AA  1               @tl_on:
0008AA  1  A2 21           ldx #33
0008AC  1  A0 1E           ldy #30
0008AE  1  18              clc
0008AF  1  20 F0 FF        jsr PLOT
0008B2  1  A2 00           ldx #0
0008B4  1  BD 98 1D     @tl_print: lda str_press_space, x
0008B7  1  F0 06           beq @tl_print_done
0008B9  1  20 D2 FF        jsr CHROUT
0008BC  1  E8              inx
0008BD  1  80 F5           bra @tl_print
0008BF  1               @tl_print_done:
0008BF  1  4C 78 08        jmp title_loop
0008C2  1               
0008C2  1               start_game:
0008C2  1  20 E3 0C        jsr update_invader_sprites   ; re-enable all 55 invaders at grid positions
0008C5  1  20 27 16        jsr init_shields             ; upload shield tiles, init damage counters, place sprites
0008C8  1  A9 93           lda #PETSCII_CLR
0008CA  1  20 D2 FF        jsr CHROUT                   ; clear title text, leave sprites visible
0008CD  1  20 6B 14        jsr draw_score_labels        ; paint "SCORE" / "HI-SCORE" headings
0008D0  1               
0008D0  1               ;******************************************************************
0008D0  1               ; main_loop — one iteration per video frame (60 Hz)
0008D0  1               ;******************************************************************
0008D0  1               main_loop:
0008D0  1  20 51 09        jsr wait_vsync
0008D3  1               
0008D3  1  E6 rr           inc frame_count
0008D5  1               
0008D5  1  20 53 09        jsr update_input              ; fills key_flags (joystick) + key_last (GETIN)
0008D8  1               
0008D8  1  A5 rr           lda key_last
0008DA  1  C9 51           cmp #CHAR_Q
0008DC  1  F0 5D           beq exit_game
0008DE  1               
0008DE  1                  ; --- invincibility timer ---
0008DE  1  A5 rr           lda inv_hit_timer
0008E0  1  F0 02           beq @no_inv_dec
0008E2  1  C6 rr           dec inv_hit_timer
0008E4  1               @no_inv_dec:
0008E4  1               
0008E4  1  20 99 0D        jsr move_player               ; apply movement, clamp to boundaries
0008E7  1  20 E8 0D        jsr update_player_sprite      ; write new X to VERA sprite 1
0008EA  1               
0008EA  1                  ; --- fire player bullet (SPACE pressed, bullet inactive, and player not dead) ---
0008EA  1  A5 rr           lda key_flags
0008EC  1  29 04           and #KEY_FIRE
0008EE  1  F0 0B           beq @skip_fire
0008F0  1  A5 rr           lda bullet_active
0008F2  1  D0 07           bne @skip_fire
0008F4  1  A5 rr           lda inv_hit_timer
0008F6  1  D0 03           bne @skip_fire
0008F8  1  20 2B 0E        jsr fire_bullet
0008FB  1               @skip_fire:
0008FB  1               
0008FB  1                  ; --- move bullet if active ---
0008FB  1  A5 rr           lda bullet_active
0008FD  1  F0 03           beq @skip_bullet_move
0008FF  1  20 4D 0E        jsr move_bullet
000902  1               @skip_bullet_move:
000902  1               
000902  1                  ; --- check player bullet vs invader collision ---
000902  1  20 9E 0E        jsr check_bullet_invader
000905  1               
000905  1                  ; --- check player bullet vs shield collision ---
000905  1  20 B3 18        jsr check_bullet_shields
000908  1               
000908  1                  ; --- explosion timer ---
000908  1  20 F0 0F        jsr update_explosion
00090B  1               
00090B  1                  ; --- invader bullets: move, spawn, boundary check ---
00090B  1  20 1F 10        jsr update_inv_bullets
00090E  1               
00090E  1                  ; --- invader bullet vs player collision ---
00090E  1  20 2D 11        jsr check_inv_bullet_player
000911  1               
000911  1                  ; --- invader bullet vs shield collision ---
000911  1  20 25 19        jsr check_invbullet_shields
000914  1               
000914  1                  ; --- UFO spawn/move and player bullet collision ---
000914  1  20 C6 19        jsr update_ufo
000917  1  20 5F 1A        jsr check_bullet_ufo
00091A  1               
00091A  1                  ; --- Invader march timer ---
00091A  1  C6 rr           dec inv_move_timer
00091C  1  D0 07           bne @skip_inv_step
00091E  1  20 7B 0C        jsr step_invaders             ; move grid, check bounds, update sprites
000921  1  A5 rr           lda inv_move_speed
000923  1  85 rr           sta inv_move_timer
000925  1               @skip_inv_step:
000925  1               
000925  1                  ; --- check wave clear (all 55 invaders dead) ---
000925  1  A5 rr           lda inv_count
000927  1  D0 03           bne @no_wave_clear
000929  1  4C 6F 13        jmp wave_clear_screen
00092C  1               @no_wave_clear:
00092C  1               
00092C  1  20 C2 1B        jsr snd_tick_march            ; silence march note when timer expires
00092F  1  20 27 1C        jsr snd_tick_fire             ; silence fire tone when timer expires
000932  1  20 8C 1C        jsr snd_tick_exp              ; silence explosion noise when timer expires
000935  1  20 C6 1C        jsr update_hud                ; refresh text readouts
000938  1               
000938  1  4C D0 08        jmp main_loop
00093B  1               
00093B  1               ;------------------------------------------------------------------
00093B  1               exit_game:
00093B  1  20 0A 16        jsr hide_all_sprites
00093E  1  A9 05           lda #PETSCII_WHITE
000940  1  20 D2 FF        jsr CHROUT
000943  1  A9 93           lda #PETSCII_CLR
000945  1  20 D2 FF        jsr CHROUT
000948  1  18              clc
000949  1  A9 00           lda #$00
00094B  1  20 5F FF        jsr SCREEN_MODE
00094E  1               
00094E  1  4C 47 FF        jmp ENTER_BASIC
000951  1               
000951  1               ;******************************************************************
000951  1               ; wait_vsync — busy-poll VERA_isr until VSYNC, then clear flag
000951  1               ;******************************************************************
000951  1               wait_vsync:
000951  1                  ; WAI sleeps the CPU until any IRQ fires.  The KERNAL's VSYNC IRQ
000951  1                  ; handler (60 Hz) wakes us up and has already cleared VERA_isr bit 0
000951  1                  ; by the time execution returns here, so polling VERA_isr would loop
000951  1                  ; forever.  Just return — one WAI ≈ one frame.
000951  1  CB              wai
000952  1  60              rts
000953  1               
000953  1               ;******************************************************************
000953  1               ; update_input — joystick + GETIN keyboard input each frame
000953  1               ;
000953  1               ;   key_flags bits set this frame:
000953  1               ;     KEY_LEFT  — left arrow held
000953  1               ;     KEY_RIGHT — right arrow held
000953  1               ;     KEY_FIRE  — space bar pressed
000953  1               ;   key_last   — raw PETSCII from GETIN (Q etc.)
000953  1               ;
000953  1               ;   JOYSTICK_GET(0) = keyboard-as-joystick; gives smooth held-key
000953  1               ;   movement with no repeat delay.  GETIN handles space and Q.
000953  1               ;******************************************************************
000953  1               update_input:
000953  1  64 rr           stz key_flags
000955  1  64 rr           stz key_last
000957  1               
000957  1                  ; --- joystick 0 = keyboard d-pad (active low: 0 = pressed) ---
000957  1                  ; Byte returned: {B,Y,Sel,Sta,Up,Dn,Left,Right} bits 7–0
000957  1  A9 00           lda #0
000959  1  20 56 FF        jsr JOYSTICK_GET
00095C  1  48              pha                           ; save — AND destroys .A
00095D  1               
00095D  1  29 01           and #JOY_RIGHT                ; bit 0: right arrow
00095F  1  D0 06           bne @not_right
000961  1  A5 rr           lda key_flags
000963  1  09 02           ora #KEY_RIGHT
000965  1  85 rr           sta key_flags
000967  1               @not_right:
000967  1  68              pla
000968  1  29 02           and #JOY_LEFT                 ; bit 1: left arrow
00096A  1  D0 06           bne @not_left
00096C  1  A5 rr           lda key_flags
00096E  1  09 01           ora #KEY_LEFT
000970  1  85 rr           sta key_flags
000972  1               @not_left:
000972  1               
000972  1                  ; --- GETIN — discrete events: fire, Q, arrow fallback ---
000972  1               @getin_drain:
000972  1  20 E4 FF        jsr GETIN
000975  1  F0 26           beq @getin_done               ; buffer empty
000977  1  85 rr           sta key_last
000979  1  C9 9D           cmp #$9D                      ; cursor left (PETSCII)
00097B  1  D0 08           bne @chk_right_getin
00097D  1  A5 rr           lda key_flags
00097F  1  09 01           ora #KEY_LEFT
000981  1  85 rr           sta key_flags
000983  1  80 ED           bra @getin_drain
000985  1               @chk_right_getin:
000985  1  C9 1D           cmp #$1D                      ; cursor right (PETSCII)
000987  1  D0 08           bne @chk_fire_getin
000989  1  A5 rr           lda key_flags
00098B  1  09 02           ora #KEY_RIGHT
00098D  1  85 rr           sta key_flags
00098F  1  80 E1           bra @getin_drain
000991  1               @chk_fire_getin:
000991  1  C9 20           cmp #$20                      ; space = fire
000993  1  D0 DD           bne @getin_drain
000995  1  A5 rr           lda key_flags
000997  1  09 04           ora #KEY_FIRE
000999  1  85 rr           sta key_flags
00099B  1  80 D5           bra @getin_drain
00099D  1               @getin_done:
00099D  1  60              rts
00099E  1               
00099E  1               ;******************************************************************
00099E  1               ; init_player — set player_x to starting position
00099E  1               ;******************************************************************
00099E  1               init_player:
00099E  1  A9 38           lda #<PLAYER_X_INIT
0009A0  1  85 rr           sta player_x_lo
0009A2  1  A9 01           lda #>PLAYER_X_INIT
0009A4  1  85 rr           sta player_x_hi
0009A6  1  A9 03           lda #LIVES_INIT
0009A8  1  85 rr           sta lives
0009AA  1  64 rr           stz inv_hit_timer
0009AC  1  60              rts
0009AD  1               
0009AD  1               ;******************************************************************
0009AD  1               ; init_sprites — upload pixel data + write sprite 1 attributes
0009AD  1               ;
0009AD  1               ;   Sprite 0 ($1FC00) is reserved by the KERNAL mouse cursor —
0009AD  1               ;   we disable it and keep clear of $1FC00.
0009AD  1               ;
0009AD  1               ;   Sprite 1 ($1FC08) = player ship
0009AD  1               ;   Pixel data at VRAM $00080 (128 bytes, 16x16 4bpp)
0009AD  1               ;   Address encoding:  addr[12:5] = $00080>>5 = $04  → byte 0 = $04
0009AD  1               ;                      4bpp, addr[16:13] = 0          → byte 1 = $00
0009AD  1               ;******************************************************************
0009AD  1               init_sprites:
0009AD  1  9C 25 9F        stz VERA_ctrl
0009B0  1               
0009B0  1                  ; --- set palette entries 1-4 ---
0009B0  1                  ; VERA palette entry N is 2 bytes at VRAM_palette + N*2
0009B0  1                  ; Byte 0: [7:4]=Green [3:0]=Blue   Byte 1: [3:0]=Red (bits 7-4 unused)
0009B0  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_palette + 2), 1   ; entry 1 (player white); stride=1 auto-advances
0009B4  1  9F A9 FA 8D  
0009B8  1  21 9F A9 02  
0009BF  1  A9 FF           lda #$FF                               ; G=$F, B=$F
0009C1  1  8D 23 9F        sta VERA_data0
0009C4  1  A9 0F           lda #$0F                               ; R=$F  → white
0009C6  1  8D 23 9F        sta VERA_data0
0009C9  1                  ; entry 2 = cyan  (R=0, G=$F, B=$F)
0009C9  1  A9 FF           lda #$FF                               ; G=$F, B=$F
0009CB  1  8D 23 9F        sta VERA_data0
0009CE  1  A9 00           lda #$00                               ; R=$0
0009D0  1  8D 23 9F        sta VERA_data0
0009D3  1                  ; entry 3 = magenta (R=$F, G=0, B=$F)
0009D3  1  A9 0F           lda #$0F                               ; G=$0, B=$F
0009D5  1  8D 23 9F        sta VERA_data0
0009D8  1  A9 0F           lda #$0F                               ; R=$F
0009DA  1  8D 23 9F        sta VERA_data0
0009DD  1                  ; entry 4 = green  (R=0, G=$F, B=0)
0009DD  1  A9 F0           lda #$F0                               ; G=$F, B=$0
0009DF  1  8D 23 9F        sta VERA_data0
0009E2  1  A9 00           lda #$00                               ; R=$0
0009E4  1  8D 23 9F        sta VERA_data0
0009E7  1                  ; entry 5 = red    (R=$F, G=0, B=0)
0009E7  1  A9 00           lda #$00                               ; G=$0, B=$0
0009E9  1  8D 23 9F        sta VERA_data0
0009EC  1  A9 0F           lda #$0F                               ; R=$F
0009EE  1  8D 23 9F        sta VERA_data0
0009F1  1                  ; --- disable sprite 0 (KERNAL mouse cursor) ---
0009F1  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_sprattr + 6), 1   ; sprite 0 byte 6 = z-depth
0009F5  1  9F A9 FC 8D  
0009F9  1  21 9F A9 06  
000A00  1  A9 00           lda #$00                               ; z-depth=0 → disabled
000A02  1  8D 23 9F        sta VERA_data0
000A05  1               
000A05  1                  ; --- upload player sprite pixel data to VRAM $00080 ---
000A05  1  A9 10 8D 22     VERA_SET_ADDR $00080, 1
000A09  1  9F A9 00 8D  
000A0D  1  21 9F A9 80  
000A14  1  A2 00           ldx #0
000A16  1               @upload:
000A16  1  BD 18 1E        lda player_spr_data,x
000A19  1  8D 23 9F        sta VERA_data0
000A1C  1  E8              inx
000A1D  1  E0 80           cpx #128
000A1F  1  D0 F5           bne @upload
000A21  1               
000A21  1                  ; --- write sprite 1 attribute bytes ---
000A21  1  A9 11 8D 22     VERA_SET_ADDR SPRITE1_ATTR, 1
000A25  1  9F A9 FC 8D  
000A29  1  21 9F A9 08  
000A30  1  A9 04           lda #$04
000A32  1  8D 23 9F        sta VERA_data0               ; byte 0: addr[12:5] = $00080>>5 = $04
000A35  1  A9 00           lda #$00
000A37  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, addr[16:13] = 0
000A3A  1  A5 rr           lda player_x_lo
000A3C  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000A3F  1  A5 rr           lda player_x_hi
000A41  1  29 03           and #$03
000A43  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000A46  1  A9 A4           lda #<PLAYER_Y
000A48  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000A4B  1  A9 01           lda #>PLAYER_Y
000A4D  1  29 03           and #$03
000A4F  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000A52  1  A9 0C           lda #SPR_Z_FRONT
000A54  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3, no collision, no flip
000A57  1  A9 50           lda #SPR_16x16_PAL0
000A59  1  8D 23 9F        sta VERA_data0               ; byte 7: palette 0, 16x16
000A5C  1               
000A5C  1                  ; --- upload player bullet pixel data to VRAM $00400 ---
000A5C  1  A9 10 8D 22     VERA_SET_ADDR VRAM_BULLET, 1
000A60  1  9F A9 04 8D  
000A64  1  21 9F A9 00  
000A6B  1  A2 00           ldx #0
000A6D  1               @up_bullet:
000A6D  1  BD 98 1E        lda bullet_spr_data,x
000A70  1  8D 23 9F        sta VERA_data0
000A73  1  E8              inx
000A74  1  E0 20           cpx #32
000A76  1  D0 F5           bne @up_bullet
000A78  1               
000A78  1                  ; --- write sprite 2 attributes (initially disabled, z-depth=0) ---
000A78  1  A9 11 8D 22     VERA_SET_ADDR BULLET_SPRITE_ATTR, 1
000A7C  1  9F A9 FC 8D  
000A80  1  21 9F A9 10  
000A87  1  A9 20           lda #$20                     ; byte 0: addr[12:5] = $00400>>5 = $20
000A89  1  8D 23 9F        sta VERA_data0
000A8C  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000A8E  1  8D 23 9F        sta VERA_data0
000A91  1  A9 00           lda #$00                     ; byte 2: X lo (arbitrary; sprite disabled)
000A93  1  8D 23 9F        sta VERA_data0
000A96  1  A9 00           lda #$00                     ; byte 3: X hi
000A98  1  8D 23 9F        sta VERA_data0
000A9B  1  A9 00           lda #$00                     ; byte 4: Y lo
000A9D  1  8D 23 9F        sta VERA_data0
000AA0  1  A9 00           lda #$00                     ; byte 5: Y hi
000AA2  1  8D 23 9F        sta VERA_data0
000AA5  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000AA7  1  8D 23 9F        sta VERA_data0
000AAA  1  A9 00           lda #SPR_8x8_PAL0            ; byte 7: 8x8, palette 0
000AAC  1  8D 23 9F        sta VERA_data0
000AAF  1               
000AAF  1                  ; --- upload explosion pixel data to VRAM $00440 ---
000AAF  1  A9 10 8D 22     VERA_SET_ADDR VRAM_EXPLOSION, 1
000AB3  1  9F A9 04 8D  
000AB7  1  21 9F A9 40  
000ABE  1  A2 00           ldx #0
000AC0  1               @up_exp:
000AC0  1  BD 72 1F        lda explosion_pixels,x
000AC3  1  8D 23 9F        sta VERA_data0
000AC6  1  E8              inx
000AC7  1  E0 80           cpx #128
000AC9  1  D0 F5           bne @up_exp
000ACB  1               
000ACB  1                  ; --- write sprite 4 attributes (initially disabled) ---
000ACB  1                  ; addr[12:5] = VRAM_EXPLOSION>>5 = $00440>>5 = $22
000ACB  1  A9 11 8D 22     VERA_SET_ADDR EXPLODE_SPRITE_ATTR, 1
000ACF  1  9F A9 FC 8D  
000AD3  1  21 9F A9 20  
000ADA  1  A9 22           lda #$22                     ; byte 0: addr[12:5]
000ADC  1  8D 23 9F        sta VERA_data0
000ADF  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000AE1  1  8D 23 9F        sta VERA_data0
000AE4  1  A9 00           lda #$00                     ; byte 2: X lo (placeholder)
000AE6  1  8D 23 9F        sta VERA_data0
000AE9  1  A9 00           lda #$00                     ; byte 3: X hi
000AEB  1  8D 23 9F        sta VERA_data0
000AEE  1  A9 00           lda #$00                     ; byte 4: Y lo (placeholder)
000AF0  1  8D 23 9F        sta VERA_data0
000AF3  1  A9 00           lda #$00                     ; byte 5: Y hi
000AF5  1  8D 23 9F        sta VERA_data0
000AF8  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000AFA  1  8D 23 9F        sta VERA_data0
000AFD  1  A9 50           lda #SPR_16x16_PAL0          ; byte 7: 16x16, palette 0
000AFF  1  8D 23 9F        sta VERA_data0
000B02  1               
000B02  1  64 rr           stz exp_timer
000B04  1               
000B04  1                  ; --- upload invader bullet pixel data to VRAM $00420 ---
000B04  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_BULLET, 1
000B08  1  9F A9 04 8D  
000B0C  1  21 9F A9 20  
000B13  1  A2 00           ldx #0
000B15  1               @up_ibul:
000B15  1  BD 52 1F        lda inv_bullet_spr_data,x
000B18  1  8D 23 9F        sta VERA_data0
000B1B  1  E8              inx
000B1C  1  E0 20           cpx #32
000B1E  1  D0 F5           bne @up_ibul
000B20  1               
000B20  1                  ; --- init 3 invader bullet sprites (slots 5-7, base $1FC28), all disabled ---
000B20  1                  ; addr[12:5] = VRAM_INV_BULLET>>5 = $00420>>5 = $21
000B20  1  A9 11 8D 22     VERA_SET_ADDR INV_BULLET_SPR_BASE, 1
000B24  1  9F A9 FC 8D  
000B28  1  21 9F A9 28  
000B2F  1  A2 03           ldx #3                       ; 3 sprites
000B31  1               @init_ibspr:
000B31  1  A9 21           lda #$21                     ; byte 0: addr[12:5] = $21
000B33  1  8D 23 9F        sta VERA_data0
000B36  1  A9 00           lda #$00
000B38  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, bank 0
000B3B  1  8D 23 9F        sta VERA_data0               ; byte 2: X lo
000B3E  1  8D 23 9F        sta VERA_data0               ; byte 3: X hi
000B41  1  8D 23 9F        sta VERA_data0               ; byte 4: Y lo
000B44  1  8D 23 9F        sta VERA_data0               ; byte 5: Y hi
000B47  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=0 → disabled
000B4A  1  8D 23 9F        sta VERA_data0               ; byte 7: 8x8, palette 0
000B4D  1  CA              dex
000B4E  1  D0 E1           bne @init_ibspr
000B50  1               
000B50  1                  ; --- clear invader bullet state ---
000B50  1  64 rr           stz ibul_active+0
000B52  1  64 rr           stz ibul_active+1
000B54  1  64 rr           stz ibul_active+2
000B56  1  A9 5A           lda #INV_FIRE_TIMER_INIT
000B58  1  85 rr           sta inv_fire_timer
000B5A  1               
000B5A  1                  ; --- upload UFO pixel data → VRAM $01500 ---
000B5A  1  A9 10 8D 22     VERA_SET_ADDR VRAM_UFO, 1
000B5E  1  9F A9 15 8D  
000B62  1  21 9F A9 00  
000B69  1  A2 80           ldx #128
000B6B  1  BD 72 1F     @up_ufo: lda ufo_spr_data-128,x
000B6E  1  8D 23 9F        sta VERA_data0
000B71  1  E8              inx
000B72  1  D0 F7           bne @up_ufo
000B74  1               
000B74  1                  ; --- write sprite 3 (UFO) attributes (initially disabled) ---
000B74  1                  ; addr[12:5] = VRAM_UFO>>5 = $01500>>5 = $A8
000B74  1  A9 11 8D 22     VERA_SET_ADDR UFO_SPRITE_ATTR, 1
000B78  1  9F A9 FC 8D  
000B7C  1  21 9F A9 18  
000B83  1  A9 A8           lda #$A8                     ; byte 0: addr[12:5]
000B85  1  8D 23 9F        sta VERA_data0
000B88  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000B8A  1  8D 23 9F        sta VERA_data0
000B8D  1  A9 00           lda #$00                     ; byte 2: X lo
000B8F  1  8D 23 9F        sta VERA_data0
000B92  1  A9 00           lda #$00                     ; byte 3: X hi
000B94  1  8D 23 9F        sta VERA_data0
000B97  1  A9 20           lda #<UFO_Y                  ; byte 4: Y lo
000B99  1  8D 23 9F        sta VERA_data0
000B9C  1  A9 00           lda #>UFO_Y                  ; byte 5: Y hi
000B9E  1  8D 23 9F        sta VERA_data0
000BA1  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000BA3  1  8D 23 9F        sta VERA_data0
000BA6  1  A9 50           lda #SPR_16x16_PAL0          ; byte 7: 16x16, palette 0
000BA8  1  8D 23 9F        sta VERA_data0
000BAB  1               
000BAB  1  60              rts
000BAC  1               
000BAC  1               ;******************************************************************
000BAC  1               ; init_invaders — upload invader pixel data, init grid state, place sprites
000BAC  1               ;******************************************************************
000BAC  1               init_invaders:
000BAC  1  9C 25 9F        stz VERA_ctrl
000BAF  1               
000BAF  1                  ; --- upload Type A frame 0 → VRAM $00100 ---
000BAF  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F0, 1
000BB3  1  9F A9 01 8D  
000BB7  1  21 9F A9 00  
000BBE  1  A2 80           ldx #128
000BC0  1  BD F2 1F     @up_af0: lda inv_a_spr_f0-128,x
000BC3  1  8D 23 9F        sta VERA_data0
000BC6  1  E8              inx
000BC7  1  D0 F7           bne @up_af0
000BC9  1               
000BC9  1                  ; --- upload Type A frame 1 → VRAM $00180 ---
000BC9  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F1, 1
000BCD  1  9F A9 01 8D  
000BD1  1  21 9F A9 80  
000BD8  1  A2 80           ldx #128
000BDA  1  BD 72 20     @up_af1: lda inv_a_spr_f1-128,x
000BDD  1  8D 23 9F        sta VERA_data0
000BE0  1  E8              inx
000BE1  1  D0 F7           bne @up_af1
000BE3  1               
000BE3  1                  ; --- upload Type B frame 0 → VRAM $00200 ---
000BE3  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F0, 1
000BE7  1  9F A9 02 8D  
000BEB  1  21 9F A9 00  
000BF2  1  A2 80           ldx #128
000BF4  1  BD F2 20     @up_bf0: lda inv_b_spr_f0-128,x
000BF7  1  8D 23 9F        sta VERA_data0
000BFA  1  E8              inx
000BFB  1  D0 F7           bne @up_bf0
000BFD  1               
000BFD  1                  ; --- upload Type B frame 1 → VRAM $00280 ---
000BFD  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F1, 1
000C01  1  9F A9 02 8D  
000C05  1  21 9F A9 80  
000C0C  1  A2 80           ldx #128
000C0E  1  BD 72 21     @up_bf1: lda inv_b_spr_f1-128,x
000C11  1  8D 23 9F        sta VERA_data0
000C14  1  E8              inx
000C15  1  D0 F7           bne @up_bf1
000C17  1               
000C17  1                  ; --- upload Type C frame 0 → VRAM $00300 ---
000C17  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F0, 1
000C1B  1  9F A9 03 8D  
000C1F  1  21 9F A9 00  
000C26  1  A2 80           ldx #128
000C28  1  BD F2 21     @up_cf0: lda inv_c_spr_f0-128,x
000C2B  1  8D 23 9F        sta VERA_data0
000C2E  1  E8              inx
000C2F  1  D0 F7           bne @up_cf0
000C31  1               
000C31  1                  ; --- upload Type C frame 1 → VRAM $00380 ---
000C31  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F1, 1
000C35  1  9F A9 03 8D  
000C39  1  21 9F A9 80  
000C40  1  A2 80           ldx #128
000C42  1  BD 72 22     @up_cf1: lda inv_c_spr_f1-128,x
000C45  1  8D 23 9F        sta VERA_data0
000C48  1  E8              inx
000C49  1  D0 F7           bne @up_cf1
000C4B  1               
000C4B  1                  ; --- initialize zero-page grid variables ---
000C4B  1  A9 70           lda #<INV_GRID_X_INIT
000C4D  1  85 rr           sta inv_grid_x_lo
000C4F  1  A9 00           lda #>INV_GRID_X_INIT
000C51  1  85 rr           sta inv_grid_x_hi
000C53  1  64 rr           stz inv_offset_y
000C55  1  64 rr           stz inv_direction
000C57  1  64 rr           stz inv_anim_frame
000C59  1  64 rr           stz inv_drop_flag
000C5B  1               
000C5B  1                  ; all 55 invaders alive: bytes 0-5 = $FF, byte 6 = $7F (55 bits)
000C5B  1  A9 FF           lda #$FF
000C5D  1  85 rr           sta inv_alive+0
000C5F  1  85 rr           sta inv_alive+1
000C61  1  85 rr           sta inv_alive+2
000C63  1  85 rr           sta inv_alive+3
000C65  1  85 rr           sta inv_alive+4
000C67  1  85 rr           sta inv_alive+5
000C69  1  A9 7F           lda #$7F
000C6B  1  85 rr           sta inv_alive+6
000C6D  1               
000C6D  1  A9 37           lda #INV_COUNT_INIT
000C6F  1  85 rr           sta inv_count
000C71  1  A5 rr           lda wave_init_speed
000C73  1  85 rr           sta inv_move_speed
000C75  1  85 rr           sta inv_move_timer
000C77  1               
000C77  1                  ; --- write initial sprite attributes for all 55 invaders ---
000C77  1  20 E3 0C        jsr update_invader_sprites
000C7A  1  60              rts
000C7B  1               
000C7B  1               ;******************************************************************
000C7B  1               ; step_invaders — one march step: move or drop grid, toggle anim frame
000C7B  1               ;   Called when inv_move_timer reaches 0.
000C7B  1               ;   Updates inv_grid_x / inv_offset_y, sets inv_drop_flag as needed,
000C7B  1               ;   then refreshes all VERA sprite positions.
000C7B  1               ;******************************************************************
000C7B  1               step_invaders:
000C7B  1                  ; toggle animation frame
000C7B  1  A5 rr           lda inv_anim_frame
000C7D  1  49 01           eor #1
000C7F  1  85 rr           sta inv_anim_frame
000C81  1               
000C81  1                  ; if drop flag is set: drop grid this step, skip march
000C81  1  A5 rr           lda inv_drop_flag
000C83  1  F0 0B           beq @do_march
000C85  1  64 rr           stz inv_drop_flag
000C87  1  A5 rr           lda inv_offset_y
000C89  1  18              clc
000C8A  1  69 10           adc #INV_DROP_Y
000C8C  1  85 rr           sta inv_offset_y
000C8E  1  80 4C           bra @sprites_done
000C90  1               
000C90  1               @do_march:
000C90  1  A5 rr           lda inv_direction
000C92  1  D0 25           bne @march_left
000C94  1               
000C94  1                  ; --- march right ---
000C94  1  A5 rr           lda inv_grid_x_lo
000C96  1  18              clc
000C97  1  69 04           adc #INV_STEP_X
000C99  1  85 rr           sta inv_grid_x_lo
000C9B  1  90 02           bcc @chk_right
000C9D  1  E6 rr           inc inv_grid_x_hi
000C9F  1               @chk_right:
000C9F  1                  ; hit right if grid_x > INV_X_RIGHT_LIM (208, fits in 1 byte, hi always 0)
000C9F  1  A5 rr           lda inv_grid_x_hi
000CA1  1  D0 06           bne @clamp_right          ; hi > 0 → definitely over limit
000CA3  1  A5 rr           lda inv_grid_x_lo
000CA5  1  C9 D1           cmp #INV_X_RIGHT_LIM + 1  ; C set if lo > limit
000CA7  1  90 33           bcc @sprites_done
000CA9  1               @clamp_right:
000CA9  1  A9 D0           lda #<INV_X_RIGHT_LIM
000CAB  1  85 rr           sta inv_grid_x_lo
000CAD  1  A9 00           lda #>INV_X_RIGHT_LIM
000CAF  1  85 rr           sta inv_grid_x_hi
000CB1  1  A9 01           lda #1
000CB3  1  85 rr           sta inv_direction
000CB5  1  85 rr           sta inv_drop_flag
000CB7  1  80 23           bra @sprites_done
000CB9  1               
000CB9  1                  ; --- march left ---
000CB9  1               @march_left:
000CB9  1  A5 rr           lda inv_grid_x_lo
000CBB  1  38              sec
000CBC  1  E9 04           sbc #INV_STEP_X
000CBE  1  85 rr           sta inv_grid_x_lo
000CC0  1  B0 02           bcs @chk_left             ; no borrow
000CC2  1  C6 rr           dec inv_grid_x_hi
000CC4  1               @chk_left:
000CC4  1                  ; hit left if hi went negative OR lo < INV_X_LEFT_LIM
000CC4  1  A5 rr           lda inv_grid_x_hi
000CC6  1  30 06           bmi @clamp_left
000CC8  1  A5 rr           lda inv_grid_x_lo
000CCA  1  C9 10           cmp #INV_X_LEFT_LIM
000CCC  1  B0 0E           bcs @sprites_done         ; lo >= left limit → ok
000CCE  1               @clamp_left:
000CCE  1  A9 10           lda #<INV_X_LEFT_LIM
000CD0  1  85 rr           sta inv_grid_x_lo
000CD2  1  A9 00           lda #>INV_X_LEFT_LIM
000CD4  1  85 rr           sta inv_grid_x_hi
000CD6  1  64 rr           stz inv_direction
000CD8  1  A9 01           lda #1
000CDA  1  85 rr           sta inv_drop_flag
000CDC  1               
000CDC  1               @sprites_done:
000CDC  1  20 8C 1B        jsr snd_march_step
000CDF  1  20 E3 0C        jsr update_invader_sprites
000CE2  1  60              rts
000CE3  1               
000CE3  1               ;******************************************************************
000CE3  1               ; update_invader_sprites — write all 55 invader sprite attributes to VERA
000CE3  1               ;
000CE3  1               ;   VERA sprite slots 11-65 hold the 55 invaders.
000CE3  1               ;   Attributes base: $1FC58 ($1FC00 + 11*8).
000CE3  1               ;   With stride=1 the VERA address auto-increments, so we set it
000CE3  1               ;   once and write all 440 bytes sequentially.
000CE3  1               ;
000CE3  1               ;   Byte layout per sprite:
000CE3  1               ;     0: data addr[12:5]   (encodes VRAM pixel data address + frame)
000CE3  1               ;     1: $00               (4bpp, addr[16:13]=0)
000CE3  1               ;     2: X[7:0]
000CE3  1               ;     3: X[9:8]
000CE3  1               ;     4: Y[7:0]
000CE3  1               ;     5: Y[9:8]
000CE3  1               ;     6: z-depth/collision
000CE3  1               ;     7: palette / size
000CE3  1               ;
000CE3  1               ;   Invader index i = row*11 + col; alive bit i in inv_alive bitmap.
000CE3  1               ;   For Phase 3 all invaders are alive; alive check will be added Phase 4.
000CE3  1               ;******************************************************************
000CE3  1               update_invader_sprites:
000CE3  1  9C 25 9F        stz VERA_ctrl
000CE6  1  A9 11           lda #$11              ; stride=1, VRAM bank bit=1 (addr $1Fxxxx)
000CE8  1  8D 22 9F        sta VERA_addr_bank
000CEB  1  A9 FC           lda #$FC
000CED  1  8D 21 9F        sta VERA_addr_high
000CF0  1  A9 58           lda #$58
000CF2  1  8D 20 9F        sta VERA_addr_low     ; VERA now at $1FC58, auto-increments by 1
000CF5  1               
000CF5  1                  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000CF5  1  A9 50           lda #<INV_GRID_Y_BASE
000CF7  1  18              clc
000CF8  1  65 rr           adc inv_offset_y
000CFA  1  85 rr           sta zp_y_base_lo
000CFC  1  A9 00           lda #>INV_GRID_Y_BASE
000CFE  1  69 00           adc #0
000D00  1  85 rr           sta zp_y_base_hi
000D02  1               
000D02  1  64 rr           stz zp_row
000D04  1               @row_loop:
000D04  1                  ; compute row Y: zp_row_y = zp_y_base + row_y_offsets[row]
000D04  1  A4 rr           ldy zp_row
000D06  1  B9 D8 1E        lda row_y_offsets,y
000D09  1  18              clc
000D0A  1  65 rr           adc zp_y_base_lo
000D0C  1  85 rr           sta zp_row_y_lo
000D0E  1  A9 00           lda #0
000D10  1  65 rr           adc zp_y_base_hi
000D12  1  85 rr           sta zp_row_y_hi
000D14  1               
000D14  1                  ; select addr byte0 based on row type and animation frame
000D14  1  A4 rr           ldy zp_row
000D16  1  A5 rr           lda inv_anim_frame
000D18  1  F0 05           beq @use_f0
000D1A  1  B9 BD 1E        lda inv_addr_b0_f1,y
000D1D  1  80 03           bra @got_b0
000D1F  1               @use_f0:
000D1F  1  B9 B8 1E        lda inv_addr_b0_f0,y
000D22  1               @got_b0:
000D22  1  85 rr           sta zp_addr_b0
000D24  1               
000D24  1  20 30 0D        jsr update_invader_row
000D27  1               
000D27  1  E6 rr           inc zp_row
000D29  1  A5 rr           lda zp_row
000D2B  1  C9 05           cmp #5
000D2D  1  D0 D5           bne @row_loop
000D2F  1               
000D2F  1  60              rts
000D30  1               
000D30  1               ;******************************************************************
000D30  1               ; update_invader_row — write 11 sprite attribute blocks for one row
000D30  1               ;
000D30  1               ;   Inputs (ZP): zp_row, zp_addr_b0, zp_row_y_lo/hi, inv_grid_x_lo/hi
000D30  1               ;   VERA address register must already be set to the first sprite slot
000D30  1               ;   for this row on entry (maintained by the sequential write stream).
000D30  1               ;******************************************************************
000D30  1               update_invader_row:
000D30  1  64 rr           stz zp_col
000D32  1               @col_loop:
000D32  1                  ; --- determine z-depth from alive bitmap ---
000D32  1                  ; index = inv_row_base[row] + col; byte = index>>3; bit = index&7
000D32  1  A4 rr           ldy zp_row
000D34  1  B9 DD 1E        lda inv_row_base,y
000D37  1  18              clc
000D38  1  65 rr           adc zp_col
000D3A  1  A8              tay                   ; Y = invader index
000D3B  1  29 07           and #$07
000D3D  1  AA              tax                   ; X = bit index
000D3E  1  BD E2 1E        lda bit_masks,x
000D41  1  48              pha                   ; save bit mask
000D42  1  98              tya
000D43  1  4A              lsr
000D44  1  4A              lsr
000D45  1  4A              lsr
000D46  1  A8              tay                   ; Y = byte index into inv_alive
000D47  1  68              pla                   ; A = bit mask
000D48  1  39 rr rr        and inv_alive,y
000D4B  1  F0 04           beq @zdepth_off
000D4D  1  A9 0C           lda #SPR_Z_FRONT
000D4F  1  80 02           bra @zdepth_done
000D51  1               @zdepth_off:
000D51  1  A9 00           lda #0
000D53  1               @zdepth_done:
000D53  1  85 rr           sta zp_scratch_lo     ; save z-depth before VERA stream starts
000D55  1               
000D55  1                  ; --- compute sprite X = inv_grid_x + col_x_offsets[col] ---
000D55  1  A4 rr           ldy zp_col
000D57  1  B9 C2 1E        lda col_x_lo,y
000D5A  1  18              clc
000D5B  1  65 rr           adc inv_grid_x_lo
000D5D  1  85 rr           sta zp_x_lo
000D5F  1  B9 CD 1E        lda col_x_hi,y
000D62  1  65 rr           adc inv_grid_x_hi
000D64  1  85 rr           sta zp_x_hi
000D66  1               
000D66  1                  ; --- write 8 attribute bytes (VERA auto-increments) ---
000D66  1  A5 rr           lda zp_addr_b0
000D68  1  8D 23 9F        sta VERA_data0        ; byte 0: data addr[12:5]
000D6B  1  9C 23 9F        stz VERA_data0        ; byte 1: 4bpp, addr[16:13]=0
000D6E  1  A5 rr           lda zp_x_lo
000D70  1  8D 23 9F        sta VERA_data0        ; byte 2: X[7:0]
000D73  1  A5 rr           lda zp_x_hi
000D75  1  29 03           and #$03
000D77  1  8D 23 9F        sta VERA_data0        ; byte 3: X[9:8]
000D7A  1  A5 rr           lda zp_row_y_lo
000D7C  1  8D 23 9F        sta VERA_data0        ; byte 4: Y[7:0]
000D7F  1  A5 rr           lda zp_row_y_hi
000D81  1  29 03           and #$03
000D83  1  8D 23 9F        sta VERA_data0        ; byte 5: Y[9:8]
000D86  1  A5 rr           lda zp_scratch_lo
000D88  1  8D 23 9F        sta VERA_data0        ; byte 6: z-depth (SPR_Z_FRONT if alive, 0 if dead)
000D8B  1  A9 50           lda #SPR_16x16_PAL0
000D8D  1  8D 23 9F        sta VERA_data0        ; byte 7: 16x16, palette offset 0
000D90  1               
000D90  1  E6 rr           inc zp_col
000D92  1  A5 rr           lda zp_col
000D94  1  C9 0B           cmp #11
000D96  1  D0 9A           bne @col_loop
000D98  1               
000D98  1  60              rts
000D99  1               
000D99  1               ;******************************************************************
000D99  1               ; move_player — apply key_flags movement and clamp to screen edges
000D99  1               ;******************************************************************
000D99  1               move_player:
000D99  1  A5 rr           lda key_flags
000D9B  1               
000D9B  1                  ; --- move left ---
000D9B  1  29 01           and #KEY_LEFT
000D9D  1  F0 1F           beq @check_right
000D9F  1  A5 rr           lda player_x_lo
000DA1  1  38              sec
000DA2  1  E9 04           sbc #PLAYER_SPEED
000DA4  1  85 rr           sta player_x_lo
000DA6  1  B0 02           bcs @clamp_left              ; no borrow → hi unchanged
000DA8  1  C6 rr           dec player_x_hi
000DAA  1               @clamp_left:
000DAA  1                  ; Clamp: if hi went negative ($FF) or (hi=0 AND lo < min) → set to min
000DAA  1  A5 rr           lda player_x_hi
000DAC  1  30 08           bmi @set_min                 ; $80–$FF = underflowed
000DAE  1  D0 0E           bne @check_right             ; hi > 0 → still above minimum
000DB0  1  A5 rr           lda player_x_lo
000DB2  1  C9 08           cmp #PLAYER_X_MIN
000DB4  1  B0 08           bcs @check_right             ; lo >= min → ok
000DB6  1               @set_min:
000DB6  1  A9 08           lda #<PLAYER_X_MIN
000DB8  1  85 rr           sta player_x_lo
000DBA  1  A9 00           lda #>PLAYER_X_MIN
000DBC  1  85 rr           sta player_x_hi
000DBE  1               
000DBE  1                  ; --- move right ---
000DBE  1               @check_right:
000DBE  1  A5 rr           lda key_flags
000DC0  1  29 02           and #KEY_RIGHT
000DC2  1  F0 23           beq @move_done
000DC4  1  A5 rr           lda player_x_lo
000DC6  1  18              clc
000DC7  1  69 04           adc #PLAYER_SPEED
000DC9  1  85 rr           sta player_x_lo
000DCB  1  90 02           bcc @clamp_right             ; no carry → hi unchanged
000DCD  1  E6 rr           inc player_x_hi
000DCF  1               @clamp_right:
000DCF  1                  ; Clamp: if hi > max_hi, OR (hi == max_hi AND lo > max_lo) → set to max
000DCF  1  A5 rr           lda player_x_hi
000DD1  1  C9 02           cmp #>PLAYER_X_MAX
000DD3  1  90 12           bcc @move_done               ; hi < max_hi → definitely ok
000DD5  1  D0 08           bne @set_max                 ; hi > max_hi → over limit
000DD7  1  A5 rr           lda player_x_lo
000DD9  1  C9 68           cmp #<PLAYER_X_MAX
000DDB  1  90 0A           bcc @move_done               ; lo < max_lo when hi == max_hi → ok
000DDD  1  F0 08           beq @move_done               ; lo == max_lo → exactly at max, ok
000DDF  1               @set_max:
000DDF  1  A9 68           lda #<PLAYER_X_MAX
000DE1  1  85 rr           sta player_x_lo
000DE3  1  A9 02           lda #>PLAYER_X_MAX
000DE5  1  85 rr           sta player_x_hi
000DE7  1               
000DE7  1               @move_done:
000DE7  1  60              rts
000DE8  1               
000DE8  1               ;******************************************************************
000DE8  1               ; update_player_sprite — write current X position to sprite 1 in VERA
000DE8  1               ;   Only X needs updating (Y is fixed)
000DE8  1               ;******************************************************************
000DE8  1               update_player_sprite:
000DE8  1  9C 25 9F        stz VERA_ctrl
000DEB  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 2), 1
000DEF  1  9F A9 FC 8D  
000DF3  1  21 9F A9 0A  
000DFA  1  A5 rr           lda player_x_lo
000DFC  1  8D 23 9F        sta VERA_data0               ; sprite byte 2: X[7:0]
000DFF  1  A5 rr           lda player_x_hi
000E01  1  29 03           and #$03
000E03  1  8D 23 9F        sta VERA_data0               ; sprite byte 3: X[9:8]
000E06  1                  ; update z-depth based on inv_hit_timer:
000E06  1                  ;   timer = 0        → show solid (not hit)
000E06  1                  ;   timer = 61-120   → hidden solid (1-second respawn delay)
000E06  1                  ;   timer = 1-60     → flashing (invincible, visible warning)
000E06  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 6), 1
000E0A  1  9F A9 FC 8D  
000E0E  1  21 9F A9 0E  
000E15  1  A5 rr           lda inv_hit_timer
000E17  1  F0 08           beq @show                    ; timer=0 → show solid
000E19  1  C9 3D           cmp #61
000E1B  1  B0 08           bcs @hide                    ; timer>=61 → first second: fully hidden
000E1D  1  29 08           and #$08                     ; timer 1-60: bit 3 flips every 8 frames → ~4 Hz flash
000E1F  1  D0 04           bne @hide
000E21  1               @show:
000E21  1  A9 0C           lda #SPR_Z_FRONT
000E23  1  80 02           bra @write_z
000E25  1               @hide:
000E25  1  A9 00           lda #0
000E27  1               @write_z:
000E27  1  8D 23 9F        sta VERA_data0               ; sprite byte 6: z-depth
000E2A  1  60              rts
000E2B  1               
000E2B  1               ;******************************************************************
000E2B  1               ; fire_bullet — activate player bullet at cannon tip, update sprite
000E2B  1               ;   Bullet X centers the 8-px bullet over the 16-px player ship:
000E2B  1               ;     bullet_x = player_x + 4
000E2B  1               ;   Bullet Y starts 8 VERA pixels above the player sprite top.
000E2B  1               ;   Caller must check bullet_active == 0 before calling.
000E2B  1               ;******************************************************************
000E2B  1               fire_bullet:
000E2B  1  A5 rr           lda player_x_lo
000E2D  1  18              clc
000E2E  1  69 04           adc #4
000E30  1  85 rr           sta bullet_x_lo
000E32  1  A5 rr           lda player_x_hi
000E34  1  69 00           adc #0
000E36  1  85 rr           sta bullet_x_hi
000E38  1               
000E38  1  A9 9C           lda #<BULLET_Y_INIT
000E3A  1  85 rr           sta bullet_y_lo
000E3C  1  A9 01           lda #>BULLET_Y_INIT
000E3E  1  85 rr           sta bullet_y_hi
000E40  1               
000E40  1  A9 01           lda #1
000E42  1  85 rr           sta bullet_active
000E44  1  E6 rr           inc shot_count
000E46  1  20 66 0E        jsr update_bullet_sprite
000E49  1  20 FC 1B        jsr snd_fire
000E4C  1  60              rts
000E4D  1               
000E4D  1               ;******************************************************************
000E4D  1               ; move_bullet — move bullet upward by BULLET_SPEED each frame;
000E4D  1               ;   deactivate when it reaches the top of the screen (Y underflows 0)
000E4D  1               ;******************************************************************
000E4D  1               move_bullet:
000E4D  1  A5 rr           lda bullet_y_lo
000E4F  1  38              sec
000E50  1  E9 0C           sbc #BULLET_SPEED
000E52  1  85 rr           sta bullet_y_lo
000E54  1  A5 rr           lda bullet_y_hi
000E56  1  E9 00           sbc #0
000E58  1  85 rr           sta bullet_y_hi
000E5A  1  30 04           bmi @deactivate              ; 16-bit underflow past 0 → off screen
000E5C  1               
000E5C  1  20 66 0E        jsr update_bullet_sprite
000E5F  1  60              rts
000E60  1               
000E60  1               @deactivate:
000E60  1  64 rr           stz bullet_active
000E62  1  20 66 0E        jsr update_bullet_sprite     ; disables sprite (z-depth=0)
000E65  1  60              rts
000E66  1               
000E66  1               ;******************************************************************
000E66  1               ; update_bullet_sprite — write bullet position and enable/disable
000E66  1               ;   to VERA sprite 2 (bytes 2-6); byte 7 set once at init.
000E66  1               ;   z-depth = SPR_Z_FRONT when active, 0 when inactive.
000E66  1               ;******************************************************************
000E66  1               update_bullet_sprite:
000E66  1  9C 25 9F        stz VERA_ctrl
000E69  1  A9 11 8D 22     VERA_SET_ADDR (BULLET_SPRITE_ATTR + 2), 1
000E6D  1  9F A9 FC 8D  
000E71  1  21 9F A9 12  
000E78  1  A5 rr           lda bullet_x_lo
000E7A  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000E7D  1  A5 rr           lda bullet_x_hi
000E7F  1  29 03           and #$03
000E81  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000E84  1  A5 rr           lda bullet_y_lo
000E86  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000E89  1  A5 rr           lda bullet_y_hi
000E8B  1  29 03           and #$03
000E8D  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000E90  1  A5 rr           lda bullet_active
000E92  1  F0 04           beq @z_off
000E94  1  A9 0C           lda #SPR_Z_FRONT
000E96  1  80 02           bra @write_z
000E98  1               @z_off:
000E98  1  A9 00           lda #$00
000E9A  1               @write_z:
000E9A  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
000E9D  1  60              rts
000E9E  1               
000E9E  1               ;******************************************************************
000E9E  1               ; check_bullet_invader — scan all 55 invaders for a hit with the player bullet
000E9E  1               ;
000E9E  1               ;   Iterates rows 0-4, columns 0-10.  Skips dead invaders.
000E9E  1               ;   For each live invader checks 16-bit AABB overlap:
000E9E  1               ;     X: bullet_x+8 > inv_x  AND  bullet_x < inv_x+16
000E9E  1               ;     Y: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000E9E  1               ;   On hit: calls kill_invader_hit and returns immediately.
000E9E  1               ;
000E9E  1               ;   Scratch used: zp_y_base_lo/hi, zp_row_y_lo/hi, zp_x_lo/hi,
000E9E  1               ;                 zp_scratch_lo/hi, zp_row, zp_col
000E9E  1               ;******************************************************************
000E9E  1               check_bullet_invader:
000E9E  1  A5 rr           lda bullet_active
000EA0  1  D0 01           bne :+
000EA2  1  60              rts
000EA3  1               :  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000EA3  1  A9 50           lda #<INV_GRID_Y_BASE
000EA5  1  18              clc
000EA6  1  65 rr           adc inv_offset_y
000EA8  1  85 rr           sta zp_y_base_lo
000EAA  1  A9 00           lda #>INV_GRID_Y_BASE
000EAC  1  69 00           adc #0
000EAE  1  85 rr           sta zp_y_base_hi
000EB0  1               
000EB0  1  64 rr           stz zp_row
000EB2  1               @row_loop:
000EB2  1                  ; row Y = y_base + row_y_offsets[row]
000EB2  1  A4 rr           ldy zp_row
000EB4  1  B9 D8 1E        lda row_y_offsets,y
000EB7  1  18              clc
000EB8  1  65 rr           adc zp_y_base_lo
000EBA  1  85 rr           sta zp_row_y_lo
000EBC  1  A9 00           lda #0
000EBE  1  65 rr           adc zp_y_base_hi
000EC0  1  85 rr           sta zp_row_y_hi
000EC2  1               
000EC2  1                  ; --- Quick Y range check for whole row ---
000EC2  1                  ; Need: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000EC2  1               
000EC2  1                  ; (1) bullet_y+8 > inv_y  →  (bullet_y+8) - inv_y > 0
000EC2  1                  ;     result negative (bmi) means bullet above this row
000EC2  1  A5 rr           lda bullet_y_lo
000EC4  1  18              clc
000EC5  1  69 08           adc #8
000EC7  1  85 rr           sta zp_scratch_lo
000EC9  1  A5 rr           lda bullet_y_hi
000ECB  1  69 00           adc #0
000ECD  1  85 rr           sta zp_scratch_hi
000ECF  1  A5 rr           lda zp_scratch_lo
000ED1  1  38              sec
000ED2  1  E5 rr           sbc zp_row_y_lo
000ED4  1  A5 rr           lda zp_scratch_hi
000ED6  1  E5 rr           sbc zp_row_y_hi
000ED8  1  30 1D           bmi @next_row         ; bullet bottom above invader top → no hit in this row
000EDA  1               
000EDA  1                  ; (2) bullet_y < inv_y+16  →  bullet_y - (inv_y+16) < 0
000EDA  1                  ;     result >= 0 (bpl) means bullet below this row
000EDA  1  A5 rr           lda zp_row_y_lo
000EDC  1  18              clc
000EDD  1  69 10           adc #16
000EDF  1  85 rr           sta zp_scratch_lo
000EE1  1  A5 rr           lda zp_row_y_hi
000EE3  1  69 00           adc #0
000EE5  1  85 rr           sta zp_scratch_hi
000EE7  1  A5 rr           lda bullet_y_lo
000EE9  1  38              sec
000EEA  1  E5 rr           sbc zp_scratch_lo
000EEC  1  A5 rr           lda bullet_y_hi
000EEE  1  E5 rr           sbc zp_scratch_hi
000EF0  1  10 05           bpl @next_row         ; bullet top at or below invader bottom → no hit
000EF2  1               
000EF2  1                  ; Y overlaps this row — check each column
000EF2  1  20 00 0F        jsr cbi_check_cols
000EF5  1  B0 08           bcs @done             ; hit found; bullet already handled
000EF7  1               
000EF7  1               @next_row:
000EF7  1  E6 rr           inc zp_row
000EF9  1  A5 rr           lda zp_row
000EFB  1  C9 05           cmp #5
000EFD  1  D0 B3           bne @row_loop
000EFF  1               
000EFF  1               @done:
000EFF  1  60              rts
000F00  1               
000F00  1               ;******************************************************************
000F00  1               ; cbi_check_cols — column scan for check_bullet_invader
000F00  1               ;
000F00  1               ;   Scans all 11 columns of zp_row for an X overlap with the bullet.
000F00  1               ;   Assumes Y overlap for this row has already been confirmed.
000F00  1               ;   Returns: C set if hit (kill_invader_hit already called),
000F00  1               ;            C clear if no hit.
000F00  1               ;   Scratch used: zp_col, zp_x_lo/hi, zp_scratch_lo/hi
000F00  1               ;******************************************************************
000F00  1               cbi_check_cols:
000F00  1  64 rr           stz zp_col
000F02  1               @col_loop:
000F02  1                  ; skip if invader is dead
000F02  1  A4 rr           ldy zp_row
000F04  1  B9 DD 1E        lda inv_row_base,y
000F07  1  18              clc
000F08  1  65 rr           adc zp_col
000F0A  1  A8              tay                   ; Y = invader index
000F0B  1  29 07           and #$07
000F0D  1  AA              tax
000F0E  1  BD E2 1E        lda bit_masks,x
000F11  1  48              pha
000F12  1  98              tya
000F13  1  4A              lsr
000F14  1  4A              lsr
000F15  1  4A              lsr
000F16  1  A8              tay                   ; Y = byte index into inv_alive
000F17  1  68              pla
000F18  1  39 rr rr        and inv_alive,y
000F1B  1  F0 46           beq @next_col         ; dead
000F1D  1               
000F1D  1                  ; compute inv_x = inv_grid_x + col_x_offsets[col]
000F1D  1  A4 rr           ldy zp_col
000F1F  1  B9 C2 1E        lda col_x_lo,y
000F22  1  18              clc
000F23  1  65 rr           adc inv_grid_x_lo
000F25  1  85 rr           sta zp_x_lo
000F27  1  B9 CD 1E        lda col_x_hi,y
000F2A  1  65 rr           adc inv_grid_x_hi
000F2C  1  85 rr           sta zp_x_hi
000F2E  1               
000F2E  1                  ; X check (1): bullet_x+8 > inv_x
000F2E  1  A5 rr           lda bullet_x_lo
000F30  1  18              clc
000F31  1  69 08           adc #8
000F33  1  85 rr           sta zp_scratch_lo
000F35  1  A5 rr           lda bullet_x_hi
000F37  1  69 00           adc #0
000F39  1  85 rr           sta zp_scratch_hi
000F3B  1  A5 rr           lda zp_scratch_lo
000F3D  1  38              sec
000F3E  1  E5 rr           sbc zp_x_lo
000F40  1  A5 rr           lda zp_scratch_hi
000F42  1  E5 rr           sbc zp_x_hi
000F44  1  30 1D           bmi @next_col         ; bullet right edge left of invader → no hit
000F46  1               
000F46  1                  ; X check (2): bullet_x < inv_x+16
000F46  1  A5 rr           lda zp_x_lo
000F48  1  18              clc
000F49  1  69 10           adc #16
000F4B  1  85 rr           sta zp_scratch_lo
000F4D  1  A5 rr           lda zp_x_hi
000F4F  1  69 00           adc #0
000F51  1  85 rr           sta zp_scratch_hi
000F53  1  A5 rr           lda bullet_x_lo
000F55  1  38              sec
000F56  1  E5 rr           sbc zp_scratch_lo
000F58  1  A5 rr           lda bullet_x_hi
000F5A  1  E5 rr           sbc zp_scratch_hi
000F5C  1  10 05           bpl @next_col         ; bullet left edge at or right of invader → no hit
000F5E  1               
000F5E  1                  ; --- HIT ---
000F5E  1  20 6D 0F        jsr kill_invader_hit
000F61  1  38              sec                   ; signal hit to caller
000F62  1  60              rts
000F63  1               
000F63  1               @next_col:
000F63  1  E6 rr           inc zp_col
000F65  1  A5 rr           lda zp_col
000F67  1  C9 0B           cmp #11
000F69  1  D0 97           bne @col_loop
000F6B  1               
000F6B  1  18              clc                   ; no hit
000F6C  1  60              rts
000F6D  1               
000F6D  1               ;******************************************************************
000F6D  1               ; kill_invader_hit — clear alive bit, deactivate bullet, update score & speed
000F6D  1               ;   Expects zp_row, zp_col to identify the hit invader.
000F6D  1               ;******************************************************************
000F6D  1               kill_invader_hit:
000F6D  1                  ; --- clear alive bit ---
000F6D  1  A4 rr           ldy zp_row
000F6F  1  B9 DD 1E        lda inv_row_base,y
000F72  1  18              clc
000F73  1  65 rr           adc zp_col
000F75  1  A8              tay                   ; Y = invader index
000F76  1  29 07           and #$07
000F78  1  AA              tax
000F79  1  BD E2 1E        lda bit_masks,x       ; bit mask for this invader
000F7C  1  48              pha
000F7D  1  98              tya
000F7E  1  4A              lsr
000F7F  1  4A              lsr
000F80  1  4A              lsr
000F81  1  A8              tay                   ; Y = byte index into inv_alive
000F82  1  68              pla
000F83  1  49 FF           eor #$FF              ; invert → clear mask
000F85  1  39 rr rr        and inv_alive,y
000F88  1  99 rr rr        sta inv_alive,y
000F8B  1               
000F8B  1                  ; --- start explosion at the hit invader's position ---
000F8B  1                  ; zp_x_lo/hi and zp_row_y_lo/hi still hold the invader coords from collision detection
000F8B  1  20 B9 0F        jsr start_explosion
000F8E  1               
000F8E  1                  ; --- deactivate bullet ---
000F8E  1  64 rr           stz bullet_active
000F90  1  20 66 0E        jsr update_bullet_sprite
000F93  1               
000F93  1                  ; --- decrement inv_count ---
000F93  1  C6 rr           dec inv_count
000F95  1               
000F95  1                  ; --- update inv_move_speed: proportional to remaining count ---
000F95  1  A6 rr           ldx inv_count
000F97  1  BD EF 1E        lda inv_speed_table,x
000F9A  1  85 rr           sta inv_move_speed
000F9C  1               
000F9C  1                  ; --- add score for this row's invader type ---
000F9C  1  A4 rr           ldy zp_row
000F9E  1  B9 EA 1E        lda score_by_row_bcd,y
000FA1  1  20 A5 0F        jsr add_score
000FA4  1  60              rts
000FA5  1               
000FA5  1               ;******************************************************************
000FA5  1               ; add_score — add BCD value in A to score_lo/mid/hi
000FA5  1               ;******************************************************************
000FA5  1               add_score:
000FA5  1  F8              sed
000FA6  1  18              clc
000FA7  1  65 rr           adc score_lo
000FA9  1  85 rr           sta score_lo
000FAB  1  A5 rr           lda score_mid
000FAD  1  69 00           adc #0
000FAF  1  85 rr           sta score_mid
000FB1  1  A5 rr           lda score_hi
000FB3  1  69 00           adc #0
000FB5  1  85 rr           sta score_hi
000FB7  1  D8              cld
000FB8  1  60              rts
000FB9  1               
000FB9  1               ;******************************************************************
000FB9  1               ; start_explosion — position sprite 4 at the hit invader and start timer
000FB9  1               ;
000FB9  1               ;   Inputs: zp_x_lo/hi     — invader X (VERA coords)
000FB9  1               ;           zp_row_y_lo/hi — invader Y (VERA coords)
000FB9  1               ;   Sets exp_timer = EXPLODE_FRAMES and enables sprite 4.
000FB9  1               ;******************************************************************
000FB9  1               start_explosion:
000FB9  1  9C 25 9F        stz VERA_ctrl
000FBC  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 2), 1  ; start at byte 2 (X lo)
000FC0  1  9F A9 FC 8D  
000FC4  1  21 9F A9 22  
000FCB  1  A5 rr           lda zp_x_lo
000FCD  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000FD0  1  A5 rr           lda zp_x_hi
000FD2  1  29 03           and #$03
000FD4  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000FD7  1  A5 rr           lda zp_row_y_lo
000FD9  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000FDC  1  A5 rr           lda zp_row_y_hi
000FDE  1  29 03           and #$03
000FE0  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000FE3  1  A9 0C           lda #SPR_Z_FRONT
000FE5  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3 → enabled, in front
000FE8  1  A9 1E           lda #EXPLODE_FRAMES
000FEA  1  85 rr           sta exp_timer
000FEC  1  20 61 1C        jsr snd_explosion
000FEF  1  60              rts
000FF0  1               
000FF0  1               ;******************************************************************
000FF0  1               ; update_explosion — decrement exp_timer; disable sprite when it hits 0
000FF0  1               ;******************************************************************
000FF0  1               update_explosion:
000FF0  1  A5 rr           lda exp_timer
000FF2  1  F0 1B           beq @inactive
000FF4  1  C6 rr           dec exp_timer
000FF6  1  D0 17           bne @inactive
000FF8  1                  ; timer just expired — disable sprite 4
000FF8  1  9C 25 9F        stz VERA_ctrl
000FFB  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1  ; byte 6 = z-depth
000FFF  1  9F A9 FC 8D  
001003  1  21 9F A9 26  
00100A  1  A9 00           lda #$00
00100C  1  8D 23 9F        sta VERA_data0               ; z-depth=0 → disabled
00100F  1               @inactive:
00100F  1  60              rts
001010  1               
001010  1               ;******************************************************************
001010  1               ; prng — 16-bit Galois LFSR, feedback polynomial $B400
001010  1               ;   Updates rand_seed_lo/hi; returns pseudo-random byte in A.
001010  1               ;******************************************************************
001010  1               prng:
001010  1  46 rr           lsr rand_seed_hi          ; shift 16-bit state right; carry = old hi[0]
001012  1  66 rr           ror rand_seed_lo          ; lo[7] = old hi[0]; carry = old lo[0] (feedback bit)
001014  1  90 06           bcc @done                 ; feedback bit=0: no XOR
001016  1  A5 rr           lda rand_seed_hi
001018  1  49 B4           eor #$B4                  ; XOR hi byte with feedback poly ($B400 >> 8)
00101A  1  85 rr           sta rand_seed_hi
00101C  1               @done:
00101C  1  A5 rr           lda rand_seed_lo
00101E  1  60              rts
00101F  1               
00101F  1               ;******************************************************************
00101F  1               ; update_inv_bullets — fire timer, move active bullets, boundary check,
00101F  1               ;   update VERA sprites for all 3 invader bullet slots.
00101F  1               ;******************************************************************
00101F  1               update_inv_bullets:
00101F  1                  ; --- fire timer ---
00101F  1  C6 rr           dec inv_fire_timer
001021  1  D0 0D           bne @move_loop
001023  1                  ; reset timer = max(inv_move_speed, INV_FIRE_TIMER_MIN)
001023  1  A5 rr           lda inv_move_speed
001025  1  C9 0A           cmp #INV_FIRE_TIMER_MIN
001027  1  B0 02           bcs @set_timer
001029  1  A9 0A           lda #INV_FIRE_TIMER_MIN
00102B  1               @set_timer:
00102B  1  85 rr           sta inv_fire_timer
00102D  1  20 9A 10        jsr try_fire_inv_bullet
001030  1               
001030  1               @move_loop:
001030  1  A2 00           ldx #0
001032  1               @slot_loop:
001032  1  B5 rr           lda ibul_active,x
001034  1  F0 1B           beq @update_spr           ; inactive: just hide sprite
001036  1               
001036  1                  ; move bullet down by INV_BULLET_SPEED
001036  1  B5 rr           lda ibul_y_lo,x
001038  1  18              clc
001039  1  69 06           adc #INV_BULLET_SPEED
00103B  1  95 rr           sta ibul_y_lo,x
00103D  1  B5 rr           lda ibul_y_hi,x
00103F  1  69 00           adc #0
001041  1  95 rr           sta ibul_y_hi,x
001043  1               
001043  1                  ; boundary: deactivate if Y >= 480 ($01E0)
001043  1  C9 01           cmp #>480                 ; A = new hi byte; compare with 1
001045  1  90 0A           bcc @update_spr           ; hi < 1: still on screen
001047  1  D0 06           bne @deactivate           ; hi > 1: off screen
001049  1  B5 rr           lda ibul_y_lo,x
00104B  1  C9 E0           cmp #<480                 ; compare lo with $E0
00104D  1  90 02           bcc @update_spr           ; lo < $E0: still on screen
00104F  1               @deactivate:
00104F  1  74 rr           stz ibul_active,x
001051  1               
001051  1               @update_spr:
001051  1  20 5A 10        jsr update_inv_bullet_sprite   ; preserves X
001054  1  E8              inx
001055  1  E0 03           cpx #3
001057  1  D0 D9           bne @slot_loop
001059  1  60              rts
00105A  1               
00105A  1               ;******************************************************************
00105A  1               ; update_inv_bullet_sprite — write VERA sprite attrs bytes 2-6 for slot X
00105A  1               ;   X = slot index (0-2).  Preserves X.
00105A  1               ;******************************************************************
00105A  1               update_inv_bullet_sprite:
00105A  1  86 rr           stx zp_scratch_lo              ; preserve slot index
00105C  1  9C 25 9F        stz VERA_ctrl
00105F  1  A9 11           lda #$11                       ; stride=1, bank bit=1
001061  1  8D 22 9F        sta VERA_addr_bank
001064  1  A9 FC           lda #$FC
001066  1  8D 21 9F        sta VERA_addr_high
001069  1  BD 27 1F        lda ibul_spr_lo,x
00106C  1  18              clc
00106D  1  69 02           adc #2                         ; point to byte 2 (X position)
00106F  1  8D 20 9F        sta VERA_addr_low
001072  1  B5 rr           lda ibul_x_lo,x
001074  1  8D 23 9F        sta VERA_data0                 ; byte 2: X lo
001077  1  B5 rr           lda ibul_x_hi,x
001079  1  29 03           and #$03
00107B  1  8D 23 9F        sta VERA_data0                 ; byte 3: X hi
00107E  1  B5 rr           lda ibul_y_lo,x
001080  1  8D 23 9F        sta VERA_data0                 ; byte 4: Y lo
001083  1  B5 rr           lda ibul_y_hi,x
001085  1  29 03           and #$03
001087  1  8D 23 9F        sta VERA_data0                 ; byte 5: Y hi
00108A  1  B5 rr           lda ibul_active,x
00108C  1  F0 04           beq @disabled
00108E  1  A9 0C           lda #SPR_Z_FRONT
001090  1  80 02           bra @write_z
001092  1               @disabled:
001092  1  A9 00           lda #0
001094  1               @write_z:
001094  1  8D 23 9F        sta VERA_data0                 ; byte 6: z-depth
001097  1  A6 rr           ldx zp_scratch_lo
001099  1  60              rts
00109A  1               
00109A  1               ;******************************************************************
00109A  1               ; try_fire_inv_bullet — find a free slot and spawn a bullet from the
00109A  1               ;   bottommost live invader in a randomly chosen column.
00109A  1               ;   Returns immediately if all slots busy or chosen column is empty.
00109A  1               ;   Scratch used: zp_row, zp_col, zp_scratch_lo (slot index)
00109A  1               ;******************************************************************
00109A  1               try_fire_inv_bullet:
00109A  1                  ; find a free bullet slot
00109A  1  A2 00           ldx #0
00109C  1               @find_slot:
00109C  1  B5 rr           lda ibul_active,x
00109E  1  F0 06           beq @slot_found
0010A0  1  E8              inx
0010A1  1  E0 03           cpx #3
0010A3  1  D0 F7           bne @find_slot
0010A5  1  60              rts                            ; all slots busy
0010A6  1               
0010A6  1               @slot_found:
0010A6  1  86 rr           stx zp_scratch_lo              ; save free slot index
0010A8  1               
0010A8  1                  ; pick a random column 0-10
0010A8  1  20 10 10        jsr prng
0010AB  1  29 0F           and #$0F                       ; 0-15
0010AD  1  C9 0B           cmp #11
0010AF  1  90 03           bcc @col_ok
0010B1  1  38              sec
0010B2  1  E9 0B           sbc #11                        ; wrap 11-15 → 0-4 (slight bias, acceptable)
0010B4  1               @col_ok:
0010B4  1  85 rr           sta zp_col
0010B6  1               
0010B6  1                  ; scan rows 4 down to 0 for bottommost live invader in this column
0010B6  1  A9 04           lda #4
0010B8  1  85 rr           sta zp_row
0010BA  1               @row_scan:
0010BA  1  A4 rr           ldy zp_row
0010BC  1  B9 DD 1E        lda inv_row_base,y
0010BF  1  18              clc
0010C0  1  65 rr           adc zp_col
0010C2  1  A8              tay                            ; Y = invader index
0010C3  1  29 07           and #$07
0010C5  1  AA              tax                            ; X = bit position
0010C6  1  BD E2 1E        lda bit_masks,x
0010C9  1  48              pha
0010CA  1  98              tya
0010CB  1  4A              lsr
0010CC  1  4A              lsr
0010CD  1  4A              lsr
0010CE  1  A8              tay                            ; Y = byte index into inv_alive
0010CF  1  68              pla
0010D0  1  39 rr rr        and inv_alive,y
0010D3  1  D0 09           bne @found_invader
0010D5  1  A5 rr           lda zp_row
0010D7  1  F0 04           beq @no_invader                ; checked row 0, nothing alive
0010D9  1  C6 rr           dec zp_row
0010DB  1  80 DD           bra @row_scan
0010DD  1               
0010DD  1               @no_invader:
0010DD  1  60              rts                            ; column empty, skip fire
0010DE  1               
0010DE  1               @found_invader:
0010DE  1  A6 rr           ldx zp_scratch_lo              ; restore free slot index
0010E0  1  A9 01           lda #1
0010E2  1  95 rr           sta ibul_active,x
0010E4  1               
0010E4  1                  ; spawn X = inv_grid_x + col_x_offsets[col]  (16-bit, matching update_invader_sprites)
0010E4  1  A4 rr           ldy zp_col
0010E6  1  B9 C2 1E        lda col_x_lo,y
0010E9  1  18              clc
0010EA  1  65 rr           adc inv_grid_x_lo
0010EC  1  95 rr           sta ibul_x_lo,x
0010EE  1  B9 CD 1E        lda col_x_hi,y
0010F1  1  65 rr           adc inv_grid_x_hi
0010F3  1  95 rr           sta ibul_x_hi,x
0010F5  1                  ; add +4 as a separate 16-bit step to centre the 8px bullet in the 16px invader
0010F5  1  B5 rr           lda ibul_x_lo,x
0010F7  1  18              clc
0010F8  1  69 04           adc #4
0010FA  1  95 rr           sta ibul_x_lo,x
0010FC  1  B5 rr           lda ibul_x_hi,x
0010FE  1  69 00           adc #0
001100  1  95 rr           sta ibul_x_hi,x
001102  1               
001102  1                  ; spawn Y: compute y_base first (same two-step pattern as update_invader_sprites)
001102  1                  ; step 1: y_base = INV_GRID_Y_BASE + inv_offset_y  (16-bit)
001102  1  A9 50           lda #<INV_GRID_Y_BASE
001104  1  18              clc
001105  1  65 rr           adc inv_offset_y
001107  1  85 rr           sta zp_y_base_lo
001109  1  A9 00           lda #>INV_GRID_Y_BASE
00110B  1  69 00           adc #0
00110D  1  85 rr           sta zp_y_base_hi
00110F  1                  ; step 2: spawn_y = y_base + row_y_offsets[row]
00110F  1  A4 rr           ldy zp_row
001111  1  B9 D8 1E        lda row_y_offsets,y
001114  1  18              clc
001115  1  65 rr           adc zp_y_base_lo
001117  1  95 rr           sta ibul_y_lo,x
001119  1  A9 00           lda #0
00111B  1  65 rr           adc zp_y_base_hi
00111D  1  95 rr           sta ibul_y_hi,x
00111F  1                  ; step 3: +16 to place bullet at the bottom edge of the 16px invader
00111F  1  B5 rr           lda ibul_y_lo,x
001121  1  18              clc
001122  1  69 10           adc #16
001124  1  95 rr           sta ibul_y_lo,x
001126  1  B5 rr           lda ibul_y_hi,x
001128  1  69 00           adc #0
00112A  1  95 rr           sta ibul_y_hi,x
00112C  1               
00112C  1  60              rts
00112D  1               
00112D  1               ;******************************************************************
00112D  1               ; check_inv_bullet_player — AABB test each active invader bullet vs. player
00112D  1               ;
00112D  1               ;   Player rect: (player_x, PLAYER_Y) to (player_x+15, PLAYER_Y+15), 16x16
00112D  1               ;   Bullet rect: (ibul_x,   ibul_y)   to (ibul_x+7,   ibul_y+7),     8x8
00112D  1               ;
00112D  1               ;   On hit: bullet deactivated, jsr player_hit called, loop continues
00112D  1               ;   (remaining bullets checked — at most one hit landing per frame).
00112D  1               ;   Scratch: zp_scratch_lo/hi, X (slot index)
00112D  1               ;******************************************************************
00112D  1               check_inv_bullet_player:
00112D  1  A2 00           ldx #0
00112F  1               @slot_loop:
00112F  1  B5 rr           lda ibul_active,x
001131  1  F0 5B           beq @next_slot
001133  1               
001133  1                  ; --- Y check 1: (bullet_y + 8) > PLAYER_Y  →  bullet_y + 8 - PLAYER_Y > 0 ---
001133  1  B5 rr           lda ibul_y_lo,x
001135  1  18              clc
001136  1  69 08           adc #8
001138  1  85 rr           sta zp_scratch_lo
00113A  1  B5 rr           lda ibul_y_hi,x
00113C  1  69 00           adc #0
00113E  1  85 rr           sta zp_scratch_hi
001140  1  A5 rr           lda zp_scratch_lo
001142  1  38              sec
001143  1  E9 A4           sbc #<PLAYER_Y
001145  1  A5 rr           lda zp_scratch_hi
001147  1  E9 01           sbc #>PLAYER_Y
001149  1  30 43           bmi @next_slot            ; bullet bottom above player top → no hit
00114B  1               
00114B  1                  ; --- Y check 2: bullet_y < PLAYER_Y + 16 → bullet_y - (PLAYER_Y+16) < 0 ---
00114B  1  B5 rr           lda ibul_y_lo,x
00114D  1  38              sec
00114E  1  E9 B4           sbc #<(PLAYER_Y+16)
001150  1  B5 rr           lda ibul_y_hi,x
001152  1  E9 01           sbc #>(PLAYER_Y+16)
001154  1  10 38           bpl @next_slot            ; bullet top at or below player bottom → no hit
001156  1               
001156  1                  ; --- X check 1: (bullet_x + 8) > player_x ---
001156  1  B5 rr           lda ibul_x_lo,x
001158  1  18              clc
001159  1  69 08           adc #8
00115B  1  85 rr           sta zp_scratch_lo
00115D  1  B5 rr           lda ibul_x_hi,x
00115F  1  69 00           adc #0
001161  1  85 rr           sta zp_scratch_hi
001163  1  A5 rr           lda zp_scratch_lo
001165  1  38              sec
001166  1  E5 rr           sbc player_x_lo
001168  1  A5 rr           lda zp_scratch_hi
00116A  1  E5 rr           sbc player_x_hi
00116C  1  30 20           bmi @next_slot            ; bullet right edge left of player → no hit
00116E  1               
00116E  1                  ; --- X check 2: bullet_x < player_x + 16 ---
00116E  1  A5 rr           lda player_x_lo
001170  1  18              clc
