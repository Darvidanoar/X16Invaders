0017B0  1               ;******************************************************************
0017B0  1               ; update_shield_sprite — write new data-addr byte to shield sprite N
0017B0  1               ;   Input:  X = shield index (0–3)
0017B0  1               ;           shield_damage[X] = current damage level (1–7)
0017B0  1               ;   Writes sprite byte 0 (addr[12:5]) using shield_addr_b0 lookup.
0017B0  1               ;   VERA addr for byte 0 of sprite N: $1FE10 + N*8
0017B0  1               ;******************************************************************
0017B0  1               update_shield_sprite:
0017B0  1  9C 25 9F        stz VERA_ctrl
0017B3  1  A9 11           lda #$11               ; stride=1, bank=1
0017B5  1  8D 22 9F        sta VERA_addr_bank
0017B8  1  A9 FE           lda #$FE
0017BA  1  8D 21 9F        sta VERA_addr_high
0017BD  1  8A              txa                    ; A = shield index
0017BE  1  0A              asl                    ; ×2
0017BF  1  0A              asl                    ; ×4
0017C0  1  0A              asl                    ; ×8
0017C1  1  18              clc
0017C2  1  69 10           adc #$10               ; + low byte of $1FE10
0017C4  1  8D 20 9F        sta VERA_addr_low
0017C7  1  B4 rr           ldy shield_damage, x   ; Y = damage level (1-3)
0017C9  1  B9 31 1D        lda shield_addr_b0, y  ; addr[12:5] for this tile
0017CC  1  8D 23 9F        sta VERA_data0
0017CF  1  60              rts
0017D0  1               
0017D0  1               ;******************************************************************
0017D0  1               ; hide_shield_sprite — disable sprite for shield N (z-depth=0)
0017D0  1               ;   Input: X = shield index (0–3)
0017D0  1               ;   Writes sprite byte 6 at $1FE10 + N*8 + 6 = $1FE16 + N*8
0017D0  1               ;******************************************************************
0017D0  1               hide_shield_sprite:
0017D0  1  9C 25 9F        stz VERA_ctrl
0017D3  1  A9 11           lda #$11
0017D5  1  8D 22 9F        sta VERA_addr_bank
0017D8  1  A9 FE           lda #$FE
0017DA  1  8D 21 9F        sta VERA_addr_high
0017DD  1  8A              txa
0017DE  1  0A              asl
0017DF  1  0A              asl
0017E0  1  0A              asl
0017E1  1  18              clc
0017E2  1  69 16           adc #$16               ; low($1FE10) + 6 = $16, + N*8
0017E4  1  8D 20 9F        sta VERA_addr_low
0017E7  1  A9 00           lda #0                 ; z-depth=0 → sprite disabled
0017E9  1  8D 23 9F        sta VERA_data0
0017EC  1  60              rts
0017ED  1               
0017ED  1               ;******************************************************************
0017ED  1               ; damage_shield — increment damage counter for shield X and update
0017ED  1               ;   sprite (or disable it when counter reaches 8 = destroyed).
0017ED  1               ;   Input:  X = shield index (0–3)
0017ED  1               ;   Clobbers: A, Y, VERA registers.  Preserves X.
0017ED  1               ;******************************************************************
0017ED  1               damage_shield:
0017ED  1  F6 rr           inc shield_damage, x
0017EF  1  B5 rr           lda shield_damage, x
0017F1  1  C9 08           cmp #8
0017F3  1  F0 06           beq @destroy
0017F5  1  B0 07           bcs @done              ; already at 8 (safety guard)
0017F7  1  20 B0 17        jsr update_shield_sprite
0017FA  1  60              rts
0017FB  1               @destroy:
0017FB  1  20 D0 17        jsr hide_shield_sprite
0017FE  1               @done:
0017FE  1  60              rts
0017FF  1               
0017FF  1               ;******************************************************************
0017FF  1               ; check_bullet_shields — test active player bullet vs all 4 shields
0017FF  1               ;
0017FF  1               ;   Overlap condition (AABB, all values VERA 16-bit):
0017FF  1               ;     X: bullet_x+8 > shield_x  AND  bullet_x < shield_x+16
0017FF  1               ;     Y: bullet_y+8 > SHIELD_Y  AND  bullet_y < SHIELD_Y+16
0017FF  1               ;
0017FF  1               ;   On hit: calls damage_shield, deactivates bullet, returns.
0017FF  1               ;   Scratch used: zp_scratch_lo/hi.  Preserves nothing.
0017FF  1               ;******************************************************************
0017FF  1               check_bullet_shields:
0017FF  1  A5 rr           lda bullet_active
001801  1  F0 6D           beq @done
001803  1               
001803  1                  ; --- Y quick check (same band for all shields) ---
001803  1                  ; (1) bullet_y+8 > SHIELD_Y
001803  1  A5 rr           lda bullet_y_lo
001805  1  18              clc
001806  1  69 08           adc #8
001808  1  85 rr           sta zp_scratch_lo
00180A  1  A5 rr           lda bullet_y_hi
00180C  1  69 00           adc #0
00180E  1  85 rr           sta zp_scratch_hi
001810  1  A5 rr           lda zp_scratch_lo
001812  1  38              sec
001813  1  E9 60           sbc #<SHIELD_Y
001815  1  A5 rr           lda zp_scratch_hi
001817  1  E9 01           sbc #>SHIELD_Y
001819  1  30 55           bmi @done              ; bullet bottom above shield top
00181B  1               
00181B  1                  ; (2) bullet_y < SHIELD_Y+32
00181B  1  A5 rr           lda bullet_y_lo
00181D  1  38              sec
00181E  1  E9 80           sbc #<(SHIELD_Y + 32)
001820  1  A5 rr           lda bullet_y_hi
001822  1  E9 01           sbc #>(SHIELD_Y + 32)
001824  1  10 4A           bpl @done              ; bullet top at or below shield bottom
001826  1               
001826  1                  ; --- Y overlaps: scan each shield ---
001826  1  A2 00           ldx #0
001828  1               @sld_loop:
001828  1  B5 rr           lda shield_damage, x
00182A  1  C9 08           cmp #8
00182C  1  B0 3D           bcs @next_sld          ; destroyed, skip
00182E  1               
00182E  1                  ; X check (1): bullet_x+8 > shield_x[x]
00182E  1  A5 rr           lda bullet_x_lo
001830  1  18              clc
001831  1  69 08           adc #8
001833  1  85 rr           sta zp_scratch_lo
001835  1  A5 rr           lda bullet_x_hi
001837  1  69 00           adc #0
001839  1  85 rr           sta zp_scratch_hi
00183B  1  A5 rr           lda zp_scratch_lo
00183D  1  38              sec
00183E  1  FD 29 1D        sbc shield_x_lo, x
001841  1  A5 rr           lda zp_scratch_hi
001843  1  FD 2D 1D        sbc shield_x_hi, x
001846  1  30 23           bmi @next_sld
001848  1               
001848  1                  ; X check (2): bullet_x < shield_x[x]+32
001848  1  BD 29 1D        lda shield_x_lo, x
00184B  1  18              clc
00184C  1  69 20           adc #32
00184E  1  85 rr           sta zp_scratch_lo
001850  1  BD 2D 1D        lda shield_x_hi, x
001853  1  69 00           adc #0
001855  1  85 rr           sta zp_scratch_hi
001857  1  A5 rr           lda bullet_x_lo
001859  1  38              sec
00185A  1  E5 rr           sbc zp_scratch_lo
00185C  1  A5 rr           lda bullet_x_hi
00185E  1  E5 rr           sbc zp_scratch_hi
001860  1  10 09           bpl @next_sld
001862  1               
001862  1                  ; --- HIT ---
001862  1  20 ED 17        jsr damage_shield      ; X = shield index
001865  1  64 rr           stz bullet_active
001867  1  20 3D 0E        jsr update_bullet_sprite
00186A  1  60              rts
00186B  1               
00186B  1               @next_sld:
00186B  1  E8              inx
00186C  1  E0 04           cpx #4
00186E  1  D0 B8           bne @sld_loop
001870  1               @done:
001870  1  60              rts
001871  1               
001871  1               ;******************************************************************
001871  1               ; check_invbullet_shields — test each active invader bullet vs all
001871  1               ;   4 shields.  Same AABB logic as check_bullet_shields but loops
001871  1               ;   over 3 bullet slots (ibul_active / ibul_x / ibul_y arrays).
001871  1               ;
001871  1               ;   Scratch: zp_scratch_lo/hi, zp_row (bullet slot index),
001871  1               ;            zp_col (shield index during inner scan).
001871  1               ;******************************************************************
001871  1               check_invbullet_shields:
001871  1  A2 00           ldx #0                 ; outer loop: invader bullet slot
001873  1               @ibul_loop:
001873  1  86 rr           stx zp_row             ; save slot before any branch
001875  1  B5 rr           lda ibul_active, x
001877  1  F0 7B           beq @next_ibul
001879  1               
001879  1                  ; --- Y quick check ---
001879  1                  ; (1) ibul_y+8 > SHIELD_Y
001879  1  B5 rr           lda ibul_y_lo, x
00187B  1  18              clc
00187C  1  69 08           adc #8
00187E  1  85 rr           sta zp_scratch_lo
001880  1  B5 rr           lda ibul_y_hi, x
001882  1  69 00           adc #0
001884  1  85 rr           sta zp_scratch_hi
001886  1  A5 rr           lda zp_scratch_lo
001888  1  38              sec
001889  1  E9 60           sbc #<SHIELD_Y
00188B  1  A5 rr           lda zp_scratch_hi
00188D  1  E9 01           sbc #>SHIELD_Y
00188F  1  30 63           bmi @next_ibul
001891  1               
001891  1                  ; (2) ibul_y < SHIELD_Y+32
001891  1  A6 rr           ldx zp_row
001893  1  B5 rr           lda ibul_y_lo, x
001895  1  38              sec
001896  1  E9 80           sbc #<(SHIELD_Y + 32)
001898  1  B5 rr           lda ibul_y_hi, x
00189A  1  E9 01           sbc #>(SHIELD_Y + 32)
00189C  1  10 56           bpl @next_ibul
00189E  1               
00189E  1                  ; --- Y overlaps: scan shields with Y register ---
00189E  1  A0 00           ldy #0
0018A0  1               @sld_scan:
0018A0  1  B9 rr rr        lda shield_damage, y
0018A3  1  C9 08           cmp #8
0018A5  1  B0 48           bcs @next_sld_y        ; destroyed
0018A7  1               
0018A7  1                  ; X check (1): ibul_x+8 > shield_x[y]
0018A7  1  A6 rr           ldx zp_row
0018A9  1  B5 rr           lda ibul_x_lo, x
0018AB  1  18              clc
0018AC  1  69 08           adc #8
0018AE  1  85 rr           sta zp_scratch_lo
0018B0  1  B5 rr           lda ibul_x_hi, x
0018B2  1  69 00           adc #0
0018B4  1  85 rr           sta zp_scratch_hi
0018B6  1  A5 rr           lda zp_scratch_lo
0018B8  1  38              sec
0018B9  1  F9 29 1D        sbc shield_x_lo, y
0018BC  1  A5 rr           lda zp_scratch_hi
0018BE  1  F9 2D 1D        sbc shield_x_hi, y
0018C1  1  30 2C           bmi @next_sld_y
0018C3  1               
0018C3  1                  ; X check (2): ibul_x < shield_x[y]+32
0018C3  1  B9 29 1D        lda shield_x_lo, y
0018C6  1  18              clc
0018C7  1  69 20           adc #32
0018C9  1  85 rr           sta zp_scratch_lo
0018CB  1  B9 2D 1D        lda shield_x_hi, y
0018CE  1  69 00           adc #0
0018D0  1  85 rr           sta zp_scratch_hi
0018D2  1  A6 rr           ldx zp_row
0018D4  1  B5 rr           lda ibul_x_lo, x
0018D6  1  38              sec
0018D7  1  E5 rr           sbc zp_scratch_lo
0018D9  1  B5 rr           lda ibul_x_hi, x
0018DB  1  E5 rr           sbc zp_scratch_hi
0018DD  1  10 10           bpl @next_sld_y
0018DF  1               
0018DF  1                  ; --- HIT ---
0018DF  1  98              tya                    ; shield index → A → X for damage_shield
0018E0  1  AA              tax
0018E1  1  20 ED 17        jsr damage_shield
0018E4  1  A6 rr           ldx zp_row             ; restore bullet slot
0018E6  1  74 rr           stz ibul_active, x
0018E8  1  20 2E 10        jsr update_inv_bullet_sprite
0018EB  1  A6 rr           ldx zp_row
0018ED  1  80 05           bra @next_ibul         ; done with this bullet
0018EF  1               
0018EF  1               @next_sld_y:
0018EF  1  C8              iny
0018F0  1  C0 04           cpy #4
0018F2  1  D0 AC           bne @sld_scan
0018F4  1               
0018F4  1               @next_ibul:
0018F4  1  A6 rr           ldx zp_row
0018F6  1  E8              inx
0018F7  1  E0 03           cpx #3
0018F9  1  F0 03           beq @cis_done
0018FB  1  4C 73 18        jmp @ibul_loop
0018FE  1               @cis_done:
0018FE  1  60              rts
0018FF  1               
0018FF  1               ;******************************************************************
0018FF  1               ; add_score_bcd — add a 2-byte BCD pair to the score
0018FF  1               ;   A = BCD low byte (units/tens), Y = BCD mid byte (hundreds/thousands)
0018FF  1               ;******************************************************************
0018FF  1               add_score_bcd:
0018FF  1  F8              sed
001900  1  18              clc
001901  1  65 rr           adc score_lo
001903  1  85 rr           sta score_lo
001905  1  98              tya
001906  1  65 rr           adc score_mid
001908  1  85 rr           sta score_mid
00190A  1  A5 rr           lda score_hi
00190C  1  69 00           adc #0
00190E  1  85 rr           sta score_hi
001910  1  D8              cld
001911  1  60              rts
001912  1               
001912  1               ;******************************************************************
001912  1               ; update_ufo — per-frame UFO logic: spawn timer + movement
001912  1               ;
001912  1               ;   Inactive: 16-bit ufo_timer counts down each frame.
001912  1               ;   On zero: UFO spawns at left edge (X=0), timer reset to
001912  1               ;             UFO_TIMER_INIT + (prng() & $7F) for next cycle.
001912  1               ;   Active: move right UFO_SPEED VERA pixels/frame.
001912  1               ;           Deactivate when X >= 640 (off right edge).
001912  1               ;   Updates VERA sprite 3 after any state change.
001912  1               ;******************************************************************
001912  1               update_ufo:
001912  1  A5 rr           lda ufo_active
001914  1  D0 36           bne @move_ufo
001916  1               
001916  1                  ; --- timer countdown (16-bit decrement) ---
001916  1  A5 rr           lda ufo_timer_lo
001918  1  D0 0B           bne @dec_lo
00191A  1  A5 rr           lda ufo_timer_hi
00191C  1  F0 0F           beq @spawn                   ; both zero → spawn (guard against stuck state)
00191E  1  C6 rr           dec ufo_timer_hi
001920  1  A9 FF           lda #$FF
001922  1  85 rr           sta ufo_timer_lo
001924  1  60              rts
001925  1               @dec_lo:
001925  1  C6 rr           dec ufo_timer_lo
001927  1  A5 rr           lda ufo_timer_lo
001929  1  05 rr           ora ufo_timer_hi
00192B  1  D0 47           bne @ufo_done                ; timer not yet zero
00192D  1               
00192D  1               @spawn:
00192D  1  A9 01           lda #1
00192F  1  85 rr           sta ufo_active
001931  1  64 rr           stz ufo_x_lo
001933  1  64 rr           stz ufo_x_hi
001935  1                  ; next timer = UFO_TIMER_INIT + (prng() & $7F) so interval varies by 0-127 frames
001935  1  20 E4 0F        jsr prng
001938  1  29 7F           and #$7F
00193A  1  18              clc
00193B  1  69 58           adc #<UFO_TIMER_INIT
00193D  1  85 rr           sta ufo_timer_lo
00193F  1  A9 02           lda #>UFO_TIMER_INIT
001941  1  69 00           adc #0
001943  1  85 rr           sta ufo_timer_hi
001945  1  20 75 19        jsr update_ufo_sprite
001948  1  20 37 1A        jsr snd_start_ufo_drone
00194B  1  60              rts
00194C  1               
00194C  1                  ; --- move UFO right ---
00194C  1               @move_ufo:
00194C  1  A5 rr           lda ufo_x_lo
00194E  1  18              clc
00194F  1  69 02           adc #UFO_SPEED
001951  1  85 rr           sta ufo_x_lo
001953  1  A5 rr           lda ufo_x_hi
001955  1  69 00           adc #0
001957  1  85 rr           sta ufo_x_hi
001959  1                  ; deactivate if X high byte >= 3 (≥ 768, safely off the 640-wide screen)
001959  1                  ; simpler guard: X hi > 0 means X >= 256; combined with lo check
001959  1  C9 02           cmp #>640                    ; A = new hi; >640 = 2
00195B  1  90 11           bcc @ufo_on_screen           ; hi < 2 → still visible
00195D  1  D0 06           bne @ufo_off_screen          ; hi > 2 → gone
00195F  1  A5 rr           lda ufo_x_lo
001961  1  C9 80           cmp #<640
001963  1  90 09           bcc @ufo_on_screen           ; hi=2, lo < 128 → past edge but close; still off
001965  1               @ufo_off_screen:
001965  1  64 rr           stz ufo_active
001967  1  20 75 19        jsr update_ufo_sprite
00196A  1  20 5E 1A        jsr snd_stop_ufo_drone
00196D  1  60              rts
00196E  1               @ufo_on_screen:
00196E  1  20 75 19        jsr update_ufo_sprite
001971  1  20 76 1A        jsr snd_update_ufo_drone
001974  1               @ufo_done:
001974  1  60              rts
001975  1               
001975  1               ;******************************************************************
001975  1               ; update_ufo_sprite — write sprite 3 (UFO) position + enable/disable
001975  1               ;   addr[12:5] = VRAM_UFO>>5 = $01500>>5 = $A8
001975  1               ;   Writes bytes 2-6; bytes 0-1 and 7 set once at init.
001975  1               ;******************************************************************
001975  1               update_ufo_sprite:
001975  1  9C 25 9F        stz VERA_ctrl
001978  1  A9 11 8D 22     VERA_SET_ADDR (UFO_SPRITE_ATTR + 2), 1
00197C  1  9F A9 FC 8D  
001980  1  21 9F A9 1A  
001987  1  A5 rr           lda ufo_x_lo
001989  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
00198C  1  A5 rr           lda ufo_x_hi
00198E  1  29 03           and #$03
001990  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
001993  1  A9 20           lda #<UFO_Y
001995  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
001998  1  A9 00           lda #>UFO_Y
00199A  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
00199D  1  A5 rr           lda ufo_active
00199F  1  F0 04           beq @z_off
0019A1  1  A9 0C           lda #SPR_Z_FRONT
0019A3  1  80 02           bra @write_z
0019A5  1               @z_off:
0019A5  1  A9 00           lda #0
0019A7  1               @write_z:
0019A7  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
0019AA  1  60              rts
0019AB  1               
0019AB  1               ;******************************************************************
0019AB  1               ; check_bullet_ufo — AABB test: player bullet vs. UFO sprite (16x16)
0019AB  1               ;   Bullet rect: (bullet_x, bullet_y)+(7,7);  UFO rect: (ufo_x, UFO_Y)+(15,15)
0019AB  1               ;   On hit: bullet deactivated, UFO killed, score added, explosion started.
0019AB  1               ;   Scratch: zp_scratch_lo/hi, zp_x_lo/hi, zp_row_y_lo/hi
0019AB  1               ;******************************************************************
0019AB  1               check_bullet_ufo:
0019AB  1  A5 rr           lda bullet_active
0019AD  1  D0 01           bne :+
0019AF  1  60              rts
0019B0  1  A5 rr        :  lda ufo_active
0019B2  1  D0 01           bne :+
0019B4  1  60              rts
0019B5  1               :
0019B5  1               
0019B5  1                  ; --- Y check 1: bullet_y+8 > UFO_Y ---
0019B5  1  A5 rr           lda bullet_y_lo
0019B7  1  18              clc
0019B8  1  69 08           adc #8
0019BA  1  85 rr           sta zp_scratch_lo
0019BC  1  A5 rr           lda bullet_y_hi
0019BE  1  69 00           adc #0
0019C0  1  85 rr           sta zp_scratch_hi
0019C2  1  A5 rr           lda zp_scratch_lo
0019C4  1  38              sec
0019C5  1  E9 20           sbc #<UFO_Y
0019C7  1  A5 rr           lda zp_scratch_hi
0019C9  1  E9 00           sbc #>UFO_Y
0019CB  1  30 69           bmi @done                    ; bullet bottom above UFO top → no hit
0019CD  1               
0019CD  1                  ; --- Y check 2: bullet_y < UFO_Y+16 ---
0019CD  1  A5 rr           lda bullet_y_lo
0019CF  1  38              sec
0019D0  1  E9 30           sbc #<(UFO_Y + 16)
0019D2  1  A5 rr           lda bullet_y_hi
0019D4  1  E9 00           sbc #>(UFO_Y + 16)
0019D6  1  10 5E           bpl @done                    ; bullet top at or below UFO bottom → no hit
0019D8  1               
0019D8  1                  ; --- X check 1: bullet_x+8 > ufo_x ---
0019D8  1  A5 rr           lda bullet_x_lo
0019DA  1  18              clc
0019DB  1  69 08           adc #8
0019DD  1  85 rr           sta zp_scratch_lo
0019DF  1  A5 rr           lda bullet_x_hi
0019E1  1  69 00           adc #0
0019E3  1  85 rr           sta zp_scratch_hi
0019E5  1  A5 rr           lda zp_scratch_lo
0019E7  1  38              sec
0019E8  1  E5 rr           sbc ufo_x_lo
0019EA  1  A5 rr           lda zp_scratch_hi
0019EC  1  E5 rr           sbc ufo_x_hi
0019EE  1  30 46           bmi @done                    ; bullet right edge left of UFO left edge → no hit
0019F0  1               
0019F0  1                  ; --- X check 2: bullet_x < ufo_x+16 ---
0019F0  1  A5 rr           lda ufo_x_lo
0019F2  1  18              clc
0019F3  1  69 10           adc #16
0019F5  1  85 rr           sta zp_scratch_lo
0019F7  1  A5 rr           lda ufo_x_hi
0019F9  1  69 00           adc #0
0019FB  1  85 rr           sta zp_scratch_hi
0019FD  1  A5 rr           lda bullet_x_lo
0019FF  1  38              sec
001A00  1  E5 rr           sbc zp_scratch_lo
001A02  1  A5 rr           lda bullet_x_hi
001A04  1  E5 rr           sbc zp_scratch_hi
001A06  1  10 2E           bpl @done                    ; bullet left edge at or right of UFO right edge → no hit
001A08  1               
001A08  1                  ; --- HIT ---
001A08  1  A5 rr           lda ufo_x_lo
001A0A  1  85 rr           sta zp_x_lo
001A0C  1  A5 rr           lda ufo_x_hi
001A0E  1  85 rr           sta zp_x_hi
001A10  1  A9 20           lda #<UFO_Y
001A12  1  85 rr           sta zp_row_y_lo
001A14  1  A9 00           lda #>UFO_Y
001A16  1  85 rr           sta zp_row_y_hi
001A18  1  20 90 0F        jsr start_explosion
001A1B  1               
001A1B  1  64 rr           stz bullet_active
001A1D  1  20 3D 0E        jsr update_bullet_sprite
001A20  1               
001A20  1  64 rr           stz ufo_active
001A22  1  20 75 19        jsr update_ufo_sprite
001A25  1  20 5E 1A        jsr snd_stop_ufo_drone
001A28  1               
001A28  1                  ; score: ufo_score table indexed by shot_count & 7
001A28  1  A5 rr           lda shot_count
001A2A  1  29 07           and #$07
001A2C  1  AA              tax
001A2D  1  BD 19 1D        lda ufo_score_lo, x
001A30  1  BC 21 1D        ldy ufo_score_hi, x
001A33  1  20 FF 18        jsr add_score_bcd
001A36  1               
001A36  1               @done:
001A36  1  60              rts
001A37  1               
001A37  1               ;******************************************************************
001A37  1               ; snd_start_ufo_drone — enable VERA PSG voice 3 (sawtooth, full vol, freq1)
001A37  1               ;   Called once when UFO spawns.
001A37  1               ;******************************************************************
001A37  1               snd_start_ufo_drone:
001A37  1  9C 25 9F        stz VERA_ctrl
001A3A  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
001A3E  1  9F A9 F9 8D  
001A42  1  21 9F A9 CC  
001A49  1  A9 32           lda #<UFO_DRONE_FREQ1
001A4B  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L
001A4E  1  A9 04           lda #>UFO_DRONE_FREQ1
001A50  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
001A53  1  A9 FF           lda #PSG_VOL_FULL
001A55  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001A58  1  A9 40           lda #PSG_WAVE_SAW
001A5A  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
001A5D  1  60              rts
001A5E  1               
001A5E  1               ;******************************************************************
001A5E  1               ; snd_stop_ufo_drone — silence VERA PSG voice 3
001A5E  1               ;   Called when UFO leaves screen or is destroyed.
001A5E  1               ;******************************************************************
001A5E  1               snd_stop_ufo_drone:
001A5E  1  9C 25 9F        stz VERA_ctrl
001A61  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE3 + 2), 1   ; byte 2 = volume/enable
001A65  1  9F A9 F9 8D  
001A69  1  21 9F A9 CE  
001A70  1  A9 00           lda #$00
001A72  1  8D 23 9F        sta VERA_data0               ; zero volume → silent
001A75  1  60              rts
001A76  1               
001A76  1               ;******************************************************************
001A76  1               ; snd_update_ufo_drone — warble between freq1/freq2 using frame_count
001A76  1               ;   bit 3 (flips every 8 frames ≈ 3.75 Hz wobble rate).
001A76  1               ;   Call every frame while UFO is active.
001A76  1               ;   Rewrites all 4 voice bytes (keeps volume/waveform stable).
001A76  1               ;******************************************************************
001A76  1               snd_update_ufo_drone:
001A76  1  9C 25 9F        stz VERA_ctrl
001A79  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
001A7D  1  9F A9 F9 8D  
001A81  1  21 9F A9 CC  
001A88  1  A5 rr           lda frame_count
001A8A  1  29 08           and #$08                     ; bit 3: 0 for 8 frames, 1 for 8 frames
001A8C  1  D0 09           bne @freq2
001A8E  1  A9 32           lda #<UFO_DRONE_FREQ1
001A90  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L (freq1)
001A93  1  A9 04           lda #>UFO_DRONE_FREQ1
001A95  1  80 07           bra @rest
001A97  1               @freq2:
001A97  1  A9 4B           lda #<UFO_DRONE_FREQ2
001A99  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L (freq2)
001A9C  1  A9 06           lda #>UFO_DRONE_FREQ2
001A9E  1               @rest:
001A9E  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
001AA1  1  A9 FF           lda #PSG_VOL_FULL
001AA3  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001AA6  1  A9 40           lda #PSG_WAVE_SAW
001AA8  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
001AAB  1  60              rts
001AAC  1               
001AAC  1               ;******************************************************************
001AAC  1               ; update_hud — rewrite dynamic HUD values each frame
001AAC  1               ;   Row  1, col  0: 6-digit BCD score
001AAC  1               ;   Row  1, col 16: 6-digit BCD hi-score
001AAC  1               ;   Row 29, col  1: LIVES: N
001AAC  1               ;   Row 29, col 20: WAVE: N
001AAC  1               ;   Overwrites fixed positions; no full redraw needed.
001AAC  1               ;   Note: KERNAL PLOT convention for X16: A = row, Y = col, CLC.
001AAC  1               ;******************************************************************
001AAC  1               update_hud:
001AAC  1                  ; --- score: row 1, col 0 ---
001AAC  1  A9 01           lda #1
001AAE  1  A0 00           ldy #0
001AB0  1  18              clc
001AB1  1  20 F0 FF        jsr PLOT
001AB4  1  A5 rr           lda score_hi
001AB6  1  20 19 1B        jsr print_hex_byte
001AB9  1  A5 rr           lda score_mid
001ABB  1  20 19 1B        jsr print_hex_byte
001ABE  1  A5 rr           lda score_lo
001AC0  1  20 19 1B        jsr print_hex_byte
001AC3  1               
001AC3  1                  ; --- hi-score: row 1, col 16 ---
001AC3  1  A9 01           lda #1
001AC5  1  A0 10           ldy #16
001AC7  1  18              clc
001AC8  1  20 F0 FF        jsr PLOT
001ACB  1  A5 rr           lda hi_score_hi
001ACD  1  20 19 1B        jsr print_hex_byte
001AD0  1  A5 rr           lda hi_score_mid
001AD2  1  20 19 1B        jsr print_hex_byte
001AD5  1  A5 rr           lda hi_score_lo
001AD7  1  20 19 1B        jsr print_hex_byte
001ADA  1               
001ADA  1                  ; --- lives count: row 29, col 1 ---
001ADA  1  A9 1D           lda #29
001ADC  1  A0 01           ldy #1
001ADE  1  18              clc
001ADF  1  20 F0 FF        jsr PLOT
001AE2  1  A2 00           ldx #0
001AE4  1  BD FF 1B     @lv_lbl: lda str_lives_lbl,x
001AE7  1  F0 06           beq @lv_val
001AE9  1  20 D2 FF        jsr CHROUT
001AEC  1  E8              inx
001AED  1  80 F5           bra @lv_lbl
001AEF  1               @lv_val:
001AEF  1  A5 rr           lda lives
001AF1  1  20 B9 13        jsr print_dec_byte
001AF4  1  A9 20           lda #' '
001AF6  1  20 D2 FF        jsr CHROUT                    ; erase any stale digit
001AF9  1               
001AF9  1                  ; --- wave number: row 29, col 20 ---
001AF9  1  A9 1D           lda #29
001AFB  1  A0 14           ldy #20
001AFD  1  18              clc
001AFE  1  20 F0 FF        jsr PLOT
001B01  1  A2 00           ldx #0
001B03  1  BD CF 1B     @wv_lbl: lda str_wave_lbl,x
001B06  1  F0 06           beq @wv_val
001B08  1  20 D2 FF        jsr CHROUT
001B0B  1  E8              inx
001B0C  1  80 F5           bra @wv_lbl
001B0E  1               @wv_val:
001B0E  1  A5 rr           lda wave
001B10  1  20 B9 13        jsr print_dec_byte
001B13  1  A9 20           lda #' '
001B15  1  20 D2 FF        jsr CHROUT                    ; erase any stale digit
001B18  1               
001B18  1  60              rts
001B19  1               
001B19  1               ;******************************************************************
001B19  1               ; print_hex_byte — print .A as two uppercase hex digits via CHROUT
001B19  1               ;******************************************************************
001B19  1               print_hex_byte:
001B19  1  48              pha
001B1A  1  4A              lsr                           ; shift high nibble down
001B1B  1  4A              lsr
001B1C  1  4A              lsr
001B1D  1  4A              lsr
001B1E  1  20 28 1B        jsr print_hex_nybble
001B21  1  68              pla
001B22  1  29 0F           and #$0F                      ; isolate low nibble
001B24  1  20 28 1B        jsr print_hex_nybble
001B27  1  60              rts
001B28  1               
001B28  1               ; print_hex_nybble — print lower 4 bits of .A as one hex digit
001B28  1               ;   Relies on carry state from CMP to select digit vs. letter range
001B28  1               print_hex_nybble:
001B28  1  C9 0A           cmp #10
001B2A  1  90 06           bcc @digit                    ; carry clear → 0-9
001B2C  1  69 36           adc #($41 - 10 - 1)          ; A-F: 'A'=65; carry set adds 1
001B2E  1  20 D2 FF        jsr CHROUT
001B31  1  60              rts
001B32  1               @digit:
001B32  1  69 30           adc #$30                      ; 0-9: '0'=48; carry clear adds 0
001B34  1  20 D2 FF        jsr CHROUT
001B37  1  60              rts
001B38  1               
