001354  1               
001354  1               ;------------------------------------------------------------------
001354  1               ; wave_clear_loop — wait for SPACE or timer expiry
001354  1               ;------------------------------------------------------------------
001354  1               wave_clear_loop:
001354  1  20 35 09        jsr wait_vsync
001357  1  20 37 09        jsr update_input
00135A  1               
00135A  1  A5 rr           lda key_last
00135C  1  C9 03           cmp #KEY_RUN_STOP
00135E  1  F0 0D           beq @wc_quit
001360  1               
001360  1  A5 rr           lda key_flags
001362  1  29 04           and #KEY_FIRE
001364  1  D0 04           bne @wc_advance
001366  1               
001366  1  C6 rr           dec zp_scratch_lo
001368  1  D0 EA           bne wave_clear_loop       ; timer not yet zero
00136A  1                  ; fall through when timer expires
00136A  1               
00136A  1               @wc_advance:
00136A  1  4C 75 13        jmp next_wave
00136D  1               
00136D  1               @wc_quit:
