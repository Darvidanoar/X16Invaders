001753  1  8D 23 9F        sta VERA_data0
001756  1  BD C1 1C        lda shield_x_lo, x     ; byte 2: X lo
001759  1  8D 23 9F        sta VERA_data0
00175C  1  BD C5 1C        lda shield_x_hi, x     ; byte 3: X hi
00175F  1  8D 23 9F        sta VERA_data0
