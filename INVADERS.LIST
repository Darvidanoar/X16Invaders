00169D  1  A2 80           ldx #128
00169F  1  BD EC 25     @up_s1c: lda shield_tile_dmg1 + 128, x
0016A2  1  8D 23 9F        sta VERA_data0
0016A5  1  E8              inx
0016A6  1  D0 F7           bne @up_s1c
0016A8  1  A2 80           ldx #128
0016AA  1  BD 6C 26     @up_s1d: lda shield_tile_dmg1 + 256, x
0016AD  1  8D 23 9F        sta VERA_data0
0016B0  1  E8              inx
0016B1  1  D0 F7           bne @up_s1d
