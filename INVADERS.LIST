00195D  1  B5 rr           lda ibul_x_lo, x
00195F  1  18              clc
001960  1  69 08           adc #8
001962  1  85 rr           sta zp_scratch_lo
001964  1  B5 rr           lda ibul_x_hi, x
001966  1  69 00           adc #0
001968  1  85 rr           sta zp_scratch_hi
00196A  1  A5 rr           lda zp_scratch_lo
00196C  1  38              sec
00196D  1  F9 42 1F        sbc shield_x_lo, y
001970  1  A5 rr           lda zp_scratch_hi
001972  1  F9 46 1F        sbc shield_x_hi, y
001975  1  30 2C           bmi @next_sld_y
001977  1               
001977  1                  ; X check (2): ibul_x < shield_x[y]+32
001977  1  B9 42 1F        lda shield_x_lo, y
00197A  1  18              clc
00197B  1  69 20           adc #32
00197D  1  85 rr           sta zp_scratch_lo
00197F  1  B9 46 1F        lda shield_x_hi, y
001982  1  69 00           adc #0
001984  1  85 rr           sta zp_scratch_hi
001986  1  A6 rr           ldx zp_row
001988  1  B5 rr           lda ibul_x_lo, x
00198A  1  38              sec
00198B  1  E5 rr           sbc zp_scratch_lo
00198D  1  B5 rr           lda ibul_x_hi, x
00198F  1  E5 rr           sbc zp_scratch_hi
001991  1  10 10           bpl @next_sld_y
001993  1               
001993  1                  ; --- HIT ---
001993  1  98              tya                    ; shield index → A → X for damage_shield
001994  1  AA              tax
001995  1  20 A1 18        jsr damage_shield
001998  1  A6 rr           ldx zp_row             ; restore bullet slot
00199A  1  74 rr           stz ibul_active, x
00199C  1  20 5A 10        jsr update_inv_bullet_sprite
00199F  1  A6 rr           ldx zp_row
0019A1  1  80 05           bra @next_ibul         ; done with this bullet
0019A3  1               
