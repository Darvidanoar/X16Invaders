00177C  1               ;******************************************************************
00177C  1               ; update_shield_sprite — write new data-addr byte to shield sprite N
00177C  1               ;   Input:  X = shield index (0–3)
00177C  1               ;           shield_damage[X] = current damage level (1–7)
00177C  1               ;   Writes sprite byte 0 (addr[12:5]) using shield_addr_b0 lookup.
00177C  1               ;   VERA addr for byte 0 of sprite N: $1FE10 + N*8
00177C  1               ;******************************************************************
00177C  1               update_shield_sprite:
00177C  1  9C 25 9F        stz VERA_ctrl
00177F  1  A9 11           lda #$11               ; stride=1, bank=1
001781  1  8D 22 9F        sta VERA_addr_bank
001784  1  A9 FE           lda #$FE
001786  1  8D 21 9F        sta VERA_addr_high
001789  1  8A              txa                    ; A = shield index
00178A  1  0A              asl                    ; ×2
00178B  1  0A              asl                    ; ×4
00178C  1  0A              asl                    ; ×8
00178D  1  18              clc
00178E  1  69 10           adc #$10               ; + low byte of $1FE10
001790  1  8D 20 9F        sta VERA_addr_low
001793  1  B4 rr           ldy shield_damage, x   ; Y = damage level (1-3)
001795  1  B9 C9 1C        lda shield_addr_b0, y  ; addr[12:5] for this tile
001798  1  8D 23 9F        sta VERA_data0
00179B  1  60              rts
00179C  1               
00179C  1               ;******************************************************************
00179C  1               ; hide_shield_sprite — disable sprite for shield N (z-depth=0)
00179C  1               ;   Input: X = shield index (0–3)
00179C  1               ;   Writes sprite byte 6 at $1FE10 + N*8 + 6 = $1FE16 + N*8
00179C  1               ;******************************************************************
00179C  1               hide_shield_sprite:
00179C  1  9C 25 9F        stz VERA_ctrl
00179F  1  A9 11           lda #$11
0017A1  1  8D 22 9F        sta VERA_addr_bank
0017A4  1  A9 FE           lda #$FE
0017A6  1  8D 21 9F        sta VERA_addr_high
0017A9  1  8A              txa
0017AA  1  0A              asl
0017AB  1  0A              asl
0017AC  1  0A              asl
0017AD  1  18              clc
0017AE  1  69 16           adc #$16               ; low($1FE10) + 6 = $16, + N*8
0017B0  1  8D 20 9F        sta VERA_addr_low
0017B3  1  A9 00           lda #0                 ; z-depth=0 → sprite disabled
0017B5  1  8D 23 9F        sta VERA_data0
0017B8  1  60              rts
0017B9  1               
0017B9  1               ;******************************************************************
0017B9  1               ; damage_shield — increment damage counter for shield X and update
0017B9  1               ;   sprite (or disable it when counter reaches 8 = destroyed).
0017B9  1               ;   Input:  X = shield index (0–3)
0017B9  1               ;   Clobbers: A, Y, VERA registers.  Preserves X.
0017B9  1               ;******************************************************************
0017B9  1               damage_shield:
0017B9  1  F6 rr           inc shield_damage, x
0017BB  1  B5 rr           lda shield_damage, x
0017BD  1  C9 08           cmp #8
0017BF  1  F0 06           beq @destroy
0017C1  1  B0 07           bcs @done              ; already at 8 (safety guard)
0017C3  1  20 7C 17        jsr update_shield_sprite
0017C6  1  60              rts
0017C7  1               @destroy:
0017C7  1  20 9C 17        jsr hide_shield_sprite
0017CA  1               @done:
0017CA  1  60              rts
0017CB  1               
0017CB  1               ;******************************************************************
0017CB  1               ; check_bullet_shields — test active player bullet vs all 4 shields
0017CB  1               ;
0017CB  1               ;   Overlap condition (AABB, all values VERA 16-bit):
0017CB  1               ;     X: bullet_x+8 > shield_x  AND  bullet_x < shield_x+16
0017CB  1               ;     Y: bullet_y+8 > SHIELD_Y  AND  bullet_y < SHIELD_Y+16
0017CB  1               ;
0017CB  1               ;   On hit: calls damage_shield, deactivates bullet, returns.
0017CB  1               ;   Scratch used: zp_scratch_lo/hi.  Preserves nothing.
0017CB  1               ;******************************************************************
0017CB  1               check_bullet_shields:
0017CB  1  A5 rr           lda bullet_active
0017CD  1  F0 6D           beq @done
0017CF  1               
0017CF  1                  ; --- Y quick check (same band for all shields) ---
0017CF  1                  ; (1) bullet_y+8 > SHIELD_Y
0017CF  1  A5 rr           lda bullet_y_lo
0017D1  1  18              clc
0017D2  1  69 08           adc #8
0017D4  1  85 rr           sta zp_scratch_lo
0017D6  1  A5 rr           lda bullet_y_hi
0017D8  1  69 00           adc #0
0017DA  1  85 rr           sta zp_scratch_hi
0017DC  1  A5 rr           lda zp_scratch_lo
0017DE  1  38              sec
0017DF  1  E9 60           sbc #<SHIELD_Y
0017E1  1  A5 rr           lda zp_scratch_hi
0017E3  1  E9 01           sbc #>SHIELD_Y
0017E5  1  30 55           bmi @done              ; bullet bottom above shield top
0017E7  1               
0017E7  1                  ; (2) bullet_y < SHIELD_Y+32
0017E7  1  A5 rr           lda bullet_y_lo
0017E9  1  38              sec
0017EA  1  E9 80           sbc #<(SHIELD_Y + 32)
0017EC  1  A5 rr           lda bullet_y_hi
0017EE  1  E9 01           sbc #>(SHIELD_Y + 32)
0017F0  1  10 4A           bpl @done              ; bullet top at or below shield bottom
0017F2  1               
0017F2  1                  ; --- Y overlaps: scan each shield ---
0017F2  1  A2 00           ldx #0
0017F4  1               @sld_loop:
0017F4  1  B5 rr           lda shield_damage, x
0017F6  1  C9 08           cmp #8
0017F8  1  B0 3D           bcs @next_sld          ; destroyed, skip
0017FA  1               
0017FA  1                  ; X check (1): bullet_x+8 > shield_x[x]
0017FA  1  A5 rr           lda bullet_x_lo
0017FC  1  18              clc
0017FD  1  69 08           adc #8
0017FF  1  85 rr           sta zp_scratch_lo
001801  1  A5 rr           lda bullet_x_hi
001803  1  69 00           adc #0
001805  1  85 rr           sta zp_scratch_hi
001807  1  A5 rr           lda zp_scratch_lo
001809  1  38              sec
00180A  1  FD C1 1C        sbc shield_x_lo, x
00180D  1  A5 rr           lda zp_scratch_hi
00180F  1  FD C5 1C        sbc shield_x_hi, x
001812  1  30 23           bmi @next_sld
001814  1               
001814  1                  ; X check (2): bullet_x < shield_x[x]+32
001814  1  BD C1 1C        lda shield_x_lo, x
001817  1  18              clc
001818  1  69 20           adc #32
00181A  1  85 rr           sta zp_scratch_lo
00181C  1  BD C5 1C        lda shield_x_hi, x
00181F  1  69 00           adc #0
001821  1  85 rr           sta zp_scratch_hi
001823  1  A5 rr           lda bullet_x_lo
001825  1  38              sec
001826  1  E5 rr           sbc zp_scratch_lo
001828  1  A5 rr           lda bullet_x_hi
00182A  1  E5 rr           sbc zp_scratch_hi
00182C  1  10 09           bpl @next_sld
00182E  1               
00182E  1                  ; --- HIT ---
00182E  1  20 B9 17        jsr damage_shield      ; X = shield index
001831  1  64 rr           stz bullet_active
001833  1  20 3A 0E        jsr update_bullet_sprite
001836  1  60              rts
001837  1               
001837  1               @next_sld:
001837  1  E8              inx
001838  1  E0 04           cpx #4
00183A  1  D0 B8           bne @sld_loop
00183C  1               @done:
00183C  1  60              rts
00183D  1               
00183D  1               ;******************************************************************
00183D  1               ; check_invbullet_shields — test each active invader bullet vs all
00183D  1               ;   4 shields.  Same AABB logic as check_bullet_shields but loops
00183D  1               ;   over 3 bullet slots (ibul_active / ibul_x / ibul_y arrays).
00183D  1               ;
00183D  1               ;   Scratch: zp_scratch_lo/hi, zp_row (bullet slot index),
00183D  1               ;            zp_col (shield index during inner scan).
00183D  1               ;******************************************************************
00183D  1               check_invbullet_shields:
00183D  1  A2 00           ldx #0                 ; outer loop: invader bullet slot
00183F  1               @ibul_loop:
00183F  1  86 rr           stx zp_row             ; save slot before any branch
001841  1  B5 rr           lda ibul_active, x
001843  1  F0 7B           beq @next_ibul
001845  1               
001845  1                  ; --- Y quick check ---
001845  1                  ; (1) ibul_y+8 > SHIELD_Y
001845  1  B5 rr           lda ibul_y_lo, x
001847  1  18              clc
001848  1  69 08           adc #8
00184A  1  85 rr           sta zp_scratch_lo
00184C  1  B5 rr           lda ibul_y_hi, x
00184E  1  69 00           adc #0
001850  1  85 rr           sta zp_scratch_hi
001852  1  A5 rr           lda zp_scratch_lo
001854  1  38              sec
001855  1  E9 60           sbc #<SHIELD_Y
001857  1  A5 rr           lda zp_scratch_hi
001859  1  E9 01           sbc #>SHIELD_Y
00185B  1  30 63           bmi @next_ibul
00185D  1               
00185D  1                  ; (2) ibul_y < SHIELD_Y+32
00185D  1  A6 rr           ldx zp_row
00185F  1  B5 rr           lda ibul_y_lo, x
001861  1  38              sec
001862  1  E9 80           sbc #<(SHIELD_Y + 32)
001864  1  B5 rr           lda ibul_y_hi, x
001866  1  E9 01           sbc #>(SHIELD_Y + 32)
001868  1  10 56           bpl @next_ibul
00186A  1               
00186A  1                  ; --- Y overlaps: scan shields with Y register ---
00186A  1  A0 00           ldy #0
00186C  1               @sld_scan:
00186C  1  B9 rr rr        lda shield_damage, y
00186F  1  C9 08           cmp #8
001871  1  B0 48           bcs @next_sld_y        ; destroyed
001873  1               
001873  1                  ; X check (1): ibul_x+8 > shield_x[y]
001873  1  A6 rr           ldx zp_row
001875  1  B5 rr           lda ibul_x_lo, x
001877  1  18              clc
001878  1  69 08           adc #8
00187A  1  85 rr           sta zp_scratch_lo
00187C  1  B5 rr           lda ibul_x_hi, x
00187E  1  69 00           adc #0
001880  1  85 rr           sta zp_scratch_hi
001882  1  A5 rr           lda zp_scratch_lo
001884  1  38              sec
001885  1  F9 C1 1C        sbc shield_x_lo, y
001888  1  A5 rr           lda zp_scratch_hi
00188A  1  F9 C5 1C        sbc shield_x_hi, y
00188D  1  30 2C           bmi @next_sld_y
00188F  1               
00188F  1                  ; X check (2): ibul_x < shield_x[y]+32
00188F  1  B9 C1 1C        lda shield_x_lo, y
001892  1  18              clc
001893  1  69 20           adc #32
001895  1  85 rr           sta zp_scratch_lo
001897  1  B9 C5 1C        lda shield_x_hi, y
00189A  1  69 00           adc #0
00189C  1  85 rr           sta zp_scratch_hi
00189E  1  A6 rr           ldx zp_row
0018A0  1  B5 rr           lda ibul_x_lo, x
0018A2  1  38              sec
0018A3  1  E5 rr           sbc zp_scratch_lo
0018A5  1  B5 rr           lda ibul_x_hi, x
0018A7  1  E5 rr           sbc zp_scratch_hi
0018A9  1  10 10           bpl @next_sld_y
0018AB  1               
0018AB  1                  ; --- HIT ---
0018AB  1  98              tya                    ; shield index → A → X for damage_shield
0018AC  1  AA              tax
0018AD  1  20 B9 17        jsr damage_shield
0018B0  1  A6 rr           ldx zp_row             ; restore bullet slot
0018B2  1  74 rr           stz ibul_active, x
0018B4  1  20 2B 10        jsr update_inv_bullet_sprite
0018B7  1  A6 rr           ldx zp_row
0018B9  1  80 05           bra @next_ibul         ; done with this bullet
0018BB  1               
0018BB  1               @next_sld_y:
0018BB  1  C8              iny
0018BC  1  C0 04           cpy #4
0018BE  1  D0 AC           bne @sld_scan
0018C0  1               
0018C0  1               @next_ibul:
0018C0  1  A6 rr           ldx zp_row
0018C2  1  E8              inx
0018C3  1  E0 03           cpx #3
0018C5  1  F0 03           beq @cis_done
0018C7  1  4C 3F 18        jmp @ibul_loop
0018CA  1               @cis_done:
0018CA  1  60              rts
0018CB  1               
0018CB  1               ;******************************************************************
0018CB  1               ; add_score_bcd — add a 2-byte BCD pair to the score
0018CB  1               ;   A = BCD low byte (units/tens), Y = BCD mid byte (hundreds/thousands)
0018CB  1               ;******************************************************************
0018CB  1               add_score_bcd:
0018CB  1  F8              sed
0018CC  1  18              clc
0018CD  1  65 rr           adc score_lo
0018CF  1  85 rr           sta score_lo
0018D1  1  98              tya
0018D2  1  65 rr           adc score_mid
0018D4  1  85 rr           sta score_mid
0018D6  1  A5 rr           lda score_hi
0018D8  1  69 00           adc #0
0018DA  1  85 rr           sta score_hi
0018DC  1  D8              cld
0018DD  1  60              rts
0018DE  1               
0018DE  1               ;******************************************************************
0018DE  1               ; update_ufo — per-frame UFO logic: spawn timer + movement
0018DE  1               ;
0018DE  1               ;   Inactive: 16-bit ufo_timer counts down each frame.
0018DE  1               ;   On zero: UFO spawns at left edge (X=0), timer reset to
0018DE  1               ;             UFO_TIMER_INIT + (prng() & $7F) for next cycle.
0018DE  1               ;   Active: move right UFO_SPEED VERA pixels/frame.
0018DE  1               ;           Deactivate when X >= 640 (off right edge).
0018DE  1               ;   Updates VERA sprite 3 after any state change.
0018DE  1               ;******************************************************************
0018DE  1               update_ufo:
0018DE  1  A5 rr           lda ufo_active
0018E0  1  D0 36           bne @move_ufo
0018E2  1               
0018E2  1                  ; --- timer countdown (16-bit decrement) ---
0018E2  1  A5 rr           lda ufo_timer_lo
0018E4  1  D0 0B           bne @dec_lo
0018E6  1  A5 rr           lda ufo_timer_hi
0018E8  1  F0 0F           beq @spawn                   ; both zero → spawn (guard against stuck state)
0018EA  1  C6 rr           dec ufo_timer_hi
0018EC  1  A9 FF           lda #$FF
0018EE  1  85 rr           sta ufo_timer_lo
0018F0  1  60              rts
0018F1  1               @dec_lo:
0018F1  1  C6 rr           dec ufo_timer_lo
0018F3  1  A5 rr           lda ufo_timer_lo
0018F5  1  05 rr           ora ufo_timer_hi
0018F7  1  D0 47           bne @ufo_done                ; timer not yet zero
0018F9  1               
0018F9  1               @spawn:
0018F9  1  A9 01           lda #1
0018FB  1  85 rr           sta ufo_active
0018FD  1  64 rr           stz ufo_x_lo
0018FF  1  64 rr           stz ufo_x_hi
001901  1                  ; next timer = UFO_TIMER_INIT + (prng() & $7F) so interval varies by 0-127 frames
001901  1  20 E1 0F        jsr prng
001904  1  29 7F           and #$7F
001906  1  18              clc
001907  1  69 58           adc #<UFO_TIMER_INIT
001909  1  85 rr           sta ufo_timer_lo
00190B  1  A9 02           lda #>UFO_TIMER_INIT
00190D  1  69 00           adc #0
00190F  1  85 rr           sta ufo_timer_hi
001911  1  20 41 19        jsr update_ufo_sprite
001914  1  20 03 1A        jsr snd_start_ufo_drone
001917  1  60              rts
001918  1               
001918  1                  ; --- move UFO right ---
001918  1               @move_ufo:
001918  1  A5 rr           lda ufo_x_lo
00191A  1  18              clc
00191B  1  69 02           adc #UFO_SPEED
00191D  1  85 rr           sta ufo_x_lo
00191F  1  A5 rr           lda ufo_x_hi
001921  1  69 00           adc #0
001923  1  85 rr           sta ufo_x_hi
001925  1                  ; deactivate if X high byte >= 3 (≥ 768, safely off the 640-wide screen)
001925  1                  ; simpler guard: X hi > 0 means X >= 256; combined with lo check
001925  1  C9 02           cmp #>640                    ; A = new hi; >640 = 2
001927  1  90 11           bcc @ufo_on_screen           ; hi < 2 → still visible
001929  1  D0 06           bne @ufo_off_screen          ; hi > 2 → gone
00192B  1  A5 rr           lda ufo_x_lo
00192D  1  C9 80           cmp #<640
00192F  1  90 09           bcc @ufo_on_screen           ; hi=2, lo < 128 → past edge but close; still off
001931  1               @ufo_off_screen:
001931  1  64 rr           stz ufo_active
001933  1  20 41 19        jsr update_ufo_sprite
001936  1  20 2A 1A        jsr snd_stop_ufo_drone
001939  1  60              rts
00193A  1               @ufo_on_screen:
00193A  1  20 41 19        jsr update_ufo_sprite
00193D  1  20 42 1A        jsr snd_update_ufo_drone
001940  1               @ufo_done:
001940  1  60              rts
001941  1               
001941  1               ;******************************************************************
001941  1               ; update_ufo_sprite — write sprite 3 (UFO) position + enable/disable
001941  1               ;   addr[12:5] = VRAM_UFO>>5 = $01500>>5 = $A8
001941  1               ;   Writes bytes 2-6; bytes 0-1 and 7 set once at init.
001941  1               ;******************************************************************
001941  1               update_ufo_sprite:
001941  1  9C 25 9F        stz VERA_ctrl
001944  1  A9 11 8D 22     VERA_SET_ADDR (UFO_SPRITE_ATTR + 2), 1
001948  1  9F A9 FC 8D  
00194C  1  21 9F A9 1A  
001953  1  A5 rr           lda ufo_x_lo
001955  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
001958  1  A5 rr           lda ufo_x_hi
00195A  1  29 03           and #$03
00195C  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
00195F  1  A9 20           lda #<UFO_Y
001961  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
001964  1  A9 00           lda #>UFO_Y
001966  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
001969  1  A5 rr           lda ufo_active
00196B  1  F0 04           beq @z_off
00196D  1  A9 0C           lda #SPR_Z_FRONT
00196F  1  80 02           bra @write_z
001971  1               @z_off:
001971  1  A9 00           lda #0
001973  1               @write_z:
001973  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
001976  1  60              rts
001977  1               
001977  1               ;******************************************************************
001977  1               ; check_bullet_ufo — AABB test: player bullet vs. UFO sprite (16x16)
001977  1               ;   Bullet rect: (bullet_x, bullet_y)+(7,7);  UFO rect: (ufo_x, UFO_Y)+(15,15)
001977  1               ;   On hit: bullet deactivated, UFO killed, score added, explosion started.
001977  1               ;   Scratch: zp_scratch_lo/hi, zp_x_lo/hi, zp_row_y_lo/hi
001977  1               ;******************************************************************
001977  1               check_bullet_ufo:
001977  1  A5 rr           lda bullet_active
001979  1  D0 01           bne :+
00197B  1  60              rts
00197C  1  A5 rr        :  lda ufo_active
00197E  1  D0 01           bne :+
001980  1  60              rts
001981  1               :
001981  1               
001981  1                  ; --- Y check 1: bullet_y+8 > UFO_Y ---
001981  1  A5 rr           lda bullet_y_lo
001983  1  18              clc
001984  1  69 08           adc #8
001986  1  85 rr           sta zp_scratch_lo
001988  1  A5 rr           lda bullet_y_hi
00198A  1  69 00           adc #0
00198C  1  85 rr           sta zp_scratch_hi
00198E  1  A5 rr           lda zp_scratch_lo
001990  1  38              sec
001991  1  E9 20           sbc #<UFO_Y
001993  1  A5 rr           lda zp_scratch_hi
001995  1  E9 00           sbc #>UFO_Y
001997  1  30 69           bmi @done                    ; bullet bottom above UFO top → no hit
001999  1               
001999  1                  ; --- Y check 2: bullet_y < UFO_Y+16 ---
001999  1  A5 rr           lda bullet_y_lo
00199B  1  38              sec
00199C  1  E9 30           sbc #<(UFO_Y + 16)
00199E  1  A5 rr           lda bullet_y_hi
0019A0  1  E9 00           sbc #>(UFO_Y + 16)
0019A2  1  10 5E           bpl @done                    ; bullet top at or below UFO bottom → no hit
0019A4  1               
0019A4  1                  ; --- X check 1: bullet_x+8 > ufo_x ---
0019A4  1  A5 rr           lda bullet_x_lo
0019A6  1  18              clc
0019A7  1  69 08           adc #8
0019A9  1  85 rr           sta zp_scratch_lo
0019AB  1  A5 rr           lda bullet_x_hi
0019AD  1  69 00           adc #0
0019AF  1  85 rr           sta zp_scratch_hi
0019B1  1  A5 rr           lda zp_scratch_lo
0019B3  1  38              sec
0019B4  1  E5 rr           sbc ufo_x_lo
0019B6  1  A5 rr           lda zp_scratch_hi
0019B8  1  E5 rr           sbc ufo_x_hi
0019BA  1  30 46           bmi @done                    ; bullet right edge left of UFO left edge → no hit
0019BC  1               
0019BC  1                  ; --- X check 2: bullet_x < ufo_x+16 ---
0019BC  1  A5 rr           lda ufo_x_lo
0019BE  1  18              clc
0019BF  1  69 10           adc #16
0019C1  1  85 rr           sta zp_scratch_lo
0019C3  1  A5 rr           lda ufo_x_hi
0019C5  1  69 00           adc #0
0019C7  1  85 rr           sta zp_scratch_hi
0019C9  1  A5 rr           lda bullet_x_lo
0019CB  1  38              sec
0019CC  1  E5 rr           sbc zp_scratch_lo
0019CE  1  A5 rr           lda bullet_x_hi
0019D0  1  E5 rr           sbc zp_scratch_hi
0019D2  1  10 2E           bpl @done                    ; bullet left edge at or right of UFO right edge → no hit
0019D4  1               
0019D4  1                  ; --- HIT ---
0019D4  1  A5 rr           lda ufo_x_lo
0019D6  1  85 rr           sta zp_x_lo
0019D8  1  A5 rr           lda ufo_x_hi
0019DA  1  85 rr           sta zp_x_hi
0019DC  1  A9 20           lda #<UFO_Y
0019DE  1  85 rr           sta zp_row_y_lo
0019E0  1  A9 00           lda #>UFO_Y
0019E2  1  85 rr           sta zp_row_y_hi
0019E4  1  20 8D 0F        jsr start_explosion
0019E7  1               
0019E7  1  64 rr           stz bullet_active
0019E9  1  20 3A 0E        jsr update_bullet_sprite
0019EC  1               
0019EC  1  64 rr           stz ufo_active
0019EE  1  20 41 19        jsr update_ufo_sprite
0019F1  1  20 2A 1A        jsr snd_stop_ufo_drone
0019F4  1               
0019F4  1                  ; score: ufo_score table indexed by shot_count & 7
0019F4  1  A5 rr           lda shot_count
0019F6  1  29 07           and #$07
0019F8  1  AA              tax
0019F9  1  BD B1 1C        lda ufo_score_lo, x
0019FC  1  BC B9 1C        ldy ufo_score_hi, x
0019FF  1  20 CB 18        jsr add_score_bcd
001A02  1               
001A02  1               @done:
001A02  1  60              rts
001A03  1               
001A03  1               ;******************************************************************
001A03  1               ; snd_start_ufo_drone — enable VERA PSG voice 3 (sawtooth, full vol, freq1)
001A03  1               ;   Called once when UFO spawns.
001A03  1               ;******************************************************************
001A03  1               snd_start_ufo_drone:
001A03  1  9C 25 9F        stz VERA_ctrl
001A06  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
001A0A  1  9F A9 F9 8D  
001A0E  1  21 9F A9 CC  
001A15  1  A9 32           lda #<UFO_DRONE_FREQ1
001A17  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L
001A1A  1  A9 04           lda #>UFO_DRONE_FREQ1
001A1C  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
001A1F  1  A9 FF           lda #PSG_VOL_FULL
001A21  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001A24  1  A9 40           lda #PSG_WAVE_SAW
001A26  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
001A29  1  60              rts
001A2A  1               
001A2A  1               ;******************************************************************
001A2A  1               ; snd_stop_ufo_drone — silence VERA PSG voice 3
001A2A  1               ;   Called when UFO leaves screen or is destroyed.
001A2A  1               ;******************************************************************
001A2A  1               snd_stop_ufo_drone:
001A2A  1  9C 25 9F        stz VERA_ctrl
001A2D  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE3 + 2), 1   ; byte 2 = volume/enable
001A31  1  9F A9 F9 8D  
001A35  1  21 9F A9 CE  
001A3C  1  A9 00           lda #$00
001A3E  1  8D 23 9F        sta VERA_data0               ; zero volume → silent
001A41  1  60              rts
001A42  1               
001A42  1               ;******************************************************************
001A42  1               ; snd_update_ufo_drone — warble between freq1/freq2 using frame_count
001A42  1               ;   bit 3 (flips every 8 frames ≈ 3.75 Hz wobble rate).
001A42  1               ;   Call every frame while UFO is active.
001A42  1               ;   Rewrites all 4 voice bytes (keeps volume/waveform stable).
001A42  1               ;******************************************************************
001A42  1               snd_update_ufo_drone:
001A42  1  9C 25 9F        stz VERA_ctrl
001A45  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
001A49  1  9F A9 F9 8D  
001A4D  1  21 9F A9 CC  
001A54  1  A5 rr           lda frame_count
001A56  1  29 08           and #$08                     ; bit 3: 0 for 8 frames, 1 for 8 frames
001A58  1  D0 09           bne @freq2
001A5A  1  A9 32           lda #<UFO_DRONE_FREQ1
001A5C  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L (freq1)
001A5F  1  A9 04           lda #>UFO_DRONE_FREQ1
001A61  1  80 07           bra @rest
001A63  1               @freq2:
001A63  1  A9 4B           lda #<UFO_DRONE_FREQ2
001A65  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L (freq2)
001A68  1  A9 06           lda #>UFO_DRONE_FREQ2
001A6A  1               @rest:
001A6A  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
001A6D  1  A9 FF           lda #PSG_VOL_FULL
001A6F  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001A72  1  A9 40           lda #PSG_WAVE_SAW
001A74  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
001A77  1  60              rts
001A78  1               
001A78  1               ;******************************************************************
001A78  1               ; update_hud — rewrite dynamic HUD values each frame
001A78  1               ;   Row 29, col  1: LIVES: N
001A78  1               ;   Row 29, col 20: WAVE: N
001A78  1               ;   Overwrites fixed positions; no full redraw needed.
001A78  1               ;******************************************************************
001A78  1               update_hud:
001A78  1                  ; --- lives count: row 29, col 1 ---
001A78  1  A9 1D           lda #29
001A7A  1  A0 01           ldy #1
001A7C  1  18              clc
001A7D  1  20 F0 FF        jsr PLOT
001A80  1  A2 00           ldx #0
001A82  1  BD 97 1B     @lv_lbl: lda str_lives_lbl,x
001A85  1  F0 06           beq @lv_val
001A87  1  20 D2 FF        jsr CHROUT
001A8A  1  E8              inx
001A8B  1  80 F5           bra @lv_lbl
001A8D  1               @lv_val:
001A8D  1  A5 rr           lda lives
001A8F  1  20 B0 13        jsr print_dec_byte
001A92  1  A9 20           lda #' '
001A94  1  20 D2 FF        jsr CHROUT                    ; erase any stale digit
001A97  1               
001A97  1                  ; --- wave number: row 29, col 20 ---
001A97  1  A9 1D           lda #29
001A99  1  A0 14           ldy #20
001A9B  1  18              clc
001A9C  1  20 F0 FF        jsr PLOT
001A9F  1  A2 00           ldx #0
001AA1  1  BD 67 1B     @wv_lbl: lda str_wave_lbl,x
001AA4  1  F0 06           beq @wv_val
001AA6  1  20 D2 FF        jsr CHROUT
001AA9  1  E8              inx
001AAA  1  80 F5           bra @wv_lbl
001AAC  1               @wv_val:
001AAC  1  A5 rr           lda wave
001AAE  1  20 B0 13        jsr print_dec_byte
001AB1  1  A9 20           lda #' '
001AB3  1  20 D2 FF        jsr CHROUT                    ; erase any stale digit
001AB6  1               
001AB6  1  60              rts
001AB7  1               
001AB7  1               ;******************************************************************
001AB7  1               ; print_hex_byte — print .A as two uppercase hex digits via CHROUT
001AB7  1               ;******************************************************************
001AB7  1               print_hex_byte:
001AB7  1  48              pha
001AB8  1  4A              lsr                           ; shift high nibble down
001AB9  1  4A              lsr
001ABA  1  4A              lsr
001ABB  1  4A              lsr
001ABC  1  20 C6 1A        jsr print_hex_nybble
001ABF  1  68              pla
001AC0  1  29 0F           and #$0F                      ; isolate low nibble
001AC2  1  20 C6 1A        jsr print_hex_nybble
001AC5  1  60              rts
001AC6  1               
001AC6  1               ; print_hex_nybble — print lower 4 bits of .A as one hex digit
001AC6  1               ;   Relies on carry state from CMP to select digit vs. letter range
001AC6  1               print_hex_nybble:
001AC6  1  C9 0A           cmp #10
001AC8  1  90 06           bcc @digit                    ; carry clear → 0-9
001ACA  1  69 36           adc #($41 - 10 - 1)          ; A-F: 'A'=65; carry set adds 1
001ACC  1  20 D2 FF        jsr CHROUT
001ACF  1  60              rts
001AD0  1               @digit:
001AD0  1  69 30           adc #$30                      ; 0-9: '0'=48; carry clear adds 0
001AD2  1  20 D2 FF        jsr CHROUT
001AD5  1  60              rts
001AD6  1               
