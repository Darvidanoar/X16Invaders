00160E  1               ;******************************************************************
00160E  1               ; update_hud — rewrite dynamic values each frame
00160E  1               ;   Overwrites fixed screen positions; no full redraw needed
00160E  1               ;******************************************************************
00160E  1               update_hud:
00160E  1                  ; Frame counter at row 19, col 2
00160E  1  A9 13           lda #19
001610  1  A0 02           ldy #2
001612  1  18              clc
001613  1  20 F0 FF        jsr PLOT
001616  1  A2 00           ldx #0
001618  1  BD CE 16     @fc_lbl: lda str_frame_lbl,x
00161B  1  F0 06           beq @fc_val
00161D  1  20 D2 FF        jsr CHROUT
001620  1  E8              inx
001621  1  80 F5           bra @fc_lbl
001623  1               @fc_val:
001623  1  A5 rr           lda frame_count
001625  1  20 48 16        jsr print_hex_byte
001628  1               
001628  1                  ; Last key at row 21, col 2
001628  1  A9 15           lda #21
00162A  1  A0 02           ldy #2
00162C  1  18              clc
00162D  1  20 F0 FF        jsr PLOT
001630  1  A2 00           ldx #0
001632  1  BD DA 16     @kl_lbl: lda str_key_lbl,x
001635  1  F0 06           beq @kl_val
001637  1  20 D2 FF        jsr CHROUT
00163A  1  E8              inx
00163B  1  80 F5           bra @kl_lbl
00163D  1               @kl_val:
00163D  1  A5 rr           lda key_last
00163F  1  20 48 16        jsr print_hex_byte
001642  1  A9 20           lda #' '
001644  1  20 D2 FF        jsr CHROUT                    ; erase stale digit if value shrank
001647  1               
001647  1  60              rts
001648  1               
001648  1               ;******************************************************************
001648  1               ; print_hex_byte — print .A as two uppercase hex digits via CHROUT
001648  1               ;******************************************************************
001648  1               print_hex_byte:
001648  1  48              pha
001649  1  4A              lsr                           ; shift high nibble down
00164A  1  4A              lsr
00164B  1  4A              lsr
00164C  1  4A              lsr
00164D  1  20 57 16        jsr print_hex_nybble
001650  1  68              pla
001651  1  29 0F           and #$0F                      ; isolate low nibble
001653  1  20 57 16        jsr print_hex_nybble
001656  1  60              rts
001657  1               
001657  1               ; print_hex_nybble — print lower 4 bits of .A as one hex digit
001657  1               ;   Relies on carry state from CMP to select digit vs. letter range
001657  1               print_hex_nybble:
001657  1  C9 0A           cmp #10
001659  1  90 06           bcc @digit                    ; carry clear → 0-9
00165B  1  69 36           adc #($41 - 10 - 1)          ; A-F: 'A'=65; carry set adds 1
00165D  1  20 D2 FF        jsr CHROUT
001660  1  60              rts
001661  1               @digit:
001661  1  69 30           adc #$30                      ; 0-9: '0'=48; carry clear adds 0
001663  1  20 D2 FF        jsr CHROUT
001666  1  60              rts
