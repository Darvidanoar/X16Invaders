0014F6  1  9C 25 9F        stz VERA_ctrl
0014F9  1                  ; --- sprite 11 (Type C, squid/cyan): attr $1FC00+11*8=$1FC58 ---
0014F9  1                  ; addr[12:5] = VRAM_INV_C_F0>>5 = $00300>>5 = $18
0014F9  1  A9 11           lda #$11               ; stride=1, bank=1
