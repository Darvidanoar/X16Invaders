0019B3  1               ;******************************************************************
0019B3  1               ; add_score_bcd — add a 2-byte BCD pair to the score
0019B3  1               ;   A = BCD low byte (units/tens), Y = BCD mid byte (hundreds/thousands)
0019B3  1               ;******************************************************************
0019B3  1               add_score_bcd:
0019B3  1  F8              sed
0019B4  1  18              clc
0019B5  1  65 rr           adc score_lo
0019B7  1  85 rr           sta score_lo
0019B9  1  98              tya
0019BA  1  65 rr           adc score_mid
0019BC  1  85 rr           sta score_mid
0019BE  1  A5 rr           lda score_hi
0019C0  1  69 00           adc #0
0019C2  1  85 rr           sta score_hi
0019C4  1  D8              cld
0019C5  1  60              rts
0019C6  1               
0019C6  1               ;******************************************************************
0019C6  1               ; update_ufo — per-frame UFO logic: spawn timer + movement
0019C6  1               ;
0019C6  1               ;   Inactive: 16-bit ufo_timer counts down each frame.
0019C6  1               ;   On zero: UFO spawns at left edge (X=0), timer reset to
0019C6  1               ;             UFO_TIMER_INIT + (prng() & $7F) for next cycle.
0019C6  1               ;   Active: move right UFO_SPEED VERA pixels/frame.
0019C6  1               ;           Deactivate when X >= 640 (off right edge).
0019C6  1               ;   Updates VERA sprite 3 after any state change.
0019C6  1               ;******************************************************************
0019C6  1               update_ufo:
0019C6  1  A5 rr           lda ufo_active
0019C8  1  D0 36           bne @move_ufo
0019CA  1               
0019CA  1                  ; --- timer countdown (16-bit decrement) ---
0019CA  1  A5 rr           lda ufo_timer_lo
0019CC  1  D0 0B           bne @dec_lo
0019CE  1  A5 rr           lda ufo_timer_hi
0019D0  1  F0 0F           beq @spawn                   ; both zero → spawn (guard against stuck state)
0019D2  1  C6 rr           dec ufo_timer_hi
0019D4  1  A9 FF           lda #$FF
0019D6  1  85 rr           sta ufo_timer_lo
0019D8  1  60              rts
0019D9  1               @dec_lo:
0019D9  1  C6 rr           dec ufo_timer_lo
0019DB  1  A5 rr           lda ufo_timer_lo
0019DD  1  05 rr           ora ufo_timer_hi
0019DF  1  D0 47           bne @ufo_done                ; timer not yet zero
0019E1  1               
0019E1  1               @spawn:
0019E1  1  A9 01           lda #1
0019E3  1  85 rr           sta ufo_active
0019E5  1  64 rr           stz ufo_x_lo
0019E7  1  64 rr           stz ufo_x_hi
0019E9  1                  ; next timer = UFO_TIMER_INIT + (prng() & $7F) so interval varies by 0-127 frames
0019E9  1  20 10 10        jsr prng
0019EC  1  29 7F           and #$7F
0019EE  1  18              clc
0019EF  1  69 58           adc #<UFO_TIMER_INIT
0019F1  1  85 rr           sta ufo_timer_lo
0019F3  1  A9 02           lda #>UFO_TIMER_INIT
0019F5  1  69 00           adc #0
0019F7  1  85 rr           sta ufo_timer_hi
0019F9  1  20 29 1A        jsr update_ufo_sprite
0019FC  1  20 EB 1A        jsr snd_start_ufo_drone
0019FF  1  60              rts
001A00  1               
001A00  1                  ; --- move UFO right ---
001A00  1               @move_ufo:
001A00  1  A5 rr           lda ufo_x_lo
001A02  1  18              clc
001A03  1  69 02           adc #UFO_SPEED
001A05  1  85 rr           sta ufo_x_lo
001A07  1  A5 rr           lda ufo_x_hi
001A09  1  69 00           adc #0
001A0B  1  85 rr           sta ufo_x_hi
001A0D  1                  ; deactivate if X high byte >= 3 (≥ 768, safely off the 640-wide screen)
001A0D  1                  ; simpler guard: X hi > 0 means X >= 256; combined with lo check
001A0D  1  C9 02           cmp #>640                    ; A = new hi; >640 = 2
001A0F  1  90 11           bcc @ufo_on_screen           ; hi < 2 → still visible
001A11  1  D0 06           bne @ufo_off_screen          ; hi > 2 → gone
001A13  1  A5 rr           lda ufo_x_lo
001A15  1  C9 80           cmp #<640
001A17  1  90 09           bcc @ufo_on_screen           ; hi=2, lo < 128 → past edge but close; still off
001A19  1               @ufo_off_screen:
001A19  1  64 rr           stz ufo_active
001A1B  1  20 29 1A        jsr update_ufo_sprite
001A1E  1  20 1E 1B        jsr snd_stop_ufo_drone
001A21  1  60              rts
001A22  1               @ufo_on_screen:
001A22  1  20 29 1A        jsr update_ufo_sprite
001A25  1  20 36 1B        jsr snd_update_ufo_drone
001A28  1               @ufo_done:
001A28  1  60              rts
001A29  1               
001A29  1               ;******************************************************************
001A29  1               ; update_ufo_sprite — write sprite 3 (UFO) position + enable/disable
001A29  1               ;   addr[12:5] = VRAM_UFO>>5 = $01500>>5 = $A8
001A29  1               ;   Writes bytes 2-6; bytes 0-1 and 7 set once at init.
001A29  1               ;******************************************************************
001A29  1               update_ufo_sprite:
001A29  1  9C 25 9F        stz VERA_ctrl
001A2C  1  A9 11 8D 22     VERA_SET_ADDR (UFO_SPRITE_ATTR + 2), 1
001A30  1  9F A9 FC 8D  
001A34  1  21 9F A9 1A  
001A3B  1  A5 rr           lda ufo_x_lo
001A3D  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
001A40  1  A5 rr           lda ufo_x_hi
001A42  1  29 03           and #$03
001A44  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
001A47  1  A9 20           lda #<UFO_Y
001A49  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
001A4C  1  A9 00           lda #>UFO_Y
001A4E  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
001A51  1  A5 rr           lda ufo_active
001A53  1  F0 04           beq @z_off
001A55  1  A9 0C           lda #SPR_Z_FRONT
001A57  1  80 02           bra @write_z
001A59  1               @z_off:
001A59  1  A9 00           lda #0
001A5B  1               @write_z:
001A5B  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
001A5E  1  60              rts
001A5F  1               
001A5F  1               ;******************************************************************
001A5F  1               ; check_bullet_ufo — AABB test: player bullet vs. UFO sprite (16x16)
001A5F  1               ;   Bullet rect: (bullet_x, bullet_y)+(7,7);  UFO rect: (ufo_x, UFO_Y)+(15,15)
001A5F  1               ;   On hit: bullet deactivated, UFO killed, score added, explosion started.
001A5F  1               ;   Scratch: zp_scratch_lo/hi, zp_x_lo/hi, zp_row_y_lo/hi
001A5F  1               ;******************************************************************
001A5F  1               check_bullet_ufo:
001A5F  1  A5 rr           lda bullet_active
001A61  1  D0 01           bne :+
001A63  1  60              rts
001A64  1  A5 rr        :  lda ufo_active
001A66  1  D0 01           bne :+
001A68  1  60              rts
001A69  1               :
001A69  1               
001A69  1                  ; --- Y check 1: bullet_y+8 > UFO_Y ---
001A69  1  A5 rr           lda bullet_y_lo
001A6B  1  18              clc
001A6C  1  69 08           adc #8
001A6E  1  85 rr           sta zp_scratch_lo
001A70  1  A5 rr           lda bullet_y_hi
001A72  1  69 00           adc #0
001A74  1  85 rr           sta zp_scratch_hi
001A76  1  A5 rr           lda zp_scratch_lo
001A78  1  38              sec
001A79  1  E9 20           sbc #<UFO_Y
001A7B  1  A5 rr           lda zp_scratch_hi
001A7D  1  E9 00           sbc #>UFO_Y
001A7F  1  30 69           bmi @done                    ; bullet bottom above UFO top → no hit
001A81  1               
001A81  1                  ; --- Y check 2: bullet_y < UFO_Y+16 ---
001A81  1  A5 rr           lda bullet_y_lo
001A83  1  38              sec
001A84  1  E9 30           sbc #<(UFO_Y + 16)
001A86  1  A5 rr           lda bullet_y_hi
001A88  1  E9 00           sbc #>(UFO_Y + 16)
001A8A  1  10 5E           bpl @done                    ; bullet top at or below UFO bottom → no hit
001A8C  1               
001A8C  1                  ; --- X check 1: bullet_x+8 > ufo_x ---
001A8C  1  A5 rr           lda bullet_x_lo
001A8E  1  18              clc
001A8F  1  69 08           adc #8
001A91  1  85 rr           sta zp_scratch_lo
001A93  1  A5 rr           lda bullet_x_hi
001A95  1  69 00           adc #0
001A97  1  85 rr           sta zp_scratch_hi
001A99  1  A5 rr           lda zp_scratch_lo
001A9B  1  38              sec
001A9C  1  E5 rr           sbc ufo_x_lo
001A9E  1  A5 rr           lda zp_scratch_hi
001AA0  1  E5 rr           sbc ufo_x_hi
001AA2  1  30 46           bmi @done                    ; bullet right edge left of UFO left edge → no hit
001AA4  1               
001AA4  1                  ; --- X check 2: bullet_x < ufo_x+16 ---
001AA4  1  A5 rr           lda ufo_x_lo
001AA6  1  18              clc
001AA7  1  69 10           adc #16
001AA9  1  85 rr           sta zp_scratch_lo
001AAB  1  A5 rr           lda ufo_x_hi
001AAD  1  69 00           adc #0
001AAF  1  85 rr           sta zp_scratch_hi
001AB1  1  A5 rr           lda bullet_x_lo
001AB3  1  38              sec
001AB4  1  E5 rr           sbc zp_scratch_lo
001AB6  1  A5 rr           lda bullet_x_hi
001AB8  1  E5 rr           sbc zp_scratch_hi
001ABA  1  10 2E           bpl @done                    ; bullet left edge at or right of UFO right edge → no hit
001ABC  1               
001ABC  1                  ; --- HIT ---
001ABC  1  A5 rr           lda ufo_x_lo
001ABE  1  85 rr           sta zp_x_lo
001AC0  1  A5 rr           lda ufo_x_hi
001AC2  1  85 rr           sta zp_x_hi
001AC4  1  A9 20           lda #<UFO_Y
001AC6  1  85 rr           sta zp_row_y_lo
001AC8  1  A9 00           lda #>UFO_Y
001ACA  1  85 rr           sta zp_row_y_hi
001ACC  1  20 B9 0F        jsr start_explosion
001ACF  1               
001ACF  1  64 rr           stz bullet_active
001AD1  1  20 66 0E        jsr update_bullet_sprite
001AD4  1               
001AD4  1  64 rr           stz ufo_active
001AD6  1  20 29 1A        jsr update_ufo_sprite
001AD9  1  20 1E 1B        jsr snd_stop_ufo_drone
001ADC  1               
001ADC  1                  ; score: ufo_score table indexed by shot_count & 7
001ADC  1  A5 rr           lda shot_count
001ADE  1  29 07           and #$07
001AE0  1  AA              tax
001AE1  1  BD 32 1F        lda ufo_score_lo, x
001AE4  1  BC 3A 1F        ldy ufo_score_hi, x
001AE7  1  20 B3 19        jsr add_score_bcd
001AEA  1               
001AEA  1               @done:
001AEA  1  60              rts
001AEB  1               
001AEB  1               ;******************************************************************
001AEB  1               ; snd_start_ufo_drone — enable VERA PSG voice 3 (sawtooth, full vol, freq1)
001AEB  1               ;   Called once when UFO spawns.
001AEB  1               ;******************************************************************
001AEB  1               snd_start_ufo_drone:
001AEB  1                  ; set starting UFO_DRONE_FREQ
001AEB  1  A9 00           lda #<UFO_DRONE_FREQ1
001AED  1  85 rr           sta UFO_DRONE_FREQ
001AEF  1  A9 04           lda #>UFO_DRONE_FREQ1
001AF1  1  85 rr           sta UFO_DRONE_FREQ + 1
001AF3  1  A9 FF           lda #$ff
001AF5  1  85 rr           sta UFO_FREQ_DIR
001AF7  1                  ; set VERA
001AF7  1  9C 25 9F        stz VERA_ctrl
001AFA  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
001AFE  1  9F A9 F9 8D  
001B02  1  21 9F A9 CC  
001B09  1  A5 rr           lda UFO_DRONE_FREQ
001B0B  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L
001B0E  1  A5 rr           lda UFO_DRONE_FREQ + 1
001B10  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
001B13  1  A9 DF           lda #PSG_VOL_HALF
001B15  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001B18  1  A9 40           lda #PSG_WAVE_SAW
001B1A  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
001B1D  1  60              rts
001B1E  1               
001B1E  1               ;******************************************************************
001B1E  1               ; snd_stop_ufo_drone — silence VERA PSG voice 3
001B1E  1               ;   Called when UFO leaves screen or is destroyed.
001B1E  1               ;******************************************************************
001B1E  1               snd_stop_ufo_drone:
001B1E  1  9C 25 9F        stz VERA_ctrl
001B21  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE3 + 2), 1   ; byte 2 = volume/enable
001B25  1  9F A9 F9 8D  
001B29  1  21 9F A9 CE  
001B30  1  A9 00           lda #$00
001B32  1  8D 23 9F        sta VERA_data0               ; zero volume → silent
001B35  1  60              rts
001B36  1               
001B36  1               ;******************************************************************
001B36  1               ; snd_update_ufo_drone — warble between freq1/freq2 using frame_count
001B36  1               ;   bit 3 (flips every 8 frames ≈ 3.75 Hz wobble rate).
001B36  1               ;   Call every frame while UFO is active.
001B36  1               ;   Rewrites all 4 voice bytes (keeps volume/waveform stable).
001B36  1               ;******************************************************************
001B36  1               snd_update_ufo_drone:
001B36  1  9C 25 9F        stz VERA_ctrl
001B39  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
001B3D  1  9F A9 F9 8D  
001B41  1  21 9F A9 CC  
001B48  1  A5 rr           lda UFO_DRONE_FREQ
001B4A  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L
001B4D  1  A5 rr           lda UFO_DRONE_FREQ + 1
001B4F  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
001B52  1  A9 DF           lda #PSG_VOL_HALF
001B54  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001B57  1  A9 40           lda #PSG_WAVE_SAW
001B59  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
001B5C  1                  ; change the frequency
001B5C  1  A5 rr           lda UFO_FREQ_DIR
001B5E  1  F0 16           beq @ufo_tone_down
001B60  1  A9 10           lda #$10
001B62  1  18              clc
001B63  1  65 rr           adc UFO_DRONE_FREQ
001B65  1  85 rr           sta UFO_DRONE_FREQ
001B67  1  A9 00           lda #$00
001B69  1  65 rr           adc UFO_DRONE_FREQ + 1
001B6B  1  85 rr           sta UFO_DRONE_FREQ + 1
001B6D  1  C9 06           cmp #>UFO_DRONE_FREQ2
001B6F  1  D0 1A           bne @ufo_update_done
001B71  1  64 rr           stz UFO_FREQ_DIR
001B73  1  4C 8B 1B        jmp @ufo_update_done
001B76  1               @ufo_tone_down:
001B76  1  A5 rr           lda UFO_DRONE_FREQ
001B78  1  38              sec
001B79  1  E9 10           sbc #$10
001B7B  1  85 rr           sta UFO_DRONE_FREQ
001B7D  1  A5 rr           lda UFO_DRONE_FREQ + 1
001B7F  1  E9 00           sbc #$00
001B81  1  85 rr           sta UFO_DRONE_FREQ + 1
001B83  1  C9 04           cmp #>UFO_DRONE_FREQ1
001B85  1  D0 04           bne @ufo_update_done
001B87  1  A9 FF           lda #$ff
001B89  1  85 rr           sta UFO_FREQ_DIR
001B8B  1               @ufo_update_done:
001B8B  1  60              rts
001B8C  1               
001B8C  1               ;******************************************************************
001B8C  1               ; snd_march_step — advance march_beat and play next note on PSG voice 0
001B8C  1               ;   Called once per invader march step (from step_invaders).
001B8C  1               ;   Increments beat index mod 4, writes freq/vol/wave to voice 0,
001B8C  1               ;   and arms march_snd_timer so snd_tick_march will silence it.
001B8C  1               ;******************************************************************
001B8C  1               snd_march_step:
001B8C  1  E6 rr           inc march_beat
001B8E  1  A5 rr           lda march_beat
001B90  1  29 03           and #$03
001B92  1  85 rr           sta march_beat
001B94  1  AA              tax                            ; X = note index 0-3
001B95  1  9C 25 9F        stz VERA_ctrl
001B98  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE0, 1
001B9C  1  9F A9 F9 8D  
001BA0  1  21 9F A9 C0  
001BA7  1  BD 2A 1F        lda march_freq_lo, x
001BAA  1  8D 23 9F        sta VERA_data0                 ; byte 0: FREQ_L
001BAD  1  BD 2E 1F        lda march_freq_hi, x
001BB0  1  8D 23 9F        sta VERA_data0                 ; byte 1: FREQ_H
001BB3  1  A9 FF           lda #PSG_MARCH_VOL
001BB5  1  8D 23 9F        sta VERA_data0                 ; byte 2: volume (stereo, full)
001BB8  1  A9 C0           lda #PSG_WAVE_PULSE
001BBA  1  8D 23 9F        sta VERA_data0                 ; byte 3: pulse waveform
001BBD  1  A9 06           lda #MARCH_NOTE_FRAMES
001BBF  1  85 rr           sta march_snd_timer
001BC1  1  60              rts
001BC2  1               
001BC2  1               ;******************************************************************
001BC2  1               ; snd_tick_march — decrement march note timer; silence voice 0 when it expires
001BC2  1               ;   Call once per frame from main_loop.
001BC2  1               ;******************************************************************
001BC2  1               snd_tick_march:
001BC2  1  A5 rr           lda march_snd_timer
001BC4  1  F0 1B           beq @done
001BC6  1  C6 rr           dec march_snd_timer
001BC8  1  D0 17           bne @done
001BCA  1  9C 25 9F        stz VERA_ctrl
001BCD  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE0 + 2), 1
001BD1  1  9F A9 F9 8D  
001BD5  1  21 9F A9 C2  
001BDC  1  A9 00           lda #$00
001BDE  1  8D 23 9F        sta VERA_data0                 ; zero volume → silent
001BE1  1               @done:
001BE1  1  60              rts
001BE2  1               
001BE2  1               ;******************************************************************
001BE2  1               ; snd_stop_march — immediately silence PSG voice 0 and clear timer
001BE2  1               ;   Call when leaving gameplay (game over, wave clear, restart).
001BE2  1               ;******************************************************************
001BE2  1               snd_stop_march:
001BE2  1  64 rr           stz march_snd_timer
001BE4  1  9C 25 9F        stz VERA_ctrl
001BE7  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE0 + 2), 1
001BEB  1  9F A9 F9 8D  
001BEF  1  21 9F A9 C2  
001BF6  1  A9 00           lda #$00
001BF8  1  8D 23 9F        sta VERA_data0
001BFB  1  60              rts
001BFC  1               
001BFC  1               ;******************************************************************
001BFC  1               ; snd_fire — play short high-pitched pulse on PSG voice 1 (~800 Hz, 5 frames)
001BFC  1               ;   Called from fire_bullet.
001BFC  1               ;******************************************************************
001BFC  1               snd_fire:
001BFC  1  9C 25 9F        stz VERA_ctrl
001BFF  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE1, 1
001C03  1  9F A9 F9 8D  
001C07  1  21 9F A9 C4  
001C0E  1  A9 63           lda #PSG_FIRE_FREQ_L
001C10  1  8D 23 9F        sta VERA_data0                 ; byte 0: FREQ_L
001C13  1  A9 7F           lda #PSG_FIRE_FREQ_H
001C15  1  8D 23 9F        sta VERA_data0                 ; byte 1: FREQ_H
001C18  1  A9 FF           lda #PSG_MARCH_VOL             ; reuse full-volume constant
001C1A  1  8D 23 9F        sta VERA_data0                 ; byte 2: volume
001C1D  1  A9 C0           lda #PSG_WAVE_PULSE
001C1F  1  8D 23 9F        sta VERA_data0                 ; byte 3: pulse waveform
001C22  1  A9 05           lda #FIRE_NOTE_FRAMES
001C24  1  85 rr           sta fire_snd_timer
001C26  1  60              rts
001C27  1               
001C27  1               ;******************************************************************
001C27  1               ; snd_tick_fire — decrement fire timer; silence voice 1 when it expires
001C27  1               ;   Call once per frame from main_loop.
001C27  1               ;******************************************************************
001C27  1               snd_tick_fire:
001C27  1  A5 rr           lda fire_snd_timer
001C29  1  F0 1B           beq @done
001C2B  1  C6 rr           dec fire_snd_timer
001C2D  1  D0 17           bne @done
001C2F  1  9C 25 9F        stz VERA_ctrl
001C32  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE1 + 2), 1
001C36  1  9F A9 F9 8D  
001C3A  1  21 9F A9 C6  
001C41  1  A9 00           lda #$00
001C43  1  8D 23 9F        sta VERA_data0
001C46  1               @done:
001C46  1  60              rts
001C47  1               
001C47  1               ;******************************************************************
001C47  1               ; snd_stop_fire — immediately silence PSG voice 1 and clear timer
001C47  1               ;******************************************************************
001C47  1               snd_stop_fire:
001C47  1  64 rr           stz fire_snd_timer
001C49  1  9C 25 9F        stz VERA_ctrl
001C4C  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE1 + 2), 1
001C50  1  9F A9 F9 8D  
001C54  1  21 9F A9 C6  
001C5B  1  A9 00           lda #$00
001C5D  1  8D 23 9F        sta VERA_data0
001C60  1  60              rts
001C61  1               
001C61  1               ;******************************************************************
001C61  1               ; snd_explosion — play low-frequency noise burst on PSG voice 2 (20 frames)
001C61  1               ;   Called from start_explosion (covers invader kills, UFO, player hit).
001C61  1               ;******************************************************************
001C61  1               snd_explosion:
001C61  1  9C 25 9F        stz VERA_ctrl
001C64  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE2, 1
001C68  1  9F A9 F9 8D  
001C6C  1  21 9F A9 C8  
001C73  1  A9 40           lda #PSG_EXP_FREQ_L
001C75  1  8D 23 9F        sta VERA_data0                 ; byte 0: FREQ_L (slow noise clock → deep rumble)
001C78  1  A9 00           lda #PSG_EXP_FREQ_H
001C7A  1  8D 23 9F        sta VERA_data0                 ; byte 1: FREQ_H
001C7D  1  A9 FF           lda #PSG_MARCH_VOL             ; reuse full-volume constant
001C7F  1  8D 23 9F        sta VERA_data0                 ; byte 2: volume
001C82  1  A9 C0           lda #PSG_WAVE_NOISE
001C84  1  8D 23 9F        sta VERA_data0                 ; byte 3: noise waveform
001C87  1  A9 14           lda #EXP_NOTE_FRAMES
001C89  1  85 rr           sta exp_snd_timer
001C8B  1  60              rts
001C8C  1               
001C8C  1               ;******************************************************************
001C8C  1               ; snd_tick_exp — decrement explosion timer; silence voice 2 when it expires
001C8C  1               ;   Call once per frame from main_loop.
001C8C  1               ;******************************************************************
001C8C  1               snd_tick_exp:
001C8C  1  A5 rr           lda exp_snd_timer
001C8E  1  F0 1B           beq @done
001C90  1  C6 rr           dec exp_snd_timer
001C92  1  D0 17           bne @done
001C94  1  9C 25 9F        stz VERA_ctrl
001C97  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE2 + 2), 1
001C9B  1  9F A9 F9 8D  
001C9F  1  21 9F A9 CA  
001CA6  1  A9 00           lda #$00
001CA8  1  8D 23 9F        sta VERA_data0
001CAB  1               @done:
001CAB  1  60              rts
001CAC  1               
001CAC  1               ;******************************************************************
001CAC  1               ; snd_stop_exp — immediately silence PSG voice 2 and clear timer
001CAC  1               ;******************************************************************
001CAC  1               snd_stop_exp:
001CAC  1  64 rr           stz exp_snd_timer
001CAE  1  9C 25 9F        stz VERA_ctrl
001CB1  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE2 + 2), 1
001CB5  1  9F A9 F9 8D  
001CB9  1  21 9F A9 CA  
