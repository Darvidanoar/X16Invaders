00122E  1  D0 3B           bne @go_restart
001230  1               
001230  1  A5 rr           lda frame_count
001232  1  29 20           and #$20                  ; bit 5: flips every 32 frames ≈ 2 Hz blink
001234  1  D0 15           bne @go_show
001236  1               @go_hide:
001236  1                  ;   (Plot: Set X to Row, Set Y to Col)
001236  1  A2 14           ldx #20
001238  1  A0 1F           ldy #31
00123A  1  18              clc
00123B  1  20 F0 FF        jsr PLOT
00123E  1  A2 12           ldx #18
001240  1  A9 20        @go_erase: lda #' '
001242  1  20 D2 FF        jsr CHROUT
001245  1  CA              dex
001246  1  D0 F8           bne @go_erase
001248  1  4C 1C 12        jmp game_over_loop
00124B  1               @go_show:
00124B  1                  ;   (Plot: Set X to Row, Set Y to Col)
00124B  1  A2 14           ldx #20
00124D  1  A0 1F           ldy #31
00124F  1  18              clc
001250  1  20 F0 FF        jsr PLOT
001253  1  A2 00           ldx #0
001255  1  BD 33 1C     @go_print: lda str_play_again, x
001258  1  F0 06           beq @go_pd
00125A  1  20 D2 FF        jsr CHROUT
00125D  1  E8              inx
00125E  1  80 F5           bra @go_print
001260  1               @go_pd:
001260  1  4C 1C 12        jmp game_over_loop
001263  1               
001263  1               @go_quit:
001263  1  A9 93           lda #PETSCII_CLR
001265  1  20 D2 FF        jsr CHROUT
001268  1  4C 47 FF        jmp ENTER_BASIC
