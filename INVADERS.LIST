000810  1               ;******************************************************************
000810  1               ; Constants
000810  1               ;******************************************************************
000810  1               
000810  1               ; VERA display control
000810  1               VERA_SPRITE_EN  = %01000000      ; VERA_dc_video bit 6: enable sprites
000810  1               
000810  1               ; PETSCII control codes
000810  1               PETSCII_WHITE   = $05            ; set text color to white
000810  1               PETSCII_CLR     = $93            ; clear screen and home cursor
000810  1               PETSCII_HOME    = $13            ; home cursor (no clear)
000810  1               PETSCII_RETURN  = $0D            ; carriage return
000810  1               
000810  1               ; SCREEN_SET_CHARSET font numbers (call address $FF62)
000810  1               CHARSET_UPPER   = 1              ; Commodore upper/graphics: $41-$5A = A-Z
000810  1               CHARSET_LOWER   = 2              ; Commodore lower/upper:    $41-$5A = a-z (lowercase)
000810  1               
000810  1               ; Key codes (PETSCII)
000810  1               KEY_RUN_STOP    = $03            ; RUN/STOP — exit game
000810  1               
000810  1               ; Input flag bits (key_flags)
000810  1               KEY_LEFT        = %00000001
000810  1               KEY_RIGHT       = %00000010
000810  1               KEY_FIRE        = %00000100
000810  1               
000810  1               ; JOYSTICK_GET .A return: {B,Y,Sel,Sta,Up,Dn,Left,Right} active low
000810  1               JOY_RIGHT       = %00000001     ; bit 0
000810  1               JOY_LEFT        = %00000010     ; bit 1
000810  1               
000810  1               ; Player ship — all positions in VERA 640x480 coordinate space
000810  1               PLAYER_Y        = 420            ; fixed Y, near bottom (479 = bottom edge)
000810  1               PLAYER_X_INIT   = 312            ; starting X, centred  ((640-16)/2)
000810  1               PLAYER_X_MIN    = 8              ; left  boundary (sprite left edge)
000810  1               PLAYER_X_MAX    = 616            ; right boundary (640 - 16px sprite - 8px margin)
000810  1               PLAYER_SPEED    = 4              ; pixels per frame
000810  1               
000810  1               ; Sprite attribute encoding helpers
000810  1               SPRITE1_ATTR    = $1FC08 ; sprite 1 attribute base ($1FC00=sprite 0, reserved for KERNAL mouse)
000810  1               SPR_Z_FRONT     = %00001100     ; byte 6: z-depth = %11 in bits 3-2 (in front of all layers)
000810  1               SPR_16x16_PAL0  = %01010000     ; byte 7: width=1(16px), height=1(16px), palette_off=0
000810  1               SPR_8x8_PAL0    = %00000000     ; byte 7: width=0(8px),  height=0(8px),  palette_off=0
000810  1               
000810  1               ; Explosion sprite (slot 4)
000810  1               VRAM_EXPLOSION     = $00440     ; explosion pixel data (128 bytes, 16x16 4bpp)
000810  1               EXPLODE_SPRITE_ATTR = $1FC20    ; sprite 4 attribute base (explosion)
000810  1               EXPLODE_FRAMES     = 30         ; display duration in frames (~0.5 sec at 60 Hz)
000810  1               
000810  1               ; Invader bullets (sprite slots 5-7)
000810  1               VRAM_INV_BULLET    = $00420     ; invader bullet pixel data (32 bytes, 8x8 4bpp)
000810  1               INV_BULLET_SPR_BASE = $1FC28    ; sprite 5 attribute base (first invader bullet)
000810  1               INV_BULLET_SPEED   = 6          ; VERA pixels per frame downward (=3 game pixels)
000810  1               INV_FIRE_TIMER_MIN = 10         ; minimum frames between fire attempts
000810  1               INV_FIRE_TIMER_INIT = 90        ; frames before first shot
000810  1               
000810  1               ; Player lives
000810  1               LIVES_INIT         = 3          ; starting lives
000810  1               INV_HIT_FRAMES     = 120        ; invincibility duration after being hit (2 sec at 60 Hz)
000810  1               
000810  1               ; Player bullet
000810  1               BULLET_SPRITE_ATTR = $1FC10     ; sprite 2 attribute base (player bullet)
000810  1               VRAM_BULLET     = $00400        ; player bullet pixel data (32 bytes, 8x8 4bpp)
000810  1               BULLET_SPEED    = 12            ; VERA pixels per frame upward (= 6 game pixels)
000810  1               BULLET_Y_INIT   = PLAYER_Y - 8 ; bullet starts just above player ship top
000810  1               
000810  1               ; Invader grid geometry (VERA 640x480 coordinate space)
000810  1               INV_GRID_X_INIT   = 112         ; left-column X at start (centered: (640 - 10*40 - 16) / 2 = 112)
000810  1               INV_GRID_Y_BASE   = 80          ; top-row Y, fixed base (drops added via inv_offset_y)
000810  1               INV_SPACING_X     = 40          ; VERA pixels between invader column origins
000810  1               INV_SPACING_Y     = 48          ; VERA pixels between invader row origins
000810  1               INV_STEP_X        = 4           ; VERA pixels per march step
000810  1               INV_DROP_Y        = 16          ; VERA pixels per grid drop
000810  1               INV_MOVE_SPEED_INIT = 50        ; frames between march steps (initial)
000810  1               INV_COUNT_INIT    = 55
000810  1               INV_MOVE_SPEED_MIN = 5           ; minimum frames per march step
000810  1               
000810  1               ; Grid boundary: when grid_x reaches these values, reverse and drop
000810  1               ; Rightmost invader base X = grid_x + 10*INV_SPACING_X (=400). Right wall = 624 (640-16px).
000810  1               ; So right limit = 624 - 400 - 16 = 208
000810  1               INV_X_RIGHT_LIM   = 208
000810  1               INV_X_LEFT_LIM    = 16          ; leftmost sprite at x=grid_x must stay >= 16
000810  1               
000810  1               ; VRAM addresses for invader sprite pixel data (128 bytes each, 16x16 4bpp)
000810  1               VRAM_INV_A_F0   = $00100        ; Type A (crab,   bottom rows 3-4), frame 0
000810  1               VRAM_INV_A_F1   = $00180        ; Type A frame 1
000810  1               VRAM_INV_B_F0   = $00200        ; Type B (octopus, middle rows 1-2), frame 0
000810  1               VRAM_INV_B_F1   = $00280        ; Type B frame 1
000810  1               VRAM_INV_C_F0   = $00300        ; Type C (squid,   top row 0), frame 0
000810  1               VRAM_INV_C_F1   = $00380        ; Type C frame 1
000810  1               
000810  1               ; Sprite addr[12:5] byte values for each type/frame (= VRAM_addr >> 5)
000810  1               ;   VRAM $00100>>5=$08  $00180>>5=$0C  $00200>>5=$10  $00280>>5=$14  $00300>>5=$18  $00380>>5=$1C
000810  1               INV_ATTR_BASE   = $1FC58        ; sprite slot 11 = first invader ($1FC00 + 11*8)
000810  1               INV_SPRITE_SLOT = 11            ; first invader sprite slot index
000810  1               
000810  1               ;******************************************************************
000810  1               ; start — main program entry point
000810  1               ;******************************************************************
000810  1               start:
000810  1  78              sei                           ; disable interrupts during init
000811  1               
000811  1                  ; Switch to 40-column text mode (mode 0)
000811  1                  ; Carry clear = SET mode (carry set = READ mode)
000811  1  18              clc
000812  1  A9 00           lda #$00
000814  1  20 5F FF        jsr SCREEN_MODE
000817  1               
000817  1                  ; Seed PRNG with hardware entropy
000817  1  20 CF FE        jsr ENTROPY_GET
00081A  1  85 rr           sta rand_seed_lo
00081C  1  86 rr           stx rand_seed_hi
00081E  1               
00081E  1                  ; Enable sprites in VERA display controller
00081E  1  9C 25 9F        stz VERA_ctrl                 ; DCSEL=0, ADDRSEL=0
000821  1  AD 29 9F        lda VERA_dc_video
000824  1  09 40           ora #VERA_SPRITE_EN
000826  1  8D 29 9F        sta VERA_dc_video
000829  1               
000829  1               
000829  1                  ; Clear game variables
000829  1  64 rr           stz key_last
00082B  1  64 rr           stz key_flags
00082D  1  64 rr           stz frame_count
00082F  1  64 rr           stz bullet_active
000831  1  64 rr           stz score_lo
000833  1  64 rr           stz score_mid
000835  1  64 rr           stz score_hi
000837  1  64 rr           stz hi_score_lo
000839  1  64 rr           stz hi_score_mid
00083B  1  64 rr           stz hi_score_hi
00083D  1               
00083D  1                  ; Set initial player position before sprite init reads it
00083D  1  20 4E 09        jsr init_player
000840  1               
000840  1  58              cli                           ; re-enable interrupts
000841  1               
000841  1                  ; Switch to Commodore uppercase/graphics charset: $41-$5A = A-Z
000841  1                  ; Must be called AFTER SCREEN_MODE (which resets to lowercase by default)
000841  1  A9 01           lda #CHARSET_UPPER
000843  1  20 62 FF        jsr SCREEN_SET_CHARSET
000846  1               
000846  1                  ; Clear screen and set text color
000846  1  A9 05           lda #PETSCII_WHITE
000848  1  20 D2 FF        jsr CHROUT
00084B  1  A9 93           lda #PETSCII_CLR
00084D  1  20 D2 FF        jsr CHROUT
000850  1               
000850  1                  ; Upload sprite pixel data and configure sprite 1 attributes
000850  1  20 5D 09        jsr init_sprites
000853  1               
000853  1                  ; Upload invader sprite data, set palette, init grid state, place sprites
000853  1  20 01 0B        jsr init_invaders
000856  1  20 5C 12        jsr hide_all_inv_sprites     ; hide all 55 during title screen
000859  1               
000859  1  20 05 11        jsr draw_title_screen
00085C  1               
00085C  1               ;------------------------------------------------------------------
00085C  1               ; title_loop — wait for SPACE; blink "PRESS SPACE TO START"
00085C  1               ;------------------------------------------------------------------
00085C  1               title_loop:
00085C  1  20 01 09        jsr wait_vsync
00085F  1  E6 rr           inc frame_count
000861  1  20 03 09        jsr update_input
000864  1               
000864  1  A5 rr           lda key_last
000866  1  C9 03           cmp #KEY_RUN_STOP
000868  1  D0 03           bne @tl_no_exit
00086A  1  4C F9 08        jmp exit_game
00086D  1               @tl_no_exit:
00086D  1               
00086D  1  A5 rr           lda key_flags
00086F  1  29 04           and #KEY_FIRE
000871  1  D0 33           bne start_game
000873  1               
000873  1                  ; blink using frame_count bit 5 (~2 Hz)
000873  1  A5 rr           lda frame_count
000875  1  29 20           and #$20
000877  1  D0 15           bne @tl_on
000879  1               @tl_off:
000879  1  A9 11           lda #17
00087B  1  A0 0A           ldy #10
00087D  1  18              clc
00087E  1  20 F0 FF        jsr PLOT
000881  1  A2 14           ldx #20                      ; erase 20 chars of "PRESS SPACE TO START"
000883  1  A9 20        @tl_erase: lda #' '
000885  1  20 D2 FF        jsr CHROUT
000888  1  CA              dex
000889  1  D0 F8           bne @tl_erase
00088B  1  4C 5C 08        jmp title_loop
00088E  1               @tl_on:
00088E  1  A9 11           lda #17
000890  1  A0 0A           ldy #10
000892  1  18              clc
000893  1  20 F0 FF        jsr PLOT
000896  1  A2 00           ldx #0
000898  1  BD 13 13     @tl_print: lda str_press_space, x
00089B  1  F0 06           beq @tl_print_done
00089D  1  20 D2 FF        jsr CHROUT
0008A0  1  E8              inx
0008A1  1  80 F5           bra @tl_print
0008A3  1               @tl_print_done:
0008A3  1  4C 5C 08        jmp title_loop
0008A6  1               
0008A6  1               start_game:
0008A6  1  20 35 0C        jsr update_invader_sprites   ; re-enable all 55 invaders at grid positions
0008A9  1  A9 93           lda #PETSCII_CLR
0008AB  1  20 D2 FF        jsr CHROUT                   ; clear title text, leave sprites visible
0008AE  1               
0008AE  1               ;******************************************************************
0008AE  1               ; main_loop — one iteration per video frame (60 Hz)
0008AE  1               ;******************************************************************
0008AE  1               main_loop:
0008AE  1  20 01 09        jsr wait_vsync
0008B1  1               
0008B1  1  E6 rr           inc frame_count
0008B3  1               
0008B3  1  20 03 09        jsr update_input              ; fills key_flags (joystick) + key_last (GETIN)
0008B6  1               
0008B6  1  A5 rr           lda key_last
0008B8  1  C9 03           cmp #KEY_RUN_STOP
0008BA  1  F0 3D           beq exit_game
0008BC  1               
0008BC  1                  ; --- invincibility timer ---
0008BC  1  A5 rr           lda inv_hit_timer
0008BE  1  F0 02           beq @no_inv_dec
0008C0  1  C6 rr           dec inv_hit_timer
0008C2  1               @no_inv_dec:
0008C2  1               
0008C2  1  20 EB 0C        jsr move_player               ; apply movement, clamp to boundaries
0008C5  1  20 3A 0D        jsr update_player_sprite      ; write new X to VERA sprite 1
0008C8  1               
0008C8  1                  ; --- fire player bullet (SPACE pressed and bullet not already active) ---
0008C8  1  A5 rr           lda key_flags
0008CA  1  29 04           and #KEY_FIRE
0008CC  1  F0 07           beq @skip_fire
0008CE  1  A5 rr           lda bullet_active
0008D0  1  D0 03           bne @skip_fire
0008D2  1  20 7D 0D        jsr fire_bullet
0008D5  1               @skip_fire:
0008D5  1               
0008D5  1                  ; --- move bullet if active ---
0008D5  1  A5 rr           lda bullet_active
0008D7  1  F0 03           beq @skip_bullet_move
0008D9  1  20 9A 0D        jsr move_bullet
0008DC  1               @skip_bullet_move:
0008DC  1               
0008DC  1                  ; --- check player bullet vs invader collision ---
0008DC  1  20 EB 0D        jsr check_bullet_invader
0008DF  1               
0008DF  1                  ; --- explosion timer ---
0008DF  1  20 3A 0F        jsr update_explosion
0008E2  1               
0008E2  1                  ; --- invader bullets: move, spawn, boundary check ---
0008E2  1  20 69 0F        jsr update_inv_bullets
0008E5  1               
0008E5  1                  ; --- invader bullet vs player collision ---
0008E5  1  20 77 10        jsr check_inv_bullet_player
0008E8  1               
0008E8  1                  ; --- Invader march timer ---
0008E8  1  C6 rr           dec inv_move_timer
0008EA  1  D0 07           bne @skip_inv_step
0008EC  1  20 D0 0B        jsr step_invaders             ; move grid, check bounds, update sprites
0008EF  1  A5 rr           lda inv_move_speed
0008F1  1  85 rr           sta inv_move_timer
0008F3  1               @skip_inv_step:
0008F3  1               
0008F3  1  20 79 12        jsr update_hud                ; refresh text readouts
0008F6  1               
0008F6  1  4C AE 08        jmp main_loop
0008F9  1               
0008F9  1               ;------------------------------------------------------------------
0008F9  1               exit_game:
0008F9  1  A9 93           lda #PETSCII_CLR
0008FB  1  20 D2 FF        jsr CHROUT
0008FE  1  4C 47 FF        jmp ENTER_BASIC
000901  1               
000901  1               ;******************************************************************
000901  1               ; wait_vsync — busy-poll VERA_isr until VSYNC, then clear flag
000901  1               ;******************************************************************
000901  1               wait_vsync:
000901  1                  ; WAI sleeps the CPU until any IRQ fires.  The KERNAL's VSYNC IRQ
000901  1                  ; handler (60 Hz) wakes us up and has already cleared VERA_isr bit 0
000901  1                  ; by the time execution returns here, so polling VERA_isr would loop
000901  1                  ; forever.  Just return — one WAI ≈ one frame.
000901  1  CB              wai
000902  1  60              rts
000903  1               
000903  1               ;******************************************************************
000903  1               ; update_input — joystick + GETIN keyboard input each frame
000903  1               ;
000903  1               ;   key_flags bits set this frame:
000903  1               ;     KEY_LEFT  — left arrow held
000903  1               ;     KEY_RIGHT — right arrow held
000903  1               ;     KEY_FIRE  — space bar pressed
000903  1               ;   key_last   — raw PETSCII from GETIN (RUN/STOP etc.)
000903  1               ;
000903  1               ;   JOYSTICK_GET(0) = keyboard-as-joystick; gives smooth held-key
000903  1               ;   movement with no repeat delay.  GETIN handles space and RUN/STOP.
000903  1               ;******************************************************************
000903  1               update_input:
000903  1  64 rr           stz key_flags
000905  1  64 rr           stz key_last
000907  1               
000907  1                  ; --- joystick 0 = keyboard d-pad (active low: 0 = pressed) ---
000907  1                  ; Byte returned: {B,Y,Sel,Sta,Up,Dn,Left,Right} bits 7–0
000907  1  A9 00           lda #0
000909  1  20 56 FF        jsr JOYSTICK_GET
00090C  1  48              pha                           ; save — AND destroys .A
00090D  1               
00090D  1  29 01           and #JOY_RIGHT                ; bit 0: right arrow
00090F  1  D0 06           bne @not_right
000911  1  A5 rr           lda key_flags
000913  1  09 02           ora #KEY_RIGHT
000915  1  85 rr           sta key_flags
000917  1               @not_right:
000917  1  68              pla
000918  1  29 02           and #JOY_LEFT                 ; bit 1: left arrow
00091A  1  D0 06           bne @not_left
00091C  1  A5 rr           lda key_flags
00091E  1  09 01           ora #KEY_LEFT
000920  1  85 rr           sta key_flags
000922  1               @not_left:
000922  1               
000922  1                  ; --- GETIN — discrete events: fire, RUN/STOP, arrow fallback ---
000922  1               @getin_drain:
000922  1  20 E4 FF        jsr GETIN
000925  1  F0 26           beq @getin_done               ; buffer empty
000927  1  85 rr           sta key_last
000929  1  C9 9D           cmp #$9D                      ; cursor left (PETSCII)
00092B  1  D0 08           bne @chk_right_getin
00092D  1  A5 rr           lda key_flags
00092F  1  09 01           ora #KEY_LEFT
000931  1  85 rr           sta key_flags
000933  1  80 ED           bra @getin_drain
000935  1               @chk_right_getin:
000935  1  C9 1D           cmp #$1D                      ; cursor right (PETSCII)
000937  1  D0 08           bne @chk_fire_getin
000939  1  A5 rr           lda key_flags
00093B  1  09 02           ora #KEY_RIGHT
00093D  1  85 rr           sta key_flags
00093F  1  80 E1           bra @getin_drain
000941  1               @chk_fire_getin:
000941  1  C9 20           cmp #$20                      ; space = fire
000943  1  D0 DD           bne @getin_drain
000945  1  A5 rr           lda key_flags
000947  1  09 04           ora #KEY_FIRE
000949  1  85 rr           sta key_flags
00094B  1  80 D5           bra @getin_drain
00094D  1               @getin_done:
00094D  1  60              rts
00094E  1               
00094E  1               ;******************************************************************
00094E  1               ; init_player — set player_x to starting position
00094E  1               ;******************************************************************
00094E  1               init_player:
00094E  1  A9 38           lda #<PLAYER_X_INIT
000950  1  85 rr           sta player_x_lo
000952  1  A9 01           lda #>PLAYER_X_INIT
000954  1  85 rr           sta player_x_hi
000956  1  A9 03           lda #LIVES_INIT
000958  1  85 rr           sta lives
00095A  1  64 rr           stz inv_hit_timer
00095C  1  60              rts
00095D  1               
00095D  1               ;******************************************************************
00095D  1               ; init_sprites — upload pixel data + write sprite 1 attributes
00095D  1               ;
00095D  1               ;   Sprite 0 ($1FC00) is reserved by the KERNAL mouse cursor —
00095D  1               ;   we disable it and keep clear of $1FC00.
00095D  1               ;
00095D  1               ;   Sprite 1 ($1FC08) = player ship
00095D  1               ;   Pixel data at VRAM $00080 (128 bytes, 16x16 4bpp)
00095D  1               ;   Address encoding:  addr[12:5] = $00080>>5 = $04  → byte 0 = $04
00095D  1               ;                      4bpp, addr[16:13] = 0          → byte 1 = $00
00095D  1               ;******************************************************************
00095D  1               init_sprites:
00095D  1  9C 25 9F        stz VERA_ctrl
000960  1               
000960  1                  ; --- set palette entries 1-4 ---
000960  1                  ; VERA palette entry N is 2 bytes at VRAM_palette + N*2
000960  1                  ; Byte 0: [7:4]=Green [3:0]=Blue   Byte 1: [3:0]=Red (bits 7-4 unused)
000960  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_palette + 2), 1   ; entry 1 (player white); stride=1 auto-advances
000964  1  9F A9 FA 8D  
000968  1  21 9F A9 02  
00096F  1  A9 FF           lda #$FF                               ; G=$F, B=$F
000971  1  8D 23 9F        sta VERA_data0
000974  1  A9 0F           lda #$0F                               ; R=$F  → white
000976  1  8D 23 9F        sta VERA_data0
000979  1                  ; entry 2 = cyan  (R=0, G=$F, B=$F)
000979  1  A9 FF           lda #$FF                               ; G=$F, B=$F
00097B  1  8D 23 9F        sta VERA_data0
00097E  1  A9 00           lda #$00                               ; R=$0
000980  1  8D 23 9F        sta VERA_data0
000983  1                  ; entry 3 = magenta (R=$F, G=0, B=$F)
000983  1  A9 0F           lda #$0F                               ; G=$0, B=$F
000985  1  8D 23 9F        sta VERA_data0
000988  1  A9 0F           lda #$0F                               ; R=$F
00098A  1  8D 23 9F        sta VERA_data0
00098D  1                  ; entry 4 = green  (R=0, G=$F, B=0)
00098D  1  A9 F0           lda #$F0                               ; G=$F, B=$0
00098F  1  8D 23 9F        sta VERA_data0
000992  1  A9 00           lda #$00                               ; R=$0
000994  1  8D 23 9F        sta VERA_data0
000997  1                  ; --- disable sprite 0 (KERNAL mouse cursor) ---
000997  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_sprattr + 6), 1   ; sprite 0 byte 6 = z-depth
00099B  1  9F A9 FC 8D  
00099F  1  21 9F A9 06  
0009A6  1  A9 00           lda #$00                               ; z-depth=0 → disabled
0009A8  1  8D 23 9F        sta VERA_data0
0009AB  1               
0009AB  1                  ; --- upload player sprite pixel data to VRAM $00080 ---
0009AB  1  A9 10 8D 22     VERA_SET_ADDR $00080, 1
0009AF  1  9F A9 00 8D  
0009B3  1  21 9F A9 80  
0009BA  1  A2 00           ldx #0
0009BC  1               @upload:
0009BC  1  BD 51 13        lda player_spr_data,x
0009BF  1  8D 23 9F        sta VERA_data0
0009C2  1  E8              inx
0009C3  1  E0 80           cpx #128
0009C5  1  D0 F5           bne @upload
0009C7  1               
0009C7  1                  ; --- write sprite 1 attribute bytes ---
0009C7  1  A9 11 8D 22     VERA_SET_ADDR SPRITE1_ATTR, 1
0009CB  1  9F A9 FC 8D  
0009CF  1  21 9F A9 08  
0009D6  1  A9 04           lda #$04
0009D8  1  8D 23 9F        sta VERA_data0               ; byte 0: addr[12:5] = $00080>>5 = $04
0009DB  1  A9 00           lda #$00
0009DD  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, addr[16:13] = 0
0009E0  1  A5 rr           lda player_x_lo
0009E2  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
0009E5  1  A5 rr           lda player_x_hi
0009E7  1  29 03           and #$03
0009E9  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
0009EC  1  A9 A4           lda #<PLAYER_Y
0009EE  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
0009F1  1  A9 01           lda #>PLAYER_Y
0009F3  1  29 03           and #$03
0009F5  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
0009F8  1  A9 0C           lda #SPR_Z_FRONT
0009FA  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3, no collision, no flip
0009FD  1  A9 50           lda #SPR_16x16_PAL0
0009FF  1  8D 23 9F        sta VERA_data0               ; byte 7: palette 0, 16x16
000A02  1               
000A02  1                  ; --- upload player bullet pixel data to VRAM $00400 ---
000A02  1  A9 10 8D 22     VERA_SET_ADDR VRAM_BULLET, 1
000A06  1  9F A9 04 8D  
000A0A  1  21 9F A9 00  
000A11  1  A2 00           ldx #0
000A13  1               @up_bullet:
000A13  1  BD D1 13        lda bullet_spr_data,x
000A16  1  8D 23 9F        sta VERA_data0
000A19  1  E8              inx
000A1A  1  E0 20           cpx #32
000A1C  1  D0 F5           bne @up_bullet
000A1E  1               
000A1E  1                  ; --- write sprite 2 attributes (initially disabled, z-depth=0) ---
000A1E  1  A9 11 8D 22     VERA_SET_ADDR BULLET_SPRITE_ATTR, 1
000A22  1  9F A9 FC 8D  
000A26  1  21 9F A9 10  
000A2D  1  A9 20           lda #$20                     ; byte 0: addr[12:5] = $00400>>5 = $20
000A2F  1  8D 23 9F        sta VERA_data0
000A32  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000A34  1  8D 23 9F        sta VERA_data0
000A37  1  A9 00           lda #$00                     ; byte 2: X lo (arbitrary; sprite disabled)
000A39  1  8D 23 9F        sta VERA_data0
000A3C  1  A9 00           lda #$00                     ; byte 3: X hi
000A3E  1  8D 23 9F        sta VERA_data0
000A41  1  A9 00           lda #$00                     ; byte 4: Y lo
000A43  1  8D 23 9F        sta VERA_data0
000A46  1  A9 00           lda #$00                     ; byte 5: Y hi
000A48  1  8D 23 9F        sta VERA_data0
000A4B  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000A4D  1  8D 23 9F        sta VERA_data0
000A50  1  A9 00           lda #SPR_8x8_PAL0            ; byte 7: 8x8, palette 0
000A52  1  8D 23 9F        sta VERA_data0
000A55  1               
000A55  1                  ; --- upload explosion pixel data to VRAM $00440 ---
000A55  1  A9 10 8D 22     VERA_SET_ADDR VRAM_EXPLOSION, 1
000A59  1  9F A9 04 8D  
000A5D  1  21 9F A9 40  
000A64  1  A2 00           ldx #0
000A66  1               @up_exp:
000A66  1  BD 83 14        lda explosion_pixels,x
000A69  1  8D 23 9F        sta VERA_data0
000A6C  1  E8              inx
000A6D  1  E0 80           cpx #128
000A6F  1  D0 F5           bne @up_exp
000A71  1               
000A71  1                  ; --- write sprite 4 attributes (initially disabled) ---
000A71  1                  ; addr[12:5] = VRAM_EXPLOSION>>5 = $00440>>5 = $22
000A71  1  A9 11 8D 22     VERA_SET_ADDR EXPLODE_SPRITE_ATTR, 1
000A75  1  9F A9 FC 8D  
000A79  1  21 9F A9 20  
000A80  1  A9 22           lda #$22                     ; byte 0: addr[12:5]
000A82  1  8D 23 9F        sta VERA_data0
000A85  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000A87  1  8D 23 9F        sta VERA_data0
000A8A  1  A9 00           lda #$00                     ; byte 2: X lo (placeholder)
000A8C  1  8D 23 9F        sta VERA_data0
000A8F  1  A9 00           lda #$00                     ; byte 3: X hi
000A91  1  8D 23 9F        sta VERA_data0
000A94  1  A9 00           lda #$00                     ; byte 4: Y lo (placeholder)
000A96  1  8D 23 9F        sta VERA_data0
000A99  1  A9 00           lda #$00                     ; byte 5: Y hi
000A9B  1  8D 23 9F        sta VERA_data0
000A9E  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000AA0  1  8D 23 9F        sta VERA_data0
000AA3  1  A9 50           lda #SPR_16x16_PAL0          ; byte 7: 16x16, palette 0
000AA5  1  8D 23 9F        sta VERA_data0
000AA8  1               
000AA8  1  64 rr           stz exp_timer
000AAA  1               
000AAA  1                  ; --- upload invader bullet pixel data to VRAM $00420 ---
000AAA  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_BULLET, 1
000AAE  1  9F A9 04 8D  
000AB2  1  21 9F A9 20  
000AB9  1  A2 00           ldx #0
000ABB  1               @up_ibul:
000ABB  1  BD 63 14        lda inv_bullet_spr_data,x
000ABE  1  8D 23 9F        sta VERA_data0
000AC1  1  E8              inx
000AC2  1  E0 20           cpx #32
000AC4  1  D0 F5           bne @up_ibul
000AC6  1               
000AC6  1                  ; --- init 3 invader bullet sprites (slots 5-7, base $1FC28), all disabled ---
000AC6  1                  ; addr[12:5] = VRAM_INV_BULLET>>5 = $00420>>5 = $21
000AC6  1  A9 11 8D 22     VERA_SET_ADDR INV_BULLET_SPR_BASE, 1
000ACA  1  9F A9 FC 8D  
000ACE  1  21 9F A9 28  
000AD5  1  A2 03           ldx #3                       ; 3 sprites
000AD7  1               @init_ibspr:
000AD7  1  A9 21           lda #$21                     ; byte 0: addr[12:5] = $21
000AD9  1  8D 23 9F        sta VERA_data0
000ADC  1  A9 00           lda #$00
000ADE  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, bank 0
000AE1  1  8D 23 9F        sta VERA_data0               ; byte 2: X lo
000AE4  1  8D 23 9F        sta VERA_data0               ; byte 3: X hi
000AE7  1  8D 23 9F        sta VERA_data0               ; byte 4: Y lo
000AEA  1  8D 23 9F        sta VERA_data0               ; byte 5: Y hi
000AED  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=0 → disabled
000AF0  1  8D 23 9F        sta VERA_data0               ; byte 7: 8x8, palette 0
000AF3  1  CA              dex
000AF4  1  D0 E1           bne @init_ibspr
000AF6  1               
000AF6  1                  ; --- clear invader bullet state ---
000AF6  1  64 rr           stz ibul_active+0
000AF8  1  64 rr           stz ibul_active+1
000AFA  1  64 rr           stz ibul_active+2
000AFC  1  A9 5A           lda #INV_FIRE_TIMER_INIT
000AFE  1  85 rr           sta inv_fire_timer
000B00  1               
000B00  1  60              rts
000B01  1               
000B01  1               ;******************************************************************
000B01  1               ; init_invaders — upload invader pixel data, init grid state, place sprites
000B01  1               ;******************************************************************
000B01  1               init_invaders:
000B01  1  9C 25 9F        stz VERA_ctrl
000B04  1               
000B04  1                  ; --- upload Type A frame 0 → VRAM $00100 ---
000B04  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F0, 1
000B08  1  9F A9 01 8D  
000B0C  1  21 9F A9 00  
000B13  1  A2 80           ldx #128
000B15  1  BD 83 14     @up_af0: lda inv_a_spr_f0-128,x
000B18  1  8D 23 9F        sta VERA_data0
000B1B  1  E8              inx
000B1C  1  D0 F7           bne @up_af0
000B1E  1               
000B1E  1                  ; --- upload Type A frame 1 → VRAM $00180 ---
000B1E  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F1, 1
000B22  1  9F A9 01 8D  
000B26  1  21 9F A9 80  
000B2D  1  A2 80           ldx #128
000B2F  1  BD 03 15     @up_af1: lda inv_a_spr_f1-128,x
000B32  1  8D 23 9F        sta VERA_data0
000B35  1  E8              inx
000B36  1  D0 F7           bne @up_af1
000B38  1               
000B38  1                  ; --- upload Type B frame 0 → VRAM $00200 ---
000B38  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F0, 1
000B3C  1  9F A9 02 8D  
000B40  1  21 9F A9 00  
000B47  1  A2 80           ldx #128
000B49  1  BD 83 15     @up_bf0: lda inv_b_spr_f0-128,x
000B4C  1  8D 23 9F        sta VERA_data0
000B4F  1  E8              inx
000B50  1  D0 F7           bne @up_bf0
000B52  1               
000B52  1                  ; --- upload Type B frame 1 → VRAM $00280 ---
000B52  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F1, 1
000B56  1  9F A9 02 8D  
000B5A  1  21 9F A9 80  
000B61  1  A2 80           ldx #128
000B63  1  BD 03 16     @up_bf1: lda inv_b_spr_f1-128,x
000B66  1  8D 23 9F        sta VERA_data0
000B69  1  E8              inx
000B6A  1  D0 F7           bne @up_bf1
000B6C  1               
000B6C  1                  ; --- upload Type C frame 0 → VRAM $00300 ---
000B6C  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F0, 1
000B70  1  9F A9 03 8D  
000B74  1  21 9F A9 00  
000B7B  1  A2 80           ldx #128
000B7D  1  BD 83 16     @up_cf0: lda inv_c_spr_f0-128,x
000B80  1  8D 23 9F        sta VERA_data0
000B83  1  E8              inx
000B84  1  D0 F7           bne @up_cf0
000B86  1               
000B86  1                  ; --- upload Type C frame 1 → VRAM $00380 ---
000B86  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F1, 1
000B8A  1  9F A9 03 8D  
000B8E  1  21 9F A9 80  
000B95  1  A2 80           ldx #128
000B97  1  BD 03 17     @up_cf1: lda inv_c_spr_f1-128,x
000B9A  1  8D 23 9F        sta VERA_data0
000B9D  1  E8              inx
000B9E  1  D0 F7           bne @up_cf1
000BA0  1               
000BA0  1                  ; --- initialize zero-page grid variables ---
000BA0  1  A9 70           lda #<INV_GRID_X_INIT
000BA2  1  85 rr           sta inv_grid_x_lo
000BA4  1  A9 00           lda #>INV_GRID_X_INIT
000BA6  1  85 rr           sta inv_grid_x_hi
000BA8  1  64 rr           stz inv_offset_y
000BAA  1  64 rr           stz inv_direction
000BAC  1  64 rr           stz inv_anim_frame
000BAE  1  64 rr           stz inv_drop_flag
000BB0  1               
000BB0  1                  ; all 55 invaders alive: bytes 0-5 = $FF, byte 6 = $7F (55 bits)
000BB0  1  A9 FF           lda #$FF
000BB2  1  85 rr           sta inv_alive+0
000BB4  1  85 rr           sta inv_alive+1
000BB6  1  85 rr           sta inv_alive+2
000BB8  1  85 rr           sta inv_alive+3
000BBA  1  85 rr           sta inv_alive+4
000BBC  1  85 rr           sta inv_alive+5
000BBE  1  A9 7F           lda #$7F
000BC0  1  85 rr           sta inv_alive+6
000BC2  1               
000BC2  1  A9 37           lda #INV_COUNT_INIT
000BC4  1  85 rr           sta inv_count
000BC6  1  A9 32           lda #INV_MOVE_SPEED_INIT
000BC8  1  85 rr           sta inv_move_speed
000BCA  1  85 rr           sta inv_move_timer
000BCC  1               
000BCC  1                  ; --- write initial sprite attributes for all 55 invaders ---
000BCC  1  20 35 0C        jsr update_invader_sprites
000BCF  1  60              rts
000BD0  1               
000BD0  1               ;******************************************************************
000BD0  1               ; step_invaders — one march step: move or drop grid, toggle anim frame
000BD0  1               ;   Called when inv_move_timer reaches 0.
000BD0  1               ;   Updates inv_grid_x / inv_offset_y, sets inv_drop_flag as needed,
000BD0  1               ;   then refreshes all VERA sprite positions.
000BD0  1               ;******************************************************************
000BD0  1               step_invaders:
000BD0  1                  ; toggle animation frame
000BD0  1  A5 rr           lda inv_anim_frame
000BD2  1  49 01           eor #1
000BD4  1  85 rr           sta inv_anim_frame
000BD6  1               
000BD6  1                  ; if drop flag is set: drop grid this step, skip march
000BD6  1  A5 rr           lda inv_drop_flag
000BD8  1  F0 0B           beq @do_march
000BDA  1  64 rr           stz inv_drop_flag
000BDC  1  A5 rr           lda inv_offset_y
000BDE  1  18              clc
000BDF  1  69 10           adc #INV_DROP_Y
000BE1  1  85 rr           sta inv_offset_y
000BE3  1  80 4C           bra @sprites_done
000BE5  1               
000BE5  1               @do_march:
000BE5  1  A5 rr           lda inv_direction
000BE7  1  D0 25           bne @march_left
000BE9  1               
000BE9  1                  ; --- march right ---
000BE9  1  A5 rr           lda inv_grid_x_lo
000BEB  1  18              clc
000BEC  1  69 04           adc #INV_STEP_X
000BEE  1  85 rr           sta inv_grid_x_lo
000BF0  1  90 02           bcc @chk_right
000BF2  1  E6 rr           inc inv_grid_x_hi
000BF4  1               @chk_right:
000BF4  1                  ; hit right if grid_x > INV_X_RIGHT_LIM (208, fits in 1 byte, hi always 0)
000BF4  1  A5 rr           lda inv_grid_x_hi
000BF6  1  D0 06           bne @clamp_right          ; hi > 0 → definitely over limit
000BF8  1  A5 rr           lda inv_grid_x_lo
000BFA  1  C9 D1           cmp #INV_X_RIGHT_LIM + 1  ; C set if lo > limit
000BFC  1  90 33           bcc @sprites_done
000BFE  1               @clamp_right:
000BFE  1  A9 D0           lda #<INV_X_RIGHT_LIM
000C00  1  85 rr           sta inv_grid_x_lo
000C02  1  A9 00           lda #>INV_X_RIGHT_LIM
000C04  1  85 rr           sta inv_grid_x_hi
000C06  1  A9 01           lda #1
000C08  1  85 rr           sta inv_direction
000C0A  1  85 rr           sta inv_drop_flag
000C0C  1  80 23           bra @sprites_done
000C0E  1               
000C0E  1                  ; --- march left ---
000C0E  1               @march_left:
000C0E  1  A5 rr           lda inv_grid_x_lo
000C10  1  38              sec
000C11  1  E9 04           sbc #INV_STEP_X
000C13  1  85 rr           sta inv_grid_x_lo
000C15  1  B0 02           bcs @chk_left             ; no borrow
000C17  1  C6 rr           dec inv_grid_x_hi
000C19  1               @chk_left:
000C19  1                  ; hit left if hi went negative OR lo < INV_X_LEFT_LIM
000C19  1  A5 rr           lda inv_grid_x_hi
000C1B  1  30 06           bmi @clamp_left
000C1D  1  A5 rr           lda inv_grid_x_lo
000C1F  1  C9 10           cmp #INV_X_LEFT_LIM
000C21  1  B0 0E           bcs @sprites_done         ; lo >= left limit → ok
000C23  1               @clamp_left:
000C23  1  A9 10           lda #<INV_X_LEFT_LIM
000C25  1  85 rr           sta inv_grid_x_lo
000C27  1  A9 00           lda #>INV_X_LEFT_LIM
000C29  1  85 rr           sta inv_grid_x_hi
000C2B  1  64 rr           stz inv_direction
000C2D  1  A9 01           lda #1
000C2F  1  85 rr           sta inv_drop_flag
000C31  1               
000C31  1               @sprites_done:
000C31  1  20 35 0C        jsr update_invader_sprites
000C34  1  60              rts
000C35  1               
000C35  1               ;******************************************************************
000C35  1               ; update_invader_sprites — write all 55 invader sprite attributes to VERA
000C35  1               ;
000C35  1               ;   VERA sprite slots 11-65 hold the 55 invaders.
000C35  1               ;   Attributes base: $1FC58 ($1FC00 + 11*8).
000C35  1               ;   With stride=1 the VERA address auto-increments, so we set it
000C35  1               ;   once and write all 440 bytes sequentially.
000C35  1               ;
000C35  1               ;   Byte layout per sprite:
000C35  1               ;     0: data addr[12:5]   (encodes VRAM pixel data address + frame)
000C35  1               ;     1: $00               (4bpp, addr[16:13]=0)
000C35  1               ;     2: X[7:0]
000C35  1               ;     3: X[9:8]
000C35  1               ;     4: Y[7:0]
000C35  1               ;     5: Y[9:8]
000C35  1               ;     6: z-depth/collision
000C35  1               ;     7: palette / size
000C35  1               ;
000C35  1               ;   Invader index i = row*11 + col; alive bit i in inv_alive bitmap.
000C35  1               ;   For Phase 3 all invaders are alive; alive check will be added Phase 4.
000C35  1               ;******************************************************************
000C35  1               update_invader_sprites:
000C35  1  9C 25 9F        stz VERA_ctrl
000C38  1  A9 11           lda #$11              ; stride=1, VRAM bank bit=1 (addr $1Fxxxx)
000C3A  1  8D 22 9F        sta VERA_addr_bank
000C3D  1  A9 FC           lda #$FC
000C3F  1  8D 21 9F        sta VERA_addr_high
000C42  1  A9 58           lda #$58
000C44  1  8D 20 9F        sta VERA_addr_low     ; VERA now at $1FC58, auto-increments by 1
000C47  1               
000C47  1                  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000C47  1  A9 50           lda #<INV_GRID_Y_BASE
000C49  1  18              clc
000C4A  1  65 rr           adc inv_offset_y
000C4C  1  85 rr           sta zp_y_base_lo
000C4E  1  A9 00           lda #>INV_GRID_Y_BASE
000C50  1  69 00           adc #0
000C52  1  85 rr           sta zp_y_base_hi
000C54  1               
000C54  1  64 rr           stz zp_row
000C56  1               @row_loop:
000C56  1                  ; compute row Y: zp_row_y = zp_y_base + row_y_offsets[row]
000C56  1  A4 rr           ldy zp_row
000C58  1  B9 11 14        lda row_y_offsets,y
000C5B  1  18              clc
000C5C  1  65 rr           adc zp_y_base_lo
000C5E  1  85 rr           sta zp_row_y_lo
000C60  1  A9 00           lda #0
000C62  1  65 rr           adc zp_y_base_hi
000C64  1  85 rr           sta zp_row_y_hi
000C66  1               
000C66  1                  ; select addr byte0 based on row type and animation frame
000C66  1  A4 rr           ldy zp_row
000C68  1  A5 rr           lda inv_anim_frame
000C6A  1  F0 05           beq @use_f0
000C6C  1  B9 F6 13        lda inv_addr_b0_f1,y
000C6F  1  80 03           bra @got_b0
000C71  1               @use_f0:
000C71  1  B9 F1 13        lda inv_addr_b0_f0,y
000C74  1               @got_b0:
000C74  1  85 rr           sta zp_addr_b0
000C76  1               
000C76  1  20 82 0C        jsr update_invader_row
000C79  1               
000C79  1  E6 rr           inc zp_row
000C7B  1  A5 rr           lda zp_row
000C7D  1  C9 05           cmp #5
000C7F  1  D0 D5           bne @row_loop
000C81  1               
000C81  1  60              rts
000C82  1               
000C82  1               ;******************************************************************
000C82  1               ; update_invader_row — write 11 sprite attribute blocks for one row
000C82  1               ;
000C82  1               ;   Inputs (ZP): zp_row, zp_addr_b0, zp_row_y_lo/hi, inv_grid_x_lo/hi
000C82  1               ;   VERA address register must already be set to the first sprite slot
000C82  1               ;   for this row on entry (maintained by the sequential write stream).
000C82  1               ;******************************************************************
000C82  1               update_invader_row:
000C82  1  64 rr           stz zp_col
000C84  1               @col_loop:
000C84  1                  ; --- determine z-depth from alive bitmap ---
000C84  1                  ; index = inv_row_base[row] + col; byte = index>>3; bit = index&7
000C84  1  A4 rr           ldy zp_row
000C86  1  B9 16 14        lda inv_row_base,y
000C89  1  18              clc
000C8A  1  65 rr           adc zp_col
000C8C  1  A8              tay                   ; Y = invader index
000C8D  1  29 07           and #$07
000C8F  1  AA              tax                   ; X = bit index
000C90  1  BD 1B 14        lda bit_masks,x
000C93  1  48              pha                   ; save bit mask
000C94  1  98              tya
000C95  1  4A              lsr
000C96  1  4A              lsr
000C97  1  4A              lsr
000C98  1  A8              tay                   ; Y = byte index into inv_alive
000C99  1  68              pla                   ; A = bit mask
000C9A  1  39 rr rr        and inv_alive,y
000C9D  1  F0 04           beq @zdepth_off
000C9F  1  A9 0C           lda #SPR_Z_FRONT
000CA1  1  80 02           bra @zdepth_done
000CA3  1               @zdepth_off:
000CA3  1  A9 00           lda #0
000CA5  1               @zdepth_done:
000CA5  1  85 rr           sta zp_scratch_lo     ; save z-depth before VERA stream starts
000CA7  1               
000CA7  1                  ; --- compute sprite X = inv_grid_x + col_x_offsets[col] ---
000CA7  1  A4 rr           ldy zp_col
000CA9  1  B9 FB 13        lda col_x_lo,y
000CAC  1  18              clc
000CAD  1  65 rr           adc inv_grid_x_lo
000CAF  1  85 rr           sta zp_x_lo
000CB1  1  B9 06 14        lda col_x_hi,y
000CB4  1  65 rr           adc inv_grid_x_hi
000CB6  1  85 rr           sta zp_x_hi
000CB8  1               
000CB8  1                  ; --- write 8 attribute bytes (VERA auto-increments) ---
000CB8  1  A5 rr           lda zp_addr_b0
000CBA  1  8D 23 9F        sta VERA_data0        ; byte 0: data addr[12:5]
000CBD  1  9C 23 9F        stz VERA_data0        ; byte 1: 4bpp, addr[16:13]=0
000CC0  1  A5 rr           lda zp_x_lo
000CC2  1  8D 23 9F        sta VERA_data0        ; byte 2: X[7:0]
000CC5  1  A5 rr           lda zp_x_hi
000CC7  1  29 03           and #$03
000CC9  1  8D 23 9F        sta VERA_data0        ; byte 3: X[9:8]
000CCC  1  A5 rr           lda zp_row_y_lo
000CCE  1  8D 23 9F        sta VERA_data0        ; byte 4: Y[7:0]
000CD1  1  A5 rr           lda zp_row_y_hi
000CD3  1  29 03           and #$03
000CD5  1  8D 23 9F        sta VERA_data0        ; byte 5: Y[9:8]
000CD8  1  A5 rr           lda zp_scratch_lo
000CDA  1  8D 23 9F        sta VERA_data0        ; byte 6: z-depth (SPR_Z_FRONT if alive, 0 if dead)
000CDD  1  A9 50           lda #SPR_16x16_PAL0
000CDF  1  8D 23 9F        sta VERA_data0        ; byte 7: 16x16, palette offset 0
000CE2  1               
000CE2  1  E6 rr           inc zp_col
000CE4  1  A5 rr           lda zp_col
000CE6  1  C9 0B           cmp #11
000CE8  1  D0 9A           bne @col_loop
000CEA  1               
000CEA  1  60              rts
000CEB  1               
000CEB  1               ;******************************************************************
000CEB  1               ; move_player — apply key_flags movement and clamp to screen edges
000CEB  1               ;******************************************************************
000CEB  1               move_player:
000CEB  1  A5 rr           lda key_flags
000CED  1               
000CED  1                  ; --- move left ---
000CED  1  29 01           and #KEY_LEFT
000CEF  1  F0 1F           beq @check_right
000CF1  1  A5 rr           lda player_x_lo
000CF3  1  38              sec
000CF4  1  E9 04           sbc #PLAYER_SPEED
000CF6  1  85 rr           sta player_x_lo
000CF8  1  B0 02           bcs @clamp_left              ; no borrow → hi unchanged
000CFA  1  C6 rr           dec player_x_hi
000CFC  1               @clamp_left:
000CFC  1                  ; Clamp: if hi went negative ($FF) or (hi=0 AND lo < min) → set to min
000CFC  1  A5 rr           lda player_x_hi
000CFE  1  30 08           bmi @set_min                 ; $80–$FF = underflowed
000D00  1  D0 0E           bne @check_right             ; hi > 0 → still above minimum
000D02  1  A5 rr           lda player_x_lo
000D04  1  C9 08           cmp #PLAYER_X_MIN
000D06  1  B0 08           bcs @check_right             ; lo >= min → ok
000D08  1               @set_min:
000D08  1  A9 08           lda #<PLAYER_X_MIN
000D0A  1  85 rr           sta player_x_lo
000D0C  1  A9 00           lda #>PLAYER_X_MIN
000D0E  1  85 rr           sta player_x_hi
000D10  1               
000D10  1                  ; --- move right ---
000D10  1               @check_right:
000D10  1  A5 rr           lda key_flags
000D12  1  29 02           and #KEY_RIGHT
000D14  1  F0 23           beq @move_done
000D16  1  A5 rr           lda player_x_lo
000D18  1  18              clc
000D19  1  69 04           adc #PLAYER_SPEED
000D1B  1  85 rr           sta player_x_lo
000D1D  1  90 02           bcc @clamp_right             ; no carry → hi unchanged
000D1F  1  E6 rr           inc player_x_hi
000D21  1               @clamp_right:
000D21  1                  ; Clamp: if hi > max_hi, OR (hi == max_hi AND lo > max_lo) → set to max
000D21  1  A5 rr           lda player_x_hi
000D23  1  C9 02           cmp #>PLAYER_X_MAX
000D25  1  90 12           bcc @move_done               ; hi < max_hi → definitely ok
000D27  1  D0 08           bne @set_max                 ; hi > max_hi → over limit
000D29  1  A5 rr           lda player_x_lo
000D2B  1  C9 68           cmp #<PLAYER_X_MAX
000D2D  1  90 0A           bcc @move_done               ; lo < max_lo when hi == max_hi → ok
000D2F  1  F0 08           beq @move_done               ; lo == max_lo → exactly at max, ok
000D31  1               @set_max:
000D31  1  A9 68           lda #<PLAYER_X_MAX
000D33  1  85 rr           sta player_x_lo
000D35  1  A9 02           lda #>PLAYER_X_MAX
000D37  1  85 rr           sta player_x_hi
000D39  1               
000D39  1               @move_done:
000D39  1  60              rts
000D3A  1               
000D3A  1               ;******************************************************************
000D3A  1               ; update_player_sprite — write current X position to sprite 1 in VERA
000D3A  1               ;   Only X needs updating (Y is fixed)
000D3A  1               ;******************************************************************
000D3A  1               update_player_sprite:
000D3A  1  9C 25 9F        stz VERA_ctrl
000D3D  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 2), 1
000D41  1  9F A9 FC 8D  
000D45  1  21 9F A9 0A  
000D4C  1  A5 rr           lda player_x_lo
000D4E  1  8D 23 9F        sta VERA_data0               ; sprite byte 2: X[7:0]
000D51  1  A5 rr           lda player_x_hi
000D53  1  29 03           and #$03
000D55  1  8D 23 9F        sta VERA_data0               ; sprite byte 3: X[9:8]
000D58  1                  ; update z-depth based on inv_hit_timer:
000D58  1                  ;   timer = 0        → show solid (not hit)
000D58  1                  ;   timer = 61-120   → hidden solid (1-second respawn delay)
000D58  1                  ;   timer = 1-60     → flashing (invincible, visible warning)
000D58  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 6), 1
000D5C  1  9F A9 FC 8D  
000D60  1  21 9F A9 0E  
000D67  1  A5 rr           lda inv_hit_timer
000D69  1  F0 08           beq @show                    ; timer=0 → show solid
000D6B  1  C9 3D           cmp #61
000D6D  1  B0 08           bcs @hide                    ; timer>=61 → first second: fully hidden
000D6F  1  29 08           and #$08                     ; timer 1-60: bit 3 flips every 8 frames → ~4 Hz flash
000D71  1  D0 04           bne @hide
000D73  1               @show:
000D73  1  A9 0C           lda #SPR_Z_FRONT
000D75  1  80 02           bra @write_z
000D77  1               @hide:
000D77  1  A9 00           lda #0
000D79  1               @write_z:
000D79  1  8D 23 9F        sta VERA_data0               ; sprite byte 6: z-depth
000D7C  1  60              rts
000D7D  1               
000D7D  1               ;******************************************************************
000D7D  1               ; fire_bullet — activate player bullet at cannon tip, update sprite
000D7D  1               ;   Bullet X centers the 8-px bullet over the 16-px player ship:
000D7D  1               ;     bullet_x = player_x + 4
000D7D  1               ;   Bullet Y starts 8 VERA pixels above the player sprite top.
000D7D  1               ;   Caller must check bullet_active == 0 before calling.
000D7D  1               ;******************************************************************
000D7D  1               fire_bullet:
000D7D  1  A5 rr           lda player_x_lo
000D7F  1  18              clc
000D80  1  69 04           adc #4
000D82  1  85 rr           sta bullet_x_lo
000D84  1  A5 rr           lda player_x_hi
000D86  1  69 00           adc #0
000D88  1  85 rr           sta bullet_x_hi
000D8A  1               
000D8A  1  A9 9C           lda #<BULLET_Y_INIT
000D8C  1  85 rr           sta bullet_y_lo
000D8E  1  A9 01           lda #>BULLET_Y_INIT
000D90  1  85 rr           sta bullet_y_hi
000D92  1               
000D92  1  A9 01           lda #1
000D94  1  85 rr           sta bullet_active
000D96  1  20 B3 0D        jsr update_bullet_sprite
000D99  1  60              rts
000D9A  1               
000D9A  1               ;******************************************************************
000D9A  1               ; move_bullet — move bullet upward by BULLET_SPEED each frame;
000D9A  1               ;   deactivate when it reaches the top of the screen (Y underflows 0)
000D9A  1               ;******************************************************************
000D9A  1               move_bullet:
000D9A  1  A5 rr           lda bullet_y_lo
000D9C  1  38              sec
000D9D  1  E9 0C           sbc #BULLET_SPEED
000D9F  1  85 rr           sta bullet_y_lo
000DA1  1  A5 rr           lda bullet_y_hi
000DA3  1  E9 00           sbc #0
000DA5  1  85 rr           sta bullet_y_hi
000DA7  1  30 04           bmi @deactivate              ; 16-bit underflow past 0 → off screen
000DA9  1               
000DA9  1  20 B3 0D        jsr update_bullet_sprite
000DAC  1  60              rts
000DAD  1               
000DAD  1               @deactivate:
000DAD  1  64 rr           stz bullet_active
000DAF  1  20 B3 0D        jsr update_bullet_sprite     ; disables sprite (z-depth=0)
000DB2  1  60              rts
000DB3  1               
000DB3  1               ;******************************************************************
000DB3  1               ; update_bullet_sprite — write bullet position and enable/disable
000DB3  1               ;   to VERA sprite 2 (bytes 2-6); byte 7 set once at init.
000DB3  1               ;   z-depth = SPR_Z_FRONT when active, 0 when inactive.
000DB3  1               ;******************************************************************
000DB3  1               update_bullet_sprite:
000DB3  1  9C 25 9F        stz VERA_ctrl
000DB6  1  A9 11 8D 22     VERA_SET_ADDR (BULLET_SPRITE_ATTR + 2), 1
000DBA  1  9F A9 FC 8D  
000DBE  1  21 9F A9 12  
000DC5  1  A5 rr           lda bullet_x_lo
000DC7  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000DCA  1  A5 rr           lda bullet_x_hi
000DCC  1  29 03           and #$03
000DCE  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000DD1  1  A5 rr           lda bullet_y_lo
000DD3  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000DD6  1  A5 rr           lda bullet_y_hi
000DD8  1  29 03           and #$03
000DDA  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000DDD  1  A5 rr           lda bullet_active
000DDF  1  F0 04           beq @z_off
000DE1  1  A9 0C           lda #SPR_Z_FRONT
000DE3  1  80 02           bra @write_z
000DE5  1               @z_off:
000DE5  1  A9 00           lda #$00
000DE7  1               @write_z:
000DE7  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
000DEA  1  60              rts
000DEB  1               
000DEB  1               ;******************************************************************
000DEB  1               ; check_bullet_invader — scan all 55 invaders for a hit with the player bullet
000DEB  1               ;
000DEB  1               ;   Iterates rows 0-4, columns 0-10.  Skips dead invaders.
000DEB  1               ;   For each live invader checks 16-bit AABB overlap:
000DEB  1               ;     X: bullet_x+8 > inv_x  AND  bullet_x < inv_x+16
000DEB  1               ;     Y: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000DEB  1               ;   On hit: calls kill_invader_hit and returns immediately.
000DEB  1               ;
000DEB  1               ;   Scratch used: zp_y_base_lo/hi, zp_row_y_lo/hi, zp_x_lo/hi,
000DEB  1               ;                 zp_scratch_lo/hi, zp_row, zp_col
000DEB  1               ;******************************************************************
000DEB  1               check_bullet_invader:
000DEB  1  A5 rr           lda bullet_active
000DED  1  D0 01           bne :+
000DEF  1  60              rts
000DF0  1               :  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000DF0  1  A9 50           lda #<INV_GRID_Y_BASE
000DF2  1  18              clc
000DF3  1  65 rr           adc inv_offset_y
000DF5  1  85 rr           sta zp_y_base_lo
000DF7  1  A9 00           lda #>INV_GRID_Y_BASE
000DF9  1  69 00           adc #0
000DFB  1  85 rr           sta zp_y_base_hi
000DFD  1               
000DFD  1  64 rr           stz zp_row
000DFF  1               @row_loop:
000DFF  1                  ; row Y = y_base + row_y_offsets[row]
000DFF  1  A4 rr           ldy zp_row
000E01  1  B9 11 14        lda row_y_offsets,y
000E04  1  18              clc
000E05  1  65 rr           adc zp_y_base_lo
000E07  1  85 rr           sta zp_row_y_lo
000E09  1  A9 00           lda #0
000E0B  1  65 rr           adc zp_y_base_hi
000E0D  1  85 rr           sta zp_row_y_hi
000E0F  1               
000E0F  1                  ; --- Quick Y range check for whole row ---
000E0F  1                  ; Need: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000E0F  1               
000E0F  1                  ; (1) bullet_y+8 > inv_y  →  (bullet_y+8) - inv_y > 0
000E0F  1                  ;     result negative (bmi) means bullet above this row
000E0F  1  A5 rr           lda bullet_y_lo
000E11  1  18              clc
000E12  1  69 08           adc #8
000E14  1  85 rr           sta zp_scratch_lo
000E16  1  A5 rr           lda bullet_y_hi
000E18  1  69 00           adc #0
000E1A  1  85 rr           sta zp_scratch_hi
000E1C  1  A5 rr           lda zp_scratch_lo
000E1E  1  38              sec
000E1F  1  E5 rr           sbc zp_row_y_lo
000E21  1  A5 rr           lda zp_scratch_hi
000E23  1  E5 rr           sbc zp_row_y_hi
000E25  1  30 1D           bmi @next_row         ; bullet bottom above invader top → no hit in this row
000E27  1               
000E27  1                  ; (2) bullet_y < inv_y+16  →  bullet_y - (inv_y+16) < 0
000E27  1                  ;     result >= 0 (bpl) means bullet below this row
000E27  1  A5 rr           lda zp_row_y_lo
000E29  1  18              clc
000E2A  1  69 10           adc #16
000E2C  1  85 rr           sta zp_scratch_lo
000E2E  1  A5 rr           lda zp_row_y_hi
000E30  1  69 00           adc #0
000E32  1  85 rr           sta zp_scratch_hi
000E34  1  A5 rr           lda bullet_y_lo
000E36  1  38              sec
000E37  1  E5 rr           sbc zp_scratch_lo
000E39  1  A5 rr           lda bullet_y_hi
000E3B  1  E5 rr           sbc zp_scratch_hi
000E3D  1  10 05           bpl @next_row         ; bullet top at or below invader bottom → no hit
000E3F  1               
000E3F  1                  ; Y overlaps this row — check each column
000E3F  1  20 4D 0E        jsr cbi_check_cols
000E42  1  B0 08           bcs @done             ; hit found; bullet already handled
000E44  1               
000E44  1               @next_row:
000E44  1  E6 rr           inc zp_row
000E46  1  A5 rr           lda zp_row
000E48  1  C9 05           cmp #5
000E4A  1  D0 B3           bne @row_loop
000E4C  1               
000E4C  1               @done:
000E4C  1  60              rts
000E4D  1               
000E4D  1               ;******************************************************************
000E4D  1               ; cbi_check_cols — column scan for check_bullet_invader
000E4D  1               ;
000E4D  1               ;   Scans all 11 columns of zp_row for an X overlap with the bullet.
000E4D  1               ;   Assumes Y overlap for this row has already been confirmed.
000E4D  1               ;   Returns: C set if hit (kill_invader_hit already called),
000E4D  1               ;            C clear if no hit.
000E4D  1               ;   Scratch used: zp_col, zp_x_lo/hi, zp_scratch_lo/hi
000E4D  1               ;******************************************************************
000E4D  1               cbi_check_cols:
000E4D  1  64 rr           stz zp_col
000E4F  1               @col_loop:
000E4F  1                  ; skip if invader is dead
000E4F  1  A4 rr           ldy zp_row
000E51  1  B9 16 14        lda inv_row_base,y
000E54  1  18              clc
000E55  1  65 rr           adc zp_col
000E57  1  A8              tay                   ; Y = invader index
000E58  1  29 07           and #$07
000E5A  1  AA              tax
000E5B  1  BD 1B 14        lda bit_masks,x
000E5E  1  48              pha
000E5F  1  98              tya
000E60  1  4A              lsr
000E61  1  4A              lsr
000E62  1  4A              lsr
000E63  1  A8              tay                   ; Y = byte index into inv_alive
000E64  1  68              pla
000E65  1  39 rr rr        and inv_alive,y
000E68  1  F0 46           beq @next_col         ; dead
000E6A  1               
000E6A  1                  ; compute inv_x = inv_grid_x + col_x_offsets[col]
000E6A  1  A4 rr           ldy zp_col
000E6C  1  B9 FB 13        lda col_x_lo,y
000E6F  1  18              clc
000E70  1  65 rr           adc inv_grid_x_lo
000E72  1  85 rr           sta zp_x_lo
000E74  1  B9 06 14        lda col_x_hi,y
000E77  1  65 rr           adc inv_grid_x_hi
000E79  1  85 rr           sta zp_x_hi
000E7B  1               
000E7B  1                  ; X check (1): bullet_x+8 > inv_x
000E7B  1  A5 rr           lda bullet_x_lo
000E7D  1  18              clc
000E7E  1  69 08           adc #8
000E80  1  85 rr           sta zp_scratch_lo
000E82  1  A5 rr           lda bullet_x_hi
000E84  1  69 00           adc #0
000E86  1  85 rr           sta zp_scratch_hi
000E88  1  A5 rr           lda zp_scratch_lo
000E8A  1  38              sec
000E8B  1  E5 rr           sbc zp_x_lo
000E8D  1  A5 rr           lda zp_scratch_hi
000E8F  1  E5 rr           sbc zp_x_hi
000E91  1  30 1D           bmi @next_col         ; bullet right edge left of invader → no hit
000E93  1               
000E93  1                  ; X check (2): bullet_x < inv_x+16
000E93  1  A5 rr           lda zp_x_lo
000E95  1  18              clc
000E96  1  69 10           adc #16
000E98  1  85 rr           sta zp_scratch_lo
000E9A  1  A5 rr           lda zp_x_hi
000E9C  1  69 00           adc #0
000E9E  1  85 rr           sta zp_scratch_hi
000EA0  1  A5 rr           lda bullet_x_lo
000EA2  1  38              sec
000EA3  1  E5 rr           sbc zp_scratch_lo
000EA5  1  A5 rr           lda bullet_x_hi
000EA7  1  E5 rr           sbc zp_scratch_hi
000EA9  1  10 05           bpl @next_col         ; bullet left edge at or right of invader → no hit
000EAB  1               
000EAB  1                  ; --- HIT ---
000EAB  1  20 BA 0E        jsr kill_invader_hit
000EAE  1  38              sec                   ; signal hit to caller
000EAF  1  60              rts
000EB0  1               
000EB0  1               @next_col:
000EB0  1  E6 rr           inc zp_col
000EB2  1  A5 rr           lda zp_col
000EB4  1  C9 0B           cmp #11
000EB6  1  D0 97           bne @col_loop
000EB8  1               
000EB8  1  18              clc                   ; no hit
000EB9  1  60              rts
000EBA  1               
000EBA  1               ;******************************************************************
000EBA  1               ; kill_invader_hit — clear alive bit, deactivate bullet, update score & speed
000EBA  1               ;   Expects zp_row, zp_col to identify the hit invader.
000EBA  1               ;******************************************************************
000EBA  1               kill_invader_hit:
000EBA  1                  ; --- clear alive bit ---
000EBA  1  A4 rr           ldy zp_row
000EBC  1  B9 16 14        lda inv_row_base,y
000EBF  1  18              clc
000EC0  1  65 rr           adc zp_col
000EC2  1  A8              tay                   ; Y = invader index
000EC3  1  29 07           and #$07
000EC5  1  AA              tax
000EC6  1  BD 1B 14        lda bit_masks,x       ; bit mask for this invader
000EC9  1  48              pha
000ECA  1  98              tya
000ECB  1  4A              lsr
000ECC  1  4A              lsr
000ECD  1  4A              lsr
000ECE  1  A8              tay                   ; Y = byte index into inv_alive
000ECF  1  68              pla
000ED0  1  49 FF           eor #$FF              ; invert → clear mask
000ED2  1  39 rr rr        and inv_alive,y
000ED5  1  99 rr rr        sta inv_alive,y
000ED8  1               
000ED8  1                  ; --- start explosion at the hit invader's position ---
000ED8  1                  ; zp_x_lo/hi and zp_row_y_lo/hi still hold the invader coords from collision detection
000ED8  1  20 06 0F        jsr start_explosion
000EDB  1               
000EDB  1                  ; --- deactivate bullet ---
000EDB  1  64 rr           stz bullet_active
000EDD  1  20 B3 0D        jsr update_bullet_sprite
000EE0  1               
000EE0  1                  ; --- decrement inv_count ---
000EE0  1  C6 rr           dec inv_count
000EE2  1               
000EE2  1                  ; --- update inv_move_speed: proportional to remaining count ---
000EE2  1  A6 rr           ldx inv_count
000EE4  1  BD 28 14        lda inv_speed_table,x
000EE7  1  85 rr           sta inv_move_speed
000EE9  1               
000EE9  1                  ; --- add score for this row's invader type ---
000EE9  1  A4 rr           ldy zp_row
000EEB  1  B9 23 14        lda score_by_row_bcd,y
000EEE  1  20 F2 0E        jsr add_score
000EF1  1  60              rts
000EF2  1               
000EF2  1               ;******************************************************************
000EF2  1               ; add_score — add BCD value in A to score_lo/mid/hi
000EF2  1               ;******************************************************************
000EF2  1               add_score:
000EF2  1  F8              sed
000EF3  1  18              clc
000EF4  1  65 rr           adc score_lo
000EF6  1  85 rr           sta score_lo
000EF8  1  A5 rr           lda score_mid
000EFA  1  69 00           adc #0
000EFC  1  85 rr           sta score_mid
000EFE  1  A5 rr           lda score_hi
000F00  1  69 00           adc #0
000F02  1  85 rr           sta score_hi
000F04  1  D8              cld
000F05  1  60              rts
000F06  1               
000F06  1               ;******************************************************************
000F06  1               ; start_explosion — position sprite 4 at the hit invader and start timer
000F06  1               ;
000F06  1               ;   Inputs: zp_x_lo/hi     — invader X (VERA coords)
000F06  1               ;           zp_row_y_lo/hi — invader Y (VERA coords)
000F06  1               ;   Sets exp_timer = EXPLODE_FRAMES and enables sprite 4.
000F06  1               ;******************************************************************
000F06  1               start_explosion:
000F06  1  9C 25 9F        stz VERA_ctrl
000F09  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 2), 1  ; start at byte 2 (X lo)
000F0D  1  9F A9 FC 8D  
000F11  1  21 9F A9 22  
000F18  1  A5 rr           lda zp_x_lo
000F1A  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000F1D  1  A5 rr           lda zp_x_hi
000F1F  1  29 03           and #$03
000F21  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000F24  1  A5 rr           lda zp_row_y_lo
000F26  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000F29  1  A5 rr           lda zp_row_y_hi
000F2B  1  29 03           and #$03
000F2D  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000F30  1  A9 0C           lda #SPR_Z_FRONT
000F32  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3 → enabled, in front
000F35  1  A9 1E           lda #EXPLODE_FRAMES
000F37  1  85 rr           sta exp_timer
000F39  1  60              rts
000F3A  1               
000F3A  1               ;******************************************************************
000F3A  1               ; update_explosion — decrement exp_timer; disable sprite when it hits 0
000F3A  1               ;******************************************************************
000F3A  1               update_explosion:
000F3A  1  A5 rr           lda exp_timer
000F3C  1  F0 1B           beq @inactive
000F3E  1  C6 rr           dec exp_timer
000F40  1  D0 17           bne @inactive
000F42  1                  ; timer just expired — disable sprite 4
000F42  1  9C 25 9F        stz VERA_ctrl
000F45  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1  ; byte 6 = z-depth
000F49  1  9F A9 FC 8D  
000F4D  1  21 9F A9 26  
000F54  1  A9 00           lda #$00
000F56  1  8D 23 9F        sta VERA_data0               ; z-depth=0 → disabled
000F59  1               @inactive:
000F59  1  60              rts
000F5A  1               
000F5A  1               ;******************************************************************
000F5A  1               ; prng — 16-bit Galois LFSR, feedback polynomial $B400
000F5A  1               ;   Updates rand_seed_lo/hi; returns pseudo-random byte in A.
000F5A  1               ;******************************************************************
000F5A  1               prng:
000F5A  1  46 rr           lsr rand_seed_hi          ; shift 16-bit state right; carry = old hi[0]
000F5C  1  66 rr           ror rand_seed_lo          ; lo[7] = old hi[0]; carry = old lo[0] (feedback bit)
000F5E  1  90 06           bcc @done                 ; feedback bit=0: no XOR
000F60  1  A5 rr           lda rand_seed_hi
000F62  1  49 B4           eor #$B4                  ; XOR hi byte with feedback poly ($B400 >> 8)
000F64  1  85 rr           sta rand_seed_hi
000F66  1               @done:
000F66  1  A5 rr           lda rand_seed_lo
000F68  1  60              rts
000F69  1               
000F69  1               ;******************************************************************
000F69  1               ; update_inv_bullets — fire timer, move active bullets, boundary check,
000F69  1               ;   update VERA sprites for all 3 invader bullet slots.
000F69  1               ;******************************************************************
000F69  1               update_inv_bullets:
000F69  1                  ; --- fire timer ---
000F69  1  C6 rr           dec inv_fire_timer
000F6B  1  D0 0D           bne @move_loop
000F6D  1                  ; reset timer = max(inv_move_speed, INV_FIRE_TIMER_MIN)
000F6D  1  A5 rr           lda inv_move_speed
000F6F  1  C9 0A           cmp #INV_FIRE_TIMER_MIN
000F71  1  B0 02           bcs @set_timer
000F73  1  A9 0A           lda #INV_FIRE_TIMER_MIN
000F75  1               @set_timer:
000F75  1  85 rr           sta inv_fire_timer
000F77  1  20 E4 0F        jsr try_fire_inv_bullet
000F7A  1               
000F7A  1               @move_loop:
000F7A  1  A2 00           ldx #0
000F7C  1               @slot_loop:
000F7C  1  B5 rr           lda ibul_active,x
000F7E  1  F0 1B           beq @update_spr           ; inactive: just hide sprite
000F80  1               
000F80  1                  ; move bullet down by INV_BULLET_SPEED
000F80  1  B5 rr           lda ibul_y_lo,x
000F82  1  18              clc
000F83  1  69 06           adc #INV_BULLET_SPEED
000F85  1  95 rr           sta ibul_y_lo,x
000F87  1  B5 rr           lda ibul_y_hi,x
000F89  1  69 00           adc #0
000F8B  1  95 rr           sta ibul_y_hi,x
000F8D  1               
000F8D  1                  ; boundary: deactivate if Y >= 480 ($01E0)
000F8D  1  C9 01           cmp #>480                 ; A = new hi byte; compare with 1
000F8F  1  90 0A           bcc @update_spr           ; hi < 1: still on screen
000F91  1  D0 06           bne @deactivate           ; hi > 1: off screen
000F93  1  B5 rr           lda ibul_y_lo,x
000F95  1  C9 E0           cmp #<480                 ; compare lo with $E0
000F97  1  90 02           bcc @update_spr           ; lo < $E0: still on screen
000F99  1               @deactivate:
000F99  1  74 rr           stz ibul_active,x
000F9B  1               
000F9B  1               @update_spr:
000F9B  1  20 A4 0F        jsr update_inv_bullet_sprite   ; preserves X
000F9E  1  E8              inx
000F9F  1  E0 03           cpx #3
000FA1  1  D0 D9           bne @slot_loop
000FA3  1  60              rts
000FA4  1               
000FA4  1               ;******************************************************************
000FA4  1               ; update_inv_bullet_sprite — write VERA sprite attrs bytes 2-6 for slot X
000FA4  1               ;   X = slot index (0-2).  Preserves X.
000FA4  1               ;******************************************************************
000FA4  1               update_inv_bullet_sprite:
000FA4  1  86 rr           stx zp_scratch_lo              ; preserve slot index
000FA6  1  9C 25 9F        stz VERA_ctrl
000FA9  1  A9 11           lda #$11                       ; stride=1, bank bit=1
000FAB  1  8D 22 9F        sta VERA_addr_bank
000FAE  1  A9 FC           lda #$FC
000FB0  1  8D 21 9F        sta VERA_addr_high
000FB3  1  BD 60 14        lda ibul_spr_lo,x
000FB6  1  18              clc
000FB7  1  69 02           adc #2                         ; point to byte 2 (X position)
000FB9  1  8D 20 9F        sta VERA_addr_low
000FBC  1  B5 rr           lda ibul_x_lo,x
000FBE  1  8D 23 9F        sta VERA_data0                 ; byte 2: X lo
000FC1  1  B5 rr           lda ibul_x_hi,x
000FC3  1  29 03           and #$03
000FC5  1  8D 23 9F        sta VERA_data0                 ; byte 3: X hi
000FC8  1  B5 rr           lda ibul_y_lo,x
000FCA  1  8D 23 9F        sta VERA_data0                 ; byte 4: Y lo
000FCD  1  B5 rr           lda ibul_y_hi,x
000FCF  1  29 03           and #$03
000FD1  1  8D 23 9F        sta VERA_data0                 ; byte 5: Y hi
000FD4  1  B5 rr           lda ibul_active,x
000FD6  1  F0 04           beq @disabled
000FD8  1  A9 0C           lda #SPR_Z_FRONT
000FDA  1  80 02           bra @write_z
000FDC  1               @disabled:
000FDC  1  A9 00           lda #0
000FDE  1               @write_z:
000FDE  1  8D 23 9F        sta VERA_data0                 ; byte 6: z-depth
000FE1  1  A6 rr           ldx zp_scratch_lo
000FE3  1  60              rts
000FE4  1               
000FE4  1               ;******************************************************************
000FE4  1               ; try_fire_inv_bullet — find a free slot and spawn a bullet from the
000FE4  1               ;   bottommost live invader in a randomly chosen column.
000FE4  1               ;   Returns immediately if all slots busy or chosen column is empty.
000FE4  1               ;   Scratch used: zp_row, zp_col, zp_scratch_lo (slot index)
000FE4  1               ;******************************************************************
000FE4  1               try_fire_inv_bullet:
000FE4  1                  ; find a free bullet slot
000FE4  1  A2 00           ldx #0
000FE6  1               @find_slot:
000FE6  1  B5 rr           lda ibul_active,x
000FE8  1  F0 06           beq @slot_found
000FEA  1  E8              inx
000FEB  1  E0 03           cpx #3
000FED  1  D0 F7           bne @find_slot
000FEF  1  60              rts                            ; all slots busy
000FF0  1               
000FF0  1               @slot_found:
000FF0  1  86 rr           stx zp_scratch_lo              ; save free slot index
000FF2  1               
000FF2  1                  ; pick a random column 0-10
000FF2  1  20 5A 0F        jsr prng
000FF5  1  29 0F           and #$0F                       ; 0-15
000FF7  1  C9 0B           cmp #11
000FF9  1  90 03           bcc @col_ok
000FFB  1  38              sec
000FFC  1  E9 0B           sbc #11                        ; wrap 11-15 → 0-4 (slight bias, acceptable)
000FFE  1               @col_ok:
000FFE  1  85 rr           sta zp_col
001000  1               
001000  1                  ; scan rows 4 down to 0 for bottommost live invader in this column
001000  1  A9 04           lda #4
001002  1  85 rr           sta zp_row
001004  1               @row_scan:
001004  1  A4 rr           ldy zp_row
001006  1  B9 16 14        lda inv_row_base,y
001009  1  18              clc
00100A  1  65 rr           adc zp_col
00100C  1  A8              tay                            ; Y = invader index
00100D  1  29 07           and #$07
00100F  1  AA              tax                            ; X = bit position
001010  1  BD 1B 14        lda bit_masks,x
001013  1  48              pha
001014  1  98              tya
001015  1  4A              lsr
001016  1  4A              lsr
001017  1  4A              lsr
001018  1  A8              tay                            ; Y = byte index into inv_alive
001019  1  68              pla
00101A  1  39 rr rr        and inv_alive,y
00101D  1  D0 09           bne @found_invader
00101F  1  A5 rr           lda zp_row
001021  1  F0 04           beq @no_invader                ; checked row 0, nothing alive
001023  1  C6 rr           dec zp_row
001025  1  80 DD           bra @row_scan
001027  1               
001027  1               @no_invader:
001027  1  60              rts                            ; column empty, skip fire
001028  1               
001028  1               @found_invader:
001028  1  A6 rr           ldx zp_scratch_lo              ; restore free slot index
00102A  1  A9 01           lda #1
00102C  1  95 rr           sta ibul_active,x
00102E  1               
00102E  1                  ; spawn X = inv_grid_x + col_x_offsets[col]  (16-bit, matching update_invader_sprites)
00102E  1  A4 rr           ldy zp_col
001030  1  B9 FB 13        lda col_x_lo,y
001033  1  18              clc
001034  1  65 rr           adc inv_grid_x_lo
001036  1  95 rr           sta ibul_x_lo,x
001038  1  B9 06 14        lda col_x_hi,y
00103B  1  65 rr           adc inv_grid_x_hi
00103D  1  95 rr           sta ibul_x_hi,x
00103F  1                  ; add +4 as a separate 16-bit step to centre the 8px bullet in the 16px invader
00103F  1  B5 rr           lda ibul_x_lo,x
001041  1  18              clc
001042  1  69 04           adc #4
001044  1  95 rr           sta ibul_x_lo,x
001046  1  B5 rr           lda ibul_x_hi,x
001048  1  69 00           adc #0
00104A  1  95 rr           sta ibul_x_hi,x
00104C  1               
00104C  1                  ; spawn Y: compute y_base first (same two-step pattern as update_invader_sprites)
00104C  1                  ; step 1: y_base = INV_GRID_Y_BASE + inv_offset_y  (16-bit)
00104C  1  A9 50           lda #<INV_GRID_Y_BASE
00104E  1  18              clc
00104F  1  65 rr           adc inv_offset_y
001051  1  85 rr           sta zp_y_base_lo
001053  1  A9 00           lda #>INV_GRID_Y_BASE
001055  1  69 00           adc #0
001057  1  85 rr           sta zp_y_base_hi
001059  1                  ; step 2: spawn_y = y_base + row_y_offsets[row]
001059  1  A4 rr           ldy zp_row
00105B  1  B9 11 14        lda row_y_offsets,y
00105E  1  18              clc
00105F  1  65 rr           adc zp_y_base_lo
001061  1  95 rr           sta ibul_y_lo,x
001063  1  A9 00           lda #0
001065  1  65 rr           adc zp_y_base_hi
001067  1  95 rr           sta ibul_y_hi,x
001069  1                  ; step 3: +16 to place bullet at the bottom edge of the 16px invader
001069  1  B5 rr           lda ibul_y_lo,x
00106B  1  18              clc
00106C  1  69 10           adc #16
00106E  1  95 rr           sta ibul_y_lo,x
001070  1  B5 rr           lda ibul_y_hi,x
001072  1  69 00           adc #0
001074  1  95 rr           sta ibul_y_hi,x
001076  1               
001076  1  60              rts
001077  1               
001077  1               ;******************************************************************
001077  1               ; check_inv_bullet_player — AABB test each active invader bullet vs. player
001077  1               ;
001077  1               ;   Player rect: (player_x, PLAYER_Y) to (player_x+15, PLAYER_Y+15), 16x16
001077  1               ;   Bullet rect: (ibul_x,   ibul_y)   to (ibul_x+7,   ibul_y+7),     8x8
001077  1               ;
001077  1               ;   On hit: bullet deactivated, jsr player_hit called, loop continues
001077  1               ;   (remaining bullets checked — at most one hit landing per frame).
001077  1               ;   Scratch: zp_scratch_lo/hi, X (slot index)
001077  1               ;******************************************************************
001077  1               check_inv_bullet_player:
001077  1  A2 00           ldx #0
001079  1               @slot_loop:
001079  1  B5 rr           lda ibul_active,x
00107B  1  F0 5B           beq @next_slot
00107D  1               
00107D  1                  ; --- Y check 1: (bullet_y + 8) > PLAYER_Y  →  bullet_y + 8 - PLAYER_Y > 0 ---
00107D  1  B5 rr           lda ibul_y_lo,x
00107F  1  18              clc
001080  1  69 08           adc #8
001082  1  85 rr           sta zp_scratch_lo
001084  1  B5 rr           lda ibul_y_hi,x
001086  1  69 00           adc #0
001088  1  85 rr           sta zp_scratch_hi
00108A  1  A5 rr           lda zp_scratch_lo
00108C  1  38              sec
00108D  1  E9 A4           sbc #<PLAYER_Y
00108F  1  A5 rr           lda zp_scratch_hi
001091  1  E9 01           sbc #>PLAYER_Y
001093  1  30 43           bmi @next_slot            ; bullet bottom above player top → no hit
001095  1               
001095  1                  ; --- Y check 2: bullet_y < PLAYER_Y + 16 → bullet_y - (PLAYER_Y+16) < 0 ---
001095  1  B5 rr           lda ibul_y_lo,x
001097  1  38              sec
001098  1  E9 B4           sbc #<(PLAYER_Y+16)
00109A  1  B5 rr           lda ibul_y_hi,x
00109C  1  E9 01           sbc #>(PLAYER_Y+16)
00109E  1  10 38           bpl @next_slot            ; bullet top at or below player bottom → no hit
0010A0  1               
0010A0  1                  ; --- X check 1: (bullet_x + 8) > player_x ---
0010A0  1  B5 rr           lda ibul_x_lo,x
0010A2  1  18              clc
0010A3  1  69 08           adc #8
0010A5  1  85 rr           sta zp_scratch_lo
0010A7  1  B5 rr           lda ibul_x_hi,x
0010A9  1  69 00           adc #0
0010AB  1  85 rr           sta zp_scratch_hi
0010AD  1  A5 rr           lda zp_scratch_lo
0010AF  1  38              sec
0010B0  1  E5 rr           sbc player_x_lo
0010B2  1  A5 rr           lda zp_scratch_hi
0010B4  1  E5 rr           sbc player_x_hi
0010B6  1  30 20           bmi @next_slot            ; bullet right edge left of player → no hit
0010B8  1               
0010B8  1                  ; --- X check 2: bullet_x < player_x + 16 ---
0010B8  1  A5 rr           lda player_x_lo
0010BA  1  18              clc
0010BB  1  69 10           adc #16
0010BD  1  85 rr           sta zp_scratch_lo
0010BF  1  A5 rr           lda player_x_hi
0010C1  1  69 00           adc #0
0010C3  1  85 rr           sta zp_scratch_hi
0010C5  1  B5 rr           lda ibul_x_lo,x
0010C7  1  38              sec
0010C8  1  E5 rr           sbc zp_scratch_lo
0010CA  1  B5 rr           lda ibul_x_hi,x
0010CC  1  E5 rr           sbc zp_scratch_hi
0010CE  1  10 08           bpl @next_slot            ; bullet left edge at or right of player → no hit
0010D0  1               
0010D0  1                  ; --- HIT ---
0010D0  1  74 rr           stz ibul_active,x         ; deactivate this bullet
0010D2  1  20 A4 0F        jsr update_inv_bullet_sprite
0010D5  1  20 DE 10        jsr player_hit
0010D8  1               
0010D8  1               @next_slot:
0010D8  1  E8              inx
0010D9  1  E0 03           cpx #3
0010DB  1  D0 9C           bne @slot_loop
0010DD  1  60              rts
0010DE  1               
0010DE  1               ;******************************************************************
0010DE  1               ; player_hit — handle a bullet-player collision:
0010DE  1               ;   explosion at player position, decrement lives, respawn, invincibility
0010DE  1               ;******************************************************************
0010DE  1               player_hit:
0010DE  1                  ; start explosion at player position
0010DE  1  A5 rr           lda player_x_lo
0010E0  1  85 rr           sta zp_x_lo
0010E2  1  A5 rr           lda player_x_hi
0010E4  1  85 rr           sta zp_x_hi
0010E6  1  A9 A4           lda #<PLAYER_Y
0010E8  1  85 rr           sta zp_row_y_lo
0010EA  1  A9 01           lda #>PLAYER_Y
0010EC  1  85 rr           sta zp_row_y_hi
0010EE  1  20 06 0F        jsr start_explosion
0010F1  1               
0010F1  1                  ; decrement lives
0010F1  1  C6 rr           dec lives
0010F3  1  F0 0D           beq @game_over            ; lives hit 0 → end game (Phase 6 will handle this properly)
0010F5  1               
0010F5  1                  ; grant invincibility and re-centre the ship
0010F5  1  A9 78           lda #INV_HIT_FRAMES
0010F7  1  85 rr           sta inv_hit_timer
0010F9  1  A9 38           lda #<PLAYER_X_INIT
0010FB  1  85 rr           sta player_x_lo
0010FD  1  A9 01           lda #>PLAYER_X_INIT
0010FF  1  85 rr           sta player_x_hi
001101  1  60              rts
001102  1               
001102  1               @game_over:
001102  1  4C F9 08        jmp exit_game             ; placeholder: Phase 6 will show a game-over screen
001105  1               
001105  1               ;******************************************************************
001105  1               ; draw_title_screen — paint the title screen; called once before title_loop
001105  1               ;
001105  1               ;   Layout (40-col text, VERA Y=row*16):
001105  1               ;     Row  1, col 14: "X16 INVADERS"      (12 chars, centred)
001105  1               ;     Row  3, col 16: "HI-SCORE"          (8 chars, centred)
001105  1               ;     Row  4, col 17: 000000              (6-digit BCD hi-score)
001105  1               ;     Row  5, col  5: "?UFO? = ??? PTS"
001105  1               ;     Row  7, col  9: "= 30 PTS"          + Type C sprite at X=96,Y=112
001105  1               ;     Row 10, col  9: "= 20 PTS"          + Type B sprite at X=96,Y=160
001105  1               ;     Row 13, col  9: "= 10 PTS"          + Type A sprite at X=96,Y=208
001105  1               ;     Row 17, col 10: (PRESS SPACE TO START — blinked by title_loop)
001105  1               ;     Row 19, col 12: "RUN/STOP TO QUIT"
001105  1               ;******************************************************************
001105  1               draw_title_screen:
001105  1                  ; Row 1, col 14: "X16 INVADERS"
001105  1  A9 01           lda #1
001107  1  A0 0E           ldy #14
001109  1  18              clc
00110A  1  20 F0 FF        jsr PLOT
00110D  1  A2 00           ldx #0
00110F  1  BD D2 12     @lp1: lda str_title_main, x
001112  1  F0 06           beq @lp1_done
001114  1  20 D2 FF        jsr CHROUT
001117  1  E8              inx
001118  1  80 F5           bra @lp1
00111A  1               @lp1_done:
00111A  1               
00111A  1                  ; Row 3, col 16: "HI-SCORE"
00111A  1  A9 03           lda #3
00111C  1  A0 10           ldy #16
00111E  1  18              clc
00111F  1  20 F0 FF        jsr PLOT
001122  1  A2 00           ldx #0
001124  1  BD DF 12     @lp2: lda str_hi_score_lbl, x
001127  1  F0 06           beq @lp2_done
001129  1  20 D2 FF        jsr CHROUT
00112C  1  E8              inx
00112D  1  80 F5           bra @lp2
00112F  1               @lp2_done:
00112F  1               
00112F  1                  ; Row 4, col 17: hi-score 6 BCD digits (000000 at start)
00112F  1  A9 04           lda #4
001131  1  A0 11           ldy #17
001133  1  18              clc
001134  1  20 F0 FF        jsr PLOT
001137  1  A5 rr           lda hi_score_hi
001139  1  20 B3 12        jsr print_hex_byte
00113C  1  A5 rr           lda hi_score_mid
00113E  1  20 B3 12        jsr print_hex_byte
001141  1  A5 rr           lda hi_score_lo
001143  1  20 B3 12        jsr print_hex_byte
001146  1               
001146  1                  ; Row 5, col 5: "?UFO? = ??? PTS"
001146  1  A9 05           lda #5
001148  1  A0 05           ldy #5
00114A  1  18              clc
00114B  1  20 F0 FF        jsr PLOT
00114E  1  A2 00           ldx #0
001150  1  BD E8 12     @lp3: lda str_ufo_score, x
001153  1  F0 06           beq @lp3_done
001155  1  20 D2 FF        jsr CHROUT
001158  1  E8              inx
001159  1  80 F5           bra @lp3
00115B  1               @lp3_done:
00115B  1               
00115B  1                  ; Sample invader sprites (Types C, B, A) + score labels
00115B  1  20 74 11        jsr show_title_sprites
00115E  1               
00115E  1                  ; Row 19, col 12: "RUN/STOP TO QUIT"
00115E  1  A9 13           lda #19
001160  1  A0 0C           ldy #12
001162  1  18              clc
001163  1  20 F0 FF        jsr PLOT
001166  1  A2 00           ldx #0
001168  1  BD 28 13     @lp4: lda str_run_stop_hint, x
00116B  1  F0 06           beq @lp4_done
00116D  1  20 D2 FF        jsr CHROUT
001170  1  E8              inx
001171  1  80 F5           bra @lp4
001173  1               @lp4_done:
001173  1               
001173  1  60              rts
001174  1               
001174  1               ;******************************************************************
001174  1               ; show_title_sprites — enable one sprite of each type at fixed
001174  1               ;   title-screen positions and print score labels beside them.
001174  1               ;
001174  1               ;   In VERA 640x480 space, 1 text row/col = 16 VERA pixels.
001174  1               ;   Sprites: X=96 (col 6), score labels at col 9.
001174  1               ;   Sprite 11 (Type C): Y=112 → text row 7,  "= 30 PTS"
001174  1               ;   Sprite 22 (Type B): Y=160 → text row 10, "= 20 PTS"
001174  1               ;   Sprite 44 (Type A): Y=208 → text row 13, "= 10 PTS"
001174  1               ;******************************************************************
001174  1               show_title_sprites:
001174  1  9C 25 9F        stz VERA_ctrl
001177  1                  ; --- sprite 11 (Type C, squid/cyan): attr $1FC00+11*8=$1FC58 ---
001177  1                  ; addr[12:5] = VRAM_INV_C_F0>>5 = $00300>>5 = $18
001177  1  A9 11           lda #$11               ; stride=1, bank=1
001179  1  8D 22 9F        sta VERA_addr_bank
00117C  1  A9 FC           lda #$FC
00117E  1  8D 21 9F        sta VERA_addr_high
001181  1  A9 58           lda #$58               ; low byte of $1FC58
001183  1  8D 20 9F        sta VERA_addr_low
001186  1  A9 18           lda #$18               ; byte 0: data addr[12:5]
001188  1  8D 23 9F        sta VERA_data0
00118B  1  A9 00           lda #$00               ; byte 1: 4bpp, addr[16:13]=0
00118D  1  8D 23 9F        sta VERA_data0
001190  1  A9 60           lda #96                ; byte 2: X lo
001192  1  8D 23 9F        sta VERA_data0
001195  1  A9 00           lda #0                 ; byte 3: X hi
001197  1  8D 23 9F        sta VERA_data0
00119A  1  A9 70           lda #112               ; byte 4: Y lo (row 7: 7*16=112)
00119C  1  8D 23 9F        sta VERA_data0
00119F  1  A9 00           lda #0                 ; byte 5: Y hi
0011A1  1  8D 23 9F        sta VERA_data0
0011A4  1  A9 0C           lda #SPR_Z_FRONT       ; byte 6: z-depth=3
0011A6  1  8D 23 9F        sta VERA_data0
0011A9  1  A9 50           lda #SPR_16x16_PAL0    ; byte 7: 16x16, palette 0
0011AB  1  8D 23 9F        sta VERA_data0
0011AE  1               
0011AE  1  A9 07           lda #7
0011B0  1  A0 09           ldy #9
0011B2  1  18              clc
0011B3  1  20 F0 FF        jsr PLOT
0011B6  1  A2 00           ldx #0
0011B8  1  BD F8 12     @lp_c: lda str_score_c, x
0011BB  1  F0 06           beq @lp_c_done
0011BD  1  20 D2 FF        jsr CHROUT
0011C0  1  E8              inx
0011C1  1  80 F5           bra @lp_c
0011C3  1               @lp_c_done:
0011C3  1               
0011C3  1                  ; --- sprite 22 (Type B, octopus/magenta): attr $1FC00+22*8=$1FCB0 ---
0011C3  1                  ; addr[12:5] = VRAM_INV_B_F0>>5 = $00200>>5 = $10
0011C3  1  A9 11           lda #$11
0011C5  1  8D 22 9F        sta VERA_addr_bank
0011C8  1  A9 FC           lda #$FC
0011CA  1  8D 21 9F        sta VERA_addr_high
0011CD  1  A9 B0           lda #$B0               ; low byte of $1FCB0
0011CF  1  8D 20 9F        sta VERA_addr_low
0011D2  1  A9 10           lda #$10               ; byte 0: addr[12:5]
0011D4  1  8D 23 9F        sta VERA_data0
0011D7  1  A9 00           lda #$00
0011D9  1  8D 23 9F        sta VERA_data0
0011DC  1  A9 60           lda #96                ; X
0011DE  1  8D 23 9F        sta VERA_data0
0011E1  1  A9 00           lda #0
0011E3  1  8D 23 9F        sta VERA_data0
0011E6  1  A9 A0           lda #160               ; Y (row 10: 10*16=160)
0011E8  1  8D 23 9F        sta VERA_data0
0011EB  1  A9 00           lda #0
0011ED  1  8D 23 9F        sta VERA_data0
0011F0  1  A9 0C           lda #SPR_Z_FRONT
0011F2  1  8D 23 9F        sta VERA_data0
0011F5  1  A9 50           lda #SPR_16x16_PAL0
0011F7  1  8D 23 9F        sta VERA_data0
0011FA  1               
0011FA  1  A9 0A           lda #10
0011FC  1  A0 09           ldy #9
0011FE  1  18              clc
0011FF  1  20 F0 FF        jsr PLOT
001202  1  A2 00           ldx #0
001204  1  BD 01 13     @lp_b: lda str_score_b, x
001207  1  F0 06           beq @lp_b_done
001209  1  20 D2 FF        jsr CHROUT
00120C  1  E8              inx
