001CC6  1               
001CC6  1               ;******************************************************************
001CC6  1               ; update_hud — rewrite dynamic HUD values each frame
001CC6  1               ;   Row  1, col  0: 6-digit BCD score
001CC6  1               ;   Row  1, col 16: 6-digit BCD hi-score
001CC6  1               ;   Row 29, col  1: LIVES: N
001CC6  1               ;   Row 29, col 20: WAVE: N
001CC6  1               ;   Overwrites fixed positions; no full redraw needed.
001CC6  1               ;   Note: KERNAL PLOT convention for X16: A = row, Y = col, CLC.
001CC6  1               ;******************************************************************
001CC6  1               update_hud:
001CC6  1                  ; --- score: row 1, col 0 (Plot: Set X to Row, Set Y to Col) ---
001CC6  1  A2 01           ldx #1
001CC8  1  A0 0A           ldy #10
001CCA  1  18              clc
001CCB  1  20 F0 FF        jsr PLOT
001CCE  1  A5 rr           lda score_hi
001CD0  1  20 33 1D        jsr print_hex_byte
001CD3  1  A5 rr           lda score_mid
001CD5  1  20 33 1D        jsr print_hex_byte
001CD8  1  A5 rr           lda score_lo
001CDA  1  20 33 1D        jsr print_hex_byte
001CDD  1               
001CDD  1                  ; --- hi-score: row 1, col 16  (Plot: Set X to Row, Set Y to Col) ---
001CDD  1  A2 01           ldx #1
001CDF  1  A0 49           ldy #73
001CE1  1  18              clc
001CE2  1  20 F0 FF        jsr PLOT
001CE5  1  A5 rr           lda hi_score_hi
001CE7  1  20 33 1D        jsr print_hex_byte
001CEA  1  A5 rr           lda hi_score_mid
001CEC  1  20 33 1D        jsr print_hex_byte
001CEF  1  A5 rr           lda hi_score_lo
001CF1  1  20 33 1D        jsr print_hex_byte
001CF4  1               
001CF4  1                  ; --- lives count: row 58, col 1  (Plot: Set X to Row, Set Y to Col) ---
001CF4  1  A2 3A           ldx #58
001CF6  1  A0 01           ldy #1
001CF8  1  18              clc
001CF9  1  20 F0 FF        jsr PLOT
001CFC  1  A2 00           ldx #0
001CFE  1  BD 10 1E     @lv_lbl: lda str_lives_lbl,x
001D01  1  F0 06           beq @lv_val
001D03  1  20 D2 FF        jsr CHROUT
001D06  1  E8              inx
001D07  1  80 F5           bra @lv_lbl
001D09  1               @lv_val:
001D09  1  A5 rr           lda lives
001D0B  1  20 50 14        jsr print_dec_byte
001D0E  1  A9 20           lda #' '
001D10  1  20 D2 FF        jsr CHROUT                    ; erase any stale digit
001D13  1               
001D13  1                  ; --- wave number: row 58, col 20  (Plot: Set X to Row, Set Y to Col) ---
001D13  1  A2 3A           ldx #58
001D15  1  A0 14           ldy #20
001D17  1  18              clc
001D18  1  20 F0 FF        jsr PLOT
001D1B  1  A2 00           ldx #0
001D1D  1  BD E7 1D     @wv_lbl: lda str_wave_lbl,x
001D20  1  F0 06           beq @wv_val
001D22  1  20 D2 FF        jsr CHROUT
001D25  1  E8              inx
001D26  1  80 F5           bra @wv_lbl
001D28  1               @wv_val:
001D28  1  A5 rr           lda wave
001D2A  1  20 50 14        jsr print_dec_byte
001D2D  1  A9 20           lda #' '
001D2F  1  20 D2 FF        jsr CHROUT                    ; erase any stale digit
001D32  1               
001D32  1  60              rts
001D33  1               
001D33  1               ;******************************************************************
001D33  1               ; print_hex_byte — print .A as two uppercase hex digits via CHROUT
001D33  1               ;******************************************************************
001D33  1               print_hex_byte:
001D33  1  48              pha
001D34  1  4A              lsr                           ; shift high nibble down
001D35  1  4A              lsr
001D36  1  4A              lsr
001D37  1  4A              lsr
001D38  1  20 42 1D        jsr print_hex_nybble
001D3B  1  68              pla
001D3C  1  29 0F           and #$0F                      ; isolate low nibble
001D3E  1  20 42 1D        jsr print_hex_nybble
001D41  1  60              rts
001D42  1               
001D42  1               ; print_hex_nybble — print lower 4 bits of .A as one hex digit
001D42  1               ;   Relies on carry state from CMP to select digit vs. letter range
001D42  1               print_hex_nybble:
001D42  1  C9 0A           cmp #10
001D44  1  90 06           bcc @digit                    ; carry clear → 0-9
001D46  1  69 36           adc #($41 - 10 - 1)          ; A-F: 'A'=65; carry set adds 1
001D48  1  20 D2 FF        jsr CHROUT
001D4B  1  60              rts
001D4C  1               @digit:
001D4C  1  69 30           adc #$30                      ; 0-9: '0'=48; carry clear adds 0
001D4E  1  20 D2 FF        jsr CHROUT
001D51  1  60              rts
