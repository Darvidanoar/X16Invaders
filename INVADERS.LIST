0014FF  1               ;******************************************************************
0014FF  1               ; show_title_sprites — enable one sprite of each type at fixed
0014FF  1               ;   title-screen positions and print score labels beside them.
0014FF  1               ;
0014FF  1               ;   In VERA 640x480 space, 1 text row/col = 16 VERA pixels.
0014FF  1               ;   Sprites: X=96 (col 6), score labels at col 9.
0014FF  1               ;   Sprite 11 (Type C): Y=112 → text row 7,  "= 30 PTS"
0014FF  1               ;   Sprite 22 (Type B): Y=160 → text row 10, "= 20 PTS"
0014FF  1               ;   Sprite 44 (Type A): Y=208 → text row 13, "= 10 PTS"
0014FF  1               ;******************************************************************
0014FF  1               show_title_sprites:
0014FF  1  9C 25 9F        stz VERA_ctrl
001502  1                  ; --- sprite 11 (Type C, squid/cyan): attr $1FC00+11*8=$1FC58 ---
001502  1                  ; addr[12:5] = VRAM_INV_C_F0>>5 = $00300>>5 = $18
001502  1  A9 11           lda #$11               ; stride=1, bank=1
001504  1  8D 22 9F        sta VERA_addr_bank
001507  1  A9 FC           lda #$FC
001509  1  8D 21 9F        sta VERA_addr_high
00150C  1  A9 58           lda #$58               ; low byte of $1FC58
00150E  1  8D 20 9F        sta VERA_addr_low
001511  1  A9 18           lda #$18               ; byte 0: data addr[12:5]
001513  1  8D 23 9F        sta VERA_data0
001516  1  A9 00           lda #$00               ; byte 1: 4bpp, addr[16:13]=0
001518  1  8D 23 9F        sta VERA_data0
00151B  1  A9 60           lda #96                ; byte 2: X lo
00151D  1  8D 23 9F        sta VERA_data0
001520  1  A9 00           lda #0                 ; byte 3: X hi
001522  1  8D 23 9F        sta VERA_data0
001525  1  A9 70           lda #112               ; byte 4: Y lo (row 7: 7*16=112)
001527  1  8D 23 9F        sta VERA_data0
00152A  1  A9 00           lda #0                 ; byte 5: Y hi
00152C  1  8D 23 9F        sta VERA_data0
00152F  1  A9 0C           lda #SPR_Z_FRONT       ; byte 6: z-depth=3
001531  1  8D 23 9F        sta VERA_data0
001534  1  A9 50           lda #SPR_16x16_PAL0    ; byte 7: 16x16, palette 0
001536  1  8D 23 9F        sta VERA_data0
001539  1               
001539  1  A2 0F           ldx #15
00153B  1  A0 0F           ldy #15
00153D  1  18              clc
00153E  1  20 F0 FF        jsr PLOT
001541  1  A2 00           ldx #0
001543  1  BD 77 1D     @lp_c: lda str_score_c, x
001546  1  F0 06           beq @lp_c_done
001548  1  20 D2 FF        jsr CHROUT
