000810  1               ;******************************************************************
000810  1               ; Constants
000810  1               ;******************************************************************
000810  1               
000810  1               ; VERA display control
000810  1               VERA_SPRITE_EN  = %01000000      ; VERA_dc_video bit 6: enable sprites
000810  1               
000810  1               ; PETSCII control codes
000810  1               PETSCII_WHITE   = $05            ; set text color to white
000810  1               PETSCII_CLR     = $93            ; clear screen and home cursor
000810  1               PETSCII_HOME    = $13            ; home cursor (no clear)
000810  1               PETSCII_RETURN  = $0D            ; carriage return
000810  1               
000810  1               ; SCREEN_SET_CHARSET font numbers (call address $FF62)
000810  1               CHARSET_UPPER   = 1              ; Commodore upper/graphics: $41-$5A = A-Z
000810  1               CHARSET_LOWER   = 2              ; Commodore lower/upper:    $41-$5A = a-z (lowercase)
000810  1               
000810  1               ; Key codes (PETSCII)
000810  1               KEY_RUN_STOP    = $03            ; RUN/STOP — exit game
000810  1               
000810  1               ; Input flag bits (key_flags)
000810  1               KEY_LEFT        = %00000001
000810  1               KEY_RIGHT       = %00000010
000810  1               KEY_FIRE        = %00000100
000810  1               
000810  1               ; JOYSTICK_GET .A return: {B,Y,Sel,Sta,Up,Dn,Left,Right} active low
000810  1               JOY_RIGHT       = %00000001     ; bit 0
000810  1               JOY_LEFT        = %00000010     ; bit 1
000810  1               
000810  1               ; Player ship — all positions in VERA 640x480 coordinate space
000810  1               PLAYER_Y        = 420            ; fixed Y, near bottom (479 = bottom edge)
000810  1               PLAYER_X_INIT   = 312            ; starting X, centred  ((640-16)/2)
000810  1               PLAYER_X_MIN    = 8              ; left  boundary (sprite left edge)
000810  1               PLAYER_X_MAX    = 616            ; right boundary (640 - 16px sprite - 8px margin)
000810  1               PLAYER_SPEED    = 4              ; pixels per frame
000810  1               
000810  1               ; Sprite attribute encoding helpers
000810  1               SPRITE1_ATTR    = $1FC08 ; sprite 1 attribute base ($1FC00=sprite 0, reserved for KERNAL mouse)
000810  1               SPR_Z_FRONT     = %00001100     ; byte 6: z-depth = %11 in bits 3-2 (in front of all layers)
000810  1               SPR_16x16_PAL0  = %01010000     ; byte 7: width=1(16px), height=1(16px), palette_off=0
000810  1               SPR_32x16_PAL0  = %10010000     ; byte 7: width=2(32px), height=1(16px), palette_off=0
000810  1               SPR_32x32_PAL0  = %10100000     ; byte 7: width=2(32px), height=2(32px), palette_off=0
000810  1               SPR_8x8_PAL0    = %00000000     ; byte 7: width=0(8px),  height=0(8px),  palette_off=0
000810  1               
000810  1               ; Explosion sprite (slot 4)
000810  1               VRAM_EXPLOSION     = $00440     ; explosion pixel data (128 bytes, 16x16 4bpp)
000810  1               EXPLODE_SPRITE_ATTR = $1FC20    ; sprite 4 attribute base (explosion)
000810  1               EXPLODE_FRAMES     = 30         ; display duration in frames (~0.5 sec at 60 Hz)
000810  1               
000810  1               ; Invader bullets (sprite slots 5-7)
000810  1               VRAM_INV_BULLET    = $00420     ; invader bullet pixel data (32 bytes, 8x8 4bpp)
000810  1               INV_BULLET_SPR_BASE = $1FC28    ; sprite 5 attribute base (first invader bullet)
000810  1               INV_BULLET_SPEED   = 6          ; VERA pixels per frame downward (=3 game pixels)
000810  1               INV_FIRE_TIMER_MIN = 10         ; minimum frames between fire attempts
000810  1               INV_FIRE_TIMER_INIT = 90        ; frames before first shot
000810  1               
000810  1               ; Player lives
000810  1               LIVES_INIT         = 3          ; starting lives
000810  1               INV_HIT_FRAMES     = 120        ; invincibility duration after being hit (2 sec at 60 Hz)
000810  1               
000810  1               ; UFO saucer (sprite slot 3)
000810  1               UFO_SPRITE_ATTR    = $1FC18      ; sprite 3 attribute base ($1FC00 + 3*8)
000810  1               VRAM_UFO           = $01500      ; UFO pixel data (128 bytes, 16x16 4bpp, after shield tiles)
000810  1               UFO_Y              = 32          ; VERA Y coord (= display pixel 16, top of play field)
000810  1               UFO_SPEED          = 2           ; VERA pixels per frame rightward (1 display pixel/frame)
000810  1               UFO_TIMER_INIT     = 600         ; frames between UFO appearances (≈10 sec at 60 Hz)
000810  1               
000810  1               ; Wave progression
000810  1               WAVE_CLEAR_FRAMES  = 180         ; auto-advance delay after wave clear (≈3 sec at 60 Hz)
000810  1               WAVE_SPEED_STEP    = 5           ; inv_move_speed decreases by this each wave
000810  1               
000810  1               ; VERA PSG voice 3 — UFO drone (base addr $1F9C0 + 3*4 = $1F9CC)
000810  1               ; PSG byte layout: 0=FREQ_L, 1=FREQ_H, 2=volume([7]=R,[6]=L,[5:0]=vol 0-63), 3=waveform([7:6])
000810  1               ; Waveform codes: 00=pulse, 01=sawtooth, 10=triangle, 11=noise
000810  1               ; freq_hz ≈ freq_reg * 25000000 / (512 * 131072)  →  freq_reg ≈ freq_hz * 2.684
000810  1               VRAM_PSG_VOICE3    = VRAM_psg + 12   ; $1F9CC — voice 3 registers
000810  1               PSG_VOL_FULL       = $FF             ; R enable + L enable + volume 63
000810  1               PSG_WAVE_SAW       = %01000000       ; sawtooth waveform (bits 7:6 = 01)
000810  1               UFO_DRONE_FREQ1    = 1074            ; ≈400 Hz  ($0432)
000810  1               UFO_DRONE_FREQ2    = 1611            ; ≈600 Hz  ($064B)
000810  1               
000810  1               ; Shields
000810  1               SHIELD_Y           = 352        ; VERA Y coordinate for all 4 shields (176 display pixels)
000810  1               SHIELD_SPR_BASE    = $1FE10     ; sprite slot 66 attr ($1FC00 + 66*8); slots 8-65 in use
000810  1               VRAM_SHIELD_FULL   = $00500     ; 512-byte 32x32 4bpp tile: intact
000810  1               VRAM_SHIELD_DMG1   = $00700     ; 12% damaged
000810  1               VRAM_SHIELD_DMG2   = $00900     ; 25% damaged
000810  1               VRAM_SHIELD_DMG3   = $00B00     ; 37% damaged
000810  1               VRAM_SHIELD_DMG4   = $00D00     ; 50% damaged
000810  1               VRAM_SHIELD_DMG5   = $00F00     ; 62% damaged
000810  1               VRAM_SHIELD_DMG6   = $01100     ; 75% damaged
000810  1               VRAM_SHIELD_DMG7   = $01300     ; nearly destroyed
000810  1               
000810  1               ; Player bullet
000810  1               BULLET_SPRITE_ATTR = $1FC10     ; sprite 2 attribute base (player bullet)
000810  1               VRAM_BULLET     = $00400        ; player bullet pixel data (32 bytes, 8x8 4bpp)
000810  1               BULLET_SPEED    = 12            ; VERA pixels per frame upward (= 6 game pixels)
000810  1               BULLET_Y_INIT   = PLAYER_Y - 8 ; bullet starts just above player ship top
000810  1               
000810  1               ; Invader grid geometry (VERA 640x480 coordinate space)
000810  1               INV_GRID_X_INIT   = 112         ; left-column X at start (centered: (640 - 10*40 - 16) / 2 = 112)
000810  1               INV_GRID_Y_BASE   = 80          ; top-row Y, fixed base (drops added via inv_offset_y)
000810  1               INV_SPACING_X     = 40          ; VERA pixels between invader column origins
000810  1               INV_SPACING_Y     = 48          ; VERA pixels between invader row origins
000810  1               INV_STEP_X        = 4           ; VERA pixels per march step
000810  1               INV_DROP_Y        = 16          ; VERA pixels per grid drop
000810  1               INV_MOVE_SPEED_INIT = 50        ; frames between march steps (initial)
000810  1               INV_COUNT_INIT    = 55
000810  1               INV_MOVE_SPEED_MIN = 5           ; minimum frames per march step
000810  1               
000810  1               ; Grid boundary: when grid_x reaches these values, reverse and drop
000810  1               ; Rightmost invader base X = grid_x + 10*INV_SPACING_X (=400). Right wall = 624 (640-16px).
000810  1               ; So right limit = 624 - 400 - 16 = 208
000810  1               INV_X_RIGHT_LIM   = 208
000810  1               INV_X_LEFT_LIM    = 16          ; leftmost sprite at x=grid_x must stay >= 16
000810  1               
000810  1               ; VRAM addresses for invader sprite pixel data (128 bytes each, 16x16 4bpp)
000810  1               VRAM_INV_A_F0   = $00100        ; Type A (crab,   bottom rows 3-4), frame 0
000810  1               VRAM_INV_A_F1   = $00180        ; Type A frame 1
000810  1               VRAM_INV_B_F0   = $00200        ; Type B (octopus, middle rows 1-2), frame 0
000810  1               VRAM_INV_B_F1   = $00280        ; Type B frame 1
000810  1               VRAM_INV_C_F0   = $00300        ; Type C (squid,   top row 0), frame 0
000810  1               VRAM_INV_C_F1   = $00380        ; Type C frame 1
000810  1               
000810  1               ; Sprite addr[12:5] byte values for each type/frame (= VRAM_addr >> 5)
000810  1               ;   VRAM $00100>>5=$08  $00180>>5=$0C  $00200>>5=$10  $00280>>5=$14  $00300>>5=$18  $00380>>5=$1C
000810  1               INV_ATTR_BASE   = $1FC58        ; sprite slot 11 = first invader ($1FC00 + 11*8)
000810  1               INV_SPRITE_SLOT = 11            ; first invader sprite slot index
000810  1               
000810  1               ;******************************************************************
000810  1               ; start — main program entry point
000810  1               ;******************************************************************
000810  1               start:
000810  1  78              sei                           ; disable interrupts during init
000811  1               
000811  1                  ; Switch to 40-column text mode (mode 0)
000811  1                  ; Carry clear = SET mode (carry set = READ mode)
000811  1  18              clc
000812  1  A9 00           lda #$00
000814  1  20 5F FF        jsr SCREEN_MODE
000817  1               
000817  1                  ; Seed PRNG with hardware entropy
000817  1  20 CF FE        jsr ENTROPY_GET
00081A  1  85 rr           sta rand_seed_lo
00081C  1  86 rr           stx rand_seed_hi
00081E  1               
00081E  1                  ; Enable sprites in VERA display controller
00081E  1  9C 25 9F        stz VERA_ctrl                 ; DCSEL=0, ADDRSEL=0
000821  1  AD 29 9F        lda VERA_dc_video
000824  1  09 40           ora #VERA_SPRITE_EN
000826  1  8D 29 9F        sta VERA_dc_video
000829  1               
000829  1               
000829  1                  ; Clear game variables
000829  1  64 rr           stz key_last
00082B  1  64 rr           stz key_flags
00082D  1  64 rr           stz frame_count
00082F  1  64 rr           stz bullet_active
000831  1  64 rr           stz score_lo
000833  1  64 rr           stz score_mid
000835  1  64 rr           stz score_hi
000837  1  64 rr           stz hi_score_lo
000839  1  64 rr           stz hi_score_mid
00083B  1  64 rr           stz hi_score_hi
00083D  1  64 rr           stz ufo_active
00083F  1  A9 58           lda #<UFO_TIMER_INIT
000841  1  85 rr           sta ufo_timer_lo
000843  1  A9 02           lda #>UFO_TIMER_INIT
000845  1  85 rr           sta ufo_timer_hi
000847  1  64 rr           stz shot_count
000849  1  A9 01           lda #1
00084B  1  85 rr           sta wave
00084D  1  A9 32           lda #INV_MOVE_SPEED_INIT
00084F  1  85 rr           sta wave_init_speed
000851  1               
000851  1                  ; Set initial player position before sprite init reads it
000851  1  20 7B 09        jsr init_player
000854  1               
000854  1  58              cli                           ; re-enable interrupts
000855  1               
000855  1                  ; Switch to Commodore uppercase/graphics charset: $41-$5A = A-Z
000855  1                  ; Must be called AFTER SCREEN_MODE (which resets to lowercase by default)
000855  1  A9 01           lda #CHARSET_UPPER
000857  1  20 62 FF        jsr SCREEN_SET_CHARSET
00085A  1               
00085A  1                  ; Clear screen and set text color
00085A  1  A9 05           lda #PETSCII_WHITE
00085C  1  20 D2 FF        jsr CHROUT
00085F  1  A9 93           lda #PETSCII_CLR
000861  1  20 D2 FF        jsr CHROUT
000864  1               
000864  1                  ; Upload sprite pixel data and configure sprite 1 attributes
000864  1  20 8A 09        jsr init_sprites
000867  1               
000867  1                  ; Upload invader sprite data, set palette, init grid state, place sprites
000867  1  20 89 0B        jsr init_invaders
00086A  1  20 56 15        jsr hide_all_inv_sprites     ; hide all 55 during title screen
00086D  1               
00086D  1  20 FF 13        jsr draw_title_screen
000870  1               
000870  1               ;------------------------------------------------------------------
000870  1               ; title_loop — wait for SPACE; blink "PRESS SPACE TO START"
000870  1               ;------------------------------------------------------------------
000870  1               title_loop:
000870  1  20 2E 09        jsr wait_vsync
000873  1  E6 rr           inc frame_count
000875  1  20 30 09        jsr update_input
000878  1               
000878  1  A5 rr           lda key_last
00087A  1  C9 03           cmp #KEY_RUN_STOP
00087C  1  D0 03           bne @tl_no_exit
00087E  1  4C 26 09        jmp exit_game
000881  1               @tl_no_exit:
000881  1               
000881  1  A5 rr           lda key_flags
000883  1  29 04           and #KEY_FIRE
000885  1  D0 33           bne start_game
000887  1               
000887  1                  ; blink using frame_count bit 5 (~2 Hz)
000887  1  A5 rr           lda frame_count
000889  1  29 20           and #$20
00088B  1  D0 15           bne @tl_on
00088D  1               @tl_off:
00088D  1  A9 11           lda #17
00088F  1  A0 0A           ldy #10
000891  1  18              clc
000892  1  20 F0 FF        jsr PLOT
000895  1  A2 14           ldx #20                      ; erase 20 chars of "PRESS SPACE TO START"
000897  1  A9 20        @tl_erase: lda #' '
000899  1  20 D2 FF        jsr CHROUT
00089C  1  CA              dex
00089D  1  D0 F8           bne @tl_erase
00089F  1  4C 70 08        jmp title_loop
0008A2  1               @tl_on:
0008A2  1  A9 11           lda #17
0008A4  1  A0 0A           ldy #10
0008A6  1  18              clc
0008A7  1  20 F0 FF        jsr PLOT
0008AA  1  A2 00           ldx #0
0008AC  1  BD 7F 1B     @tl_print: lda str_press_space, x
0008AF  1  F0 06           beq @tl_print_done
0008B1  1  20 D2 FF        jsr CHROUT
0008B4  1  E8              inx
0008B5  1  80 F5           bra @tl_print
0008B7  1               @tl_print_done:
0008B7  1  4C 70 08        jmp title_loop
0008BA  1               
0008BA  1               start_game:
0008BA  1  20 BD 0C        jsr update_invader_sprites   ; re-enable all 55 invaders at grid positions
0008BD  1  20 73 15        jsr init_shields             ; upload shield tiles, init damage counters, place sprites
0008C0  1  A9 93           lda #PETSCII_CLR
0008C2  1  20 D2 FF        jsr CHROUT                   ; clear title text, leave sprites visible
0008C5  1  20 D4 13        jsr draw_score_labels        ; paint "SCORE" / "HI-SCORE" headings
0008C8  1               
0008C8  1               ;******************************************************************
0008C8  1               ; main_loop — one iteration per video frame (60 Hz)
0008C8  1               ;******************************************************************
0008C8  1               main_loop:
0008C8  1  20 2E 09        jsr wait_vsync
0008CB  1               
0008CB  1  E6 rr           inc frame_count
0008CD  1               
0008CD  1  20 30 09        jsr update_input              ; fills key_flags (joystick) + key_last (GETIN)
0008D0  1               
0008D0  1  A5 rr           lda key_last
0008D2  1  C9 03           cmp #KEY_RUN_STOP
0008D4  1  F0 50           beq exit_game
0008D6  1               
0008D6  1                  ; --- invincibility timer ---
0008D6  1  A5 rr           lda inv_hit_timer
0008D8  1  F0 02           beq @no_inv_dec
0008DA  1  C6 rr           dec inv_hit_timer
0008DC  1               @no_inv_dec:
0008DC  1               
0008DC  1  20 73 0D        jsr move_player               ; apply movement, clamp to boundaries
0008DF  1  20 C2 0D        jsr update_player_sprite      ; write new X to VERA sprite 1
0008E2  1               
0008E2  1                  ; --- fire player bullet (SPACE pressed and bullet not already active) ---
0008E2  1  A5 rr           lda key_flags
0008E4  1  29 04           and #KEY_FIRE
0008E6  1  F0 07           beq @skip_fire
0008E8  1  A5 rr           lda bullet_active
0008EA  1  D0 03           bne @skip_fire
0008EC  1  20 05 0E        jsr fire_bullet
0008EF  1               @skip_fire:
0008EF  1               
0008EF  1                  ; --- move bullet if active ---
0008EF  1  A5 rr           lda bullet_active
0008F1  1  F0 03           beq @skip_bullet_move
0008F3  1  20 24 0E        jsr move_bullet
0008F6  1               @skip_bullet_move:
0008F6  1               
0008F6  1                  ; --- check player bullet vs invader collision ---
0008F6  1  20 75 0E        jsr check_bullet_invader
0008F9  1               
0008F9  1                  ; --- check player bullet vs shield collision ---
0008F9  1  20 FF 17        jsr check_bullet_shields
0008FC  1               
0008FC  1                  ; --- explosion timer ---
0008FC  1  20 C4 0F        jsr update_explosion
0008FF  1               
0008FF  1                  ; --- invader bullets: move, spawn, boundary check ---
0008FF  1  20 F3 0F        jsr update_inv_bullets
000902  1               
000902  1                  ; --- invader bullet vs player collision ---
000902  1  20 01 11        jsr check_inv_bullet_player
000905  1               
000905  1                  ; --- invader bullet vs shield collision ---
000905  1  20 71 18        jsr check_invbullet_shields
000908  1               
000908  1                  ; --- UFO spawn/move and player bullet collision ---
000908  1  20 12 19        jsr update_ufo
00090B  1  20 AB 19        jsr check_bullet_ufo
00090E  1               
00090E  1                  ; --- Invader march timer ---
00090E  1  C6 rr           dec inv_move_timer
000910  1  D0 07           bne @skip_inv_step
000912  1  20 58 0C        jsr step_invaders             ; move grid, check bounds, update sprites
000915  1  A5 rr           lda inv_move_speed
000917  1  85 rr           sta inv_move_timer
000919  1               @skip_inv_step:
000919  1               
000919  1                  ; --- check wave clear (all 55 invaders dead) ---
000919  1  A5 rr           lda inv_count
00091B  1  D0 03           bne @no_wave_clear
00091D  1  4C EC 12        jmp wave_clear_screen
000920  1               @no_wave_clear:
000920  1               
000920  1  20 AC 1A        jsr update_hud                ; refresh text readouts
000923  1               
000923  1  4C C8 08        jmp main_loop
000926  1               
000926  1               ;------------------------------------------------------------------
000926  1               exit_game:
000926  1  A9 93           lda #PETSCII_CLR
000928  1  20 D2 FF        jsr CHROUT
00092B  1  4C 47 FF        jmp ENTER_BASIC
00092E  1               
00092E  1               ;******************************************************************
00092E  1               ; wait_vsync — busy-poll VERA_isr until VSYNC, then clear flag
00092E  1               ;******************************************************************
00092E  1               wait_vsync:
00092E  1                  ; WAI sleeps the CPU until any IRQ fires.  The KERNAL's VSYNC IRQ
00092E  1                  ; handler (60 Hz) wakes us up and has already cleared VERA_isr bit 0
00092E  1                  ; by the time execution returns here, so polling VERA_isr would loop
00092E  1                  ; forever.  Just return — one WAI ≈ one frame.
00092E  1  CB              wai
00092F  1  60              rts
000930  1               
000930  1               ;******************************************************************
000930  1               ; update_input — joystick + GETIN keyboard input each frame
000930  1               ;
000930  1               ;   key_flags bits set this frame:
000930  1               ;     KEY_LEFT  — left arrow held
000930  1               ;     KEY_RIGHT — right arrow held
000930  1               ;     KEY_FIRE  — space bar pressed
000930  1               ;   key_last   — raw PETSCII from GETIN (RUN/STOP etc.)
000930  1               ;
000930  1               ;   JOYSTICK_GET(0) = keyboard-as-joystick; gives smooth held-key
000930  1               ;   movement with no repeat delay.  GETIN handles space and RUN/STOP.
000930  1               ;******************************************************************
000930  1               update_input:
000930  1  64 rr           stz key_flags
000932  1  64 rr           stz key_last
000934  1               
000934  1                  ; --- joystick 0 = keyboard d-pad (active low: 0 = pressed) ---
000934  1                  ; Byte returned: {B,Y,Sel,Sta,Up,Dn,Left,Right} bits 7–0
000934  1  A9 00           lda #0
000936  1  20 56 FF        jsr JOYSTICK_GET
000939  1  48              pha                           ; save — AND destroys .A
00093A  1               
00093A  1  29 01           and #JOY_RIGHT                ; bit 0: right arrow
00093C  1  D0 06           bne @not_right
00093E  1  A5 rr           lda key_flags
000940  1  09 02           ora #KEY_RIGHT
000942  1  85 rr           sta key_flags
000944  1               @not_right:
000944  1  68              pla
000945  1  29 02           and #JOY_LEFT                 ; bit 1: left arrow
000947  1  D0 06           bne @not_left
000949  1  A5 rr           lda key_flags
00094B  1  09 01           ora #KEY_LEFT
00094D  1  85 rr           sta key_flags
00094F  1               @not_left:
00094F  1               
00094F  1                  ; --- GETIN — discrete events: fire, RUN/STOP, arrow fallback ---
00094F  1               @getin_drain:
00094F  1  20 E4 FF        jsr GETIN
000952  1  F0 26           beq @getin_done               ; buffer empty
000954  1  85 rr           sta key_last
000956  1  C9 9D           cmp #$9D                      ; cursor left (PETSCII)
000958  1  D0 08           bne @chk_right_getin
00095A  1  A5 rr           lda key_flags
00095C  1  09 01           ora #KEY_LEFT
00095E  1  85 rr           sta key_flags
000960  1  80 ED           bra @getin_drain
000962  1               @chk_right_getin:
000962  1  C9 1D           cmp #$1D                      ; cursor right (PETSCII)
000964  1  D0 08           bne @chk_fire_getin
000966  1  A5 rr           lda key_flags
000968  1  09 02           ora #KEY_RIGHT
00096A  1  85 rr           sta key_flags
00096C  1  80 E1           bra @getin_drain
00096E  1               @chk_fire_getin:
00096E  1  C9 20           cmp #$20                      ; space = fire
000970  1  D0 DD           bne @getin_drain
000972  1  A5 rr           lda key_flags
000974  1  09 04           ora #KEY_FIRE
000976  1  85 rr           sta key_flags
000978  1  80 D5           bra @getin_drain
00097A  1               @getin_done:
00097A  1  60              rts
00097B  1               
00097B  1               ;******************************************************************
00097B  1               ; init_player — set player_x to starting position
00097B  1               ;******************************************************************
00097B  1               init_player:
00097B  1  A9 38           lda #<PLAYER_X_INIT
00097D  1  85 rr           sta player_x_lo
00097F  1  A9 01           lda #>PLAYER_X_INIT
000981  1  85 rr           sta player_x_hi
000983  1  A9 03           lda #LIVES_INIT
000985  1  85 rr           sta lives
000987  1  64 rr           stz inv_hit_timer
000989  1  60              rts
00098A  1               
00098A  1               ;******************************************************************
00098A  1               ; init_sprites — upload pixel data + write sprite 1 attributes
00098A  1               ;
00098A  1               ;   Sprite 0 ($1FC00) is reserved by the KERNAL mouse cursor —
00098A  1               ;   we disable it and keep clear of $1FC00.
00098A  1               ;
00098A  1               ;   Sprite 1 ($1FC08) = player ship
00098A  1               ;   Pixel data at VRAM $00080 (128 bytes, 16x16 4bpp)
00098A  1               ;   Address encoding:  addr[12:5] = $00080>>5 = $04  → byte 0 = $04
00098A  1               ;                      4bpp, addr[16:13] = 0          → byte 1 = $00
00098A  1               ;******************************************************************
00098A  1               init_sprites:
00098A  1  9C 25 9F        stz VERA_ctrl
00098D  1               
00098D  1                  ; --- set palette entries 1-4 ---
00098D  1                  ; VERA palette entry N is 2 bytes at VRAM_palette + N*2
00098D  1                  ; Byte 0: [7:4]=Green [3:0]=Blue   Byte 1: [3:0]=Red (bits 7-4 unused)
00098D  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_palette + 2), 1   ; entry 1 (player white); stride=1 auto-advances
000991  1  9F A9 FA 8D  
000995  1  21 9F A9 02  
00099C  1  A9 FF           lda #$FF                               ; G=$F, B=$F
00099E  1  8D 23 9F        sta VERA_data0
0009A1  1  A9 0F           lda #$0F                               ; R=$F  → white
0009A3  1  8D 23 9F        sta VERA_data0
0009A6  1                  ; entry 2 = cyan  (R=0, G=$F, B=$F)
0009A6  1  A9 FF           lda #$FF                               ; G=$F, B=$F
0009A8  1  8D 23 9F        sta VERA_data0
0009AB  1  A9 00           lda #$00                               ; R=$0
0009AD  1  8D 23 9F        sta VERA_data0
0009B0  1                  ; entry 3 = magenta (R=$F, G=0, B=$F)
0009B0  1  A9 0F           lda #$0F                               ; G=$0, B=$F
0009B2  1  8D 23 9F        sta VERA_data0
0009B5  1  A9 0F           lda #$0F                               ; R=$F
0009B7  1  8D 23 9F        sta VERA_data0
0009BA  1                  ; entry 4 = green  (R=0, G=$F, B=0)
0009BA  1  A9 F0           lda #$F0                               ; G=$F, B=$0
0009BC  1  8D 23 9F        sta VERA_data0
0009BF  1  A9 00           lda #$00                               ; R=$0
0009C1  1  8D 23 9F        sta VERA_data0
0009C4  1                  ; entry 5 = red    (R=$F, G=0, B=0)
0009C4  1  A9 00           lda #$00                               ; G=$0, B=$0
0009C6  1  8D 23 9F        sta VERA_data0
0009C9  1  A9 0F           lda #$0F                               ; R=$F
0009CB  1  8D 23 9F        sta VERA_data0
0009CE  1                  ; --- disable sprite 0 (KERNAL mouse cursor) ---
0009CE  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_sprattr + 6), 1   ; sprite 0 byte 6 = z-depth
0009D2  1  9F A9 FC 8D  
0009D6  1  21 9F A9 06  
0009DD  1  A9 00           lda #$00                               ; z-depth=0 → disabled
0009DF  1  8D 23 9F        sta VERA_data0
0009E2  1               
0009E2  1                  ; --- upload player sprite pixel data to VRAM $00080 ---
0009E2  1  A9 10 8D 22     VERA_SET_ADDR $00080, 1
0009E6  1  9F A9 00 8D  
0009EA  1  21 9F A9 80  
0009F1  1  A2 00           ldx #0
0009F3  1               @upload:
0009F3  1  BD 07 1C        lda player_spr_data,x
0009F6  1  8D 23 9F        sta VERA_data0
0009F9  1  E8              inx
0009FA  1  E0 80           cpx #128
0009FC  1  D0 F5           bne @upload
0009FE  1               
0009FE  1                  ; --- write sprite 1 attribute bytes ---
0009FE  1  A9 11 8D 22     VERA_SET_ADDR SPRITE1_ATTR, 1
000A02  1  9F A9 FC 8D  
000A06  1  21 9F A9 08  
000A0D  1  A9 04           lda #$04
000A0F  1  8D 23 9F        sta VERA_data0               ; byte 0: addr[12:5] = $00080>>5 = $04
000A12  1  A9 00           lda #$00
000A14  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, addr[16:13] = 0
000A17  1  A5 rr           lda player_x_lo
000A19  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000A1C  1  A5 rr           lda player_x_hi
000A1E  1  29 03           and #$03
000A20  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000A23  1  A9 A4           lda #<PLAYER_Y
000A25  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000A28  1  A9 01           lda #>PLAYER_Y
000A2A  1  29 03           and #$03
000A2C  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000A2F  1  A9 0C           lda #SPR_Z_FRONT
000A31  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3, no collision, no flip
000A34  1  A9 50           lda #SPR_16x16_PAL0
000A36  1  8D 23 9F        sta VERA_data0               ; byte 7: palette 0, 16x16
000A39  1               
000A39  1                  ; --- upload player bullet pixel data to VRAM $00400 ---
000A39  1  A9 10 8D 22     VERA_SET_ADDR VRAM_BULLET, 1
000A3D  1  9F A9 04 8D  
000A41  1  21 9F A9 00  
000A48  1  A2 00           ldx #0
000A4A  1               @up_bullet:
000A4A  1  BD 87 1C        lda bullet_spr_data,x
000A4D  1  8D 23 9F        sta VERA_data0
000A50  1  E8              inx
000A51  1  E0 20           cpx #32
000A53  1  D0 F5           bne @up_bullet
000A55  1               
000A55  1                  ; --- write sprite 2 attributes (initially disabled, z-depth=0) ---
000A55  1  A9 11 8D 22     VERA_SET_ADDR BULLET_SPRITE_ATTR, 1
000A59  1  9F A9 FC 8D  
000A5D  1  21 9F A9 10  
000A64  1  A9 20           lda #$20                     ; byte 0: addr[12:5] = $00400>>5 = $20
000A66  1  8D 23 9F        sta VERA_data0
000A69  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000A6B  1  8D 23 9F        sta VERA_data0
000A6E  1  A9 00           lda #$00                     ; byte 2: X lo (arbitrary; sprite disabled)
000A70  1  8D 23 9F        sta VERA_data0
000A73  1  A9 00           lda #$00                     ; byte 3: X hi
000A75  1  8D 23 9F        sta VERA_data0
000A78  1  A9 00           lda #$00                     ; byte 4: Y lo
000A7A  1  8D 23 9F        sta VERA_data0
000A7D  1  A9 00           lda #$00                     ; byte 5: Y hi
000A7F  1  8D 23 9F        sta VERA_data0
000A82  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000A84  1  8D 23 9F        sta VERA_data0
000A87  1  A9 00           lda #SPR_8x8_PAL0            ; byte 7: 8x8, palette 0
000A89  1  8D 23 9F        sta VERA_data0
000A8C  1               
000A8C  1                  ; --- upload explosion pixel data to VRAM $00440 ---
000A8C  1  A9 10 8D 22     VERA_SET_ADDR VRAM_EXPLOSION, 1
000A90  1  9F A9 04 8D  
000A94  1  21 9F A9 40  
000A9B  1  A2 00           ldx #0
000A9D  1               @up_exp:
000A9D  1  BD 59 1D        lda explosion_pixels,x
000AA0  1  8D 23 9F        sta VERA_data0
000AA3  1  E8              inx
000AA4  1  E0 80           cpx #128
000AA6  1  D0 F5           bne @up_exp
000AA8  1               
000AA8  1                  ; --- write sprite 4 attributes (initially disabled) ---
000AA8  1                  ; addr[12:5] = VRAM_EXPLOSION>>5 = $00440>>5 = $22
000AA8  1  A9 11 8D 22     VERA_SET_ADDR EXPLODE_SPRITE_ATTR, 1
000AAC  1  9F A9 FC 8D  
000AB0  1  21 9F A9 20  
000AB7  1  A9 22           lda #$22                     ; byte 0: addr[12:5]
000AB9  1  8D 23 9F        sta VERA_data0
000ABC  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000ABE  1  8D 23 9F        sta VERA_data0
000AC1  1  A9 00           lda #$00                     ; byte 2: X lo (placeholder)
000AC3  1  8D 23 9F        sta VERA_data0
000AC6  1  A9 00           lda #$00                     ; byte 3: X hi
000AC8  1  8D 23 9F        sta VERA_data0
000ACB  1  A9 00           lda #$00                     ; byte 4: Y lo (placeholder)
000ACD  1  8D 23 9F        sta VERA_data0
000AD0  1  A9 00           lda #$00                     ; byte 5: Y hi
000AD2  1  8D 23 9F        sta VERA_data0
000AD5  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000AD7  1  8D 23 9F        sta VERA_data0
000ADA  1  A9 50           lda #SPR_16x16_PAL0          ; byte 7: 16x16, palette 0
000ADC  1  8D 23 9F        sta VERA_data0
000ADF  1               
000ADF  1  64 rr           stz exp_timer
000AE1  1               
000AE1  1                  ; --- upload invader bullet pixel data to VRAM $00420 ---
000AE1  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_BULLET, 1
000AE5  1  9F A9 04 8D  
000AE9  1  21 9F A9 20  
000AF0  1  A2 00           ldx #0
000AF2  1               @up_ibul:
000AF2  1  BD 39 1D        lda inv_bullet_spr_data,x
000AF5  1  8D 23 9F        sta VERA_data0
000AF8  1  E8              inx
000AF9  1  E0 20           cpx #32
000AFB  1  D0 F5           bne @up_ibul
000AFD  1               
000AFD  1                  ; --- init 3 invader bullet sprites (slots 5-7, base $1FC28), all disabled ---
000AFD  1                  ; addr[12:5] = VRAM_INV_BULLET>>5 = $00420>>5 = $21
000AFD  1  A9 11 8D 22     VERA_SET_ADDR INV_BULLET_SPR_BASE, 1
000B01  1  9F A9 FC 8D  
000B05  1  21 9F A9 28  
000B0C  1  A2 03           ldx #3                       ; 3 sprites
000B0E  1               @init_ibspr:
000B0E  1  A9 21           lda #$21                     ; byte 0: addr[12:5] = $21
000B10  1  8D 23 9F        sta VERA_data0
000B13  1  A9 00           lda #$00
000B15  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, bank 0
000B18  1  8D 23 9F        sta VERA_data0               ; byte 2: X lo
000B1B  1  8D 23 9F        sta VERA_data0               ; byte 3: X hi
000B1E  1  8D 23 9F        sta VERA_data0               ; byte 4: Y lo
000B21  1  8D 23 9F        sta VERA_data0               ; byte 5: Y hi
000B24  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=0 → disabled
000B27  1  8D 23 9F        sta VERA_data0               ; byte 7: 8x8, palette 0
000B2A  1  CA              dex
000B2B  1  D0 E1           bne @init_ibspr
000B2D  1               
000B2D  1                  ; --- clear invader bullet state ---
000B2D  1  64 rr           stz ibul_active+0
000B2F  1  64 rr           stz ibul_active+1
000B31  1  64 rr           stz ibul_active+2
000B33  1  A9 5A           lda #INV_FIRE_TIMER_INIT
000B35  1  85 rr           sta inv_fire_timer
000B37  1               
000B37  1                  ; --- upload UFO pixel data → VRAM $01500 ---
000B37  1  A9 10 8D 22     VERA_SET_ADDR VRAM_UFO, 1
000B3B  1  9F A9 15 8D  
000B3F  1  21 9F A9 00  
000B46  1  A2 80           ldx #128
000B48  1  BD 59 1D     @up_ufo: lda ufo_spr_data-128,x
000B4B  1  8D 23 9F        sta VERA_data0
000B4E  1  E8              inx
000B4F  1  D0 F7           bne @up_ufo
000B51  1               
000B51  1                  ; --- write sprite 3 (UFO) attributes (initially disabled) ---
000B51  1                  ; addr[12:5] = VRAM_UFO>>5 = $01500>>5 = $A8
000B51  1  A9 11 8D 22     VERA_SET_ADDR UFO_SPRITE_ATTR, 1
000B55  1  9F A9 FC 8D  
000B59  1  21 9F A9 18  
000B60  1  A9 A8           lda #$A8                     ; byte 0: addr[12:5]
000B62  1  8D 23 9F        sta VERA_data0
000B65  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000B67  1  8D 23 9F        sta VERA_data0
000B6A  1  A9 00           lda #$00                     ; byte 2: X lo
000B6C  1  8D 23 9F        sta VERA_data0
000B6F  1  A9 00           lda #$00                     ; byte 3: X hi
000B71  1  8D 23 9F        sta VERA_data0
000B74  1  A9 20           lda #<UFO_Y                  ; byte 4: Y lo
000B76  1  8D 23 9F        sta VERA_data0
000B79  1  A9 00           lda #>UFO_Y                  ; byte 5: Y hi
000B7B  1  8D 23 9F        sta VERA_data0
000B7E  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000B80  1  8D 23 9F        sta VERA_data0
000B83  1  A9 50           lda #SPR_16x16_PAL0          ; byte 7: 16x16, palette 0
000B85  1  8D 23 9F        sta VERA_data0
000B88  1               
000B88  1  60              rts
000B89  1               
000B89  1               ;******************************************************************
000B89  1               ; init_invaders — upload invader pixel data, init grid state, place sprites
000B89  1               ;******************************************************************
000B89  1               init_invaders:
000B89  1  9C 25 9F        stz VERA_ctrl
000B8C  1               
000B8C  1                  ; --- upload Type A frame 0 → VRAM $00100 ---
000B8C  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F0, 1
000B90  1  9F A9 01 8D  
000B94  1  21 9F A9 00  
000B9B  1  A2 80           ldx #128
000B9D  1  BD D9 1D     @up_af0: lda inv_a_spr_f0-128,x
000BA0  1  8D 23 9F        sta VERA_data0
000BA3  1  E8              inx
000BA4  1  D0 F7           bne @up_af0
000BA6  1               
000BA6  1                  ; --- upload Type A frame 1 → VRAM $00180 ---
000BA6  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F1, 1
000BAA  1  9F A9 01 8D  
000BAE  1  21 9F A9 80  
000BB5  1  A2 80           ldx #128
000BB7  1  BD 59 1E     @up_af1: lda inv_a_spr_f1-128,x
000BBA  1  8D 23 9F        sta VERA_data0
000BBD  1  E8              inx
000BBE  1  D0 F7           bne @up_af1
000BC0  1               
000BC0  1                  ; --- upload Type B frame 0 → VRAM $00200 ---
000BC0  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F0, 1
000BC4  1  9F A9 02 8D  
000BC8  1  21 9F A9 00  
000BCF  1  A2 80           ldx #128
000BD1  1  BD D9 1E     @up_bf0: lda inv_b_spr_f0-128,x
000BD4  1  8D 23 9F        sta VERA_data0
000BD7  1  E8              inx
000BD8  1  D0 F7           bne @up_bf0
000BDA  1               
000BDA  1                  ; --- upload Type B frame 1 → VRAM $00280 ---
000BDA  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F1, 1
000BDE  1  9F A9 02 8D  
000BE2  1  21 9F A9 80  
000BE9  1  A2 80           ldx #128
000BEB  1  BD 59 1F     @up_bf1: lda inv_b_spr_f1-128,x
000BEE  1  8D 23 9F        sta VERA_data0
000BF1  1  E8              inx
000BF2  1  D0 F7           bne @up_bf1
000BF4  1               
000BF4  1                  ; --- upload Type C frame 0 → VRAM $00300 ---
000BF4  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F0, 1
000BF8  1  9F A9 03 8D  
000BFC  1  21 9F A9 00  
000C03  1  A2 80           ldx #128
000C05  1  BD D9 1F     @up_cf0: lda inv_c_spr_f0-128,x
000C08  1  8D 23 9F        sta VERA_data0
000C0B  1  E8              inx
000C0C  1  D0 F7           bne @up_cf0
000C0E  1               
000C0E  1                  ; --- upload Type C frame 1 → VRAM $00380 ---
000C0E  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F1, 1
000C12  1  9F A9 03 8D  
000C16  1  21 9F A9 80  
000C1D  1  A2 80           ldx #128
000C1F  1  BD 59 20     @up_cf1: lda inv_c_spr_f1-128,x
000C22  1  8D 23 9F        sta VERA_data0
000C25  1  E8              inx
000C26  1  D0 F7           bne @up_cf1
000C28  1               
000C28  1                  ; --- initialize zero-page grid variables ---
000C28  1  A9 70           lda #<INV_GRID_X_INIT
000C2A  1  85 rr           sta inv_grid_x_lo
000C2C  1  A9 00           lda #>INV_GRID_X_INIT
000C2E  1  85 rr           sta inv_grid_x_hi
000C30  1  64 rr           stz inv_offset_y
000C32  1  64 rr           stz inv_direction
000C34  1  64 rr           stz inv_anim_frame
000C36  1  64 rr           stz inv_drop_flag
000C38  1               
000C38  1                  ; all 55 invaders alive: bytes 0-5 = $FF, byte 6 = $7F (55 bits)
000C38  1  A9 FF           lda #$FF
000C3A  1  85 rr           sta inv_alive+0
000C3C  1  85 rr           sta inv_alive+1
000C3E  1  85 rr           sta inv_alive+2
000C40  1  85 rr           sta inv_alive+3
000C42  1  85 rr           sta inv_alive+4
000C44  1  85 rr           sta inv_alive+5
000C46  1  A9 7F           lda #$7F
000C48  1  85 rr           sta inv_alive+6
000C4A  1               
000C4A  1  A9 37           lda #INV_COUNT_INIT
000C4C  1  85 rr           sta inv_count
000C4E  1  A5 rr           lda wave_init_speed
000C50  1  85 rr           sta inv_move_speed
000C52  1  85 rr           sta inv_move_timer
000C54  1               
000C54  1                  ; --- write initial sprite attributes for all 55 invaders ---
000C54  1  20 BD 0C        jsr update_invader_sprites
000C57  1  60              rts
000C58  1               
000C58  1               ;******************************************************************
000C58  1               ; step_invaders — one march step: move or drop grid, toggle anim frame
000C58  1               ;   Called when inv_move_timer reaches 0.
000C58  1               ;   Updates inv_grid_x / inv_offset_y, sets inv_drop_flag as needed,
000C58  1               ;   then refreshes all VERA sprite positions.
000C58  1               ;******************************************************************
000C58  1               step_invaders:
000C58  1                  ; toggle animation frame
000C58  1  A5 rr           lda inv_anim_frame
000C5A  1  49 01           eor #1
000C5C  1  85 rr           sta inv_anim_frame
000C5E  1               
000C5E  1                  ; if drop flag is set: drop grid this step, skip march
000C5E  1  A5 rr           lda inv_drop_flag
000C60  1  F0 0B           beq @do_march
000C62  1  64 rr           stz inv_drop_flag
000C64  1  A5 rr           lda inv_offset_y
000C66  1  18              clc
000C67  1  69 10           adc #INV_DROP_Y
000C69  1  85 rr           sta inv_offset_y
000C6B  1  80 4C           bra @sprites_done
000C6D  1               
000C6D  1               @do_march:
000C6D  1  A5 rr           lda inv_direction
000C6F  1  D0 25           bne @march_left
000C71  1               
000C71  1                  ; --- march right ---
000C71  1  A5 rr           lda inv_grid_x_lo
000C73  1  18              clc
000C74  1  69 04           adc #INV_STEP_X
000C76  1  85 rr           sta inv_grid_x_lo
000C78  1  90 02           bcc @chk_right
000C7A  1  E6 rr           inc inv_grid_x_hi
000C7C  1               @chk_right:
000C7C  1                  ; hit right if grid_x > INV_X_RIGHT_LIM (208, fits in 1 byte, hi always 0)
000C7C  1  A5 rr           lda inv_grid_x_hi
000C7E  1  D0 06           bne @clamp_right          ; hi > 0 → definitely over limit
000C80  1  A5 rr           lda inv_grid_x_lo
000C82  1  C9 D1           cmp #INV_X_RIGHT_LIM + 1  ; C set if lo > limit
000C84  1  90 33           bcc @sprites_done
000C86  1               @clamp_right:
000C86  1  A9 D0           lda #<INV_X_RIGHT_LIM
000C88  1  85 rr           sta inv_grid_x_lo
000C8A  1  A9 00           lda #>INV_X_RIGHT_LIM
000C8C  1  85 rr           sta inv_grid_x_hi
000C8E  1  A9 01           lda #1
000C90  1  85 rr           sta inv_direction
000C92  1  85 rr           sta inv_drop_flag
000C94  1  80 23           bra @sprites_done
000C96  1               
000C96  1                  ; --- march left ---
000C96  1               @march_left:
000C96  1  A5 rr           lda inv_grid_x_lo
000C98  1  38              sec
000C99  1  E9 04           sbc #INV_STEP_X
000C9B  1  85 rr           sta inv_grid_x_lo
000C9D  1  B0 02           bcs @chk_left             ; no borrow
000C9F  1  C6 rr           dec inv_grid_x_hi
000CA1  1               @chk_left:
000CA1  1                  ; hit left if hi went negative OR lo < INV_X_LEFT_LIM
000CA1  1  A5 rr           lda inv_grid_x_hi
000CA3  1  30 06           bmi @clamp_left
000CA5  1  A5 rr           lda inv_grid_x_lo
000CA7  1  C9 10           cmp #INV_X_LEFT_LIM
000CA9  1  B0 0E           bcs @sprites_done         ; lo >= left limit → ok
000CAB  1               @clamp_left:
000CAB  1  A9 10           lda #<INV_X_LEFT_LIM
000CAD  1  85 rr           sta inv_grid_x_lo
000CAF  1  A9 00           lda #>INV_X_LEFT_LIM
000CB1  1  85 rr           sta inv_grid_x_hi
000CB3  1  64 rr           stz inv_direction
000CB5  1  A9 01           lda #1
000CB7  1  85 rr           sta inv_drop_flag
000CB9  1               
000CB9  1               @sprites_done:
000CB9  1  20 BD 0C        jsr update_invader_sprites
000CBC  1  60              rts
000CBD  1               
000CBD  1               ;******************************************************************
000CBD  1               ; update_invader_sprites — write all 55 invader sprite attributes to VERA
000CBD  1               ;
000CBD  1               ;   VERA sprite slots 11-65 hold the 55 invaders.
000CBD  1               ;   Attributes base: $1FC58 ($1FC00 + 11*8).
000CBD  1               ;   With stride=1 the VERA address auto-increments, so we set it
000CBD  1               ;   once and write all 440 bytes sequentially.
000CBD  1               ;
000CBD  1               ;   Byte layout per sprite:
000CBD  1               ;     0: data addr[12:5]   (encodes VRAM pixel data address + frame)
000CBD  1               ;     1: $00               (4bpp, addr[16:13]=0)
000CBD  1               ;     2: X[7:0]
000CBD  1               ;     3: X[9:8]
000CBD  1               ;     4: Y[7:0]
000CBD  1               ;     5: Y[9:8]
000CBD  1               ;     6: z-depth/collision
000CBD  1               ;     7: palette / size
000CBD  1               ;
000CBD  1               ;   Invader index i = row*11 + col; alive bit i in inv_alive bitmap.
000CBD  1               ;   For Phase 3 all invaders are alive; alive check will be added Phase 4.
000CBD  1               ;******************************************************************
000CBD  1               update_invader_sprites:
000CBD  1  9C 25 9F        stz VERA_ctrl
000CC0  1  A9 11           lda #$11              ; stride=1, VRAM bank bit=1 (addr $1Fxxxx)
000CC2  1  8D 22 9F        sta VERA_addr_bank
000CC5  1  A9 FC           lda #$FC
000CC7  1  8D 21 9F        sta VERA_addr_high
000CCA  1  A9 58           lda #$58
000CCC  1  8D 20 9F        sta VERA_addr_low     ; VERA now at $1FC58, auto-increments by 1
000CCF  1               
000CCF  1                  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000CCF  1  A9 50           lda #<INV_GRID_Y_BASE
000CD1  1  18              clc
000CD2  1  65 rr           adc inv_offset_y
000CD4  1  85 rr           sta zp_y_base_lo
000CD6  1  A9 00           lda #>INV_GRID_Y_BASE
000CD8  1  69 00           adc #0
000CDA  1  85 rr           sta zp_y_base_hi
000CDC  1               
000CDC  1  64 rr           stz zp_row
000CDE  1               @row_loop:
000CDE  1                  ; compute row Y: zp_row_y = zp_y_base + row_y_offsets[row]
000CDE  1  A4 rr           ldy zp_row
000CE0  1  B9 C7 1C        lda row_y_offsets,y
000CE3  1  18              clc
000CE4  1  65 rr           adc zp_y_base_lo
000CE6  1  85 rr           sta zp_row_y_lo
000CE8  1  A9 00           lda #0
000CEA  1  65 rr           adc zp_y_base_hi
000CEC  1  85 rr           sta zp_row_y_hi
000CEE  1               
000CEE  1                  ; select addr byte0 based on row type and animation frame
000CEE  1  A4 rr           ldy zp_row
000CF0  1  A5 rr           lda inv_anim_frame
000CF2  1  F0 05           beq @use_f0
000CF4  1  B9 AC 1C        lda inv_addr_b0_f1,y
000CF7  1  80 03           bra @got_b0
000CF9  1               @use_f0:
000CF9  1  B9 A7 1C        lda inv_addr_b0_f0,y
000CFC  1               @got_b0:
000CFC  1  85 rr           sta zp_addr_b0
000CFE  1               
000CFE  1  20 0A 0D        jsr update_invader_row
000D01  1               
000D01  1  E6 rr           inc zp_row
000D03  1  A5 rr           lda zp_row
000D05  1  C9 05           cmp #5
000D07  1  D0 D5           bne @row_loop
000D09  1               
000D09  1  60              rts
000D0A  1               
000D0A  1               ;******************************************************************
000D0A  1               ; update_invader_row — write 11 sprite attribute blocks for one row
000D0A  1               ;
000D0A  1               ;   Inputs (ZP): zp_row, zp_addr_b0, zp_row_y_lo/hi, inv_grid_x_lo/hi
000D0A  1               ;   VERA address register must already be set to the first sprite slot
000D0A  1               ;   for this row on entry (maintained by the sequential write stream).
000D0A  1               ;******************************************************************
000D0A  1               update_invader_row:
000D0A  1  64 rr           stz zp_col
000D0C  1               @col_loop:
000D0C  1                  ; --- determine z-depth from alive bitmap ---
000D0C  1                  ; index = inv_row_base[row] + col; byte = index>>3; bit = index&7
000D0C  1  A4 rr           ldy zp_row
000D0E  1  B9 CC 1C        lda inv_row_base,y
000D11  1  18              clc
000D12  1  65 rr           adc zp_col
000D14  1  A8              tay                   ; Y = invader index
000D15  1  29 07           and #$07
000D17  1  AA              tax                   ; X = bit index
000D18  1  BD D1 1C        lda bit_masks,x
000D1B  1  48              pha                   ; save bit mask
000D1C  1  98              tya
000D1D  1  4A              lsr
000D1E  1  4A              lsr
000D1F  1  4A              lsr
000D20  1  A8              tay                   ; Y = byte index into inv_alive
000D21  1  68              pla                   ; A = bit mask
000D22  1  39 rr rr        and inv_alive,y
000D25  1  F0 04           beq @zdepth_off
000D27  1  A9 0C           lda #SPR_Z_FRONT
000D29  1  80 02           bra @zdepth_done
000D2B  1               @zdepth_off:
000D2B  1  A9 00           lda #0
000D2D  1               @zdepth_done:
000D2D  1  85 rr           sta zp_scratch_lo     ; save z-depth before VERA stream starts
000D2F  1               
000D2F  1                  ; --- compute sprite X = inv_grid_x + col_x_offsets[col] ---
000D2F  1  A4 rr           ldy zp_col
000D31  1  B9 B1 1C        lda col_x_lo,y
000D34  1  18              clc
000D35  1  65 rr           adc inv_grid_x_lo
000D37  1  85 rr           sta zp_x_lo
000D39  1  B9 BC 1C        lda col_x_hi,y
000D3C  1  65 rr           adc inv_grid_x_hi
000D3E  1  85 rr           sta zp_x_hi
000D40  1               
000D40  1                  ; --- write 8 attribute bytes (VERA auto-increments) ---
000D40  1  A5 rr           lda zp_addr_b0
000D42  1  8D 23 9F        sta VERA_data0        ; byte 0: data addr[12:5]
000D45  1  9C 23 9F        stz VERA_data0        ; byte 1: 4bpp, addr[16:13]=0
000D48  1  A5 rr           lda zp_x_lo
000D4A  1  8D 23 9F        sta VERA_data0        ; byte 2: X[7:0]
000D4D  1  A5 rr           lda zp_x_hi
000D4F  1  29 03           and #$03
000D51  1  8D 23 9F        sta VERA_data0        ; byte 3: X[9:8]
000D54  1  A5 rr           lda zp_row_y_lo
000D56  1  8D 23 9F        sta VERA_data0        ; byte 4: Y[7:0]
000D59  1  A5 rr           lda zp_row_y_hi
000D5B  1  29 03           and #$03
000D5D  1  8D 23 9F        sta VERA_data0        ; byte 5: Y[9:8]
000D60  1  A5 rr           lda zp_scratch_lo
000D62  1  8D 23 9F        sta VERA_data0        ; byte 6: z-depth (SPR_Z_FRONT if alive, 0 if dead)
000D65  1  A9 50           lda #SPR_16x16_PAL0
000D67  1  8D 23 9F        sta VERA_data0        ; byte 7: 16x16, palette offset 0
000D6A  1               
000D6A  1  E6 rr           inc zp_col
000D6C  1  A5 rr           lda zp_col
000D6E  1  C9 0B           cmp #11
000D70  1  D0 9A           bne @col_loop
000D72  1               
000D72  1  60              rts
000D73  1               
000D73  1               ;******************************************************************
000D73  1               ; move_player — apply key_flags movement and clamp to screen edges
000D73  1               ;******************************************************************
000D73  1               move_player:
000D73  1  A5 rr           lda key_flags
000D75  1               
000D75  1                  ; --- move left ---
000D75  1  29 01           and #KEY_LEFT
000D77  1  F0 1F           beq @check_right
000D79  1  A5 rr           lda player_x_lo
000D7B  1  38              sec
000D7C  1  E9 04           sbc #PLAYER_SPEED
000D7E  1  85 rr           sta player_x_lo
000D80  1  B0 02           bcs @clamp_left              ; no borrow → hi unchanged
000D82  1  C6 rr           dec player_x_hi
000D84  1               @clamp_left:
000D84  1                  ; Clamp: if hi went negative ($FF) or (hi=0 AND lo < min) → set to min
000D84  1  A5 rr           lda player_x_hi
000D86  1  30 08           bmi @set_min                 ; $80–$FF = underflowed
000D88  1  D0 0E           bne @check_right             ; hi > 0 → still above minimum
000D8A  1  A5 rr           lda player_x_lo
000D8C  1  C9 08           cmp #PLAYER_X_MIN
000D8E  1  B0 08           bcs @check_right             ; lo >= min → ok
000D90  1               @set_min:
000D90  1  A9 08           lda #<PLAYER_X_MIN
000D92  1  85 rr           sta player_x_lo
000D94  1  A9 00           lda #>PLAYER_X_MIN
000D96  1  85 rr           sta player_x_hi
000D98  1               
000D98  1                  ; --- move right ---
000D98  1               @check_right:
000D98  1  A5 rr           lda key_flags
000D9A  1  29 02           and #KEY_RIGHT
000D9C  1  F0 23           beq @move_done
000D9E  1  A5 rr           lda player_x_lo
000DA0  1  18              clc
000DA1  1  69 04           adc #PLAYER_SPEED
000DA3  1  85 rr           sta player_x_lo
000DA5  1  90 02           bcc @clamp_right             ; no carry → hi unchanged
000DA7  1  E6 rr           inc player_x_hi
000DA9  1               @clamp_right:
000DA9  1                  ; Clamp: if hi > max_hi, OR (hi == max_hi AND lo > max_lo) → set to max
000DA9  1  A5 rr           lda player_x_hi
000DAB  1  C9 02           cmp #>PLAYER_X_MAX
000DAD  1  90 12           bcc @move_done               ; hi < max_hi → definitely ok
000DAF  1  D0 08           bne @set_max                 ; hi > max_hi → over limit
000DB1  1  A5 rr           lda player_x_lo
000DB3  1  C9 68           cmp #<PLAYER_X_MAX
000DB5  1  90 0A           bcc @move_done               ; lo < max_lo when hi == max_hi → ok
000DB7  1  F0 08           beq @move_done               ; lo == max_lo → exactly at max, ok
000DB9  1               @set_max:
000DB9  1  A9 68           lda #<PLAYER_X_MAX
000DBB  1  85 rr           sta player_x_lo
000DBD  1  A9 02           lda #>PLAYER_X_MAX
000DBF  1  85 rr           sta player_x_hi
000DC1  1               
000DC1  1               @move_done:
000DC1  1  60              rts
000DC2  1               
000DC2  1               ;******************************************************************
000DC2  1               ; update_player_sprite — write current X position to sprite 1 in VERA
000DC2  1               ;   Only X needs updating (Y is fixed)
000DC2  1               ;******************************************************************
000DC2  1               update_player_sprite:
000DC2  1  9C 25 9F        stz VERA_ctrl
000DC5  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 2), 1
000DC9  1  9F A9 FC 8D  
000DCD  1  21 9F A9 0A  
000DD4  1  A5 rr           lda player_x_lo
000DD6  1  8D 23 9F        sta VERA_data0               ; sprite byte 2: X[7:0]
000DD9  1  A5 rr           lda player_x_hi
000DDB  1  29 03           and #$03
000DDD  1  8D 23 9F        sta VERA_data0               ; sprite byte 3: X[9:8]
000DE0  1                  ; update z-depth based on inv_hit_timer:
000DE0  1                  ;   timer = 0        → show solid (not hit)
000DE0  1                  ;   timer = 61-120   → hidden solid (1-second respawn delay)
000DE0  1                  ;   timer = 1-60     → flashing (invincible, visible warning)
000DE0  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 6), 1
000DE4  1  9F A9 FC 8D  
000DE8  1  21 9F A9 0E  
000DEF  1  A5 rr           lda inv_hit_timer
000DF1  1  F0 08           beq @show                    ; timer=0 → show solid
000DF3  1  C9 3D           cmp #61
000DF5  1  B0 08           bcs @hide                    ; timer>=61 → first second: fully hidden
000DF7  1  29 08           and #$08                     ; timer 1-60: bit 3 flips every 8 frames → ~4 Hz flash
000DF9  1  D0 04           bne @hide
000DFB  1               @show:
000DFB  1  A9 0C           lda #SPR_Z_FRONT
000DFD  1  80 02           bra @write_z
000DFF  1               @hide:
000DFF  1  A9 00           lda #0
000E01  1               @write_z:
000E01  1  8D 23 9F        sta VERA_data0               ; sprite byte 6: z-depth
000E04  1  60              rts
000E05  1               
000E05  1               ;******************************************************************
000E05  1               ; fire_bullet — activate player bullet at cannon tip, update sprite
000E05  1               ;   Bullet X centers the 8-px bullet over the 16-px player ship:
000E05  1               ;     bullet_x = player_x + 4
000E05  1               ;   Bullet Y starts 8 VERA pixels above the player sprite top.
000E05  1               ;   Caller must check bullet_active == 0 before calling.
000E05  1               ;******************************************************************
000E05  1               fire_bullet:
000E05  1  A5 rr           lda player_x_lo
000E07  1  18              clc
000E08  1  69 04           adc #4
000E0A  1  85 rr           sta bullet_x_lo
000E0C  1  A5 rr           lda player_x_hi
000E0E  1  69 00           adc #0
000E10  1  85 rr           sta bullet_x_hi
000E12  1               
000E12  1  A9 9C           lda #<BULLET_Y_INIT
000E14  1  85 rr           sta bullet_y_lo
000E16  1  A9 01           lda #>BULLET_Y_INIT
000E18  1  85 rr           sta bullet_y_hi
000E1A  1               
000E1A  1  A9 01           lda #1
000E1C  1  85 rr           sta bullet_active
000E1E  1  E6 rr           inc shot_count
000E20  1  20 3D 0E        jsr update_bullet_sprite
000E23  1  60              rts
000E24  1               
000E24  1               ;******************************************************************
000E24  1               ; move_bullet — move bullet upward by BULLET_SPEED each frame;
000E24  1               ;   deactivate when it reaches the top of the screen (Y underflows 0)
000E24  1               ;******************************************************************
000E24  1               move_bullet:
000E24  1  A5 rr           lda bullet_y_lo
000E26  1  38              sec
000E27  1  E9 0C           sbc #BULLET_SPEED
000E29  1  85 rr           sta bullet_y_lo
000E2B  1  A5 rr           lda bullet_y_hi
000E2D  1  E9 00           sbc #0
000E2F  1  85 rr           sta bullet_y_hi
000E31  1  30 04           bmi @deactivate              ; 16-bit underflow past 0 → off screen
000E33  1               
000E33  1  20 3D 0E        jsr update_bullet_sprite
000E36  1  60              rts
000E37  1               
000E37  1               @deactivate:
000E37  1  64 rr           stz bullet_active
000E39  1  20 3D 0E        jsr update_bullet_sprite     ; disables sprite (z-depth=0)
000E3C  1  60              rts
000E3D  1               
000E3D  1               ;******************************************************************
000E3D  1               ; update_bullet_sprite — write bullet position and enable/disable
000E3D  1               ;   to VERA sprite 2 (bytes 2-6); byte 7 set once at init.
000E3D  1               ;   z-depth = SPR_Z_FRONT when active, 0 when inactive.
000E3D  1               ;******************************************************************
000E3D  1               update_bullet_sprite:
000E3D  1  9C 25 9F        stz VERA_ctrl
000E40  1  A9 11 8D 22     VERA_SET_ADDR (BULLET_SPRITE_ATTR + 2), 1
000E44  1  9F A9 FC 8D  
000E48  1  21 9F A9 12  
000E4F  1  A5 rr           lda bullet_x_lo
000E51  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000E54  1  A5 rr           lda bullet_x_hi
000E56  1  29 03           and #$03
000E58  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000E5B  1  A5 rr           lda bullet_y_lo
000E5D  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000E60  1  A5 rr           lda bullet_y_hi
000E62  1  29 03           and #$03
000E64  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000E67  1  A5 rr           lda bullet_active
000E69  1  F0 04           beq @z_off
000E6B  1  A9 0C           lda #SPR_Z_FRONT
000E6D  1  80 02           bra @write_z
000E6F  1               @z_off:
000E6F  1  A9 00           lda #$00
000E71  1               @write_z:
000E71  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
000E74  1  60              rts
000E75  1               
000E75  1               ;******************************************************************
000E75  1               ; check_bullet_invader — scan all 55 invaders for a hit with the player bullet
000E75  1               ;
000E75  1               ;   Iterates rows 0-4, columns 0-10.  Skips dead invaders.
000E75  1               ;   For each live invader checks 16-bit AABB overlap:
000E75  1               ;     X: bullet_x+8 > inv_x  AND  bullet_x < inv_x+16
000E75  1               ;     Y: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000E75  1               ;   On hit: calls kill_invader_hit and returns immediately.
000E75  1               ;
000E75  1               ;   Scratch used: zp_y_base_lo/hi, zp_row_y_lo/hi, zp_x_lo/hi,
000E75  1               ;                 zp_scratch_lo/hi, zp_row, zp_col
000E75  1               ;******************************************************************
000E75  1               check_bullet_invader:
000E75  1  A5 rr           lda bullet_active
000E77  1  D0 01           bne :+
000E79  1  60              rts
000E7A  1               :  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000E7A  1  A9 50           lda #<INV_GRID_Y_BASE
000E7C  1  18              clc
000E7D  1  65 rr           adc inv_offset_y
000E7F  1  85 rr           sta zp_y_base_lo
000E81  1  A9 00           lda #>INV_GRID_Y_BASE
000E83  1  69 00           adc #0
000E85  1  85 rr           sta zp_y_base_hi
000E87  1               
000E87  1  64 rr           stz zp_row
000E89  1               @row_loop:
000E89  1                  ; row Y = y_base + row_y_offsets[row]
000E89  1  A4 rr           ldy zp_row
000E8B  1  B9 C7 1C        lda row_y_offsets,y
000E8E  1  18              clc
000E8F  1  65 rr           adc zp_y_base_lo
000E91  1  85 rr           sta zp_row_y_lo
000E93  1  A9 00           lda #0
000E95  1  65 rr           adc zp_y_base_hi
000E97  1  85 rr           sta zp_row_y_hi
000E99  1               
000E99  1                  ; --- Quick Y range check for whole row ---
000E99  1                  ; Need: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000E99  1               
000E99  1                  ; (1) bullet_y+8 > inv_y  →  (bullet_y+8) - inv_y > 0
000E99  1                  ;     result negative (bmi) means bullet above this row
000E99  1  A5 rr           lda bullet_y_lo
000E9B  1  18              clc
000E9C  1  69 08           adc #8
000E9E  1  85 rr           sta zp_scratch_lo
000EA0  1  A5 rr           lda bullet_y_hi
000EA2  1  69 00           adc #0
000EA4  1  85 rr           sta zp_scratch_hi
000EA6  1  A5 rr           lda zp_scratch_lo
000EA8  1  38              sec
000EA9  1  E5 rr           sbc zp_row_y_lo
000EAB  1  A5 rr           lda zp_scratch_hi
000EAD  1  E5 rr           sbc zp_row_y_hi
000EAF  1  30 1D           bmi @next_row         ; bullet bottom above invader top → no hit in this row
000EB1  1               
000EB1  1                  ; (2) bullet_y < inv_y+16  →  bullet_y - (inv_y+16) < 0
000EB1  1                  ;     result >= 0 (bpl) means bullet below this row
000EB1  1  A5 rr           lda zp_row_y_lo
000EB3  1  18              clc
000EB4  1  69 10           adc #16
000EB6  1  85 rr           sta zp_scratch_lo
000EB8  1  A5 rr           lda zp_row_y_hi
000EBA  1  69 00           adc #0
000EBC  1  85 rr           sta zp_scratch_hi
000EBE  1  A5 rr           lda bullet_y_lo
000EC0  1  38              sec
000EC1  1  E5 rr           sbc zp_scratch_lo
000EC3  1  A5 rr           lda bullet_y_hi
000EC5  1  E5 rr           sbc zp_scratch_hi
000EC7  1  10 05           bpl @next_row         ; bullet top at or below invader bottom → no hit
000EC9  1               
000EC9  1                  ; Y overlaps this row — check each column
000EC9  1  20 D7 0E        jsr cbi_check_cols
000ECC  1  B0 08           bcs @done             ; hit found; bullet already handled
000ECE  1               
000ECE  1               @next_row:
000ECE  1  E6 rr           inc zp_row
000ED0  1  A5 rr           lda zp_row
000ED2  1  C9 05           cmp #5
000ED4  1  D0 B3           bne @row_loop
000ED6  1               
000ED6  1               @done:
000ED6  1  60              rts
000ED7  1               
000ED7  1               ;******************************************************************
000ED7  1               ; cbi_check_cols — column scan for check_bullet_invader
000ED7  1               ;
000ED7  1               ;   Scans all 11 columns of zp_row for an X overlap with the bullet.
000ED7  1               ;   Assumes Y overlap for this row has already been confirmed.
000ED7  1               ;   Returns: C set if hit (kill_invader_hit already called),
000ED7  1               ;            C clear if no hit.
000ED7  1               ;   Scratch used: zp_col, zp_x_lo/hi, zp_scratch_lo/hi
000ED7  1               ;******************************************************************
000ED7  1               cbi_check_cols:
000ED7  1  64 rr           stz zp_col
000ED9  1               @col_loop:
000ED9  1                  ; skip if invader is dead
000ED9  1  A4 rr           ldy zp_row
000EDB  1  B9 CC 1C        lda inv_row_base,y
000EDE  1  18              clc
000EDF  1  65 rr           adc zp_col
000EE1  1  A8              tay                   ; Y = invader index
000EE2  1  29 07           and #$07
000EE4  1  AA              tax
000EE5  1  BD D1 1C        lda bit_masks,x
000EE8  1  48              pha
000EE9  1  98              tya
000EEA  1  4A              lsr
000EEB  1  4A              lsr
000EEC  1  4A              lsr
000EED  1  A8              tay                   ; Y = byte index into inv_alive
000EEE  1  68              pla
000EEF  1  39 rr rr        and inv_alive,y
000EF2  1  F0 46           beq @next_col         ; dead
000EF4  1               
000EF4  1                  ; compute inv_x = inv_grid_x + col_x_offsets[col]
000EF4  1  A4 rr           ldy zp_col
000EF6  1  B9 B1 1C        lda col_x_lo,y
000EF9  1  18              clc
000EFA  1  65 rr           adc inv_grid_x_lo
000EFC  1  85 rr           sta zp_x_lo
000EFE  1  B9 BC 1C        lda col_x_hi,y
000F01  1  65 rr           adc inv_grid_x_hi
000F03  1  85 rr           sta zp_x_hi
000F05  1               
000F05  1                  ; X check (1): bullet_x+8 > inv_x
000F05  1  A5 rr           lda bullet_x_lo
000F07  1  18              clc
000F08  1  69 08           adc #8
000F0A  1  85 rr           sta zp_scratch_lo
000F0C  1  A5 rr           lda bullet_x_hi
000F0E  1  69 00           adc #0
000F10  1  85 rr           sta zp_scratch_hi
000F12  1  A5 rr           lda zp_scratch_lo
000F14  1  38              sec
000F15  1  E5 rr           sbc zp_x_lo
000F17  1  A5 rr           lda zp_scratch_hi
000F19  1  E5 rr           sbc zp_x_hi
000F1B  1  30 1D           bmi @next_col         ; bullet right edge left of invader → no hit
000F1D  1               
000F1D  1                  ; X check (2): bullet_x < inv_x+16
000F1D  1  A5 rr           lda zp_x_lo
000F1F  1  18              clc
000F20  1  69 10           adc #16
000F22  1  85 rr           sta zp_scratch_lo
000F24  1  A5 rr           lda zp_x_hi
000F26  1  69 00           adc #0
000F28  1  85 rr           sta zp_scratch_hi
000F2A  1  A5 rr           lda bullet_x_lo
000F2C  1  38              sec
000F2D  1  E5 rr           sbc zp_scratch_lo
000F2F  1  A5 rr           lda bullet_x_hi
000F31  1  E5 rr           sbc zp_scratch_hi
000F33  1  10 05           bpl @next_col         ; bullet left edge at or right of invader → no hit
000F35  1               
000F35  1                  ; --- HIT ---
000F35  1  20 44 0F        jsr kill_invader_hit
000F38  1  38              sec                   ; signal hit to caller
000F39  1  60              rts
000F3A  1               
000F3A  1               @next_col:
000F3A  1  E6 rr           inc zp_col
000F3C  1  A5 rr           lda zp_col
000F3E  1  C9 0B           cmp #11
000F40  1  D0 97           bne @col_loop
000F42  1               
000F42  1  18              clc                   ; no hit
000F43  1  60              rts
000F44  1               
000F44  1               ;******************************************************************
000F44  1               ; kill_invader_hit — clear alive bit, deactivate bullet, update score & speed
000F44  1               ;   Expects zp_row, zp_col to identify the hit invader.
000F44  1               ;******************************************************************
000F44  1               kill_invader_hit:
000F44  1                  ; --- clear alive bit ---
000F44  1  A4 rr           ldy zp_row
000F46  1  B9 CC 1C        lda inv_row_base,y
000F49  1  18              clc
000F4A  1  65 rr           adc zp_col
000F4C  1  A8              tay                   ; Y = invader index
000F4D  1  29 07           and #$07
000F4F  1  AA              tax
000F50  1  BD D1 1C        lda bit_masks,x       ; bit mask for this invader
000F53  1  48              pha
000F54  1  98              tya
000F55  1  4A              lsr
000F56  1  4A              lsr
000F57  1  4A              lsr
000F58  1  A8              tay                   ; Y = byte index into inv_alive
000F59  1  68              pla
000F5A  1  49 FF           eor #$FF              ; invert → clear mask
000F5C  1  39 rr rr        and inv_alive,y
000F5F  1  99 rr rr        sta inv_alive,y
000F62  1               
000F62  1                  ; --- start explosion at the hit invader's position ---
000F62  1                  ; zp_x_lo/hi and zp_row_y_lo/hi still hold the invader coords from collision detection
000F62  1  20 90 0F        jsr start_explosion
000F65  1               
000F65  1                  ; --- deactivate bullet ---
000F65  1  64 rr           stz bullet_active
000F67  1  20 3D 0E        jsr update_bullet_sprite
000F6A  1               
000F6A  1                  ; --- decrement inv_count ---
000F6A  1  C6 rr           dec inv_count
000F6C  1               
000F6C  1                  ; --- update inv_move_speed: proportional to remaining count ---
000F6C  1  A6 rr           ldx inv_count
000F6E  1  BD DE 1C        lda inv_speed_table,x
000F71  1  85 rr           sta inv_move_speed
000F73  1               
000F73  1                  ; --- add score for this row's invader type ---
000F73  1  A4 rr           ldy zp_row
000F75  1  B9 D9 1C        lda score_by_row_bcd,y
000F78  1  20 7C 0F        jsr add_score
000F7B  1  60              rts
000F7C  1               
000F7C  1               ;******************************************************************
000F7C  1               ; add_score — add BCD value in A to score_lo/mid/hi
000F7C  1               ;******************************************************************
000F7C  1               add_score:
000F7C  1  F8              sed
000F7D  1  18              clc
000F7E  1  65 rr           adc score_lo
000F80  1  85 rr           sta score_lo
000F82  1  A5 rr           lda score_mid
000F84  1  69 00           adc #0
000F86  1  85 rr           sta score_mid
000F88  1  A5 rr           lda score_hi
000F8A  1  69 00           adc #0
000F8C  1  85 rr           sta score_hi
000F8E  1  D8              cld
000F8F  1  60              rts
000F90  1               
000F90  1               ;******************************************************************
000F90  1               ; start_explosion — position sprite 4 at the hit invader and start timer
000F90  1               ;
000F90  1               ;   Inputs: zp_x_lo/hi     — invader X (VERA coords)
000F90  1               ;           zp_row_y_lo/hi — invader Y (VERA coords)
000F90  1               ;   Sets exp_timer = EXPLODE_FRAMES and enables sprite 4.
000F90  1               ;******************************************************************
000F90  1               start_explosion:
000F90  1  9C 25 9F        stz VERA_ctrl
000F93  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 2), 1  ; start at byte 2 (X lo)
000F97  1  9F A9 FC 8D  
000F9B  1  21 9F A9 22  
000FA2  1  A5 rr           lda zp_x_lo
000FA4  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000FA7  1  A5 rr           lda zp_x_hi
000FA9  1  29 03           and #$03
000FAB  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000FAE  1  A5 rr           lda zp_row_y_lo
000FB0  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000FB3  1  A5 rr           lda zp_row_y_hi
000FB5  1  29 03           and #$03
000FB7  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000FBA  1  A9 0C           lda #SPR_Z_FRONT
000FBC  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3 → enabled, in front
000FBF  1  A9 1E           lda #EXPLODE_FRAMES
000FC1  1  85 rr           sta exp_timer
000FC3  1  60              rts
000FC4  1               
000FC4  1               ;******************************************************************
000FC4  1               ; update_explosion — decrement exp_timer; disable sprite when it hits 0
000FC4  1               ;******************************************************************
000FC4  1               update_explosion:
000FC4  1  A5 rr           lda exp_timer
000FC6  1  F0 1B           beq @inactive
000FC8  1  C6 rr           dec exp_timer
000FCA  1  D0 17           bne @inactive
000FCC  1                  ; timer just expired — disable sprite 4
000FCC  1  9C 25 9F        stz VERA_ctrl
000FCF  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1  ; byte 6 = z-depth
000FD3  1  9F A9 FC 8D  
000FD7  1  21 9F A9 26  
000FDE  1  A9 00           lda #$00
000FE0  1  8D 23 9F        sta VERA_data0               ; z-depth=0 → disabled
000FE3  1               @inactive:
000FE3  1  60              rts
000FE4  1               
000FE4  1               ;******************************************************************
000FE4  1               ; prng — 16-bit Galois LFSR, feedback polynomial $B400
000FE4  1               ;   Updates rand_seed_lo/hi; returns pseudo-random byte in A.
000FE4  1               ;******************************************************************
000FE4  1               prng:
000FE4  1  46 rr           lsr rand_seed_hi          ; shift 16-bit state right; carry = old hi[0]
000FE6  1  66 rr           ror rand_seed_lo          ; lo[7] = old hi[0]; carry = old lo[0] (feedback bit)
000FE8  1  90 06           bcc @done                 ; feedback bit=0: no XOR
000FEA  1  A5 rr           lda rand_seed_hi
000FEC  1  49 B4           eor #$B4                  ; XOR hi byte with feedback poly ($B400 >> 8)
000FEE  1  85 rr           sta rand_seed_hi
000FF0  1               @done:
000FF0  1  A5 rr           lda rand_seed_lo
000FF2  1  60              rts
000FF3  1               
000FF3  1               ;******************************************************************
000FF3  1               ; update_inv_bullets — fire timer, move active bullets, boundary check,
000FF3  1               ;   update VERA sprites for all 3 invader bullet slots.
000FF3  1               ;******************************************************************
000FF3  1               update_inv_bullets:
000FF3  1                  ; --- fire timer ---
000FF3  1  C6 rr           dec inv_fire_timer
000FF5  1  D0 0D           bne @move_loop
000FF7  1                  ; reset timer = max(inv_move_speed, INV_FIRE_TIMER_MIN)
000FF7  1  A5 rr           lda inv_move_speed
000FF9  1  C9 0A           cmp #INV_FIRE_TIMER_MIN
000FFB  1  B0 02           bcs @set_timer
000FFD  1  A9 0A           lda #INV_FIRE_TIMER_MIN
000FFF  1               @set_timer:
000FFF  1  85 rr           sta inv_fire_timer
001001  1  20 6E 10        jsr try_fire_inv_bullet
001004  1               
001004  1               @move_loop:
001004  1  A2 00           ldx #0
001006  1               @slot_loop:
001006  1  B5 rr           lda ibul_active,x
001008  1  F0 1B           beq @update_spr           ; inactive: just hide sprite
00100A  1               
00100A  1                  ; move bullet down by INV_BULLET_SPEED
00100A  1  B5 rr           lda ibul_y_lo,x
00100C  1  18              clc
00100D  1  69 06           adc #INV_BULLET_SPEED
00100F  1  95 rr           sta ibul_y_lo,x
001011  1  B5 rr           lda ibul_y_hi,x
001013  1  69 00           adc #0
001015  1  95 rr           sta ibul_y_hi,x
001017  1               
001017  1                  ; boundary: deactivate if Y >= 480 ($01E0)
001017  1  C9 01           cmp #>480                 ; A = new hi byte; compare with 1
001019  1  90 0A           bcc @update_spr           ; hi < 1: still on screen
00101B  1  D0 06           bne @deactivate           ; hi > 1: off screen
00101D  1  B5 rr           lda ibul_y_lo,x
00101F  1  C9 E0           cmp #<480                 ; compare lo with $E0
001021  1  90 02           bcc @update_spr           ; lo < $E0: still on screen
001023  1               @deactivate:
001023  1  74 rr           stz ibul_active,x
001025  1               
001025  1               @update_spr:
001025  1  20 2E 10        jsr update_inv_bullet_sprite   ; preserves X
001028  1  E8              inx
001029  1  E0 03           cpx #3
00102B  1  D0 D9           bne @slot_loop
00102D  1  60              rts
00102E  1               
00102E  1               ;******************************************************************
00102E  1               ; update_inv_bullet_sprite — write VERA sprite attrs bytes 2-6 for slot X
00102E  1               ;   X = slot index (0-2).  Preserves X.
00102E  1               ;******************************************************************
00102E  1               update_inv_bullet_sprite:
00102E  1  86 rr           stx zp_scratch_lo              ; preserve slot index
001030  1  9C 25 9F        stz VERA_ctrl
001033  1  A9 11           lda #$11                       ; stride=1, bank bit=1
001035  1  8D 22 9F        sta VERA_addr_bank
001038  1  A9 FC           lda #$FC
00103A  1  8D 21 9F        sta VERA_addr_high
00103D  1  BD 16 1D        lda ibul_spr_lo,x
001040  1  18              clc
001041  1  69 02           adc #2                         ; point to byte 2 (X position)
001043  1  8D 20 9F        sta VERA_addr_low
001046  1  B5 rr           lda ibul_x_lo,x
001048  1  8D 23 9F        sta VERA_data0                 ; byte 2: X lo
00104B  1  B5 rr           lda ibul_x_hi,x
00104D  1  29 03           and #$03
00104F  1  8D 23 9F        sta VERA_data0                 ; byte 3: X hi
001052  1  B5 rr           lda ibul_y_lo,x
001054  1  8D 23 9F        sta VERA_data0                 ; byte 4: Y lo
001057  1  B5 rr           lda ibul_y_hi,x
001059  1  29 03           and #$03
00105B  1  8D 23 9F        sta VERA_data0                 ; byte 5: Y hi
00105E  1  B5 rr           lda ibul_active,x
001060  1  F0 04           beq @disabled
001062  1  A9 0C           lda #SPR_Z_FRONT
001064  1  80 02           bra @write_z
001066  1               @disabled:
001066  1  A9 00           lda #0
001068  1               @write_z:
001068  1  8D 23 9F        sta VERA_data0                 ; byte 6: z-depth
00106B  1  A6 rr           ldx zp_scratch_lo
00106D  1  60              rts
00106E  1               
00106E  1               ;******************************************************************
00106E  1               ; try_fire_inv_bullet — find a free slot and spawn a bullet from the
00106E  1               ;   bottommost live invader in a randomly chosen column.
00106E  1               ;   Returns immediately if all slots busy or chosen column is empty.
00106E  1               ;   Scratch used: zp_row, zp_col, zp_scratch_lo (slot index)
00106E  1               ;******************************************************************
00106E  1               try_fire_inv_bullet:
00106E  1                  ; find a free bullet slot
00106E  1  A2 00           ldx #0
001070  1               @find_slot:
001070  1  B5 rr           lda ibul_active,x
001072  1  F0 06           beq @slot_found
001074  1  E8              inx
001075  1  E0 03           cpx #3
001077  1  D0 F7           bne @find_slot
001079  1  60              rts                            ; all slots busy
00107A  1               
00107A  1               @slot_found:
00107A  1  86 rr           stx zp_scratch_lo              ; save free slot index
00107C  1               
00107C  1                  ; pick a random column 0-10
00107C  1  20 E4 0F        jsr prng
00107F  1  29 0F           and #$0F                       ; 0-15
001081  1  C9 0B           cmp #11
001083  1  90 03           bcc @col_ok
001085  1  38              sec
001086  1  E9 0B           sbc #11                        ; wrap 11-15 → 0-4 (slight bias, acceptable)
001088  1               @col_ok:
001088  1  85 rr           sta zp_col
00108A  1               
00108A  1                  ; scan rows 4 down to 0 for bottommost live invader in this column
00108A  1  A9 04           lda #4
00108C  1  85 rr           sta zp_row
00108E  1               @row_scan:
00108E  1  A4 rr           ldy zp_row
001090  1  B9 CC 1C        lda inv_row_base,y
001093  1  18              clc
001094  1  65 rr           adc zp_col
001096  1  A8              tay                            ; Y = invader index
001097  1  29 07           and #$07
001099  1  AA              tax                            ; X = bit position
00109A  1  BD D1 1C        lda bit_masks,x
00109D  1  48              pha
00109E  1  98              tya
00109F  1  4A              lsr
0010A0  1  4A              lsr
0010A1  1  4A              lsr
0010A2  1  A8              tay                            ; Y = byte index into inv_alive
0010A3  1  68              pla
0010A4  1  39 rr rr        and inv_alive,y
0010A7  1  D0 09           bne @found_invader
0010A9  1  A5 rr           lda zp_row
0010AB  1  F0 04           beq @no_invader                ; checked row 0, nothing alive
0010AD  1  C6 rr           dec zp_row
0010AF  1  80 DD           bra @row_scan
0010B1  1               
0010B1  1               @no_invader:
0010B1  1  60              rts                            ; column empty, skip fire
0010B2  1               
0010B2  1               @found_invader:
0010B2  1  A6 rr           ldx zp_scratch_lo              ; restore free slot index
0010B4  1  A9 01           lda #1
0010B6  1  95 rr           sta ibul_active,x
0010B8  1               
0010B8  1                  ; spawn X = inv_grid_x + col_x_offsets[col]  (16-bit, matching update_invader_sprites)
0010B8  1  A4 rr           ldy zp_col
0010BA  1  B9 B1 1C        lda col_x_lo,y
0010BD  1  18              clc
0010BE  1  65 rr           adc inv_grid_x_lo
0010C0  1  95 rr           sta ibul_x_lo,x
0010C2  1  B9 BC 1C        lda col_x_hi,y
0010C5  1  65 rr           adc inv_grid_x_hi
0010C7  1  95 rr           sta ibul_x_hi,x
0010C9  1                  ; add +4 as a separate 16-bit step to centre the 8px bullet in the 16px invader
0010C9  1  B5 rr           lda ibul_x_lo,x
0010CB  1  18              clc
0010CC  1  69 04           adc #4
0010CE  1  95 rr           sta ibul_x_lo,x
0010D0  1  B5 rr           lda ibul_x_hi,x
0010D2  1  69 00           adc #0
0010D4  1  95 rr           sta ibul_x_hi,x
0010D6  1               
0010D6  1                  ; spawn Y: compute y_base first (same two-step pattern as update_invader_sprites)
0010D6  1                  ; step 1: y_base = INV_GRID_Y_BASE + inv_offset_y  (16-bit)
0010D6  1  A9 50           lda #<INV_GRID_Y_BASE
0010D8  1  18              clc
0010D9  1  65 rr           adc inv_offset_y
0010DB  1  85 rr           sta zp_y_base_lo
0010DD  1  A9 00           lda #>INV_GRID_Y_BASE
0010DF  1  69 00           adc #0
0010E1  1  85 rr           sta zp_y_base_hi
0010E3  1                  ; step 2: spawn_y = y_base + row_y_offsets[row]
0010E3  1  A4 rr           ldy zp_row
0010E5  1  B9 C7 1C        lda row_y_offsets,y
0010E8  1  18              clc
0010E9  1  65 rr           adc zp_y_base_lo
0010EB  1  95 rr           sta ibul_y_lo,x
0010ED  1  A9 00           lda #0
0010EF  1  65 rr           adc zp_y_base_hi
0010F1  1  95 rr           sta ibul_y_hi,x
0010F3  1                  ; step 3: +16 to place bullet at the bottom edge of the 16px invader
0010F3  1  B5 rr           lda ibul_y_lo,x
0010F5  1  18              clc
0010F6  1  69 10           adc #16
0010F8  1  95 rr           sta ibul_y_lo,x
0010FA  1  B5 rr           lda ibul_y_hi,x
0010FC  1  69 00           adc #0
0010FE  1  95 rr           sta ibul_y_hi,x
001100  1               
001100  1  60              rts
001101  1               
001101  1               ;******************************************************************
001101  1               ; check_inv_bullet_player — AABB test each active invader bullet vs. player
001101  1               ;
001101  1               ;   Player rect: (player_x, PLAYER_Y) to (player_x+15, PLAYER_Y+15), 16x16
001101  1               ;   Bullet rect: (ibul_x,   ibul_y)   to (ibul_x+7,   ibul_y+7),     8x8
001101  1               ;
001101  1               ;   On hit: bullet deactivated, jsr player_hit called, loop continues
001101  1               ;   (remaining bullets checked — at most one hit landing per frame).
001101  1               ;   Scratch: zp_scratch_lo/hi, X (slot index)
001101  1               ;******************************************************************
001101  1               check_inv_bullet_player:
001101  1  A2 00           ldx #0
001103  1               @slot_loop:
001103  1  B5 rr           lda ibul_active,x
001105  1  F0 5B           beq @next_slot
001107  1               
001107  1                  ; --- Y check 1: (bullet_y + 8) > PLAYER_Y  →  bullet_y + 8 - PLAYER_Y > 0 ---
001107  1  B5 rr           lda ibul_y_lo,x
001109  1  18              clc
00110A  1  69 08           adc #8
00110C  1  85 rr           sta zp_scratch_lo
00110E  1  B5 rr           lda ibul_y_hi,x
001110  1  69 00           adc #0
001112  1  85 rr           sta zp_scratch_hi
001114  1  A5 rr           lda zp_scratch_lo
001116  1  38              sec
001117  1  E9 A4           sbc #<PLAYER_Y
001119  1  A5 rr           lda zp_scratch_hi
00111B  1  E9 01           sbc #>PLAYER_Y
00111D  1  30 43           bmi @next_slot            ; bullet bottom above player top → no hit
00111F  1               
00111F  1                  ; --- Y check 2: bullet_y < PLAYER_Y + 16 → bullet_y - (PLAYER_Y+16) < 0 ---
00111F  1  B5 rr           lda ibul_y_lo,x
001121  1  38              sec
001122  1  E9 B4           sbc #<(PLAYER_Y+16)
001124  1  B5 rr           lda ibul_y_hi,x
001126  1  E9 01           sbc #>(PLAYER_Y+16)
001128  1  10 38           bpl @next_slot            ; bullet top at or below player bottom → no hit
00112A  1               
00112A  1                  ; --- X check 1: (bullet_x + 8) > player_x ---
00112A  1  B5 rr           lda ibul_x_lo,x
00112C  1  18              clc
00112D  1  69 08           adc #8
00112F  1  85 rr           sta zp_scratch_lo
001131  1  B5 rr           lda ibul_x_hi,x
001133  1  69 00           adc #0
001135  1  85 rr           sta zp_scratch_hi
001137  1  A5 rr           lda zp_scratch_lo
001139  1  38              sec
00113A  1  E5 rr           sbc player_x_lo
00113C  1  A5 rr           lda zp_scratch_hi
00113E  1  E5 rr           sbc player_x_hi
001140  1  30 20           bmi @next_slot            ; bullet right edge left of player → no hit
001142  1               
001142  1                  ; --- X check 2: bullet_x < player_x + 16 ---
001142  1  A5 rr           lda player_x_lo
001144  1  18              clc
001145  1  69 10           adc #16
001147  1  85 rr           sta zp_scratch_lo
001149  1  A5 rr           lda player_x_hi
00114B  1  69 00           adc #0
00114D  1  85 rr           sta zp_scratch_hi
00114F  1  B5 rr           lda ibul_x_lo,x
001151  1  38              sec
001152  1  E5 rr           sbc zp_scratch_lo
001154  1  B5 rr           lda ibul_x_hi,x
001156  1  E5 rr           sbc zp_scratch_hi
001158  1  10 08           bpl @next_slot            ; bullet left edge at or right of player → no hit
00115A  1               
00115A  1                  ; --- HIT ---
00115A  1  74 rr           stz ibul_active,x         ; deactivate this bullet
00115C  1  20 2E 10        jsr update_inv_bullet_sprite
00115F  1  20 68 11        jsr player_hit
001162  1               
001162  1               @next_slot:
001162  1  E8              inx
001163  1  E0 03           cpx #3
001165  1  D0 9C           bne @slot_loop
001167  1  60              rts
001168  1               
001168  1               ;******************************************************************
001168  1               ; player_hit — handle a bullet-player collision:
001168  1               ;   explosion at player position, decrement lives, respawn, invincibility
001168  1               ;******************************************************************
001168  1               player_hit:
001168  1                  ; start explosion at player position
001168  1  A5 rr           lda player_x_lo
00116A  1  85 rr           sta zp_x_lo
00116C  1  A5 rr           lda player_x_hi
00116E  1  85 rr           sta zp_x_hi
001170  1  A9 A4           lda #<PLAYER_Y
001172  1  85 rr           sta zp_row_y_lo
001174  1  A9 01           lda #>PLAYER_Y
001176  1  85 rr           sta zp_row_y_hi
001178  1  20 90 0F        jsr start_explosion
00117B  1               
00117B  1                  ; decrement lives
00117B  1  C6 rr           dec lives
00117D  1  F0 0D           beq @game_over            ; lives hit 0 → end game (Phase 6 will handle this properly)
00117F  1               
00117F  1                  ; grant invincibility and re-centre the ship
00117F  1  A9 78           lda #INV_HIT_FRAMES
001181  1  85 rr           sta inv_hit_timer
001183  1  A9 38           lda #<PLAYER_X_INIT
001185  1  85 rr           sta player_x_lo
001187  1  A9 01           lda #>PLAYER_X_INIT
001189  1  85 rr           sta player_x_hi
00118B  1  60              rts
00118C  1               
00118C  1               @game_over:
00118C  1  4C 8F 11        jmp game_over_screen
00118F  1               
00118F  1               ;******************************************************************
00118F  1               ; game_over_screen — update hi-score, draw GAME OVER, wait for input
00118F  1               ;   SPACE     → restart_game (full state reset + main_loop)
00118F  1               ;   RUN/STOP  → exit to BASIC
00118F  1               ;
00118F  1               ;   Layout (40-col text):
00118F  1               ;     Row  9, col 15: "GAME OVER"
00118F  1               ;     Row 11, col 13: "SCORE: " + 6 BCD digits
00118F  1               ;     Row 12, col 12: "HI-SCORE: " + 6 BCD digits
00118F  1               ;     Row 15, col 11: "SPACE = PLAY AGAIN"  (blinks)
00118F  1               ;     Row 17, col 12: "RUN/STOP TO QUIT"
00118F  1               ;******************************************************************
00118F  1               game_over_screen:
00118F  1  20 5E 1A        jsr snd_stop_ufo_drone    ; silence drone if UFO was active
001192  1               
001192  1  20 61 12        jsr update_hi_score       ; copy score → hi_score if score is higher
001195  1               
001195  1  20 56 15        jsr hide_all_inv_sprites  ; clear play field sprites
001198  1               
001198  1  A9 93           lda #PETSCII_CLR
00119A  1  20 D2 FF        jsr CHROUT
00119D  1               
00119D  1  A9 09           lda #9
00119F  1  A0 0F           ldy #15
0011A1  1  18              clc
0011A2  1  20 F0 FF        jsr PLOT
0011A5  1  A2 00           ldx #0
0011A7  1  BD 94 1B     @go1: lda str_game_over, x
0011AA  1  F0 06           beq @go1d
0011AC  1  20 D2 FF        jsr CHROUT
