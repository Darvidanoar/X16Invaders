0011B8  1  20 1E 1B        jsr snd_stop_ufo_drone
0011BB  1  20 E2 1B        jsr snd_stop_march
0011BE  1  20 47 1C        jsr snd_stop_fire
0011C1  1  20 AC 1C        jsr snd_stop_exp
0011C4  1               
