001495  1               ;******************************************************************
001495  1               ; draw_title_screen — paint the title screen; called once before title_loop
001495  1               ;
001495  1               ;   Layout (40-col text, VERA Y=row*16):
001495  1               ;     Row  1, col 14: "X16 INVADERS"      (12 chars, centred)
001495  1               ;     Row  3, col 16: "HI-SCORE"          (8 chars, centred)
001495  1               ;     Row  4, col 17: 000000              (6-digit BCD hi-score)
001495  1               ;     Row  5, col  5: "?UFO? = ??? PTS"
001495  1               ;     Row  7, col  9: "= 30 PTS"          + Type C sprite at X=96,Y=112
001495  1               ;     Row 10, col  9: "= 20 PTS"          + Type B sprite at X=96,Y=160
001495  1               ;     Row 13, col  9: "= 10 PTS"          + Type A sprite at X=96,Y=208
001495  1               ;     Row 17, col 10: (PRESS SPACE TO START — blinked by title_loop)
001495  1               ;     Row 19, col 12: "Q TO QUIT"
001495  1               ;******************************************************************
001495  1               draw_title_screen:
001495  1                  ; Row 1, col 14: "X16 INVADERS"
001495  1  A2 02           ldx #2
001497  1  A0 22           ldy #34
001499  1  18              clc
00149A  1  20 F0 FF        jsr PLOT
00149D  1  A2 00           ldx #0
00149F  1  BD 51 1D     @lp1: lda str_title_main, x
0014A2  1  F0 06           beq @lp1_done
0014A4  1  20 D2 FF        jsr CHROUT
0014A7  1  E8              inx
0014A8  1  80 F5           bra @lp1
0014AA  1               @lp1_done:
0014AA  1               
0014AA  1                  ; Row 3, col 16: "HI-SCORE"
0014AA  1  A2 01           ldx #1
0014AC  1  A0 3F           ldy #63
0014AE  1  18              clc
0014AF  1  20 F0 FF        jsr PLOT
0014B2  1  A2 00           ldx #0
0014B4  1  BD 64 1D     @lp2: lda str_hi_score_lbl, x
0014B7  1  F0 06           beq @lp2_done
0014B9  1  20 D2 FF        jsr CHROUT
0014BC  1  E8              inx
0014BD  1  80 F5           bra @lp2
0014BF  1               @lp2_done:
0014BF  1               
0014BF  1                  ; Row 4, col 17: hi-score 6 BCD digits (000000 at start)
0014BF  1  A2 01           ldx #1
0014C1  1  A0 49           ldy #73
0014C3  1  18              clc
0014C4  1  20 F0 FF        jsr PLOT
0014C7  1  A5 rr           lda hi_score_hi
0014C9  1  20 32 1D        jsr print_hex_byte
0014CC  1  A5 rr           lda hi_score_mid
0014CE  1  20 32 1D        jsr print_hex_byte
0014D1  1  A5 rr           lda hi_score_lo
0014D3  1  20 32 1D        jsr print_hex_byte
0014D6  1               
0014D6  1                  ; Row 5, col 5: "?UFO? = ??? PTS"
0014D6  1  A2 09           ldx #9
0014D8  1  A0 09           ldy #9
0014DA  1  18              clc
0014DB  1  20 F0 FF        jsr PLOT
0014DE  1  A2 00           ldx #0
0014E0  1  BD 6C 1D     @lp3: lda str_ufo_score, x
0014E3  1  F0 06           beq @lp3_done
0014E5  1  20 D2 FF        jsr CHROUT
0014E8  1  E8              inx
0014E9  1  80 F5           bra @lp3
0014EB  1               @lp3_done:
0014EB  1               
0014EB  1                  ; Sample invader sprites (Types C, B, A) + score labels
0014EB  1  20 04 15        jsr show_title_sprites
0014EE  1               
0014EE  1                  ; Row 19, col 12: "Q TO QUIT"  (Plot: Set X to Row, Set Y to Col)
0014EE  1  A2 25           ldx #37
0014F0  1  A0 23           ldy #35
0014F2  1  18              clc
0014F3  1  20 F0 FF        jsr PLOT
0014F6  1  A2 00           ldx #0
0014F8  1  BD 05 1E     @lp4: lda str_run_stop_hint, x
0014FB  1  F0 06           beq @lp4_done
0014FD  1  20 D2 FF        jsr CHROUT
001500  1  E8              inx
001501  1  80 F5           bra @lp4
001503  1               @lp4_done:
001503  1               
001503  1  60              rts
