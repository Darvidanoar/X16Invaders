001450  1               ;******************************************************************
001450  1               ; print_dec_byte — print .A as 1 or 2 decimal digits (values 0-99)
001450  1               ;   Suppresses leading zero for single-digit numbers.
001450  1               ;   Clobbers: A, X.  Carry is cleared on exit.
001450  1               ;******************************************************************
001450  1               print_dec_byte:
001450  1  A2 00           ldx #0
001452  1               @pdb_loop:
001452  1  C9 0A           cmp #10
001454  1  90 05           bcc @pdb_units            ; A < 10 → done dividing
001456  1  E8              inx
001457  1  E9 0A           sbc #10                   ; carry is set by cmp, so sbc = A - 10
001459  1  80 F7           bra @pdb_loop
00145B  1               @pdb_units:
00145B  1  48              pha                       ; save units digit
00145C  1  8A              txa                       ; tens digit count
00145D  1  F0 05           beq @pdb_skip_tens        ; zero → suppress leading zero
00145F  1  69 30           adc #$30                  ; carry=0 here (from last bcc), so adc = X + $30
001461  1  20 D2 FF        jsr CHROUT
001464  1               @pdb_skip_tens:
001464  1  68              pla                       ; units digit (0-9; carry=0)
001465  1  69 30           adc #$30
001467  1  20 D2 FF        jsr CHROUT
00146A  1  60              rts
00146B  1               
00146B  1               ;******************************************************************
