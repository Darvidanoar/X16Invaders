001934  1               ;******************************************************************
001934  1               ; add_score_bcd — add a 2-byte BCD pair to the score
001934  1               ;   A = BCD low byte (units/tens), Y = BCD mid byte (hundreds/thousands)
001934  1               ;******************************************************************
001934  1               add_score_bcd:
001934  1  F8              sed
001935  1  18              clc
001936  1  65 rr           adc score_lo
001938  1  85 rr           sta score_lo
00193A  1  98              tya
00193B  1  65 rr           adc score_mid
00193D  1  85 rr           sta score_mid
00193F  1  A5 rr           lda score_hi
001941  1  69 00           adc #0
001943  1  85 rr           sta score_hi
001945  1  D8              cld
001946  1  60              rts
001947  1               
001947  1               ;******************************************************************
001947  1               ; update_ufo — per-frame UFO logic: spawn timer + movement
001947  1               ;
001947  1               ;   Inactive: 16-bit ufo_timer counts down each frame.
001947  1               ;   On zero: UFO spawns at left edge (X=0), timer reset to
001947  1               ;             UFO_TIMER_INIT + (prng() & $7F) for next cycle.
001947  1               ;   Active: move right UFO_SPEED VERA pixels/frame.
001947  1               ;           Deactivate when X >= 640 (off right edge).
001947  1               ;   Updates VERA sprite 3 after any state change.
001947  1               ;******************************************************************
001947  1               update_ufo:
001947  1  A5 rr           lda ufo_active
001949  1  D0 36           bne @move_ufo
00194B  1               
00194B  1                  ; --- timer countdown (16-bit decrement) ---
00194B  1  A5 rr           lda ufo_timer_lo
00194D  1  D0 0B           bne @dec_lo
00194F  1  A5 rr           lda ufo_timer_hi
001951  1  F0 0F           beq @spawn                   ; both zero → spawn (guard against stuck state)
001953  1  C6 rr           dec ufo_timer_hi
001955  1  A9 FF           lda #$FF
001957  1  85 rr           sta ufo_timer_lo
001959  1  60              rts
00195A  1               @dec_lo:
00195A  1  C6 rr           dec ufo_timer_lo
00195C  1  A5 rr           lda ufo_timer_lo
00195E  1  05 rr           ora ufo_timer_hi
001960  1  D0 47           bne @ufo_done                ; timer not yet zero
001962  1               
001962  1               @spawn:
001962  1  A9 01           lda #1
001964  1  85 rr           sta ufo_active
001966  1  64 rr           stz ufo_x_lo
001968  1  64 rr           stz ufo_x_hi
00196A  1                  ; next timer = UFO_TIMER_INIT + (prng() & $7F) so interval varies by 0-127 frames
00196A  1  20 FE 0F        jsr prng
00196D  1  29 7F           and #$7F
00196F  1  18              clc
001970  1  69 58           adc #<UFO_TIMER_INIT
001972  1  85 rr           sta ufo_timer_lo
001974  1  A9 02           lda #>UFO_TIMER_INIT
001976  1  69 00           adc #0
001978  1  85 rr           sta ufo_timer_hi
00197A  1  20 AA 19        jsr update_ufo_sprite
00197D  1  20 6C 1A        jsr snd_start_ufo_drone
001980  1  60              rts
001981  1               
001981  1                  ; --- move UFO right ---
001981  1               @move_ufo:
001981  1  A5 rr           lda ufo_x_lo
001983  1  18              clc
001984  1  69 02           adc #UFO_SPEED
001986  1  85 rr           sta ufo_x_lo
001988  1  A5 rr           lda ufo_x_hi
00198A  1  69 00           adc #0
00198C  1  85 rr           sta ufo_x_hi
00198E  1                  ; deactivate if X high byte >= 3 (≥ 768, safely off the 640-wide screen)
00198E  1                  ; simpler guard: X hi > 0 means X >= 256; combined with lo check
00198E  1  C9 02           cmp #>640                    ; A = new hi; >640 = 2
001990  1  90 11           bcc @ufo_on_screen           ; hi < 2 → still visible
001992  1  D0 06           bne @ufo_off_screen          ; hi > 2 → gone
001994  1  A5 rr           lda ufo_x_lo
001996  1  C9 80           cmp #<640
001998  1  90 09           bcc @ufo_on_screen           ; hi=2, lo < 128 → past edge but close; still off
00199A  1               @ufo_off_screen:
00199A  1  64 rr           stz ufo_active
00199C  1  20 AA 19        jsr update_ufo_sprite
00199F  1  20 93 1A        jsr snd_stop_ufo_drone
0019A2  1  60              rts
0019A3  1               @ufo_on_screen:
0019A3  1  20 AA 19        jsr update_ufo_sprite
0019A6  1  20 AB 1A        jsr snd_update_ufo_drone
0019A9  1               @ufo_done:
0019A9  1  60              rts
0019AA  1               
0019AA  1               ;******************************************************************
0019AA  1               ; update_ufo_sprite — write sprite 3 (UFO) position + enable/disable
0019AA  1               ;   addr[12:5] = VRAM_UFO>>5 = $01500>>5 = $A8
0019AA  1               ;   Writes bytes 2-6; bytes 0-1 and 7 set once at init.
0019AA  1               ;******************************************************************
0019AA  1               update_ufo_sprite:
0019AA  1  9C 25 9F        stz VERA_ctrl
0019AD  1  A9 11 8D 22     VERA_SET_ADDR (UFO_SPRITE_ATTR + 2), 1
0019B1  1  9F A9 FC 8D  
0019B5  1  21 9F A9 1A  
0019BC  1  A5 rr           lda ufo_x_lo
0019BE  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
0019C1  1  A5 rr           lda ufo_x_hi
0019C3  1  29 03           and #$03
0019C5  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
0019C8  1  A9 20           lda #<UFO_Y
0019CA  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
0019CD  1  A9 00           lda #>UFO_Y
0019CF  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
0019D2  1  A5 rr           lda ufo_active
0019D4  1  F0 04           beq @z_off
0019D6  1  A9 0C           lda #SPR_Z_FRONT
0019D8  1  80 02           bra @write_z
0019DA  1               @z_off:
0019DA  1  A9 00           lda #0
0019DC  1               @write_z:
0019DC  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
0019DF  1  60              rts
0019E0  1               
0019E0  1               ;******************************************************************
0019E0  1               ; check_bullet_ufo — AABB test: player bullet vs. UFO sprite (16x16)
0019E0  1               ;   Bullet rect: (bullet_x, bullet_y)+(7,7);  UFO rect: (ufo_x, UFO_Y)+(15,15)
0019E0  1               ;   On hit: bullet deactivated, UFO killed, score added, explosion started.
0019E0  1               ;   Scratch: zp_scratch_lo/hi, zp_x_lo/hi, zp_row_y_lo/hi
0019E0  1               ;******************************************************************
0019E0  1               check_bullet_ufo:
0019E0  1  A5 rr           lda bullet_active
0019E2  1  D0 01           bne :+
0019E4  1  60              rts
0019E5  1  A5 rr        :  lda ufo_active
0019E7  1  D0 01           bne :+
0019E9  1  60              rts
0019EA  1               :
0019EA  1               
0019EA  1                  ; --- Y check 1: bullet_y+8 > UFO_Y ---
0019EA  1  A5 rr           lda bullet_y_lo
0019EC  1  18              clc
0019ED  1  69 08           adc #8
0019EF  1  85 rr           sta zp_scratch_lo
0019F1  1  A5 rr           lda bullet_y_hi
0019F3  1  69 00           adc #0
0019F5  1  85 rr           sta zp_scratch_hi
0019F7  1  A5 rr           lda zp_scratch_lo
0019F9  1  38              sec
0019FA  1  E9 20           sbc #<UFO_Y
0019FC  1  A5 rr           lda zp_scratch_hi
0019FE  1  E9 00           sbc #>UFO_Y
001A00  1  30 69           bmi @done                    ; bullet bottom above UFO top → no hit
001A02  1               
001A02  1                  ; --- Y check 2: bullet_y < UFO_Y+16 ---
001A02  1  A5 rr           lda bullet_y_lo
001A04  1  38              sec
001A05  1  E9 30           sbc #<(UFO_Y + 16)
001A07  1  A5 rr           lda bullet_y_hi
001A09  1  E9 00           sbc #>(UFO_Y + 16)
001A0B  1  10 5E           bpl @done                    ; bullet top at or below UFO bottom → no hit
001A0D  1               
001A0D  1                  ; --- X check 1: bullet_x+8 > ufo_x ---
001A0D  1  A5 rr           lda bullet_x_lo
001A0F  1  18              clc
001A10  1  69 08           adc #8
001A12  1  85 rr           sta zp_scratch_lo
001A14  1  A5 rr           lda bullet_x_hi
001A16  1  69 00           adc #0
001A18  1  85 rr           sta zp_scratch_hi
001A1A  1  A5 rr           lda zp_scratch_lo
001A1C  1  38              sec
001A1D  1  E5 rr           sbc ufo_x_lo
001A1F  1  A5 rr           lda zp_scratch_hi
001A21  1  E5 rr           sbc ufo_x_hi
001A23  1  30 46           bmi @done                    ; bullet right edge left of UFO left edge → no hit
001A25  1               
001A25  1                  ; --- X check 2: bullet_x < ufo_x+16 ---
001A25  1  A5 rr           lda ufo_x_lo
001A27  1  18              clc
001A28  1  69 10           adc #16
001A2A  1  85 rr           sta zp_scratch_lo
001A2C  1  A5 rr           lda ufo_x_hi
001A2E  1  69 00           adc #0
001A30  1  85 rr           sta zp_scratch_hi
001A32  1  A5 rr           lda bullet_x_lo
001A34  1  38              sec
001A35  1  E5 rr           sbc zp_scratch_lo
001A37  1  A5 rr           lda bullet_x_hi
001A39  1  E5 rr           sbc zp_scratch_hi
001A3B  1  10 2E           bpl @done                    ; bullet left edge at or right of UFO right edge → no hit
001A3D  1               
001A3D  1                  ; --- HIT ---
001A3D  1  A5 rr           lda ufo_x_lo
001A3F  1  85 rr           sta zp_x_lo
001A41  1  A5 rr           lda ufo_x_hi
001A43  1  85 rr           sta zp_x_hi
001A45  1  A9 20           lda #<UFO_Y
001A47  1  85 rr           sta zp_row_y_lo
001A49  1  A9 00           lda #>UFO_Y
001A4B  1  85 rr           sta zp_row_y_hi
001A4D  1  20 A7 0F        jsr start_explosion
001A50  1               
001A50  1  64 rr           stz bullet_active
001A52  1  20 54 0E        jsr update_bullet_sprite
001A55  1               
001A55  1  64 rr           stz ufo_active
001A57  1  20 AA 19        jsr update_ufo_sprite
001A5A  1  20 93 1A        jsr snd_stop_ufo_drone
001A5D  1               
001A5D  1                  ; score: ufo_score table indexed by shot_count & 7
001A5D  1  A5 rr           lda shot_count
001A5F  1  29 07           and #$07
001A61  1  AA              tax
001A62  1  BD 8F 1E        lda ufo_score_lo, x
001A65  1  BC 97 1E        ldy ufo_score_hi, x
001A68  1  20 34 19        jsr add_score_bcd
001A6B  1               
001A6B  1               @done:
001A6B  1  60              rts
001A6C  1               
001A6C  1               ;******************************************************************
001A6C  1               ; snd_start_ufo_drone — enable VERA PSG voice 3 (sawtooth, full vol, freq1)
001A6C  1               ;   Called once when UFO spawns.
001A6C  1               ;******************************************************************
001A6C  1               snd_start_ufo_drone:
001A6C  1  9C 25 9F        stz VERA_ctrl
001A6F  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
001A73  1  9F A9 F9 8D  
001A77  1  21 9F A9 CC  
001A7E  1  A9 32           lda #<UFO_DRONE_FREQ1
001A80  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L
001A83  1  A9 04           lda #>UFO_DRONE_FREQ1
001A85  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
001A88  1  A9 FF           lda #PSG_VOL_FULL
001A8A  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001A8D  1  A9 40           lda #PSG_WAVE_SAW
001A8F  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
001A92  1  60              rts
001A93  1               
001A93  1               ;******************************************************************
001A93  1               ; snd_stop_ufo_drone — silence VERA PSG voice 3
001A93  1               ;   Called when UFO leaves screen or is destroyed.
001A93  1               ;******************************************************************
001A93  1               snd_stop_ufo_drone:
001A93  1  9C 25 9F        stz VERA_ctrl
001A96  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE3 + 2), 1   ; byte 2 = volume/enable
001A9A  1  9F A9 F9 8D  
001A9E  1  21 9F A9 CE  
001AA5  1  A9 00           lda #$00
001AA7  1  8D 23 9F        sta VERA_data0               ; zero volume → silent
001AAA  1  60              rts
001AAB  1               
001AAB  1               ;******************************************************************
001AAB  1               ; snd_update_ufo_drone — warble between freq1/freq2 using frame_count
001AAB  1               ;   bit 3 (flips every 8 frames ≈ 3.75 Hz wobble rate).
001AAB  1               ;   Call every frame while UFO is active.
001AAB  1               ;   Rewrites all 4 voice bytes (keeps volume/waveform stable).
001AAB  1               ;******************************************************************
001AAB  1               snd_update_ufo_drone:
001AAB  1  9C 25 9F        stz VERA_ctrl
001AAE  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
001AB2  1  9F A9 F9 8D  
001AB6  1  21 9F A9 CC  
001ABD  1  A5 rr           lda frame_count
001ABF  1  29 08           and #$08                     ; bit 3: 0 for 8 frames, 1 for 8 frames
001AC1  1  D0 09           bne @freq2
001AC3  1  A9 32           lda #<UFO_DRONE_FREQ1
001AC5  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L (freq1)
001AC8  1  A9 04           lda #>UFO_DRONE_FREQ1
001ACA  1  80 07           bra @rest
001ACC  1               @freq2:
001ACC  1  A9 4B           lda #<UFO_DRONE_FREQ2
001ACE  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L (freq2)
001AD1  1  A9 06           lda #>UFO_DRONE_FREQ2
001AD3  1               @rest:
001AD3  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
001AD6  1  A9 FF           lda #PSG_VOL_FULL
001AD8  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001ADB  1  A9 40           lda #PSG_WAVE_SAW
001ADD  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
001AE0  1  60              rts
001AE1  1               
001AE1  1               ;******************************************************************
001AE1  1               ; snd_march_step — advance march_beat and play next note on PSG voice 0
001AE1  1               ;   Called once per invader march step (from step_invaders).
001AE1  1               ;   Increments beat index mod 4, writes freq/vol/wave to voice 0,
001AE1  1               ;   and arms march_snd_timer so snd_tick_march will silence it.
001AE1  1               ;******************************************************************
001AE1  1               snd_march_step:
001AE1  1  E6 rr           inc march_beat
001AE3  1  A5 rr           lda march_beat
001AE5  1  29 03           and #$03
001AE7  1  85 rr           sta march_beat
001AE9  1  AA              tax                            ; X = note index 0-3
001AEA  1  9C 25 9F        stz VERA_ctrl
001AED  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE0, 1
001AF1  1  9F A9 F9 8D  
001AF5  1  21 9F A9 C0  
001AFC  1  BD 87 1E        lda march_freq_lo, x
001AFF  1  8D 23 9F        sta VERA_data0                 ; byte 0: FREQ_L
001B02  1  BD 8B 1E        lda march_freq_hi, x
001B05  1  8D 23 9F        sta VERA_data0                 ; byte 1: FREQ_H
001B08  1  A9 FF           lda #PSG_MARCH_VOL
001B0A  1  8D 23 9F        sta VERA_data0                 ; byte 2: volume (stereo, full)
001B0D  1  A9 00           lda #PSG_WAVE_PULSE
001B0F  1  8D 23 9F        sta VERA_data0                 ; byte 3: pulse waveform
001B12  1  A9 06           lda #MARCH_NOTE_FRAMES
001B14  1  85 rr           sta march_snd_timer
001B16  1  60              rts
001B17  1               
001B17  1               ;******************************************************************
001B17  1               ; snd_tick_march — decrement march note timer; silence voice 0 when it expires
001B17  1               ;   Call once per frame from main_loop.
001B17  1               ;******************************************************************
001B17  1               snd_tick_march:
001B17  1  A5 rr           lda march_snd_timer
001B19  1  F0 1B           beq @done
001B1B  1  C6 rr           dec march_snd_timer
001B1D  1  D0 17           bne @done
001B1F  1  9C 25 9F        stz VERA_ctrl
001B22  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE0 + 2), 1
001B26  1  9F A9 F9 8D  
001B2A  1  21 9F A9 C2  
001B31  1  A9 00           lda #$00
001B33  1  8D 23 9F        sta VERA_data0                 ; zero volume → silent
001B36  1               @done:
001B36  1  60              rts
001B37  1               
001B37  1               ;******************************************************************
001B37  1               ; snd_stop_march — immediately silence PSG voice 0 and clear timer
001B37  1               ;   Call when leaving gameplay (game over, wave clear, restart).
001B37  1               ;******************************************************************
001B37  1               snd_stop_march:
001B37  1  64 rr           stz march_snd_timer
001B39  1  9C 25 9F        stz VERA_ctrl
001B3C  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE0 + 2), 1
001B40  1  9F A9 F9 8D  
001B44  1  21 9F A9 C2  
001B4B  1  A9 00           lda #$00
001B4D  1  8D 23 9F        sta VERA_data0
001B50  1  60              rts
001B51  1               
001B51  1               ;******************************************************************
001B51  1               ; snd_fire — play short high-pitched pulse on PSG voice 1 (~800 Hz, 5 frames)
001B51  1               ;   Called from fire_bullet.
001B51  1               ;******************************************************************
001B51  1               snd_fire:
001B51  1  9C 25 9F        stz VERA_ctrl
001B54  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE1, 1
001B58  1  9F A9 F9 8D  
001B5C  1  21 9F A9 C4  
001B63  1  A9 63           lda #PSG_FIRE_FREQ_L
001B65  1  8D 23 9F        sta VERA_data0                 ; byte 0: FREQ_L
001B68  1  A9 08           lda #PSG_FIRE_FREQ_H
001B6A  1  8D 23 9F        sta VERA_data0                 ; byte 1: FREQ_H
001B6D  1  A9 FF           lda #PSG_MARCH_VOL             ; reuse full-volume constant
001B6F  1  8D 23 9F        sta VERA_data0                 ; byte 2: volume
001B72  1  A9 00           lda #PSG_WAVE_PULSE
001B74  1  8D 23 9F        sta VERA_data0                 ; byte 3: pulse waveform
001B77  1  A9 05           lda #FIRE_NOTE_FRAMES
001B79  1  85 rr           sta fire_snd_timer
001B7B  1  60              rts
001B7C  1               
001B7C  1               ;******************************************************************
001B7C  1               ; snd_tick_fire — decrement fire timer; silence voice 1 when it expires
001B7C  1               ;   Call once per frame from main_loop.
001B7C  1               ;******************************************************************
001B7C  1               snd_tick_fire:
001B7C  1  A5 rr           lda fire_snd_timer
001B7E  1  F0 1B           beq @done
001B80  1  C6 rr           dec fire_snd_timer
001B82  1  D0 17           bne @done
001B84  1  9C 25 9F        stz VERA_ctrl
001B87  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE1 + 2), 1
001B8B  1  9F A9 F9 8D  
001B8F  1  21 9F A9 C6  
001B96  1  A9 00           lda #$00
001B98  1  8D 23 9F        sta VERA_data0
001B9B  1               @done:
001B9B  1  60              rts
001B9C  1               
001B9C  1               ;******************************************************************
001B9C  1               ; snd_stop_fire — immediately silence PSG voice 1 and clear timer
001B9C  1               ;******************************************************************
001B9C  1               snd_stop_fire:
001B9C  1  64 rr           stz fire_snd_timer
001B9E  1  9C 25 9F        stz VERA_ctrl
001BA1  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE1 + 2), 1
001BA5  1  9F A9 F9 8D  
001BA9  1  21 9F A9 C6  
001BB0  1  A9 00           lda #$00
001BB2  1  8D 23 9F        sta VERA_data0
001BB5  1  60              rts
001BB6  1               
001BB6  1               ;******************************************************************
001BB6  1               ; snd_explosion — play low-frequency noise burst on PSG voice 2 (20 frames)
001BB6  1               ;   Called from start_explosion (covers invader kills, UFO, player hit).
001BB6  1               ;******************************************************************
001BB6  1               snd_explosion:
001BB6  1  9C 25 9F        stz VERA_ctrl
001BB9  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE2, 1
001BBD  1  9F A9 F9 8D  
001BC1  1  21 9F A9 C8  
001BC8  1  A9 40           lda #PSG_EXP_FREQ_L
001BCA  1  8D 23 9F        sta VERA_data0                 ; byte 0: FREQ_L (slow noise clock → deep rumble)
001BCD  1  A9 00           lda #PSG_EXP_FREQ_H
001BCF  1  8D 23 9F        sta VERA_data0                 ; byte 1: FREQ_H
001BD2  1  A9 FF           lda #PSG_MARCH_VOL             ; reuse full-volume constant
001BD4  1  8D 23 9F        sta VERA_data0                 ; byte 2: volume
001BD7  1  A9 C0           lda #PSG_WAVE_NOISE
001BD9  1  8D 23 9F        sta VERA_data0                 ; byte 3: noise waveform
001BDC  1  A9 14           lda #EXP_NOTE_FRAMES
001BDE  1  85 rr           sta exp_snd_timer
001BE0  1  60              rts
001BE1  1               
001BE1  1               ;******************************************************************
001BE1  1               ; snd_tick_exp — decrement explosion timer; silence voice 2 when it expires
001BE1  1               ;   Call once per frame from main_loop.
001BE1  1               ;******************************************************************
001BE1  1               snd_tick_exp:
001BE1  1  A5 rr           lda exp_snd_timer
001BE3  1  F0 1B           beq @done
001BE5  1  C6 rr           dec exp_snd_timer
001BE7  1  D0 17           bne @done
001BE9  1  9C 25 9F        stz VERA_ctrl
001BEC  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE2 + 2), 1
001BF0  1  9F A9 F9 8D  
001BF4  1  21 9F A9 CA  
001BFB  1  A9 00           lda #$00
001BFD  1  8D 23 9F        sta VERA_data0
001C00  1               @done:
001C00  1  60              rts
001C01  1               
001C01  1               ;******************************************************************
001C01  1               ; snd_stop_exp — immediately silence PSG voice 2 and clear timer
001C01  1               ;******************************************************************
001C01  1               snd_stop_exp:
001C01  1  64 rr           stz exp_snd_timer
001C03  1  9C 25 9F        stz VERA_ctrl
001C06  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE2 + 2), 1
001C0A  1  9F A9 F9 8D  
001C0E  1  21 9F A9 CA  
001C15  1  A9 00           lda #$00
001C17  1  8D 23 9F        sta VERA_data0
001C1A  1  60              rts
001C1B  1               
001C1B  1               ;******************************************************************
001C1B  1               ; update_hud — rewrite dynamic HUD values each frame
001C1B  1               ;   Row  1, col  0: 6-digit BCD score
001C1B  1               ;   Row  1, col 16: 6-digit BCD hi-score
001C1B  1               ;   Row 29, col  1: LIVES: N
001C1B  1               ;   Row 29, col 20: WAVE: N
001C1B  1               ;   Overwrites fixed positions; no full redraw needed.
001C1B  1               ;   Note: KERNAL PLOT convention for X16: A = row, Y = col, CLC.
001C1B  1               ;******************************************************************
001C1B  1               update_hud:
001C1B  1                  ; --- score: row 1, col 0 (Plot: Set X to Row, Set Y to Col) ---
001C1B  1  A2 01           ldx #1
001C1D  1  A0 00           ldy #0
001C1F  1  18              clc
001C20  1  20 F0 FF        jsr PLOT
001C23  1  A5 rr           lda score_hi
001C25  1  20 88 1C        jsr print_hex_byte
001C28  1  A5 rr           lda score_mid
001C2A  1  20 88 1C        jsr print_hex_byte
001C2D  1  A5 rr           lda score_lo
001C2F  1  20 88 1C        jsr print_hex_byte
001C32  1               
001C32  1                  ; --- hi-score: row 1, col 16  (Plot: Set X to Row, Set Y to Col) ---
001C32  1  A2 01           ldx #1
001C34  1  A0 10           ldy #16
001C36  1  18              clc
001C37  1  20 F0 FF        jsr PLOT
001C3A  1  A5 rr           lda hi_score_hi
001C3C  1  20 88 1C        jsr print_hex_byte
001C3F  1  A5 rr           lda hi_score_mid
001C41  1  20 88 1C        jsr print_hex_byte
001C44  1  A5 rr           lda hi_score_lo
001C46  1  20 88 1C        jsr print_hex_byte
001C49  1               
001C49  1                  ; --- lives count: row 58, col 1  (Plot: Set X to Row, Set Y to Col) ---
001C49  1  A2 3A           ldx #58
001C4B  1  A0 01           ldy #1
001C4D  1  18              clc
001C4E  1  20 F0 FF        jsr PLOT
001C51  1  A2 00           ldx #0
001C53  1  BD 6D 1D     @lv_lbl: lda str_lives_lbl,x
001C56  1  F0 06           beq @lv_val
001C58  1  20 D2 FF        jsr CHROUT
001C5B  1  E8              inx
001C5C  1  80 F5           bra @lv_lbl
001C5E  1               @lv_val:
001C5E  1  A5 rr           lda lives
001C60  1  20 EE 13        jsr print_dec_byte
001C63  1  A9 20           lda #' '
001C65  1  20 D2 FF        jsr CHROUT                    ; erase any stale digit
001C68  1               
001C68  1                  ; --- wave number: row 58, col 20  (Plot: Set X to Row, Set Y to Col) ---
001C68  1  A2 3A           ldx #58
001C6A  1  A0 14           ldy #20
001C6C  1  18              clc
001C6D  1  20 F0 FF        jsr PLOT
001C70  1  A2 00           ldx #0
001C72  1  BD 3D 1D     @wv_lbl: lda str_wave_lbl,x
001C75  1  F0 06           beq @wv_val
001C77  1  20 D2 FF        jsr CHROUT
001C7A  1  E8              inx
001C7B  1  80 F5           bra @wv_lbl
001C7D  1               @wv_val:
001C7D  1  A5 rr           lda wave
001C7F  1  20 EE 13        jsr print_dec_byte
001C82  1  A9 20           lda #' '
001C84  1  20 D2 FF        jsr CHROUT                    ; erase any stale digit
001C87  1               
001C87  1  60              rts
001C88  1               
001C88  1               ;******************************************************************
001C88  1               ; print_hex_byte — print .A as two uppercase hex digits via CHROUT
001C88  1               ;******************************************************************
001C88  1               print_hex_byte:
001C88  1  48              pha
001C89  1  4A              lsr                           ; shift high nibble down
001C8A  1  4A              lsr
001C8B  1  4A              lsr
001C8C  1  4A              lsr
001C8D  1  20 97 1C        jsr print_hex_nybble
001C90  1  68              pla
001C91  1  29 0F           and #$0F                      ; isolate low nibble
001C93  1  20 97 1C        jsr print_hex_nybble
001C96  1  60              rts
001C97  1               
001C97  1               ; print_hex_nybble — print lower 4 bits of .A as one hex digit
001C97  1               ;   Relies on carry state from CMP to select digit vs. letter range
001C97  1               print_hex_nybble:
001C97  1  C9 0A           cmp #10
001C99  1  90 06           bcc @digit                    ; carry clear → 0-9
001C9B  1  69 36           adc #($41 - 10 - 1)          ; A-F: 'A'=65; carry set adds 1
001C9D  1  20 D2 FF        jsr CHROUT
001CA0  1  60              rts
001CA1  1               @digit:
001CA1  1  69 30           adc #$30                      ; 0-9: '0'=48; carry clear adds 0
001CA3  1  20 D2 FF        jsr CHROUT
001CA6  1  60              rts
001CA7  1               
001CA7  1               ;******************************************************************
001CA7  1               ; String data — null-terminated, PETSCII uppercase
001CA7  1               ;******************************************************************
001CA7  1               str_title_main:
001CA7  1  D8 31 36 20     .byte "X16 INVADERS", 0
001CAB  1  C9 CE D6 C1  
