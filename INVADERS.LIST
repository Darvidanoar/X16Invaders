00147E  1                  ; --- write sprite attributes for 4 shields (sequential VERA write) ---
00147E  1                  ; Slots 66–69: $1FE10, $1FE18, $1FE20, $1FE28  (high=$FE, bank=1)
00147E  1  A9 11           lda #$11               ; stride=1, bank=1
001480  1  8D 22 9F        sta VERA_addr_bank
001483  1  A9 FE           lda #$FE
001485  1  8D 21 9F        sta VERA_addr_high
001488  1  A9 10           lda #$10               ; low byte of $1FE10
00148A  1  8D 20 9F        sta VERA_addr_low
00148D  1               
00148D  1  A2 00           ldx #0
00148F  1               @spr_init:
00148F  1  A9 28           lda #$28               ; byte 0: addr[12:5] = VRAM_SHIELD_FULL>>5 = $00500>>5 = $28
001491  1  8D 23 9F        sta VERA_data0
001494  1  A9 00           lda #$00               ; byte 1: 4bpp, addr[16:13]=0
001496  1  8D 23 9F        sta VERA_data0
001499  1  BD F8 17        lda shield_x_lo, x     ; byte 2: X lo
00149C  1  8D 23 9F        sta VERA_data0
00149F  1  BD FC 17        lda shield_x_hi, x     ; byte 3: X hi
0014A2  1  8D 23 9F        sta VERA_data0
0014A5  1  A9 60           lda #<SHIELD_Y         ; byte 4: Y lo
0014A7  1  8D 23 9F        sta VERA_data0
0014AA  1  A9 01           lda #>SHIELD_Y         ; byte 5: Y hi
0014AC  1  8D 23 9F        sta VERA_data0
0014AF  1  A9 0C           lda #SPR_Z_FRONT       ; byte 6: z-depth=3 (in front of all layers)
0014B1  1  8D 23 9F        sta VERA_data0
0014B4  1  A9 A0           lda #SPR_32x32_PAL0    ; byte 7: 32x32, palette 0
0014B6  1  8D 23 9F        sta VERA_data0
0014B9  1  E8              inx
0014BA  1  E0 04           cpx #4
0014BC  1  D0 D1           bne @spr_init
0014BE  1               
0014BE  1  60              rts
0014BF  1               
0014BF  1               ;******************************************************************
0014BF  1               ; update_shield_sprite — write new data-addr byte to shield sprite N
0014BF  1               ;   Input:  X = shield index (0–3)
0014BF  1               ;           shield_damage[X] = current damage level (1–7)
0014BF  1               ;   Writes sprite byte 0 (addr[12:5]) using shield_addr_b0 lookup.
0014BF  1               ;   VERA addr for byte 0 of sprite N: $1FE10 + N*8
0014BF  1               ;******************************************************************
0014BF  1               update_shield_sprite:
0014BF  1  9C 25 9F        stz VERA_ctrl
0014C2  1  A9 11           lda #$11               ; stride=1, bank=1
0014C4  1  8D 22 9F        sta VERA_addr_bank
0014C7  1  A9 FE           lda #$FE
0014C9  1  8D 21 9F        sta VERA_addr_high
0014CC  1  8A              txa                    ; A = shield index
0014CD  1  0A              asl                    ; ×2
0014CE  1  0A              asl                    ; ×4
0014CF  1  0A              asl                    ; ×8
0014D0  1  18              clc
0014D1  1  69 10           adc #$10               ; + low byte of $1FE10
0014D3  1  8D 20 9F        sta VERA_addr_low
0014D6  1  B4 rr           ldy shield_damage, x   ; Y = damage level (1-3)
0014D8  1  B9 00 18        lda shield_addr_b0, y  ; addr[12:5] for this tile
0014DB  1  8D 23 9F        sta VERA_data0
0014DE  1  60              rts
0014DF  1               
0014DF  1               ;******************************************************************
0014DF  1               ; hide_shield_sprite — disable sprite for shield N (z-depth=0)
0014DF  1               ;   Input: X = shield index (0–3)
0014DF  1               ;   Writes sprite byte 6 at $1FE10 + N*8 + 6 = $1FE16 + N*8
0014DF  1               ;******************************************************************
0014DF  1               hide_shield_sprite:
0014DF  1  9C 25 9F        stz VERA_ctrl
0014E2  1  A9 11           lda #$11
0014E4  1  8D 22 9F        sta VERA_addr_bank
0014E7  1  A9 FE           lda #$FE
0014E9  1  8D 21 9F        sta VERA_addr_high
0014EC  1  8A              txa
0014ED  1  0A              asl
0014EE  1  0A              asl
0014EF  1  0A              asl
0014F0  1  18              clc
0014F1  1  69 16           adc #$16               ; low($1FE10) + 6 = $16, + N*8
0014F3  1  8D 20 9F        sta VERA_addr_low
0014F6  1  A9 00           lda #0                 ; z-depth=0 → sprite disabled
0014F8  1  8D 23 9F        sta VERA_data0
0014FB  1  60              rts
0014FC  1               
0014FC  1               ;******************************************************************
0014FC  1               ; damage_shield — increment damage counter for shield X and update
0014FC  1               ;   sprite (or disable it when counter reaches 8 = destroyed).
0014FC  1               ;   Input:  X = shield index (0–3)
0014FC  1               ;   Clobbers: A, Y, VERA registers.  Preserves X.
0014FC  1               ;******************************************************************
0014FC  1               damage_shield:
0014FC  1  F6 rr           inc shield_damage, x
0014FE  1  B5 rr           lda shield_damage, x
001500  1  C9 08           cmp #8
001502  1  F0 06           beq @destroy
001504  1  B0 07           bcs @done              ; already at 8 (safety guard)
001506  1  20 BF 14        jsr update_shield_sprite
001509  1  60              rts
00150A  1               @destroy:
00150A  1  20 DF 14        jsr hide_shield_sprite
00150D  1               @done:
00150D  1  60              rts
00150E  1               
00150E  1               ;******************************************************************
00150E  1               ; check_bullet_shields — test active player bullet vs all 4 shields
00150E  1               ;
00150E  1               ;   Overlap condition (AABB, all values VERA 16-bit):
00150E  1               ;     X: bullet_x+8 > shield_x  AND  bullet_x < shield_x+16
00150E  1               ;     Y: bullet_y+8 > SHIELD_Y  AND  bullet_y < SHIELD_Y+16
00150E  1               ;
00150E  1               ;   On hit: calls damage_shield, deactivates bullet, returns.
00150E  1               ;   Scratch used: zp_scratch_lo/hi.  Preserves nothing.
00150E  1               ;******************************************************************
00150E  1               check_bullet_shields:
00150E  1  A5 rr           lda bullet_active
001510  1  F0 6D           beq @done
001512  1               
001512  1                  ; --- Y quick check (same band for all shields) ---
001512  1                  ; (1) bullet_y+8 > SHIELD_Y
001512  1  A5 rr           lda bullet_y_lo
001514  1  18              clc
001515  1  69 08           adc #8
001517  1  85 rr           sta zp_scratch_lo
001519  1  A5 rr           lda bullet_y_hi
00151B  1  69 00           adc #0
00151D  1  85 rr           sta zp_scratch_hi
00151F  1  A5 rr           lda zp_scratch_lo
001521  1  38              sec
001522  1  E9 60           sbc #<SHIELD_Y
001524  1  A5 rr           lda zp_scratch_hi
001526  1  E9 01           sbc #>SHIELD_Y
001528  1  30 55           bmi @done              ; bullet bottom above shield top
00152A  1               
00152A  1                  ; (2) bullet_y < SHIELD_Y+32
00152A  1  A5 rr           lda bullet_y_lo
00152C  1  38              sec
00152D  1  E9 80           sbc #<(SHIELD_Y + 32)
00152F  1  A5 rr           lda bullet_y_hi
001531  1  E9 01           sbc #>(SHIELD_Y + 32)
001533  1  10 4A           bpl @done              ; bullet top at or below shield bottom
001535  1               
001535  1                  ; --- Y overlaps: scan each shield ---
001535  1  A2 00           ldx #0
001537  1               @sld_loop:
001537  1  B5 rr           lda shield_damage, x
001539  1  C9 08           cmp #8
00153B  1  B0 3D           bcs @next_sld          ; destroyed, skip
00153D  1               
00153D  1                  ; X check (1): bullet_x+8 > shield_x[x]
00153D  1  A5 rr           lda bullet_x_lo
00153F  1  18              clc
001540  1  69 08           adc #8
001542  1  85 rr           sta zp_scratch_lo
001544  1  A5 rr           lda bullet_x_hi
001546  1  69 00           adc #0
001548  1  85 rr           sta zp_scratch_hi
00154A  1  A5 rr           lda zp_scratch_lo
00154C  1  38              sec
00154D  1  FD F8 17        sbc shield_x_lo, x
001550  1  A5 rr           lda zp_scratch_hi
001552  1  FD FC 17        sbc shield_x_hi, x
001555  1  30 23           bmi @next_sld
001557  1               
001557  1                  ; X check (2): bullet_x < shield_x[x]+32
001557  1  BD F8 17        lda shield_x_lo, x
00155A  1  18              clc
00155B  1  69 20           adc #32
00155D  1  85 rr           sta zp_scratch_lo
00155F  1  BD FC 17        lda shield_x_hi, x
001562  1  69 00           adc #0
001564  1  85 rr           sta zp_scratch_hi
001566  1  A5 rr           lda bullet_x_lo
001568  1  38              sec
001569  1  E5 rr           sbc zp_scratch_lo
00156B  1  A5 rr           lda bullet_x_hi
00156D  1  E5 rr           sbc zp_scratch_hi
00156F  1  10 09           bpl @next_sld
001571  1               
001571  1                  ; --- HIT ---
001571  1  20 FC 14        jsr damage_shield      ; X = shield index
001574  1  64 rr           stz bullet_active
001576  1  20 BC 0D        jsr update_bullet_sprite
001579  1  60              rts
00157A  1               
00157A  1               @next_sld:
00157A  1  E8              inx
00157B  1  E0 04           cpx #4
00157D  1  D0 B8           bne @sld_loop
00157F  1               @done:
00157F  1  60              rts
001580  1               
001580  1               ;******************************************************************
001580  1               ; check_invbullet_shields — test each active invader bullet vs all
001580  1               ;   4 shields.  Same AABB logic as check_bullet_shields but loops
001580  1               ;   over 3 bullet slots (ibul_active / ibul_x / ibul_y arrays).
001580  1               ;
001580  1               ;   Scratch: zp_scratch_lo/hi, zp_row (bullet slot index),
001580  1               ;            zp_col (shield index during inner scan).
001580  1               ;******************************************************************
001580  1               check_invbullet_shields:
001580  1  A2 00           ldx #0                 ; outer loop: invader bullet slot
001582  1               @ibul_loop:
001582  1  86 rr           stx zp_row             ; save slot before any branch
001584  1  B5 rr           lda ibul_active, x
001586  1  F0 7B           beq @next_ibul
001588  1               
001588  1                  ; --- Y quick check ---
001588  1                  ; (1) ibul_y+8 > SHIELD_Y
001588  1  B5 rr           lda ibul_y_lo, x
00158A  1  18              clc
00158B  1  69 08           adc #8
00158D  1  85 rr           sta zp_scratch_lo
00158F  1  B5 rr           lda ibul_y_hi, x
001591  1  69 00           adc #0
001593  1  85 rr           sta zp_scratch_hi
001595  1  A5 rr           lda zp_scratch_lo
001597  1  38              sec
001598  1  E9 60           sbc #<SHIELD_Y
00159A  1  A5 rr           lda zp_scratch_hi
00159C  1  E9 01           sbc #>SHIELD_Y
00159E  1  30 63           bmi @next_ibul
0015A0  1               
0015A0  1                  ; (2) ibul_y < SHIELD_Y+32
0015A0  1  A6 rr           ldx zp_row
0015A2  1  B5 rr           lda ibul_y_lo, x
0015A4  1  38              sec
0015A5  1  E9 80           sbc #<(SHIELD_Y + 32)
0015A7  1  B5 rr           lda ibul_y_hi, x
0015A9  1  E9 01           sbc #>(SHIELD_Y + 32)
0015AB  1  10 56           bpl @next_ibul
0015AD  1               
0015AD  1                  ; --- Y overlaps: scan shields with Y register ---
0015AD  1  A0 00           ldy #0
0015AF  1               @sld_scan:
0015AF  1  B9 rr rr        lda shield_damage, y
0015B2  1  C9 08           cmp #8
0015B4  1  B0 48           bcs @next_sld_y        ; destroyed
0015B6  1               
0015B6  1                  ; X check (1): ibul_x+8 > shield_x[y]
0015B6  1  A6 rr           ldx zp_row
0015B8  1  B5 rr           lda ibul_x_lo, x
0015BA  1  18              clc
0015BB  1  69 08           adc #8
0015BD  1  85 rr           sta zp_scratch_lo
0015BF  1  B5 rr           lda ibul_x_hi, x
0015C1  1  69 00           adc #0
0015C3  1  85 rr           sta zp_scratch_hi
0015C5  1  A5 rr           lda zp_scratch_lo
0015C7  1  38              sec
0015C8  1  F9 F8 17        sbc shield_x_lo, y
0015CB  1  A5 rr           lda zp_scratch_hi
0015CD  1  F9 FC 17        sbc shield_x_hi, y
0015D0  1  30 2C           bmi @next_sld_y
0015D2  1               
0015D2  1                  ; X check (2): ibul_x < shield_x[y]+32
0015D2  1  B9 F8 17        lda shield_x_lo, y
0015D5  1  18              clc
0015D6  1  69 20           adc #32
0015D8  1  85 rr           sta zp_scratch_lo
0015DA  1  B9 FC 17        lda shield_x_hi, y
0015DD  1  69 00           adc #0
0015DF  1  85 rr           sta zp_scratch_hi
0015E1  1  A6 rr           ldx zp_row
0015E3  1  B5 rr           lda ibul_x_lo, x
0015E5  1  38              sec
0015E6  1  E5 rr           sbc zp_scratch_lo
0015E8  1  B5 rr           lda ibul_x_hi, x
0015EA  1  E5 rr           sbc zp_scratch_hi
0015EC  1  10 10           bpl @next_sld_y
0015EE  1               
0015EE  1                  ; --- HIT ---
0015EE  1  98              tya                    ; shield index → A → X for damage_shield
0015EF  1  AA              tax
0015F0  1  20 FC 14        jsr damage_shield
0015F3  1  A6 rr           ldx zp_row             ; restore bullet slot
0015F5  1  74 rr           stz ibul_active, x
0015F7  1  20 AD 0F        jsr update_inv_bullet_sprite
0015FA  1  A6 rr           ldx zp_row
0015FC  1  80 05           bra @next_ibul         ; done with this bullet
0015FE  1               
0015FE  1               @next_sld_y:
0015FE  1  C8              iny
0015FF  1  C0 04           cpy #4
001601  1  D0 AC           bne @sld_scan
001603  1               
001603  1               @next_ibul:
001603  1  A6 rr           ldx zp_row
001605  1  E8              inx
001606  1  E0 03           cpx #3
001608  1  F0 03           beq @cis_done
00160A  1  4C 82 15        jmp @ibul_loop
00160D  1               @cis_done:
00160D  1  60              rts
