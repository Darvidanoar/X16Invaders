001FF1  1               ; ufo_spr_data — 16x16 4bpp, 128 bytes, stored at VRAM $01500
001FF1  1               ;
001FF1  1               ;   Color 0 = transparent, Color 5 = red (saucer body)
001FF1  1               ;   Each byte encodes 2 pixels: high nibble = left, low nibble = right
001FF1  1               ;
001FF1  1               ;   Classic flying-saucer silhouette:
001FF1  1               ;     Row 1: ......5555......  dome top  (cols  6-9)
001FF1  1               ;     Row 2: ....55555555....  dome      (cols  4-11)
001FF1  1               ;     Row 3: 5555555555555555  wide body (all 16 cols)
001FF1  1               ;     Row 4: .5.5.5.5.5.5.5.5 body detail (odd cols lit)
001FF1  1               ;     Row 5: 5555555555555555  wide body
001FF1  1               ;     Row 6: ..555555555555..  underside (cols  2-13)
001FF1  1               ;     Row 7: ....5555..5555..  engine pods (cols 4-7, 10-13)
001FF1  1               ;     Rows 0,8-15: transparent
001FF1  1               ;******************************************************************
001FF1  1               ufo_spr_data:
001FF1  1  00 00 00 00     .byte $00,$00,$00,$00,$00,$00,$00,$00  ; row 0  blank
