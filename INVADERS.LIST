001496  1               ;******************************************************************
001496  1               ; draw_title_screen — paint the title screen; called once before title_loop
001496  1               ;
001496  1               ;   Layout (40-col text, VERA Y=row*16):
001496  1               ;     Row  1, col 14: "X16 INVADERS"      (12 chars, centred)
001496  1               ;     Row  3, col 16: "HI-SCORE"          (8 chars, centred)
001496  1               ;     Row  4, col 17: 000000              (6-digit BCD hi-score)
001496  1               ;     Row  5, col  5: "?UFO? = ??? PTS"
001496  1               ;     Row  7, col  9: "= 30 PTS"          + Type C sprite at X=96,Y=112
001496  1               ;     Row 10, col  9: "= 20 PTS"          + Type B sprite at X=96,Y=160
001496  1               ;     Row 13, col  9: "= 10 PTS"          + Type A sprite at X=96,Y=208
001496  1               ;     Row 17, col 10: (PRESS SPACE TO START — blinked by title_loop)
001496  1               ;     Row 19, col 12: "Q TO QUIT"
001496  1               ;******************************************************************
001496  1               draw_title_screen:
001496  1                  ; Row 1, col 14: "X16 INVADERS"
001496  1  A2 02           ldx #2
001498  1  A0 22           ldy #34
00149A  1  18              clc
00149B  1  20 F0 FF        jsr PLOT
00149E  1  A2 00           ldx #0
