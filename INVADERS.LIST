000AB9  1               
000AB9  1                  ; --- write sprite 4 attributes (initially disabled) ---
000AB9  1                  ; addr[12:5] = VRAM_EXPLOSION>>5 = $00440>>5 = $22
000AB9  1  A9 11 8D 22     VERA_SET_ADDR EXPLODE_SPRITE_ATTR, 1
000ABD  1  9F A9 FC 8D  
000AC1  1  21 9F A9 20  
000AC8  1  A9 22           lda #$22                     ; byte 0: addr[12:5]
000ACA  1  8D 23 9F        sta VERA_data0
000ACD  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000ACF  1  8D 23 9F        sta VERA_data0
000AD2  1  A9 00           lda #$00                     ; byte 2: X lo (placeholder)
000AD4  1  8D 23 9F        sta VERA_data0
000AD7  1  A9 00           lda #$00                     ; byte 3: X hi
000AD9  1  8D 23 9F        sta VERA_data0
000ADC  1  A9 00           lda #$00                     ; byte 4: Y lo (placeholder)
000ADE  1  8D 23 9F        sta VERA_data0
000AE1  1  A9 00           lda #$00                     ; byte 5: Y hi
000AE3  1  8D 23 9F        sta VERA_data0
000AE6  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000AE8  1  8D 23 9F        sta VERA_data0
000AEB  1  A9 50           lda #SPR_16x16_PAL0          ; byte 7: 16x16, palette 0
000AED  1  8D 23 9F        sta VERA_data0
000AF0  1               
