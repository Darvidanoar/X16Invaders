001C07  1               ;******************************************************************
001C07  1               ; player_spr_data — 16x16 4bpp sprite, 128 bytes
001C07  1               ;
001C07  1               ;   Color 0 = transparent, Color 1 = white (default palette index 1)
001C07  1               ;   Design: classic upward-pointing triangular ship with engine notches
001C07  1               ;
001C07  1               ;   Each byte encodes 2 pixels: high nibble = left, low nibble = right
001C07  1               ;   Columns: 0123456789ABCDEF
001C07  1               ;
001C07  1               ;   Row  0:  .......1........   cannon tip
001C07  1               ;   Row  1:  .......11.......
001C07  1               ;   Row  2:  ......111.......
001C07  1               ;   Row  3:  ......111.......
001C07  1               ;   Row  4:  .....11111......
001C07  1               ;   Row  5:  .....1111111....
001C07  1               ;   Row  6:  ...111111111....
001C07  1               ;   Row  7:  ..11111111111...
001C07  1               ;   Row  8:  .1111111111111..
001C07  1               ;   Row  9:  1111111111111111   full base
001C07  1               ;   Row 10:  1111111111111111
001C07  1               ;   Row 11:  1111111111111111
001C07  1               ;   Row 12:  11..11111111..11   engine notches
001C07  1               ;   Row 13:  11..11111111..11
001C07  1               ;   Row 14:  ................
001C07  1               ;   Row 15:  ................
001C07  1               ;******************************************************************
001C07  1               player_spr_data:
