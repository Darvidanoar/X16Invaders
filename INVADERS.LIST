0013EB  1  A0 10           ldy #16
0013ED  1  18              clc
0013EE  1  20 F0 FF        jsr PLOT
0013F1  1  A2 00           ldx #0
0013F3  1  BD 4B 1B     @sl2: lda str_hi_score_lbl, x
