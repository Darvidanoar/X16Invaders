000AF2  1               
000AF2  1                  ; --- upload invader bullet pixel data to VRAM $00420 ---
000AF2  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_BULLET, 1
000AF6  1  9F A9 04 8D  
000AFA  1  21 9F A9 20  
000B01  1  A2 00           ldx #0
000B03  1               @up_ibul:
000B03  1  BD AF 1E        lda inv_bullet_spr_data,x
000B06  1  8D 23 9F        sta VERA_data0
000B09  1  E8              inx
000B0A  1  E0 20           cpx #32
000B0C  1  D0 F5           bne @up_ibul
000B0E  1               
000B0E  1                  ; --- init 3 invader bullet sprites (slots 5-7, base $1FC28), all disabled ---
000B0E  1                  ; addr[12:5] = VRAM_INV_BULLET>>5 = $00420>>5 = $21
000B0E  1  A9 11 8D 22     VERA_SET_ADDR INV_BULLET_SPR_BASE, 1
000B12  1  9F A9 FC 8D  
000B16  1  21 9F A9 28  
000B1D  1  A2 03           ldx #3                       ; 3 sprites
000B1F  1               @init_ibspr:
000B1F  1  A9 21           lda #$21                     ; byte 0: addr[12:5] = $21
000B21  1  8D 23 9F        sta VERA_data0
000B24  1  A9 00           lda #$00
000B26  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, bank 0
000B29  1  8D 23 9F        sta VERA_data0               ; byte 2: X lo
000B2C  1  8D 23 9F        sta VERA_data0               ; byte 3: X hi
000B2F  1  8D 23 9F        sta VERA_data0               ; byte 4: Y lo
000B32  1  8D 23 9F        sta VERA_data0               ; byte 5: Y hi
000B35  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=0 → disabled
000B38  1  8D 23 9F        sta VERA_data0               ; byte 7: 8x8, palette 0
000B3B  1  CA              dex
000B3C  1  D0 E1           bne @init_ibspr
000B3E  1               
000B3E  1                  ; --- clear invader bullet state ---
000B3E  1  64 rr           stz ibul_active+0
000B40  1  64 rr           stz ibul_active+1
000B42  1  64 rr           stz ibul_active+2
000B44  1  A9 5A           lda #INV_FIRE_TIMER_INIT
000B46  1  85 rr           sta inv_fire_timer
000B48  1               
000B48  1                  ; --- upload UFO pixel data → VRAM $01500 ---
000B48  1  A9 10 8D 22     VERA_SET_ADDR VRAM_UFO, 1
000B4C  1  9F A9 15 8D  
000B50  1  21 9F A9 00  
000B57  1  A2 80           ldx #128
000B59  1  BD CF 1E     @up_ufo: lda ufo_spr_data-128,x
000B5C  1  8D 23 9F        sta VERA_data0
000B5F  1  E8              inx
000B60  1  D0 F7           bne @up_ufo
000B62  1               
000B62  1                  ; --- write sprite 3 (UFO) attributes (initially disabled) ---
000B62  1                  ; addr[12:5] = VRAM_UFO>>5 = $01500>>5 = $A8
000B62  1  A9 11 8D 22     VERA_SET_ADDR UFO_SPRITE_ATTR, 1
000B66  1  9F A9 FC 8D  
000B6A  1  21 9F A9 18  
000B71  1  A9 A8           lda #$A8                     ; byte 0: addr[12:5]
000B73  1  8D 23 9F        sta VERA_data0
000B76  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000B78  1  8D 23 9F        sta VERA_data0
000B7B  1  A9 00           lda #$00                     ; byte 2: X lo
000B7D  1  8D 23 9F        sta VERA_data0
000B80  1  A9 00           lda #$00                     ; byte 3: X hi
000B82  1  8D 23 9F        sta VERA_data0
000B85  1  A9 20           lda #<UFO_Y                  ; byte 4: Y lo
000B87  1  8D 23 9F        sta VERA_data0
000B8A  1  A9 00           lda #>UFO_Y                  ; byte 5: Y hi
000B8C  1  8D 23 9F        sta VERA_data0
000B8F  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000B91  1  8D 23 9F        sta VERA_data0
000B94  1  A9 50           lda #SPR_16x16_PAL0          ; byte 7: 16x16, palette 0
000B96  1  8D 23 9F        sta VERA_data0
000B99  1               
000B99  1  60              rts
000B9A  1               
000B9A  1               ;******************************************************************
000B9A  1               ; init_invaders — upload invader pixel data, init grid state, place sprites
000B9A  1               ;******************************************************************
000B9A  1               init_invaders:
000B9A  1  9C 25 9F        stz VERA_ctrl
000B9D  1               
000B9D  1                  ; --- upload Type A frame 0 → VRAM $00100 ---
000B9D  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F0, 1
000BA1  1  9F A9 01 8D  
000BA5  1  21 9F A9 00  
000BAC  1  A2 80           ldx #128
000BAE  1  BD 4F 1F     @up_af0: lda inv_a_spr_f0-128,x
000BB1  1  8D 23 9F        sta VERA_data0
000BB4  1  E8              inx
000BB5  1  D0 F7           bne @up_af0
000BB7  1               
000BB7  1                  ; --- upload Type A frame 1 → VRAM $00180 ---
000BB7  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F1, 1
000BBB  1  9F A9 01 8D  
000BBF  1  21 9F A9 80  
000BC6  1  A2 80           ldx #128
000BC8  1  BD CF 1F     @up_af1: lda inv_a_spr_f1-128,x
000BCB  1  8D 23 9F        sta VERA_data0
000BCE  1  E8              inx
000BCF  1  D0 F7           bne @up_af1
000BD1  1               
000BD1  1                  ; --- upload Type B frame 0 → VRAM $00200 ---
000BD1  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F0, 1
000BD5  1  9F A9 02 8D  
000BD9  1  21 9F A9 00  
000BE0  1  A2 80           ldx #128
000BE2  1  BD 4F 20     @up_bf0: lda inv_b_spr_f0-128,x
000BE5  1  8D 23 9F        sta VERA_data0
000BE8  1  E8              inx
000BE9  1  D0 F7           bne @up_bf0
000BEB  1               
000BEB  1                  ; --- upload Type B frame 1 → VRAM $00280 ---
000BEB  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F1, 1
000BEF  1  9F A9 02 8D  
000BF3  1  21 9F A9 80  
000BFA  1  A2 80           ldx #128
000BFC  1  BD CF 20     @up_bf1: lda inv_b_spr_f1-128,x
000BFF  1  8D 23 9F        sta VERA_data0
000C02  1  E8              inx
000C03  1  D0 F7           bne @up_bf1
000C05  1               
000C05  1                  ; --- upload Type C frame 0 → VRAM $00300 ---
000C05  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F0, 1
000C09  1  9F A9 03 8D  
000C0D  1  21 9F A9 00  
000C14  1  A2 80           ldx #128
000C16  1  BD 4F 21     @up_cf0: lda inv_c_spr_f0-128,x
000C19  1  8D 23 9F        sta VERA_data0
000C1C  1  E8              inx
000C1D  1  D0 F7           bne @up_cf0
000C1F  1               
000C1F  1                  ; --- upload Type C frame 1 → VRAM $00380 ---
000C1F  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F1, 1
000C23  1  9F A9 03 8D  
000C27  1  21 9F A9 80  
000C2E  1  A2 80           ldx #128
000C30  1  BD CF 21     @up_cf1: lda inv_c_spr_f1-128,x
000C33  1  8D 23 9F        sta VERA_data0
000C36  1  E8              inx
000C37  1  D0 F7           bne @up_cf1
000C39  1               
000C39  1                  ; --- initialize zero-page grid variables ---
000C39  1  A9 70           lda #<INV_GRID_X_INIT
000C3B  1  85 rr           sta inv_grid_x_lo
000C3D  1  A9 00           lda #>INV_GRID_X_INIT
000C3F  1  85 rr           sta inv_grid_x_hi
000C41  1  64 rr           stz inv_offset_y
000C43  1  64 rr           stz inv_direction
000C45  1  64 rr           stz inv_anim_frame
000C47  1  64 rr           stz inv_drop_flag
000C49  1               
000C49  1                  ; all 55 invaders alive: bytes 0-5 = $FF, byte 6 = $7F (55 bits)
000C49  1  A9 FF           lda #$FF
000C4B  1  85 rr           sta inv_alive+0
000C4D  1  85 rr           sta inv_alive+1
000C4F  1  85 rr           sta inv_alive+2
000C51  1  85 rr           sta inv_alive+3
000C53  1  85 rr           sta inv_alive+4
000C55  1  85 rr           sta inv_alive+5
000C57  1  A9 7F           lda #$7F
000C59  1  85 rr           sta inv_alive+6
000C5B  1               
000C5B  1  A9 37           lda #INV_COUNT_INIT
000C5D  1  85 rr           sta inv_count
000C5F  1  A5 rr           lda wave_init_speed
000C61  1  85 rr           sta inv_move_speed
000C63  1  85 rr           sta inv_move_timer
000C65  1               
000C65  1                  ; --- write initial sprite attributes for all 55 invaders ---
000C65  1  20 D1 0C        jsr update_invader_sprites
000C68  1  60              rts
000C69  1               
000C69  1               ;******************************************************************
000C69  1               ; step_invaders — one march step: move or drop grid, toggle anim frame
000C69  1               ;   Called when inv_move_timer reaches 0.
000C69  1               ;   Updates inv_grid_x / inv_offset_y, sets inv_drop_flag as needed,
000C69  1               ;   then refreshes all VERA sprite positions.
000C69  1               ;******************************************************************
000C69  1               step_invaders:
000C69  1                  ; toggle animation frame
000C69  1  A5 rr           lda inv_anim_frame
000C6B  1  49 01           eor #1
000C6D  1  85 rr           sta inv_anim_frame
000C6F  1               
000C6F  1                  ; if drop flag is set: drop grid this step, skip march
000C6F  1  A5 rr           lda inv_drop_flag
000C71  1  F0 0B           beq @do_march
000C73  1  64 rr           stz inv_drop_flag
000C75  1  A5 rr           lda inv_offset_y
000C77  1  18              clc
000C78  1  69 10           adc #INV_DROP_Y
000C7A  1  85 rr           sta inv_offset_y
000C7C  1  80 4C           bra @sprites_done
000C7E  1               
000C7E  1               @do_march:
000C7E  1  A5 rr           lda inv_direction
000C80  1  D0 25           bne @march_left
000C82  1               
000C82  1                  ; --- march right ---
000C82  1  A5 rr           lda inv_grid_x_lo
000C84  1  18              clc
000C85  1  69 04           adc #INV_STEP_X
000C87  1  85 rr           sta inv_grid_x_lo
000C89  1  90 02           bcc @chk_right
000C8B  1  E6 rr           inc inv_grid_x_hi
000C8D  1               @chk_right:
000C8D  1                  ; hit right if grid_x > INV_X_RIGHT_LIM (208, fits in 1 byte, hi always 0)
000C8D  1  A5 rr           lda inv_grid_x_hi
000C8F  1  D0 06           bne @clamp_right          ; hi > 0 → definitely over limit
000C91  1  A5 rr           lda inv_grid_x_lo
000C93  1  C9 D1           cmp #INV_X_RIGHT_LIM + 1  ; C set if lo > limit
000C95  1  90 33           bcc @sprites_done
000C97  1               @clamp_right:
000C97  1  A9 D0           lda #<INV_X_RIGHT_LIM
000C99  1  85 rr           sta inv_grid_x_lo
000C9B  1  A9 00           lda #>INV_X_RIGHT_LIM
000C9D  1  85 rr           sta inv_grid_x_hi
000C9F  1  A9 01           lda #1
000CA1  1  85 rr           sta inv_direction
000CA3  1  85 rr           sta inv_drop_flag
000CA5  1  80 23           bra @sprites_done
000CA7  1               
000CA7  1                  ; --- march left ---
000CA7  1               @march_left:
000CA7  1  A5 rr           lda inv_grid_x_lo
000CA9  1  38              sec
000CAA  1  E9 04           sbc #INV_STEP_X
000CAC  1  85 rr           sta inv_grid_x_lo
000CAE  1  B0 02           bcs @chk_left             ; no borrow
000CB0  1  C6 rr           dec inv_grid_x_hi
000CB2  1               @chk_left:
000CB2  1                  ; hit left if hi went negative OR lo < INV_X_LEFT_LIM
000CB2  1  A5 rr           lda inv_grid_x_hi
000CB4  1  30 06           bmi @clamp_left
000CB6  1  A5 rr           lda inv_grid_x_lo
000CB8  1  C9 10           cmp #INV_X_LEFT_LIM
000CBA  1  B0 0E           bcs @sprites_done         ; lo >= left limit → ok
000CBC  1               @clamp_left:
000CBC  1  A9 10           lda #<INV_X_LEFT_LIM
000CBE  1  85 rr           sta inv_grid_x_lo
000CC0  1  A9 00           lda #>INV_X_LEFT_LIM
000CC2  1  85 rr           sta inv_grid_x_hi
000CC4  1  64 rr           stz inv_direction
000CC6  1  A9 01           lda #1
000CC8  1  85 rr           sta inv_drop_flag
000CCA  1               
000CCA  1               @sprites_done:
000CCA  1  20 E1 1A        jsr snd_march_step
000CCD  1  20 D1 0C        jsr update_invader_sprites
000CD0  1  60              rts
000CD1  1               
000CD1  1               ;******************************************************************
000CD1  1               ; update_invader_sprites — write all 55 invader sprite attributes to VERA
000CD1  1               ;
000CD1  1               ;   VERA sprite slots 11-65 hold the 55 invaders.
000CD1  1               ;   Attributes base: $1FC58 ($1FC00 + 11*8).
000CD1  1               ;   With stride=1 the VERA address auto-increments, so we set it
000CD1  1               ;   once and write all 440 bytes sequentially.
000CD1  1               ;
000CD1  1               ;   Byte layout per sprite:
000CD1  1               ;     0: data addr[12:5]   (encodes VRAM pixel data address + frame)
000CD1  1               ;     1: $00               (4bpp, addr[16:13]=0)
000CD1  1               ;     2: X[7:0]
000CD1  1               ;     3: X[9:8]
000CD1  1               ;     4: Y[7:0]
000CD1  1               ;     5: Y[9:8]
000CD1  1               ;     6: z-depth/collision
000CD1  1               ;     7: palette / size
000CD1  1               ;
000CD1  1               ;   Invader index i = row*11 + col; alive bit i in inv_alive bitmap.
000CD1  1               ;   For Phase 3 all invaders are alive; alive check will be added Phase 4.
000CD1  1               ;******************************************************************
000CD1  1               update_invader_sprites:
000CD1  1  9C 25 9F        stz VERA_ctrl
000CD4  1  A9 11           lda #$11              ; stride=1, VRAM bank bit=1 (addr $1Fxxxx)
000CD6  1  8D 22 9F        sta VERA_addr_bank
000CD9  1  A9 FC           lda #$FC
000CDB  1  8D 21 9F        sta VERA_addr_high
000CDE  1  A9 58           lda #$58
000CE0  1  8D 20 9F        sta VERA_addr_low     ; VERA now at $1FC58, auto-increments by 1
000CE3  1               
000CE3  1                  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000CE3  1  A9 50           lda #<INV_GRID_Y_BASE
000CE5  1  18              clc
000CE6  1  65 rr           adc inv_offset_y
000CE8  1  85 rr           sta zp_y_base_lo
000CEA  1  A9 00           lda #>INV_GRID_Y_BASE
000CEC  1  69 00           adc #0
000CEE  1  85 rr           sta zp_y_base_hi
000CF0  1               
000CF0  1  64 rr           stz zp_row
000CF2  1               @row_loop:
000CF2  1                  ; compute row Y: zp_row_y = zp_y_base + row_y_offsets[row]
000CF2  1  A4 rr           ldy zp_row
000CF4  1  B9 35 1E        lda row_y_offsets,y
000CF7  1  18              clc
000CF8  1  65 rr           adc zp_y_base_lo
000CFA  1  85 rr           sta zp_row_y_lo
000CFC  1  A9 00           lda #0
000CFE  1  65 rr           adc zp_y_base_hi
000D00  1  85 rr           sta zp_row_y_hi
000D02  1               
000D02  1                  ; select addr byte0 based on row type and animation frame
000D02  1  A4 rr           ldy zp_row
000D04  1  A5 rr           lda inv_anim_frame
000D06  1  F0 05           beq @use_f0
000D08  1  B9 1A 1E        lda inv_addr_b0_f1,y
000D0B  1  80 03           bra @got_b0
000D0D  1               @use_f0:
000D0D  1  B9 15 1E        lda inv_addr_b0_f0,y
000D10  1               @got_b0:
000D10  1  85 rr           sta zp_addr_b0
000D12  1               
000D12  1  20 1E 0D        jsr update_invader_row
000D15  1               
000D15  1  E6 rr           inc zp_row
000D17  1  A5 rr           lda zp_row
000D19  1  C9 05           cmp #5
000D1B  1  D0 D5           bne @row_loop
000D1D  1               
000D1D  1  60              rts
000D1E  1               
000D1E  1               ;******************************************************************
000D1E  1               ; update_invader_row — write 11 sprite attribute blocks for one row
000D1E  1               ;
000D1E  1               ;   Inputs (ZP): zp_row, zp_addr_b0, zp_row_y_lo/hi, inv_grid_x_lo/hi
000D1E  1               ;   VERA address register must already be set to the first sprite slot
000D1E  1               ;   for this row on entry (maintained by the sequential write stream).
000D1E  1               ;******************************************************************
000D1E  1               update_invader_row:
000D1E  1  64 rr           stz zp_col
000D20  1               @col_loop:
000D20  1                  ; --- determine z-depth from alive bitmap ---
000D20  1                  ; index = inv_row_base[row] + col; byte = index>>3; bit = index&7
000D20  1  A4 rr           ldy zp_row
000D22  1  B9 3A 1E        lda inv_row_base,y
000D25  1  18              clc
000D26  1  65 rr           adc zp_col
000D28  1  A8              tay                   ; Y = invader index
000D29  1  29 07           and #$07
000D2B  1  AA              tax                   ; X = bit index
000D2C  1  BD 3F 1E        lda bit_masks,x
000D2F  1  48              pha                   ; save bit mask
000D30  1  98              tya
000D31  1  4A              lsr
000D32  1  4A              lsr
000D33  1  4A              lsr
000D34  1  A8              tay                   ; Y = byte index into inv_alive
000D35  1  68              pla                   ; A = bit mask
000D36  1  39 rr rr        and inv_alive,y
000D39  1  F0 04           beq @zdepth_off
000D3B  1  A9 0C           lda #SPR_Z_FRONT
000D3D  1  80 02           bra @zdepth_done
000D3F  1               @zdepth_off:
000D3F  1  A9 00           lda #0
000D41  1               @zdepth_done:
000D41  1  85 rr           sta zp_scratch_lo     ; save z-depth before VERA stream starts
000D43  1               
000D43  1                  ; --- compute sprite X = inv_grid_x + col_x_offsets[col] ---
000D43  1  A4 rr           ldy zp_col
000D45  1  B9 1F 1E        lda col_x_lo,y
000D48  1  18              clc
000D49  1  65 rr           adc inv_grid_x_lo
000D4B  1  85 rr           sta zp_x_lo
000D4D  1  B9 2A 1E        lda col_x_hi,y
000D50  1  65 rr           adc inv_grid_x_hi
000D52  1  85 rr           sta zp_x_hi
000D54  1               
000D54  1                  ; --- write 8 attribute bytes (VERA auto-increments) ---
000D54  1  A5 rr           lda zp_addr_b0
000D56  1  8D 23 9F        sta VERA_data0        ; byte 0: data addr[12:5]
000D59  1  9C 23 9F        stz VERA_data0        ; byte 1: 4bpp, addr[16:13]=0
000D5C  1  A5 rr           lda zp_x_lo
000D5E  1  8D 23 9F        sta VERA_data0        ; byte 2: X[7:0]
000D61  1  A5 rr           lda zp_x_hi
000D63  1  29 03           and #$03
000D65  1  8D 23 9F        sta VERA_data0        ; byte 3: X[9:8]
000D68  1  A5 rr           lda zp_row_y_lo
000D6A  1  8D 23 9F        sta VERA_data0        ; byte 4: Y[7:0]
000D6D  1  A5 rr           lda zp_row_y_hi
000D6F  1  29 03           and #$03
000D71  1  8D 23 9F        sta VERA_data0        ; byte 5: Y[9:8]
000D74  1  A5 rr           lda zp_scratch_lo
000D76  1  8D 23 9F        sta VERA_data0        ; byte 6: z-depth (SPR_Z_FRONT if alive, 0 if dead)
000D79  1  A9 50           lda #SPR_16x16_PAL0
000D7B  1  8D 23 9F        sta VERA_data0        ; byte 7: 16x16, palette offset 0
000D7E  1               
000D7E  1  E6 rr           inc zp_col
000D80  1  A5 rr           lda zp_col
000D82  1  C9 0B           cmp #11
000D84  1  D0 9A           bne @col_loop
000D86  1               
000D86  1  60              rts
000D87  1               
000D87  1               ;******************************************************************
000D87  1               ; move_player — apply key_flags movement and clamp to screen edges
000D87  1               ;******************************************************************
000D87  1               move_player:
000D87  1  A5 rr           lda key_flags
000D89  1               
000D89  1                  ; --- move left ---
000D89  1  29 01           and #KEY_LEFT
000D8B  1  F0 1F           beq @check_right
000D8D  1  A5 rr           lda player_x_lo
000D8F  1  38              sec
000D90  1  E9 04           sbc #PLAYER_SPEED
000D92  1  85 rr           sta player_x_lo
000D94  1  B0 02           bcs @clamp_left              ; no borrow → hi unchanged
000D96  1  C6 rr           dec player_x_hi
000D98  1               @clamp_left:
000D98  1                  ; Clamp: if hi went negative ($FF) or (hi=0 AND lo < min) → set to min
000D98  1  A5 rr           lda player_x_hi
000D9A  1  30 08           bmi @set_min                 ; $80–$FF = underflowed
000D9C  1  D0 0E           bne @check_right             ; hi > 0 → still above minimum
000D9E  1  A5 rr           lda player_x_lo
000DA0  1  C9 08           cmp #PLAYER_X_MIN
000DA2  1  B0 08           bcs @check_right             ; lo >= min → ok
000DA4  1               @set_min:
000DA4  1  A9 08           lda #<PLAYER_X_MIN
000DA6  1  85 rr           sta player_x_lo
000DA8  1  A9 00           lda #>PLAYER_X_MIN
000DAA  1  85 rr           sta player_x_hi
000DAC  1               
000DAC  1                  ; --- move right ---
000DAC  1               @check_right:
000DAC  1  A5 rr           lda key_flags
000DAE  1  29 02           and #KEY_RIGHT
000DB0  1  F0 23           beq @move_done
000DB2  1  A5 rr           lda player_x_lo
000DB4  1  18              clc
000DB5  1  69 04           adc #PLAYER_SPEED
000DB7  1  85 rr           sta player_x_lo
000DB9  1  90 02           bcc @clamp_right             ; no carry → hi unchanged
000DBB  1  E6 rr           inc player_x_hi
000DBD  1               @clamp_right:
000DBD  1                  ; Clamp: if hi > max_hi, OR (hi == max_hi AND lo > max_lo) → set to max
000DBD  1  A5 rr           lda player_x_hi
000DBF  1  C9 02           cmp #>PLAYER_X_MAX
000DC1  1  90 12           bcc @move_done               ; hi < max_hi → definitely ok
000DC3  1  D0 08           bne @set_max                 ; hi > max_hi → over limit
000DC5  1  A5 rr           lda player_x_lo
000DC7  1  C9 68           cmp #<PLAYER_X_MAX
000DC9  1  90 0A           bcc @move_done               ; lo < max_lo when hi == max_hi → ok
000DCB  1  F0 08           beq @move_done               ; lo == max_lo → exactly at max, ok
000DCD  1               @set_max:
000DCD  1  A9 68           lda #<PLAYER_X_MAX
000DCF  1  85 rr           sta player_x_lo
000DD1  1  A9 02           lda #>PLAYER_X_MAX
000DD3  1  85 rr           sta player_x_hi
000DD5  1               
000DD5  1               @move_done:
000DD5  1  60              rts
000DD6  1               
000DD6  1               ;******************************************************************
000DD6  1               ; update_player_sprite — write current X position to sprite 1 in VERA
000DD6  1               ;   Only X needs updating (Y is fixed)
000DD6  1               ;******************************************************************
000DD6  1               update_player_sprite:
000DD6  1  9C 25 9F        stz VERA_ctrl
000DD9  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 2), 1
000DDD  1  9F A9 FC 8D  
000DE1  1  21 9F A9 0A  
000DE8  1  A5 rr           lda player_x_lo
000DEA  1  8D 23 9F        sta VERA_data0               ; sprite byte 2: X[7:0]
000DED  1  A5 rr           lda player_x_hi
000DEF  1  29 03           and #$03
000DF1  1  8D 23 9F        sta VERA_data0               ; sprite byte 3: X[9:8]
000DF4  1                  ; update z-depth based on inv_hit_timer:
000DF4  1                  ;   timer = 0        → show solid (not hit)
000DF4  1                  ;   timer = 61-120   → hidden solid (1-second respawn delay)
000DF4  1                  ;   timer = 1-60     → flashing (invincible, visible warning)
000DF4  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 6), 1
000DF8  1  9F A9 FC 8D  
000DFC  1  21 9F A9 0E  
000E03  1  A5 rr           lda inv_hit_timer
000E05  1  F0 08           beq @show                    ; timer=0 → show solid
000E07  1  C9 3D           cmp #61
000E09  1  B0 08           bcs @hide                    ; timer>=61 → first second: fully hidden
000E0B  1  29 08           and #$08                     ; timer 1-60: bit 3 flips every 8 frames → ~4 Hz flash
000E0D  1  D0 04           bne @hide
000E0F  1               @show:
000E0F  1  A9 0C           lda #SPR_Z_FRONT
000E11  1  80 02           bra @write_z
000E13  1               @hide:
000E13  1  A9 00           lda #0
000E15  1               @write_z:
000E15  1  8D 23 9F        sta VERA_data0               ; sprite byte 6: z-depth
000E18  1  60              rts
000E19  1               
000E19  1               ;******************************************************************
000E19  1               ; fire_bullet — activate player bullet at cannon tip, update sprite
000E19  1               ;   Bullet X centers the 8-px bullet over the 16-px player ship:
000E19  1               ;     bullet_x = player_x + 4
000E19  1               ;   Bullet Y starts 8 VERA pixels above the player sprite top.
000E19  1               ;   Caller must check bullet_active == 0 before calling.
000E19  1               ;******************************************************************
000E19  1               fire_bullet:
000E19  1  A5 rr           lda player_x_lo
000E1B  1  18              clc
000E1C  1  69 04           adc #4
000E1E  1  85 rr           sta bullet_x_lo
000E20  1  A5 rr           lda player_x_hi
000E22  1  69 00           adc #0
000E24  1  85 rr           sta bullet_x_hi
000E26  1               
000E26  1  A9 9C           lda #<BULLET_Y_INIT
000E28  1  85 rr           sta bullet_y_lo
000E2A  1  A9 01           lda #>BULLET_Y_INIT
000E2C  1  85 rr           sta bullet_y_hi
000E2E  1               
000E2E  1  A9 01           lda #1
000E30  1  85 rr           sta bullet_active
000E32  1  E6 rr           inc shot_count
000E34  1  20 54 0E        jsr update_bullet_sprite
000E37  1  20 51 1B        jsr snd_fire
000E3A  1  60              rts
000E3B  1               
000E3B  1               ;******************************************************************
000E3B  1               ; move_bullet — move bullet upward by BULLET_SPEED each frame;
000E3B  1               ;   deactivate when it reaches the top of the screen (Y underflows 0)
000E3B  1               ;******************************************************************
000E3B  1               move_bullet:
000E3B  1  A5 rr           lda bullet_y_lo
000E3D  1  38              sec
000E3E  1  E9 0C           sbc #BULLET_SPEED
000E40  1  85 rr           sta bullet_y_lo
000E42  1  A5 rr           lda bullet_y_hi
000E44  1  E9 00           sbc #0
000E46  1  85 rr           sta bullet_y_hi
000E48  1  30 04           bmi @deactivate              ; 16-bit underflow past 0 → off screen
000E4A  1               
000E4A  1  20 54 0E        jsr update_bullet_sprite
000E4D  1  60              rts
000E4E  1               
000E4E  1               @deactivate:
000E4E  1  64 rr           stz bullet_active
000E50  1  20 54 0E        jsr update_bullet_sprite     ; disables sprite (z-depth=0)
000E53  1  60              rts
000E54  1               
000E54  1               ;******************************************************************
000E54  1               ; update_bullet_sprite — write bullet position and enable/disable
000E54  1               ;   to VERA sprite 2 (bytes 2-6); byte 7 set once at init.
000E54  1               ;   z-depth = SPR_Z_FRONT when active, 0 when inactive.
000E54  1               ;******************************************************************
000E54  1               update_bullet_sprite:
000E54  1  9C 25 9F        stz VERA_ctrl
000E57  1  A9 11 8D 22     VERA_SET_ADDR (BULLET_SPRITE_ATTR + 2), 1
000E5B  1  9F A9 FC 8D  
000E5F  1  21 9F A9 12  
000E66  1  A5 rr           lda bullet_x_lo
000E68  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000E6B  1  A5 rr           lda bullet_x_hi
000E6D  1  29 03           and #$03
000E6F  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000E72  1  A5 rr           lda bullet_y_lo
000E74  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000E77  1  A5 rr           lda bullet_y_hi
000E79  1  29 03           and #$03
000E7B  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000E7E  1  A5 rr           lda bullet_active
000E80  1  F0 04           beq @z_off
000E82  1  A9 0C           lda #SPR_Z_FRONT
000E84  1  80 02           bra @write_z
000E86  1               @z_off:
000E86  1  A9 00           lda #$00
000E88  1               @write_z:
000E88  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
000E8B  1  60              rts
000E8C  1               
000E8C  1               ;******************************************************************
000E8C  1               ; check_bullet_invader — scan all 55 invaders for a hit with the player bullet
000E8C  1               ;
000E8C  1               ;   Iterates rows 0-4, columns 0-10.  Skips dead invaders.
000E8C  1               ;   For each live invader checks 16-bit AABB overlap:
000E8C  1               ;     X: bullet_x+8 > inv_x  AND  bullet_x < inv_x+16
000E8C  1               ;     Y: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000E8C  1               ;   On hit: calls kill_invader_hit and returns immediately.
000E8C  1               ;
000E8C  1               ;   Scratch used: zp_y_base_lo/hi, zp_row_y_lo/hi, zp_x_lo/hi,
000E8C  1               ;                 zp_scratch_lo/hi, zp_row, zp_col
000E8C  1               ;******************************************************************
000E8C  1               check_bullet_invader:
000E8C  1  A5 rr           lda bullet_active
000E8E  1  D0 01           bne :+
000E90  1  60              rts
000E91  1               :  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000E91  1  A9 50           lda #<INV_GRID_Y_BASE
000E93  1  18              clc
000E94  1  65 rr           adc inv_offset_y
000E96  1  85 rr           sta zp_y_base_lo
000E98  1  A9 00           lda #>INV_GRID_Y_BASE
000E9A  1  69 00           adc #0
000E9C  1  85 rr           sta zp_y_base_hi
000E9E  1               
000E9E  1  64 rr           stz zp_row
000EA0  1               @row_loop:
000EA0  1                  ; row Y = y_base + row_y_offsets[row]
000EA0  1  A4 rr           ldy zp_row
000EA2  1  B9 35 1E        lda row_y_offsets,y
000EA5  1  18              clc
000EA6  1  65 rr           adc zp_y_base_lo
000EA8  1  85 rr           sta zp_row_y_lo
000EAA  1  A9 00           lda #0
000EAC  1  65 rr           adc zp_y_base_hi
000EAE  1  85 rr           sta zp_row_y_hi
000EB0  1               
000EB0  1                  ; --- Quick Y range check for whole row ---
000EB0  1                  ; Need: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000EB0  1               
000EB0  1                  ; (1) bullet_y+8 > inv_y  →  (bullet_y+8) - inv_y > 0
000EB0  1                  ;     result negative (bmi) means bullet above this row
000EB0  1  A5 rr           lda bullet_y_lo
000EB2  1  18              clc
000EB3  1  69 08           adc #8
000EB5  1  85 rr           sta zp_scratch_lo
000EB7  1  A5 rr           lda bullet_y_hi
000EB9  1  69 00           adc #0
000EBB  1  85 rr           sta zp_scratch_hi
000EBD  1  A5 rr           lda zp_scratch_lo
000EBF  1  38              sec
000EC0  1  E5 rr           sbc zp_row_y_lo
000EC2  1  A5 rr           lda zp_scratch_hi
000EC4  1  E5 rr           sbc zp_row_y_hi
000EC6  1  30 1D           bmi @next_row         ; bullet bottom above invader top → no hit in this row
000EC8  1               
000EC8  1                  ; (2) bullet_y < inv_y+16  →  bullet_y - (inv_y+16) < 0
000EC8  1                  ;     result >= 0 (bpl) means bullet below this row
000EC8  1  A5 rr           lda zp_row_y_lo
000ECA  1  18              clc
000ECB  1  69 10           adc #16
000ECD  1  85 rr           sta zp_scratch_lo
000ECF  1  A5 rr           lda zp_row_y_hi
000ED1  1  69 00           adc #0
000ED3  1  85 rr           sta zp_scratch_hi
000ED5  1  A5 rr           lda bullet_y_lo
000ED7  1  38              sec
000ED8  1  E5 rr           sbc zp_scratch_lo
000EDA  1  A5 rr           lda bullet_y_hi
000EDC  1  E5 rr           sbc zp_scratch_hi
000EDE  1  10 05           bpl @next_row         ; bullet top at or below invader bottom → no hit
000EE0  1               
000EE0  1                  ; Y overlaps this row — check each column
000EE0  1  20 EE 0E        jsr cbi_check_cols
000EE3  1  B0 08           bcs @done             ; hit found; bullet already handled
000EE5  1               
000EE5  1               @next_row:
000EE5  1  E6 rr           inc zp_row
000EE7  1  A5 rr           lda zp_row
000EE9  1  C9 05           cmp #5
000EEB  1  D0 B3           bne @row_loop
000EED  1               
000EED  1               @done:
000EED  1  60              rts
000EEE  1               
000EEE  1               ;******************************************************************
000EEE  1               ; cbi_check_cols — column scan for check_bullet_invader
000EEE  1               ;
000EEE  1               ;   Scans all 11 columns of zp_row for an X overlap with the bullet.
000EEE  1               ;   Assumes Y overlap for this row has already been confirmed.
000EEE  1               ;   Returns: C set if hit (kill_invader_hit already called),
000EEE  1               ;            C clear if no hit.
000EEE  1               ;   Scratch used: zp_col, zp_x_lo/hi, zp_scratch_lo/hi
000EEE  1               ;******************************************************************
000EEE  1               cbi_check_cols:
000EEE  1  64 rr           stz zp_col
000EF0  1               @col_loop:
000EF0  1                  ; skip if invader is dead
000EF0  1  A4 rr           ldy zp_row
000EF2  1  B9 3A 1E        lda inv_row_base,y
000EF5  1  18              clc
000EF6  1  65 rr           adc zp_col
000EF8  1  A8              tay                   ; Y = invader index
000EF9  1  29 07           and #$07
000EFB  1  AA              tax
000EFC  1  BD 3F 1E        lda bit_masks,x
000EFF  1  48              pha
000F00  1  98              tya
000F01  1  4A              lsr
000F02  1  4A              lsr
000F03  1  4A              lsr
000F04  1  A8              tay                   ; Y = byte index into inv_alive
000F05  1  68              pla
000F06  1  39 rr rr        and inv_alive,y
000F09  1  F0 46           beq @next_col         ; dead
000F0B  1               
000F0B  1                  ; compute inv_x = inv_grid_x + col_x_offsets[col]
000F0B  1  A4 rr           ldy zp_col
000F0D  1  B9 1F 1E        lda col_x_lo,y
000F10  1  18              clc
000F11  1  65 rr           adc inv_grid_x_lo
000F13  1  85 rr           sta zp_x_lo
000F15  1  B9 2A 1E        lda col_x_hi,y
000F18  1  65 rr           adc inv_grid_x_hi
000F1A  1  85 rr           sta zp_x_hi
000F1C  1               
000F1C  1                  ; X check (1): bullet_x+8 > inv_x
000F1C  1  A5 rr           lda bullet_x_lo
000F1E  1  18              clc
000F1F  1  69 08           adc #8
000F21  1  85 rr           sta zp_scratch_lo
000F23  1  A5 rr           lda bullet_x_hi
000F25  1  69 00           adc #0
000F27  1  85 rr           sta zp_scratch_hi
000F29  1  A5 rr           lda zp_scratch_lo
000F2B  1  38              sec
000F2C  1  E5 rr           sbc zp_x_lo
000F2E  1  A5 rr           lda zp_scratch_hi
000F30  1  E5 rr           sbc zp_x_hi
000F32  1  30 1D           bmi @next_col         ; bullet right edge left of invader → no hit
000F34  1               
000F34  1                  ; X check (2): bullet_x < inv_x+16
000F34  1  A5 rr           lda zp_x_lo
000F36  1  18              clc
000F37  1  69 10           adc #16
000F39  1  85 rr           sta zp_scratch_lo
000F3B  1  A5 rr           lda zp_x_hi
000F3D  1  69 00           adc #0
000F3F  1  85 rr           sta zp_scratch_hi
000F41  1  A5 rr           lda bullet_x_lo
000F43  1  38              sec
000F44  1  E5 rr           sbc zp_scratch_lo
000F46  1  A5 rr           lda bullet_x_hi
000F48  1  E5 rr           sbc zp_scratch_hi
000F4A  1  10 05           bpl @next_col         ; bullet left edge at or right of invader → no hit
000F4C  1               
000F4C  1                  ; --- HIT ---
000F4C  1  20 5B 0F        jsr kill_invader_hit
000F4F  1  38              sec                   ; signal hit to caller
000F50  1  60              rts
000F51  1               
000F51  1               @next_col:
000F51  1  E6 rr           inc zp_col
000F53  1  A5 rr           lda zp_col
000F55  1  C9 0B           cmp #11
000F57  1  D0 97           bne @col_loop
000F59  1               
000F59  1  18              clc                   ; no hit
000F5A  1  60              rts
000F5B  1               
000F5B  1               ;******************************************************************
000F5B  1               ; kill_invader_hit — clear alive bit, deactivate bullet, update score & speed
000F5B  1               ;   Expects zp_row, zp_col to identify the hit invader.
000F5B  1               ;******************************************************************
000F5B  1               kill_invader_hit:
000F5B  1                  ; --- clear alive bit ---
000F5B  1  A4 rr           ldy zp_row
000F5D  1  B9 3A 1E        lda inv_row_base,y
000F60  1  18              clc
000F61  1  65 rr           adc zp_col
000F63  1  A8              tay                   ; Y = invader index
000F64  1  29 07           and #$07
000F66  1  AA              tax
000F67  1  BD 3F 1E        lda bit_masks,x       ; bit mask for this invader
000F6A  1  48              pha
000F6B  1  98              tya
000F6C  1  4A              lsr
000F6D  1  4A              lsr
000F6E  1  4A              lsr
000F6F  1  A8              tay                   ; Y = byte index into inv_alive
000F70  1  68              pla
000F71  1  49 FF           eor #$FF              ; invert → clear mask
000F73  1  39 rr rr        and inv_alive,y
000F76  1  99 rr rr        sta inv_alive,y
000F79  1               
000F79  1                  ; --- start explosion at the hit invader's position ---
000F79  1                  ; zp_x_lo/hi and zp_row_y_lo/hi still hold the invader coords from collision detection
000F79  1  20 A7 0F        jsr start_explosion
000F7C  1               
000F7C  1                  ; --- deactivate bullet ---
000F7C  1  64 rr           stz bullet_active
000F7E  1  20 54 0E        jsr update_bullet_sprite
000F81  1               
000F81  1                  ; --- decrement inv_count ---
000F81  1  C6 rr           dec inv_count
000F83  1               
000F83  1                  ; --- update inv_move_speed: proportional to remaining count ---
000F83  1  A6 rr           ldx inv_count
000F85  1  BD 4C 1E        lda inv_speed_table,x
000F88  1  85 rr           sta inv_move_speed
000F8A  1               
000F8A  1                  ; --- add score for this row's invader type ---
000F8A  1  A4 rr           ldy zp_row
000F8C  1  B9 47 1E        lda score_by_row_bcd,y
000F8F  1  20 93 0F        jsr add_score
000F92  1  60              rts
000F93  1               
000F93  1               ;******************************************************************
000F93  1               ; add_score — add BCD value in A to score_lo/mid/hi
000F93  1               ;******************************************************************
000F93  1               add_score:
000F93  1  F8              sed
000F94  1  18              clc
000F95  1  65 rr           adc score_lo
000F97  1  85 rr           sta score_lo
000F99  1  A5 rr           lda score_mid
000F9B  1  69 00           adc #0
000F9D  1  85 rr           sta score_mid
000F9F  1  A5 rr           lda score_hi
000FA1  1  69 00           adc #0
000FA3  1  85 rr           sta score_hi
000FA5  1  D8              cld
000FA6  1  60              rts
000FA7  1               
000FA7  1               ;******************************************************************
000FA7  1               ; start_explosion — position sprite 4 at the hit invader and start timer
000FA7  1               ;
000FA7  1               ;   Inputs: zp_x_lo/hi     — invader X (VERA coords)
000FA7  1               ;           zp_row_y_lo/hi — invader Y (VERA coords)
000FA7  1               ;   Sets exp_timer = EXPLODE_FRAMES and enables sprite 4.
000FA7  1               ;******************************************************************
000FA7  1               start_explosion:
000FA7  1  9C 25 9F        stz VERA_ctrl
000FAA  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 2), 1  ; start at byte 2 (X lo)
000FAE  1  9F A9 FC 8D  
000FB2  1  21 9F A9 22  
000FB9  1  A5 rr           lda zp_x_lo
000FBB  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000FBE  1  A5 rr           lda zp_x_hi
000FC0  1  29 03           and #$03
000FC2  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000FC5  1  A5 rr           lda zp_row_y_lo
000FC7  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000FCA  1  A5 rr           lda zp_row_y_hi
000FCC  1  29 03           and #$03
000FCE  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000FD1  1  A9 0C           lda #SPR_Z_FRONT
000FD3  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3 → enabled, in front
000FD6  1  A9 1E           lda #EXPLODE_FRAMES
000FD8  1  85 rr           sta exp_timer
000FDA  1  20 B6 1B        jsr snd_explosion
000FDD  1  60              rts
000FDE  1               
000FDE  1               ;******************************************************************
000FDE  1               ; update_explosion — decrement exp_timer; disable sprite when it hits 0
000FDE  1               ;******************************************************************
000FDE  1               update_explosion:
000FDE  1  A5 rr           lda exp_timer
000FE0  1  F0 1B           beq @inactive
000FE2  1  C6 rr           dec exp_timer
000FE4  1  D0 17           bne @inactive
000FE6  1                  ; timer just expired — disable sprite 4
000FE6  1  9C 25 9F        stz VERA_ctrl
000FE9  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1  ; byte 6 = z-depth
000FED  1  9F A9 FC 8D  
000FF1  1  21 9F A9 26  
000FF8  1  A9 00           lda #$00
000FFA  1  8D 23 9F        sta VERA_data0               ; z-depth=0 → disabled
000FFD  1               @inactive:
000FFD  1  60              rts
000FFE  1               
000FFE  1               ;******************************************************************
000FFE  1               ; prng — 16-bit Galois LFSR, feedback polynomial $B400
000FFE  1               ;   Updates rand_seed_lo/hi; returns pseudo-random byte in A.
000FFE  1               ;******************************************************************
000FFE  1               prng:
000FFE  1  46 rr           lsr rand_seed_hi          ; shift 16-bit state right; carry = old hi[0]
001000  1  66 rr           ror rand_seed_lo          ; lo[7] = old hi[0]; carry = old lo[0] (feedback bit)
001002  1  90 06           bcc @done                 ; feedback bit=0: no XOR
001004  1  A5 rr           lda rand_seed_hi
001006  1  49 B4           eor #$B4                  ; XOR hi byte with feedback poly ($B400 >> 8)
001008  1  85 rr           sta rand_seed_hi
00100A  1               @done:
00100A  1  A5 rr           lda rand_seed_lo
00100C  1  60              rts
00100D  1               
00100D  1               ;******************************************************************
00100D  1               ; update_inv_bullets — fire timer, move active bullets, boundary check,
00100D  1               ;   update VERA sprites for all 3 invader bullet slots.
00100D  1               ;******************************************************************
00100D  1               update_inv_bullets:
00100D  1                  ; --- fire timer ---
00100D  1  C6 rr           dec inv_fire_timer
00100F  1  D0 0D           bne @move_loop
001011  1                  ; reset timer = max(inv_move_speed, INV_FIRE_TIMER_MIN)
001011  1  A5 rr           lda inv_move_speed
001013  1  C9 0A           cmp #INV_FIRE_TIMER_MIN
001015  1  B0 02           bcs @set_timer
001017  1  A9 0A           lda #INV_FIRE_TIMER_MIN
001019  1               @set_timer:
001019  1  85 rr           sta inv_fire_timer
00101B  1  20 88 10        jsr try_fire_inv_bullet
00101E  1               
00101E  1               @move_loop:
00101E  1  A2 00           ldx #0
001020  1               @slot_loop:
001020  1  B5 rr           lda ibul_active,x
001022  1  F0 1B           beq @update_spr           ; inactive: just hide sprite
001024  1               
001024  1                  ; move bullet down by INV_BULLET_SPEED
001024  1  B5 rr           lda ibul_y_lo,x
001026  1  18              clc
001027  1  69 06           adc #INV_BULLET_SPEED
001029  1  95 rr           sta ibul_y_lo,x
00102B  1  B5 rr           lda ibul_y_hi,x
00102D  1  69 00           adc #0
00102F  1  95 rr           sta ibul_y_hi,x
001031  1               
001031  1                  ; boundary: deactivate if Y >= 480 ($01E0)
001031  1  C9 01           cmp #>480                 ; A = new hi byte; compare with 1
001033  1  90 0A           bcc @update_spr           ; hi < 1: still on screen
001035  1  D0 06           bne @deactivate           ; hi > 1: off screen
001037  1  B5 rr           lda ibul_y_lo,x
001039  1  C9 E0           cmp #<480                 ; compare lo with $E0
00103B  1  90 02           bcc @update_spr           ; lo < $E0: still on screen
00103D  1               @deactivate:
00103D  1  74 rr           stz ibul_active,x
00103F  1               
00103F  1               @update_spr:
00103F  1  20 48 10        jsr update_inv_bullet_sprite   ; preserves X
001042  1  E8              inx
001043  1  E0 03           cpx #3
001045  1  D0 D9           bne @slot_loop
001047  1  60              rts
001048  1               
001048  1               ;******************************************************************
001048  1               ; update_inv_bullet_sprite — write VERA sprite attrs bytes 2-6 for slot X
001048  1               ;   X = slot index (0-2).  Preserves X.
001048  1               ;******************************************************************
001048  1               update_inv_bullet_sprite:
001048  1  86 rr           stx zp_scratch_lo              ; preserve slot index
00104A  1  9C 25 9F        stz VERA_ctrl
00104D  1  A9 11           lda #$11                       ; stride=1, bank bit=1
00104F  1  8D 22 9F        sta VERA_addr_bank
001052  1  A9 FC           lda #$FC
001054  1  8D 21 9F        sta VERA_addr_high
001057  1  BD 84 1E        lda ibul_spr_lo,x
00105A  1  18              clc
00105B  1  69 02           adc #2                         ; point to byte 2 (X position)
00105D  1  8D 20 9F        sta VERA_addr_low
001060  1  B5 rr           lda ibul_x_lo,x
001062  1  8D 23 9F        sta VERA_data0                 ; byte 2: X lo
001065  1  B5 rr           lda ibul_x_hi,x
001067  1  29 03           and #$03
001069  1  8D 23 9F        sta VERA_data0                 ; byte 3: X hi
00106C  1  B5 rr           lda ibul_y_lo,x
00106E  1  8D 23 9F        sta VERA_data0                 ; byte 4: Y lo
001071  1  B5 rr           lda ibul_y_hi,x
001073  1  29 03           and #$03
001075  1  8D 23 9F        sta VERA_data0                 ; byte 5: Y hi
001078  1  B5 rr           lda ibul_active,x
00107A  1  F0 04           beq @disabled
00107C  1  A9 0C           lda #SPR_Z_FRONT
00107E  1  80 02           bra @write_z
001080  1               @disabled:
001080  1  A9 00           lda #0
001082  1               @write_z:
001082  1  8D 23 9F        sta VERA_data0                 ; byte 6: z-depth
001085  1  A6 rr           ldx zp_scratch_lo
001087  1  60              rts
001088  1               
001088  1               ;******************************************************************
001088  1               ; try_fire_inv_bullet — find a free slot and spawn a bullet from the
001088  1               ;   bottommost live invader in a randomly chosen column.
001088  1               ;   Returns immediately if all slots busy or chosen column is empty.
001088  1               ;   Scratch used: zp_row, zp_col, zp_scratch_lo (slot index)
001088  1               ;******************************************************************
001088  1               try_fire_inv_bullet:
001088  1                  ; find a free bullet slot
001088  1  A2 00           ldx #0
00108A  1               @find_slot:
00108A  1  B5 rr           lda ibul_active,x
00108C  1  F0 06           beq @slot_found
00108E  1  E8              inx
00108F  1  E0 03           cpx #3
001091  1  D0 F7           bne @find_slot
001093  1  60              rts                            ; all slots busy
001094  1               
001094  1               @slot_found:
001094  1  86 rr           stx zp_scratch_lo              ; save free slot index
001096  1               
001096  1                  ; pick a random column 0-10
001096  1  20 FE 0F        jsr prng
001099  1  29 0F           and #$0F                       ; 0-15
00109B  1  C9 0B           cmp #11
00109D  1  90 03           bcc @col_ok
00109F  1  38              sec
0010A0  1  E9 0B           sbc #11                        ; wrap 11-15 → 0-4 (slight bias, acceptable)
0010A2  1               @col_ok:
0010A2  1  85 rr           sta zp_col
0010A4  1               
0010A4  1                  ; scan rows 4 down to 0 for bottommost live invader in this column
0010A4  1  A9 04           lda #4
0010A6  1  85 rr           sta zp_row
0010A8  1               @row_scan:
0010A8  1  A4 rr           ldy zp_row
0010AA  1  B9 3A 1E        lda inv_row_base,y
0010AD  1  18              clc
0010AE  1  65 rr           adc zp_col
0010B0  1  A8              tay                            ; Y = invader index
0010B1  1  29 07           and #$07
0010B3  1  AA              tax                            ; X = bit position
0010B4  1  BD 3F 1E        lda bit_masks,x
0010B7  1  48              pha
0010B8  1  98              tya
0010B9  1  4A              lsr
0010BA  1  4A              lsr
0010BB  1  4A              lsr
0010BC  1  A8              tay                            ; Y = byte index into inv_alive
0010BD  1  68              pla
0010BE  1  39 rr rr        and inv_alive,y
0010C1  1  D0 09           bne @found_invader
0010C3  1  A5 rr           lda zp_row
0010C5  1  F0 04           beq @no_invader                ; checked row 0, nothing alive
0010C7  1  C6 rr           dec zp_row
0010C9  1  80 DD           bra @row_scan
0010CB  1               
0010CB  1               @no_invader:
0010CB  1  60              rts                            ; column empty, skip fire
0010CC  1               
0010CC  1               @found_invader:
0010CC  1  A6 rr           ldx zp_scratch_lo              ; restore free slot index
0010CE  1  A9 01           lda #1
0010D0  1  95 rr           sta ibul_active,x
0010D2  1               
0010D2  1                  ; spawn X = inv_grid_x + col_x_offsets[col]  (16-bit, matching update_invader_sprites)
0010D2  1  A4 rr           ldy zp_col
0010D4  1  B9 1F 1E        lda col_x_lo,y
0010D7  1  18              clc
0010D8  1  65 rr           adc inv_grid_x_lo
0010DA  1  95 rr           sta ibul_x_lo,x
0010DC  1  B9 2A 1E        lda col_x_hi,y
0010DF  1  65 rr           adc inv_grid_x_hi
0010E1  1  95 rr           sta ibul_x_hi,x
0010E3  1                  ; add +4 as a separate 16-bit step to centre the 8px bullet in the 16px invader
0010E3  1  B5 rr           lda ibul_x_lo,x
0010E5  1  18              clc
0010E6  1  69 04           adc #4
0010E8  1  95 rr           sta ibul_x_lo,x
0010EA  1  B5 rr           lda ibul_x_hi,x
0010EC  1  69 00           adc #0
0010EE  1  95 rr           sta ibul_x_hi,x
0010F0  1               
0010F0  1                  ; spawn Y: compute y_base first (same two-step pattern as update_invader_sprites)
0010F0  1                  ; step 1: y_base = INV_GRID_Y_BASE + inv_offset_y  (16-bit)
0010F0  1  A9 50           lda #<INV_GRID_Y_BASE
0010F2  1  18              clc
0010F3  1  65 rr           adc inv_offset_y
0010F5  1  85 rr           sta zp_y_base_lo
0010F7  1  A9 00           lda #>INV_GRID_Y_BASE
0010F9  1  69 00           adc #0
0010FB  1  85 rr           sta zp_y_base_hi
0010FD  1                  ; step 2: spawn_y = y_base + row_y_offsets[row]
0010FD  1  A4 rr           ldy zp_row
0010FF  1  B9 35 1E        lda row_y_offsets,y
001102  1  18              clc
001103  1  65 rr           adc zp_y_base_lo
001105  1  95 rr           sta ibul_y_lo,x
001107  1  A9 00           lda #0
001109  1  65 rr           adc zp_y_base_hi
00110B  1  95 rr           sta ibul_y_hi,x
00110D  1                  ; step 3: +16 to place bullet at the bottom edge of the 16px invader
00110D  1  B5 rr           lda ibul_y_lo,x
00110F  1  18              clc
001110  1  69 10           adc #16
001112  1  95 rr           sta ibul_y_lo,x
001114  1  B5 rr           lda ibul_y_hi,x
001116  1  69 00           adc #0
001118  1  95 rr           sta ibul_y_hi,x
00111A  1               
00111A  1  60              rts
00111B  1               
00111B  1               ;******************************************************************
00111B  1               ; check_inv_bullet_player — AABB test each active invader bullet vs. player
00111B  1               ;
00111B  1               ;   Player rect: (player_x, PLAYER_Y) to (player_x+15, PLAYER_Y+15), 16x16
00111B  1               ;   Bullet rect: (ibul_x,   ibul_y)   to (ibul_x+7,   ibul_y+7),     8x8
00111B  1               ;
00111B  1               ;   On hit: bullet deactivated, jsr player_hit called, loop continues
00111B  1               ;   (remaining bullets checked — at most one hit landing per frame).
00111B  1               ;   Scratch: zp_scratch_lo/hi, X (slot index)
00111B  1               ;******************************************************************
00111B  1               check_inv_bullet_player:
00111B  1  A2 00           ldx #0
00111D  1               @slot_loop:
00111D  1  B5 rr           lda ibul_active,x
00111F  1  F0 5B           beq @next_slot
001121  1               
001121  1                  ; --- Y check 1: (bullet_y + 8) > PLAYER_Y  →  bullet_y + 8 - PLAYER_Y > 0 ---
001121  1  B5 rr           lda ibul_y_lo,x
001123  1  18              clc
001124  1  69 08           adc #8
001126  1  85 rr           sta zp_scratch_lo
001128  1  B5 rr           lda ibul_y_hi,x
00112A  1  69 00           adc #0
00112C  1  85 rr           sta zp_scratch_hi
00112E  1  A5 rr           lda zp_scratch_lo
001130  1  38              sec
001131  1  E9 A4           sbc #<PLAYER_Y
001133  1  A5 rr           lda zp_scratch_hi
001135  1  E9 01           sbc #>PLAYER_Y
001137  1  30 43           bmi @next_slot            ; bullet bottom above player top → no hit
001139  1               
001139  1                  ; --- Y check 2: bullet_y < PLAYER_Y + 16 → bullet_y - (PLAYER_Y+16) < 0 ---
001139  1  B5 rr           lda ibul_y_lo,x
00113B  1  38              sec
00113C  1  E9 B4           sbc #<(PLAYER_Y+16)
00113E  1  B5 rr           lda ibul_y_hi,x
001140  1  E9 01           sbc #>(PLAYER_Y+16)
001142  1  10 38           bpl @next_slot            ; bullet top at or below player bottom → no hit
001144  1               
001144  1                  ; --- X check 1: (bullet_x + 8) > player_x ---
001144  1  B5 rr           lda ibul_x_lo,x
001146  1  18              clc
001147  1  69 08           adc #8
001149  1  85 rr           sta zp_scratch_lo
00114B  1  B5 rr           lda ibul_x_hi,x
00114D  1  69 00           adc #0
00114F  1  85 rr           sta zp_scratch_hi
001151  1  A5 rr           lda zp_scratch_lo
001153  1  38              sec
001154  1  E5 rr           sbc player_x_lo
001156  1  A5 rr           lda zp_scratch_hi
001158  1  E5 rr           sbc player_x_hi
00115A  1  30 20           bmi @next_slot            ; bullet right edge left of player → no hit
00115C  1               
00115C  1                  ; --- X check 2: bullet_x < player_x + 16 ---
00115C  1  A5 rr           lda player_x_lo
00115E  1  18              clc
00115F  1  69 10           adc #16
001161  1  85 rr           sta zp_scratch_lo
001163  1  A5 rr           lda player_x_hi
001165  1  69 00           adc #0
001167  1  85 rr           sta zp_scratch_hi
001169  1  B5 rr           lda ibul_x_lo,x
00116B  1  38              sec
00116C  1  E5 rr           sbc zp_scratch_lo
00116E  1  B5 rr           lda ibul_x_hi,x
001170  1  E5 rr           sbc zp_scratch_hi
001172  1  10 08           bpl @next_slot            ; bullet left edge at or right of player → no hit
001174  1               
001174  1                  ; --- HIT ---
001174  1  74 rr           stz ibul_active,x         ; deactivate this bullet
001176  1  20 48 10        jsr update_inv_bullet_sprite
001179  1  20 82 11        jsr player_hit
00117C  1               
