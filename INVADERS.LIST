001825  1  8D 22 9F        sta VERA_addr_bank
001828  1  A9 FE           lda #$FE
00182A  1  8D 21 9F        sta VERA_addr_high
00182D  1  A9 10           lda #$10               ; low byte of $1FE10
00182F  1  8D 20 9F        sta VERA_addr_low
