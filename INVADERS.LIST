001627  1               ;******************************************************************
001627  1               ; init_shields — upload 8 damage tiles, set palette entry 7 to dark
001627  1               ;   green, init shield_damage counters, write sprite attributes for
001627  1               ;   all 4 shields (slots 66–69, base $1FE10).
001627  1               ;
001627  1               ;   Sprite positions: X = shield_x_lo/hi[n], Y = SHIELD_Y (352)
001627  1               ;   Each shield sprite: 32x32, palette 0 (entry 7 = dark green).
001627  1               ;******************************************************************
001627  1               init_shields:
001627  1  9C 25 9F        stz VERA_ctrl
00162A  1               
00162A  1                  ; --- palette entry 7 → dark green (R=0, G=$A, B=0) ---
00162A  1                  ; Palette byte 0: G[3:0] B[3:0] = $A0;  byte 1: R[3:0] = $00
00162A  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_palette + 14), 1   ; entry 7 = offset 14 bytes
00162E  1  9F A9 FA 8D  
001632  1  21 9F A9 0E  
001639  1  A9 A0           lda #$A0
00163B  1  8D 23 9F        sta VERA_data0
00163E  1  A9 00           lda #$00
001640  1  8D 23 9F        sta VERA_data0
001643  1               
001643  1                  ; --- upload shield_tile_full → $00500 (512 bytes: four 128-byte passes) ---
001643  1  A9 10 8D 22     VERA_SET_ADDR VRAM_SHIELD_FULL, 1
001647  1  9F A9 05 8D  
00164B  1  21 9F A9 00  
001652  1  A2 80           ldx #128
001654  1  BD F2 22     @up_s0a: lda shield_tile_full - 128, x
001657  1  8D 23 9F        sta VERA_data0
00165A  1  E8              inx
00165B  1  D0 F7           bne @up_s0a
00165D  1  A2 80           ldx #128
00165F  1  BD 72 23     @up_s0b: lda shield_tile_full, x
001662  1  8D 23 9F        sta VERA_data0
001665  1  E8              inx
001666  1  D0 F7           bne @up_s0b
001668  1  A2 80           ldx #128
00166A  1  BD F2 23     @up_s0c: lda shield_tile_full + 128, x
00166D  1  8D 23 9F        sta VERA_data0
001670  1  E8              inx
001671  1  D0 F7           bne @up_s0c
001673  1  A2 80           ldx #128
001675  1  BD 72 24     @up_s0d: lda shield_tile_full + 256, x
001678  1  8D 23 9F        sta VERA_data0
00167B  1  E8              inx
00167C  1  D0 F7           bne @up_s0d
00167E  1               
00167E  1                  ; --- upload shield_tile_dmg1 → $00700 ---
00167E  1  A9 10 8D 22     VERA_SET_ADDR VRAM_SHIELD_DMG1, 1
001682  1  9F A9 07 8D  
001686  1  21 9F A9 00  
00168D  1  A2 80           ldx #128
00168F  1  BD F2 24     @up_s1a: lda shield_tile_dmg1 - 128, x
001692  1  8D 23 9F        sta VERA_data0
001695  1  E8              inx
001696  1  D0 F7           bne @up_s1a
001698  1  A2 80           ldx #128
00169A  1  BD 72 25     @up_s1b: lda shield_tile_dmg1, x
00169D  1  8D 23 9F        sta VERA_data0
0016A0  1  E8              inx
0016A1  1  D0 F7           bne @up_s1b
0016A3  1  A2 80           ldx #128
0016A5  1  BD F2 25     @up_s1c: lda shield_tile_dmg1 + 128, x
0016A8  1  8D 23 9F        sta VERA_data0
0016AB  1  E8              inx
0016AC  1  D0 F7           bne @up_s1c
0016AE  1  A2 80           ldx #128
0016B0  1  BD 72 26     @up_s1d: lda shield_tile_dmg1 + 256, x
0016B3  1  8D 23 9F        sta VERA_data0
0016B6  1  E8              inx
0016B7  1  D0 F7           bne @up_s1d
0016B9  1               
