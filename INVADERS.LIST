001C46  1               str_wave_clear:
001C46  1  D7 C1 D6 C5     .byte "WAVE CLEAR", 0
001C4A  1  20 C3 CC C5  
001C4E  1  C1 D2 00     
001C51  1               str_wave_lbl:
001C51  1  D7 C1 D6 C5     .byte "WAVE: ", 0
001C55  1  3A 20 00     
001C58  1               str_wave_continue:
001C58  1  D0 D2 C5 D3     .byte "PRESS SPACE TO CONTINUE", 0
