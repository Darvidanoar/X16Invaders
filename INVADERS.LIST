001579  1  8D 23 9F        sta VERA_data0
00157C  1  A9 00           lda #0
00157E  1  8D 23 9F        sta VERA_data0
001581  1  A9 0C           lda #SPR_Z_FRONT
001583  1  8D 23 9F        sta VERA_data0
001586  1  A9 50           lda #SPR_16x16_PAL0
001588  1  8D 23 9F        sta VERA_data0
00158B  1               
00158B  1  A2 15           ldx #21
00158D  1  A0 0F           ldy #15
00158F  1  18              clc
001590  1  20 F0 FF        jsr PLOT
001593  1  A2 00           ldx #0
001595  1  BD 86 1D     @lp_b: lda str_score_b, x
001598  1  F0 06           beq @lp_b_done
00159A  1  20 D2 FF        jsr CHROUT
00159D  1  E8              inx
00159E  1  80 F5           bra @lp_b
0015A0  1               @lp_b_done:
