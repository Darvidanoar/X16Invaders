001924  1               ;******************************************************************
001924  1               ; check_invbullet_shields — test each active invader bullet vs all
001924  1               ;   4 shields.  Same AABB logic as check_bullet_shields but loops
001924  1               ;   over 3 bullet slots (ibul_active / ibul_x / ibul_y arrays).
001924  1               ;
001924  1               ;   Scratch: zp_scratch_lo/hi, zp_row (bullet slot index),
001924  1               ;            zp_col (shield index during inner scan).
001924  1               ;******************************************************************
001924  1               check_invbullet_shields:
001924  1  A2 00           ldx #0                 ; outer loop: invader bullet slot
001926  1               @ibul_loop:
001926  1  86 rr           stx zp_row             ; save slot before any branch
001928  1  B5 rr           lda ibul_active, x
00192A  1  F0 7B           beq @next_ibul
00192C  1               
00192C  1                  ; --- Y quick check ---
00192C  1                  ; (1) ibul_y+8 > SHIELD_Y
00192C  1  B5 rr           lda ibul_y_lo, x
00192E  1  18              clc
00192F  1  69 08           adc #8
001931  1  85 rr           sta zp_scratch_lo
001933  1  B5 rr           lda ibul_y_hi, x
001935  1  69 00           adc #0
001937  1  85 rr           sta zp_scratch_hi
001939  1  A5 rr           lda zp_scratch_lo
00193B  1  38              sec
00193C  1  E9 60           sbc #<SHIELD_Y
00193E  1  A5 rr           lda zp_scratch_hi
001940  1  E9 01           sbc #>SHIELD_Y
001942  1  30 63           bmi @next_ibul
001944  1               
001944  1                  ; (2) ibul_y < SHIELD_Y+32
001944  1  A6 rr           ldx zp_row
001946  1  B5 rr           lda ibul_y_lo, x
001948  1  38              sec
001949  1  E9 80           sbc #<(SHIELD_Y + 32)
00194B  1  B5 rr           lda ibul_y_hi, x
00194D  1  E9 01           sbc #>(SHIELD_Y + 32)
00194F  1  10 56           bpl @next_ibul
001951  1               
001951  1                  ; --- Y overlaps: scan shields with Y register ---
001951  1  A0 00           ldy #0
001953  1               @sld_scan:
001953  1  B9 rr rr        lda shield_damage, y
001956  1  C9 08           cmp #8
001958  1  B0 48           bcs @next_sld_y        ; destroyed
00195A  1               
00195A  1                  ; X check (1): ibul_x+8 > shield_x[y]
00195A  1  A6 rr           ldx zp_row
00195C  1  B5 rr           lda ibul_x_lo, x
00195E  1  18              clc
00195F  1  69 08           adc #8
001961  1  85 rr           sta zp_scratch_lo
001963  1  B5 rr           lda ibul_x_hi, x
001965  1  69 00           adc #0
001967  1  85 rr           sta zp_scratch_hi
001969  1  A5 rr           lda zp_scratch_lo
00196B  1  38              sec
00196C  1  F9 41 1F        sbc shield_x_lo, y
00196F  1  A5 rr           lda zp_scratch_hi
001971  1  F9 45 1F        sbc shield_x_hi, y
001974  1  30 2C           bmi @next_sld_y
001976  1               
001976  1                  ; X check (2): ibul_x < shield_x[y]+32
001976  1  B9 41 1F        lda shield_x_lo, y
001979  1  18              clc
00197A  1  69 20           adc #32
00197C  1  85 rr           sta zp_scratch_lo
00197E  1  B9 45 1F        lda shield_x_hi, y
001981  1  69 00           adc #0
001983  1  85 rr           sta zp_scratch_hi
001985  1  A6 rr           ldx zp_row
001987  1  B5 rr           lda ibul_x_lo, x
001989  1  38              sec
00198A  1  E5 rr           sbc zp_scratch_lo
00198C  1  B5 rr           lda ibul_x_hi, x
00198E  1  E5 rr           sbc zp_scratch_hi
001990  1  10 10           bpl @next_sld_y
001992  1               
001992  1                  ; --- HIT ---
001992  1  98              tya                    ; shield index → A → X for damage_shield
001993  1  AA              tax
001994  1  20 A0 18        jsr damage_shield
001997  1  A6 rr           ldx zp_row             ; restore bullet slot
001999  1  74 rr           stz ibul_active, x
00199B  1  20 5F 10        jsr update_inv_bullet_sprite
00199E  1  A6 rr           ldx zp_row
0019A0  1  80 05           bra @next_ibul         ; done with this bullet
0019A2  1               
0019A2  1               @next_sld_y:
0019A2  1  C8              iny
0019A3  1  C0 04           cpy #4
0019A5  1  D0 AC           bne @sld_scan
0019A7  1               
