000810  1               ;******************************************************************
000810  1               ; Constants
000810  1               ;******************************************************************
000810  1               
000810  1               ; VERA display control
000810  1               VERA_SPRITE_EN  = %01000000      ; VERA_dc_video bit 6: enable sprites
000810  1               
000810  1               ; PETSCII control codes
000810  1               PETSCII_WHITE   = $05            ; set text color to white
000810  1               PETSCII_CLR     = $93            ; clear screen and home cursor
000810  1               PETSCII_HOME    = $13            ; home cursor (no clear)
000810  1               PETSCII_RETURN  = $0D            ; carriage return
000810  1               
000810  1               ; SCREEN_SET_CHARSET font numbers (call address $FF62)
000810  1               CHARSET_UPPER   = 1              ; Commodore upper/graphics: $41-$5A = A-Z
000810  1               CHARSET_LOWER   = 2              ; Commodore lower/upper:    $41-$5A = a-z (lowercase)
000810  1               
000810  1               ; Key codes (PETSCII)
000810  1               KEY_RUN_STOP    = $03            ; RUN/STOP — exit game
000810  1               
000810  1               ; Input flag bits (key_flags)
000810  1               KEY_LEFT        = %00000001
000810  1               KEY_RIGHT       = %00000010
000810  1               KEY_FIRE        = %00000100
000810  1               
000810  1               ; JOYSTICK_GET .A return: {B,Y,Sel,Sta,Up,Dn,Left,Right} active low
000810  1               JOY_RIGHT       = %00000001     ; bit 0
000810  1               JOY_LEFT        = %00000010     ; bit 1
000810  1               
000810  1               ; Player ship — all positions in VERA 640x480 coordinate space
000810  1               PLAYER_Y        = 420            ; fixed Y, near bottom (479 = bottom edge)
000810  1               PLAYER_X_INIT   = 312            ; starting X, centred  ((640-16)/2)
000810  1               PLAYER_X_MIN    = 8              ; left  boundary (sprite left edge)
000810  1               PLAYER_X_MAX    = 616            ; right boundary (640 - 16px sprite - 8px margin)
000810  1               PLAYER_SPEED    = 4              ; pixels per frame
000810  1               
000810  1               ; Sprite attribute encoding helpers
000810  1               SPRITE1_ATTR    = $1FC08 ; sprite 1 attribute base ($1FC00=sprite 0, reserved for KERNAL mouse)
000810  1               SPR_Z_FRONT     = %00001100     ; byte 6: z-depth = %11 in bits 3-2 (in front of all layers)
000810  1               SPR_16x16_PAL0  = %01010000     ; byte 7: width=1(16px), height=1(16px), palette_off=0
000810  1               SPR_32x16_PAL0  = %10010000     ; byte 7: width=2(32px), height=1(16px), palette_off=0
000810  1               SPR_32x32_PAL0  = %10100000     ; byte 7: width=2(32px), height=2(32px), palette_off=0
000810  1               SPR_8x8_PAL0    = %00000000     ; byte 7: width=0(8px),  height=0(8px),  palette_off=0
000810  1               
000810  1               ; Explosion sprite (slot 4)
000810  1               VRAM_EXPLOSION     = $00440     ; explosion pixel data (128 bytes, 16x16 4bpp)
000810  1               EXPLODE_SPRITE_ATTR = $1FC20    ; sprite 4 attribute base (explosion)
000810  1               EXPLODE_FRAMES     = 30         ; display duration in frames (~0.5 sec at 60 Hz)
000810  1               
000810  1               ; Invader bullets (sprite slots 5-7)
000810  1               VRAM_INV_BULLET    = $00420     ; invader bullet pixel data (32 bytes, 8x8 4bpp)
000810  1               INV_BULLET_SPR_BASE = $1FC28    ; sprite 5 attribute base (first invader bullet)
000810  1               INV_BULLET_SPEED   = 6          ; VERA pixels per frame downward (=3 game pixels)
000810  1               INV_FIRE_TIMER_MIN = 10         ; minimum frames between fire attempts
000810  1               INV_FIRE_TIMER_INIT = 90        ; frames before first shot
000810  1               
000810  1               ; Player lives
000810  1               LIVES_INIT         = 3          ; starting lives
000810  1               INV_HIT_FRAMES     = 120        ; invincibility duration after being hit (2 sec at 60 Hz)
000810  1               
000810  1               ; UFO saucer (sprite slot 3)
000810  1               UFO_SPRITE_ATTR    = $1FC18      ; sprite 3 attribute base ($1FC00 + 3*8)
000810  1               VRAM_UFO           = $01500      ; UFO pixel data (128 bytes, 16x16 4bpp, after shield tiles)
000810  1               UFO_Y              = 32          ; VERA Y coord (= display pixel 16, top of play field)
000810  1               UFO_SPEED          = 2           ; VERA pixels per frame rightward (1 display pixel/frame)
000810  1               UFO_TIMER_INIT     = 600         ; frames between UFO appearances (≈10 sec at 60 Hz)
000810  1               
000810  1               ; Wave progression
000810  1               WAVE_CLEAR_FRAMES  = 180         ; auto-advance delay after wave clear (≈3 sec at 60 Hz)
000810  1               WAVE_SPEED_STEP    = 5           ; inv_move_speed decreases by this each wave
000810  1               
000810  1               ; VERA PSG voice 0 — march beat (base addr $1F9C0)
000810  1               ; 4-note cycle: ~120 Hz, ~100 Hz, ~80 Hz, ~100 Hz
000810  1               ; freq_reg = freq_hz * 25000000 / (512 * 131072) ≈ freq_hz * 2.684
000810  1               VRAM_PSG_VOICE0    = VRAM_psg + 0    ; $1F9C0 — voice 0 registers (march)
000810  1               PSG_MARCH_VOL      = $FF             ; stereo, full volume
000810  1               PSG_WAVE_PULSE     = %00000000       ; pulse waveform (bits 7:6 = 00)
000810  1               MARCH_NOTE_FRAMES  = 6               ; frames to hold each march note (~100ms)
000810  1               ; Note frequencies: 120Hz→322=$0142, 100Hz→268=$010C, 80Hz→215=$00D7
000810  1               MARCH_FREQ0_L      = $42             ; note 0: 120 Hz
000810  1               MARCH_FREQ0_H      = $01
000810  1               MARCH_FREQ1_L      = $0C             ; note 1: 100 Hz
000810  1               MARCH_FREQ1_H      = $01
000810  1               MARCH_FREQ2_L      = $D7             ; note 2:  80 Hz
000810  1               MARCH_FREQ2_H      = $00
000810  1               MARCH_FREQ3_L      = $0C             ; note 3: 100 Hz
000810  1               MARCH_FREQ3_H      = $01
000810  1               
000810  1               ; VERA PSG voice 3 — UFO drone (base addr $1F9C0 + 3*4 = $1F9CC)
000810  1               ; PSG byte layout: 0=FREQ_L, 1=FREQ_H, 2=volume([7]=R,[6]=L,[5:0]=vol 0-63), 3=waveform([7:6])
000810  1               ; Waveform codes: 00=pulse, 01=sawtooth, 10=triangle, 11=noise
000810  1               ; freq_hz ≈ freq_reg * 25000000 / (512 * 131072)  →  freq_reg ≈ freq_hz * 2.684
000810  1               VRAM_PSG_VOICE3    = VRAM_psg + 12   ; $1F9CC — voice 3 registers
000810  1               PSG_VOL_FULL       = $FF             ; R enable + L enable + volume 63
000810  1               PSG_WAVE_SAW       = %01000000       ; sawtooth waveform (bits 7:6 = 01)
000810  1               UFO_DRONE_FREQ1    = 1074            ; ≈400 Hz  ($0432)
000810  1               UFO_DRONE_FREQ2    = 1611            ; ≈600 Hz  ($064B)
000810  1               
000810  1               ; Shields
000810  1               SHIELD_Y           = 352        ; VERA Y coordinate for all 4 shields (176 display pixels)
000810  1               SHIELD_SPR_BASE    = $1FE10     ; sprite slot 66 attr ($1FC00 + 66*8); slots 8-65 in use
000810  1               VRAM_SHIELD_FULL   = $00500     ; 512-byte 32x32 4bpp tile: intact
000810  1               VRAM_SHIELD_DMG1   = $00700     ; 12% damaged
000810  1               VRAM_SHIELD_DMG2   = $00900     ; 25% damaged
000810  1               VRAM_SHIELD_DMG3   = $00B00     ; 37% damaged
000810  1               VRAM_SHIELD_DMG4   = $00D00     ; 50% damaged
000810  1               VRAM_SHIELD_DMG5   = $00F00     ; 62% damaged
000810  1               VRAM_SHIELD_DMG6   = $01100     ; 75% damaged
000810  1               VRAM_SHIELD_DMG7   = $01300     ; nearly destroyed
000810  1               
000810  1               ; Player bullet
000810  1               BULLET_SPRITE_ATTR = $1FC10     ; sprite 2 attribute base (player bullet)
000810  1               VRAM_BULLET     = $00400        ; player bullet pixel data (32 bytes, 8x8 4bpp)
000810  1               BULLET_SPEED    = 12            ; VERA pixels per frame upward (= 6 game pixels)
000810  1               BULLET_Y_INIT   = PLAYER_Y - 8 ; bullet starts just above player ship top
000810  1               
000810  1               ; Invader grid geometry (VERA 640x480 coordinate space)
000810  1               INV_GRID_X_INIT   = 112         ; left-column X at start (centered: (640 - 10*40 - 16) / 2 = 112)
000810  1               INV_GRID_Y_BASE   = 80          ; top-row Y, fixed base (drops added via inv_offset_y)
000810  1               INV_SPACING_X     = 40          ; VERA pixels between invader column origins
000810  1               INV_SPACING_Y     = 48          ; VERA pixels between invader row origins
000810  1               INV_STEP_X        = 4           ; VERA pixels per march step
000810  1               INV_DROP_Y        = 16          ; VERA pixels per grid drop
000810  1               INV_MOVE_SPEED_INIT = 50        ; frames between march steps (initial)
000810  1               INV_COUNT_INIT    = 55
000810  1               INV_MOVE_SPEED_MIN = 5           ; minimum frames per march step
000810  1               
000810  1               ; Grid boundary: when grid_x reaches these values, reverse and drop
000810  1               ; Rightmost invader base X = grid_x + 10*INV_SPACING_X (=400). Right wall = 624 (640-16px).
000810  1               ; So right limit = 624 - 400 - 16 = 208
000810  1               INV_X_RIGHT_LIM   = 208
000810  1               INV_X_LEFT_LIM    = 16          ; leftmost sprite at x=grid_x must stay >= 16
000810  1               
000810  1               ; VRAM addresses for invader sprite pixel data (128 bytes each, 16x16 4bpp)
000810  1               VRAM_INV_A_F0   = $00100        ; Type A (crab,   bottom rows 3-4), frame 0
000810  1               VRAM_INV_A_F1   = $00180        ; Type A frame 1
000810  1               VRAM_INV_B_F0   = $00200        ; Type B (octopus, middle rows 1-2), frame 0
000810  1               VRAM_INV_B_F1   = $00280        ; Type B frame 1
000810  1               VRAM_INV_C_F0   = $00300        ; Type C (squid,   top row 0), frame 0
000810  1               VRAM_INV_C_F1   = $00380        ; Type C frame 1
000810  1               
000810  1               ; Sprite addr[12:5] byte values for each type/frame (= VRAM_addr >> 5)
000810  1               ;   VRAM $00100>>5=$08  $00180>>5=$0C  $00200>>5=$10  $00280>>5=$14  $00300>>5=$18  $00380>>5=$1C
000810  1               INV_ATTR_BASE   = $1FC58        ; sprite slot 11 = first invader ($1FC00 + 11*8)
000810  1               INV_SPRITE_SLOT = 11            ; first invader sprite slot index
000810  1               
000810  1               ;******************************************************************
000810  1               ; start — main program entry point
000810  1               ;******************************************************************
000810  1               start:
000810  1  78              sei                           ; disable interrupts during init
000811  1               
000811  1                  ; Switch to 40-column text mode (mode 0)
000811  1                  ; Carry clear = SET mode (carry set = READ mode)
000811  1  18              clc
000812  1  A9 00           lda #$00
000814  1  20 5F FF        jsr SCREEN_MODE
000817  1               
000817  1                  ; Seed PRNG with hardware entropy
000817  1  20 CF FE        jsr ENTROPY_GET
00081A  1  85 rr           sta rand_seed_lo
00081C  1  86 rr           stx rand_seed_hi
00081E  1               
00081E  1                  ; Enable sprites in VERA display controller
00081E  1  9C 25 9F        stz VERA_ctrl                 ; DCSEL=0, ADDRSEL=0
000821  1  AD 29 9F        lda VERA_dc_video
000824  1  09 40           ora #VERA_SPRITE_EN
000826  1  8D 29 9F        sta VERA_dc_video
000829  1               
000829  1               
000829  1                  ; Clear game variables
000829  1  64 rr           stz key_last
00082B  1  64 rr           stz key_flags
00082D  1  64 rr           stz frame_count
00082F  1  64 rr           stz bullet_active
000831  1  64 rr           stz score_lo
000833  1  64 rr           stz score_mid
000835  1  64 rr           stz score_hi
000837  1  64 rr           stz hi_score_lo
000839  1  64 rr           stz hi_score_mid
00083B  1  64 rr           stz hi_score_hi
00083D  1  64 rr           stz ufo_active
00083F  1  A9 58           lda #<UFO_TIMER_INIT
000841  1  85 rr           sta ufo_timer_lo
000843  1  A9 02           lda #>UFO_TIMER_INIT
000845  1  85 rr           sta ufo_timer_hi
000847  1  64 rr           stz shot_count
000849  1  64 rr           stz march_beat
00084B  1  64 rr           stz march_snd_timer
00084D  1  A9 01           lda #1
00084F  1  85 rr           sta wave
000851  1  A9 32           lda #INV_MOVE_SPEED_INIT
000853  1  85 rr           sta wave_init_speed
000855  1               
000855  1                  ; Set initial player position before sprite init reads it
000855  1  20 82 09        jsr init_player
000858  1               
000858  1  58              cli                           ; re-enable interrupts
000859  1               
000859  1                  ; Switch to Commodore uppercase/graphics charset: $41-$5A = A-Z
000859  1                  ; Must be called AFTER SCREEN_MODE (which resets to lowercase by default)
000859  1  A9 01           lda #CHARSET_UPPER
00085B  1  20 62 FF        jsr SCREEN_SET_CHARSET
00085E  1               
00085E  1                  ; Clear screen and set text color
00085E  1  A9 05           lda #PETSCII_WHITE
000860  1  20 D2 FF        jsr CHROUT
000863  1  A9 93           lda #PETSCII_CLR
000865  1  20 D2 FF        jsr CHROUT
000868  1               
000868  1                  ; Upload sprite pixel data and configure sprite 1 attributes
000868  1  20 91 09        jsr init_sprites
00086B  1               
00086B  1                  ; Upload invader sprite data, set palette, init grid state, place sprites
00086B  1  20 90 0B        jsr init_invaders
00086E  1  20 69 15        jsr hide_all_inv_sprites     ; hide all 55 during title screen
000871  1               
000871  1  20 12 14        jsr draw_title_screen
000874  1               
000874  1               ;------------------------------------------------------------------
000874  1               ; title_loop — wait for SPACE; blink "PRESS SPACE TO START"
000874  1               ;------------------------------------------------------------------
000874  1               title_loop:
000874  1  20 35 09        jsr wait_vsync
000877  1  E6 rr           inc frame_count
000879  1  20 37 09        jsr update_input
00087C  1               
00087C  1  A5 rr           lda key_last
00087E  1  C9 03           cmp #KEY_RUN_STOP
000880  1  D0 03           bne @tl_no_exit
000882  1  4C 2D 09        jmp exit_game
000885  1               @tl_no_exit:
000885  1               
000885  1  A5 rr           lda key_flags
000887  1  29 04           and #KEY_FIRE
000889  1  D0 33           bne start_game
00088B  1               
00088B  1                  ; blink using frame_count bit 5 (~2 Hz)
00088B  1  A5 rr           lda frame_count
00088D  1  29 20           and #$20
00088F  1  D0 15           bne @tl_on
000891  1               @tl_off:
000891  1  A9 11           lda #17
000893  1  A0 0A           ldy #10
000895  1  18              clc
000896  1  20 F0 FF        jsr PLOT
000899  1  A2 14           ldx #20                      ; erase 20 chars of "PRESS SPACE TO START"
00089B  1  A9 20        @tl_erase: lda #' '
00089D  1  20 D2 FF        jsr CHROUT
0008A0  1  CA              dex
0008A1  1  D0 F8           bne @tl_erase
0008A3  1  4C 74 08        jmp title_loop
0008A6  1               @tl_on:
0008A6  1  A9 11           lda #17
0008A8  1  A0 0A           ldy #10
0008AA  1  18              clc
0008AB  1  20 F0 FF        jsr PLOT
0008AE  1  A2 00           ldx #0
0008B0  1  BD 02 1C     @tl_print: lda str_press_space, x
0008B3  1  F0 06           beq @tl_print_done
0008B5  1  20 D2 FF        jsr CHROUT
0008B8  1  E8              inx
0008B9  1  80 F5           bra @tl_print
0008BB  1               @tl_print_done:
0008BB  1  4C 74 08        jmp title_loop
0008BE  1               
0008BE  1               start_game:
0008BE  1  20 C7 0C        jsr update_invader_sprites   ; re-enable all 55 invaders at grid positions
0008C1  1  20 86 15        jsr init_shields             ; upload shield tiles, init damage counters, place sprites
0008C4  1  A9 93           lda #PETSCII_CLR
0008C6  1  20 D2 FF        jsr CHROUT                   ; clear title text, leave sprites visible
0008C9  1  20 E7 13        jsr draw_score_labels        ; paint "SCORE" / "HI-SCORE" headings
0008CC  1               
0008CC  1               ;******************************************************************
0008CC  1               ; main_loop — one iteration per video frame (60 Hz)
0008CC  1               ;******************************************************************
0008CC  1               main_loop:
0008CC  1  20 35 09        jsr wait_vsync
0008CF  1               
0008CF  1  E6 rr           inc frame_count
0008D1  1               
0008D1  1  20 37 09        jsr update_input              ; fills key_flags (joystick) + key_last (GETIN)
0008D4  1               
0008D4  1  A5 rr           lda key_last
0008D6  1  C9 03           cmp #KEY_RUN_STOP
0008D8  1  F0 53           beq exit_game
0008DA  1               
0008DA  1                  ; --- invincibility timer ---
0008DA  1  A5 rr           lda inv_hit_timer
0008DC  1  F0 02           beq @no_inv_dec
0008DE  1  C6 rr           dec inv_hit_timer
0008E0  1               @no_inv_dec:
0008E0  1               
0008E0  1  20 7D 0D        jsr move_player               ; apply movement, clamp to boundaries
0008E3  1  20 CC 0D        jsr update_player_sprite      ; write new X to VERA sprite 1
0008E6  1               
0008E6  1                  ; --- fire player bullet (SPACE pressed and bullet not already active) ---
0008E6  1  A5 rr           lda key_flags
0008E8  1  29 04           and #KEY_FIRE
0008EA  1  F0 07           beq @skip_fire
0008EC  1  A5 rr           lda bullet_active
0008EE  1  D0 03           bne @skip_fire
0008F0  1  20 0F 0E        jsr fire_bullet
0008F3  1               @skip_fire:
0008F3  1               
0008F3  1                  ; --- move bullet if active ---
0008F3  1  A5 rr           lda bullet_active
0008F5  1  F0 03           beq @skip_bullet_move
0008F7  1  20 2E 0E        jsr move_bullet
0008FA  1               @skip_bullet_move:
0008FA  1               
0008FA  1                  ; --- check player bullet vs invader collision ---
0008FA  1  20 7F 0E        jsr check_bullet_invader
0008FD  1               
0008FD  1                  ; --- check player bullet vs shield collision ---
0008FD  1  20 12 18        jsr check_bullet_shields
000900  1               
000900  1                  ; --- explosion timer ---
000900  1  20 CE 0F        jsr update_explosion
000903  1               
000903  1                  ; --- invader bullets: move, spawn, boundary check ---
000903  1  20 FD 0F        jsr update_inv_bullets
000906  1               
000906  1                  ; --- invader bullet vs player collision ---
000906  1  20 0B 11        jsr check_inv_bullet_player
000909  1               
000909  1                  ; --- invader bullet vs shield collision ---
000909  1  20 84 18        jsr check_invbullet_shields
00090C  1               
00090C  1                  ; --- UFO spawn/move and player bullet collision ---
00090C  1  20 25 19        jsr update_ufo
00090F  1  20 BE 19        jsr check_bullet_ufo
000912  1               
000912  1                  ; --- Invader march timer ---
000912  1  C6 rr           dec inv_move_timer
000914  1  D0 07           bne @skip_inv_step
000916  1  20 5F 0C        jsr step_invaders             ; move grid, check bounds, update sprites
000919  1  A5 rr           lda inv_move_speed
00091B  1  85 rr           sta inv_move_timer
00091D  1               @skip_inv_step:
00091D  1               
00091D  1                  ; --- check wave clear (all 55 invaders dead) ---
00091D  1  A5 rr           lda inv_count
00091F  1  D0 03           bne @no_wave_clear
000921  1  4C FC 12        jmp wave_clear_screen
000924  1               @no_wave_clear:
000924  1               
000924  1  20 F5 1A        jsr snd_tick_march            ; silence march note when timer expires
000927  1  20 2F 1B        jsr update_hud                ; refresh text readouts
00092A  1               
00092A  1  4C CC 08        jmp main_loop
00092D  1               
00092D  1               ;------------------------------------------------------------------
00092D  1               exit_game:
00092D  1  A9 93           lda #PETSCII_CLR
00092F  1  20 D2 FF        jsr CHROUT
000932  1  4C 47 FF        jmp ENTER_BASIC
000935  1               
000935  1               ;******************************************************************
000935  1               ; wait_vsync — busy-poll VERA_isr until VSYNC, then clear flag
000935  1               ;******************************************************************
000935  1               wait_vsync:
000935  1                  ; WAI sleeps the CPU until any IRQ fires.  The KERNAL's VSYNC IRQ
000935  1                  ; handler (60 Hz) wakes us up and has already cleared VERA_isr bit 0
000935  1                  ; by the time execution returns here, so polling VERA_isr would loop
000935  1                  ; forever.  Just return — one WAI ≈ one frame.
000935  1  CB              wai
000936  1  60              rts
000937  1               
000937  1               ;******************************************************************
000937  1               ; update_input — joystick + GETIN keyboard input each frame
000937  1               ;
000937  1               ;   key_flags bits set this frame:
000937  1               ;     KEY_LEFT  — left arrow held
000937  1               ;     KEY_RIGHT — right arrow held
000937  1               ;     KEY_FIRE  — space bar pressed
000937  1               ;   key_last   — raw PETSCII from GETIN (RUN/STOP etc.)
000937  1               ;
000937  1               ;   JOYSTICK_GET(0) = keyboard-as-joystick; gives smooth held-key
000937  1               ;   movement with no repeat delay.  GETIN handles space and RUN/STOP.
000937  1               ;******************************************************************
000937  1               update_input:
000937  1  64 rr           stz key_flags
000939  1  64 rr           stz key_last
00093B  1               
00093B  1                  ; --- joystick 0 = keyboard d-pad (active low: 0 = pressed) ---
00093B  1                  ; Byte returned: {B,Y,Sel,Sta,Up,Dn,Left,Right} bits 7–0
00093B  1  A9 00           lda #0
00093D  1  20 56 FF        jsr JOYSTICK_GET
000940  1  48              pha                           ; save — AND destroys .A
000941  1               
000941  1  29 01           and #JOY_RIGHT                ; bit 0: right arrow
000943  1  D0 06           bne @not_right
000945  1  A5 rr           lda key_flags
000947  1  09 02           ora #KEY_RIGHT
000949  1  85 rr           sta key_flags
00094B  1               @not_right:
00094B  1  68              pla
00094C  1  29 02           and #JOY_LEFT                 ; bit 1: left arrow
00094E  1  D0 06           bne @not_left
000950  1  A5 rr           lda key_flags
000952  1  09 01           ora #KEY_LEFT
000954  1  85 rr           sta key_flags
000956  1               @not_left:
000956  1               
000956  1                  ; --- GETIN — discrete events: fire, RUN/STOP, arrow fallback ---
000956  1               @getin_drain:
000956  1  20 E4 FF        jsr GETIN
000959  1  F0 26           beq @getin_done               ; buffer empty
00095B  1  85 rr           sta key_last
00095D  1  C9 9D           cmp #$9D                      ; cursor left (PETSCII)
00095F  1  D0 08           bne @chk_right_getin
000961  1  A5 rr           lda key_flags
000963  1  09 01           ora #KEY_LEFT
000965  1  85 rr           sta key_flags
000967  1  80 ED           bra @getin_drain
000969  1               @chk_right_getin:
000969  1  C9 1D           cmp #$1D                      ; cursor right (PETSCII)
00096B  1  D0 08           bne @chk_fire_getin
00096D  1  A5 rr           lda key_flags
00096F  1  09 02           ora #KEY_RIGHT
000971  1  85 rr           sta key_flags
000973  1  80 E1           bra @getin_drain
000975  1               @chk_fire_getin:
000975  1  C9 20           cmp #$20                      ; space = fire
000977  1  D0 DD           bne @getin_drain
000979  1  A5 rr           lda key_flags
00097B  1  09 04           ora #KEY_FIRE
00097D  1  85 rr           sta key_flags
00097F  1  80 D5           bra @getin_drain
000981  1               @getin_done:
000981  1  60              rts
000982  1               
000982  1               ;******************************************************************
000982  1               ; init_player — set player_x to starting position
000982  1               ;******************************************************************
000982  1               init_player:
000982  1  A9 38           lda #<PLAYER_X_INIT
000984  1  85 rr           sta player_x_lo
000986  1  A9 01           lda #>PLAYER_X_INIT
000988  1  85 rr           sta player_x_hi
00098A  1  A9 03           lda #LIVES_INIT
00098C  1  85 rr           sta lives
00098E  1  64 rr           stz inv_hit_timer
000990  1  60              rts
000991  1               
000991  1               ;******************************************************************
000991  1               ; init_sprites — upload pixel data + write sprite 1 attributes
000991  1               ;
000991  1               ;   Sprite 0 ($1FC00) is reserved by the KERNAL mouse cursor —
000991  1               ;   we disable it and keep clear of $1FC00.
000991  1               ;
000991  1               ;   Sprite 1 ($1FC08) = player ship
000991  1               ;   Pixel data at VRAM $00080 (128 bytes, 16x16 4bpp)
000991  1               ;   Address encoding:  addr[12:5] = $00080>>5 = $04  → byte 0 = $04
000991  1               ;                      4bpp, addr[16:13] = 0          → byte 1 = $00
000991  1               ;******************************************************************
000991  1               init_sprites:
000991  1  9C 25 9F        stz VERA_ctrl
000994  1               
000994  1                  ; --- set palette entries 1-4 ---
000994  1                  ; VERA palette entry N is 2 bytes at VRAM_palette + N*2
000994  1                  ; Byte 0: [7:4]=Green [3:0]=Blue   Byte 1: [3:0]=Red (bits 7-4 unused)
000994  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_palette + 2), 1   ; entry 1 (player white); stride=1 auto-advances
000998  1  9F A9 FA 8D  
00099C  1  21 9F A9 02  
0009A3  1  A9 FF           lda #$FF                               ; G=$F, B=$F
0009A5  1  8D 23 9F        sta VERA_data0
0009A8  1  A9 0F           lda #$0F                               ; R=$F  → white
0009AA  1  8D 23 9F        sta VERA_data0
0009AD  1                  ; entry 2 = cyan  (R=0, G=$F, B=$F)
0009AD  1  A9 FF           lda #$FF                               ; G=$F, B=$F
0009AF  1  8D 23 9F        sta VERA_data0
0009B2  1  A9 00           lda #$00                               ; R=$0
0009B4  1  8D 23 9F        sta VERA_data0
0009B7  1                  ; entry 3 = magenta (R=$F, G=0, B=$F)
0009B7  1  A9 0F           lda #$0F                               ; G=$0, B=$F
0009B9  1  8D 23 9F        sta VERA_data0
0009BC  1  A9 0F           lda #$0F                               ; R=$F
0009BE  1  8D 23 9F        sta VERA_data0
0009C1  1                  ; entry 4 = green  (R=0, G=$F, B=0)
0009C1  1  A9 F0           lda #$F0                               ; G=$F, B=$0
0009C3  1  8D 23 9F        sta VERA_data0
0009C6  1  A9 00           lda #$00                               ; R=$0
0009C8  1  8D 23 9F        sta VERA_data0
0009CB  1                  ; entry 5 = red    (R=$F, G=0, B=0)
0009CB  1  A9 00           lda #$00                               ; G=$0, B=$0
0009CD  1  8D 23 9F        sta VERA_data0
0009D0  1  A9 0F           lda #$0F                               ; R=$F
0009D2  1  8D 23 9F        sta VERA_data0
0009D5  1                  ; --- disable sprite 0 (KERNAL mouse cursor) ---
0009D5  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_sprattr + 6), 1   ; sprite 0 byte 6 = z-depth
0009D9  1  9F A9 FC 8D  
0009DD  1  21 9F A9 06  
0009E4  1  A9 00           lda #$00                               ; z-depth=0 → disabled
0009E6  1  8D 23 9F        sta VERA_data0
0009E9  1               
0009E9  1                  ; --- upload player sprite pixel data to VRAM $00080 ---
0009E9  1  A9 10 8D 22     VERA_SET_ADDR $00080, 1
0009ED  1  9F A9 00 8D  
0009F1  1  21 9F A9 80  
0009F8  1  A2 00           ldx #0
0009FA  1               @upload:
0009FA  1  BD 89 1C        lda player_spr_data,x
0009FD  1  8D 23 9F        sta VERA_data0
000A00  1  E8              inx
000A01  1  E0 80           cpx #128
000A03  1  D0 F5           bne @upload
000A05  1               
000A05  1                  ; --- write sprite 1 attribute bytes ---
000A05  1  A9 11 8D 22     VERA_SET_ADDR SPRITE1_ATTR, 1
000A09  1  9F A9 FC 8D  
000A0D  1  21 9F A9 08  
000A14  1  A9 04           lda #$04
000A16  1  8D 23 9F        sta VERA_data0               ; byte 0: addr[12:5] = $00080>>5 = $04
000A19  1  A9 00           lda #$00
000A1B  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, addr[16:13] = 0
000A1E  1  A5 rr           lda player_x_lo
000A20  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000A23  1  A5 rr           lda player_x_hi
000A25  1  29 03           and #$03
000A27  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000A2A  1  A9 A4           lda #<PLAYER_Y
000A2C  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000A2F  1  A9 01           lda #>PLAYER_Y
000A31  1  29 03           and #$03
000A33  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000A36  1  A9 0C           lda #SPR_Z_FRONT
000A38  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3, no collision, no flip
000A3B  1  A9 50           lda #SPR_16x16_PAL0
000A3D  1  8D 23 9F        sta VERA_data0               ; byte 7: palette 0, 16x16
000A40  1               
000A40  1                  ; --- upload player bullet pixel data to VRAM $00400 ---
000A40  1  A9 10 8D 22     VERA_SET_ADDR VRAM_BULLET, 1
000A44  1  9F A9 04 8D  
000A48  1  21 9F A9 00  
000A4F  1  A2 00           ldx #0
000A51  1               @up_bullet:
000A51  1  BD 09 1D        lda bullet_spr_data,x
000A54  1  8D 23 9F        sta VERA_data0
000A57  1  E8              inx
000A58  1  E0 20           cpx #32
000A5A  1  D0 F5           bne @up_bullet
000A5C  1               
000A5C  1                  ; --- write sprite 2 attributes (initially disabled, z-depth=0) ---
000A5C  1  A9 11 8D 22     VERA_SET_ADDR BULLET_SPRITE_ATTR, 1
000A60  1  9F A9 FC 8D  
000A64  1  21 9F A9 10  
000A6B  1  A9 20           lda #$20                     ; byte 0: addr[12:5] = $00400>>5 = $20
000A6D  1  8D 23 9F        sta VERA_data0
000A70  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000A72  1  8D 23 9F        sta VERA_data0
000A75  1  A9 00           lda #$00                     ; byte 2: X lo (arbitrary; sprite disabled)
000A77  1  8D 23 9F        sta VERA_data0
000A7A  1  A9 00           lda #$00                     ; byte 3: X hi
000A7C  1  8D 23 9F        sta VERA_data0
000A7F  1  A9 00           lda #$00                     ; byte 4: Y lo
000A81  1  8D 23 9F        sta VERA_data0
000A84  1  A9 00           lda #$00                     ; byte 5: Y hi
000A86  1  8D 23 9F        sta VERA_data0
000A89  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000A8B  1  8D 23 9F        sta VERA_data0
000A8E  1  A9 00           lda #SPR_8x8_PAL0            ; byte 7: 8x8, palette 0
000A90  1  8D 23 9F        sta VERA_data0
000A93  1               
000A93  1                  ; --- upload explosion pixel data to VRAM $00440 ---
000A93  1  A9 10 8D 22     VERA_SET_ADDR VRAM_EXPLOSION, 1
000A97  1  9F A9 04 8D  
000A9B  1  21 9F A9 40  
000AA2  1  A2 00           ldx #0
000AA4  1               @up_exp:
000AA4  1  BD E3 1D        lda explosion_pixels,x
000AA7  1  8D 23 9F        sta VERA_data0
000AAA  1  E8              inx
000AAB  1  E0 80           cpx #128
000AAD  1  D0 F5           bne @up_exp
000AAF  1               
000AAF  1                  ; --- write sprite 4 attributes (initially disabled) ---
000AAF  1                  ; addr[12:5] = VRAM_EXPLOSION>>5 = $00440>>5 = $22
000AAF  1  A9 11 8D 22     VERA_SET_ADDR EXPLODE_SPRITE_ATTR, 1
000AB3  1  9F A9 FC 8D  
000AB7  1  21 9F A9 20  
000ABE  1  A9 22           lda #$22                     ; byte 0: addr[12:5]
000AC0  1  8D 23 9F        sta VERA_data0
000AC3  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000AC5  1  8D 23 9F        sta VERA_data0
000AC8  1  A9 00           lda #$00                     ; byte 2: X lo (placeholder)
000ACA  1  8D 23 9F        sta VERA_data0
000ACD  1  A9 00           lda #$00                     ; byte 3: X hi
000ACF  1  8D 23 9F        sta VERA_data0
000AD2  1  A9 00           lda #$00                     ; byte 4: Y lo (placeholder)
000AD4  1  8D 23 9F        sta VERA_data0
000AD7  1  A9 00           lda #$00                     ; byte 5: Y hi
000AD9  1  8D 23 9F        sta VERA_data0
000ADC  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000ADE  1  8D 23 9F        sta VERA_data0
000AE1  1  A9 50           lda #SPR_16x16_PAL0          ; byte 7: 16x16, palette 0
000AE3  1  8D 23 9F        sta VERA_data0
000AE6  1               
000AE6  1  64 rr           stz exp_timer
000AE8  1               
000AE8  1                  ; --- upload invader bullet pixel data to VRAM $00420 ---
000AE8  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_BULLET, 1
000AEC  1  9F A9 04 8D  
000AF0  1  21 9F A9 20  
000AF7  1  A2 00           ldx #0
000AF9  1               @up_ibul:
000AF9  1  BD C3 1D        lda inv_bullet_spr_data,x
000AFC  1  8D 23 9F        sta VERA_data0
000AFF  1  E8              inx
000B00  1  E0 20           cpx #32
000B02  1  D0 F5           bne @up_ibul
000B04  1               
000B04  1                  ; --- init 3 invader bullet sprites (slots 5-7, base $1FC28), all disabled ---
000B04  1                  ; addr[12:5] = VRAM_INV_BULLET>>5 = $00420>>5 = $21
000B04  1  A9 11 8D 22     VERA_SET_ADDR INV_BULLET_SPR_BASE, 1
000B08  1  9F A9 FC 8D  
000B0C  1  21 9F A9 28  
000B13  1  A2 03           ldx #3                       ; 3 sprites
000B15  1               @init_ibspr:
000B15  1  A9 21           lda #$21                     ; byte 0: addr[12:5] = $21
000B17  1  8D 23 9F        sta VERA_data0
000B1A  1  A9 00           lda #$00
000B1C  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, bank 0
000B1F  1  8D 23 9F        sta VERA_data0               ; byte 2: X lo
000B22  1  8D 23 9F        sta VERA_data0               ; byte 3: X hi
000B25  1  8D 23 9F        sta VERA_data0               ; byte 4: Y lo
000B28  1  8D 23 9F        sta VERA_data0               ; byte 5: Y hi
000B2B  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=0 → disabled
000B2E  1  8D 23 9F        sta VERA_data0               ; byte 7: 8x8, palette 0
000B31  1  CA              dex
000B32  1  D0 E1           bne @init_ibspr
000B34  1               
000B34  1                  ; --- clear invader bullet state ---
000B34  1  64 rr           stz ibul_active+0
000B36  1  64 rr           stz ibul_active+1
000B38  1  64 rr           stz ibul_active+2
000B3A  1  A9 5A           lda #INV_FIRE_TIMER_INIT
000B3C  1  85 rr           sta inv_fire_timer
000B3E  1               
000B3E  1                  ; --- upload UFO pixel data → VRAM $01500 ---
000B3E  1  A9 10 8D 22     VERA_SET_ADDR VRAM_UFO, 1
000B42  1  9F A9 15 8D  
000B46  1  21 9F A9 00  
000B4D  1  A2 80           ldx #128
000B4F  1  BD E3 1D     @up_ufo: lda ufo_spr_data-128,x
000B52  1  8D 23 9F        sta VERA_data0
000B55  1  E8              inx
000B56  1  D0 F7           bne @up_ufo
000B58  1               
000B58  1                  ; --- write sprite 3 (UFO) attributes (initially disabled) ---
000B58  1                  ; addr[12:5] = VRAM_UFO>>5 = $01500>>5 = $A8
000B58  1  A9 11 8D 22     VERA_SET_ADDR UFO_SPRITE_ATTR, 1
000B5C  1  9F A9 FC 8D  
000B60  1  21 9F A9 18  
000B67  1  A9 A8           lda #$A8                     ; byte 0: addr[12:5]
000B69  1  8D 23 9F        sta VERA_data0
000B6C  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000B6E  1  8D 23 9F        sta VERA_data0
000B71  1  A9 00           lda #$00                     ; byte 2: X lo
000B73  1  8D 23 9F        sta VERA_data0
000B76  1  A9 00           lda #$00                     ; byte 3: X hi
000B78  1  8D 23 9F        sta VERA_data0
000B7B  1  A9 20           lda #<UFO_Y                  ; byte 4: Y lo
000B7D  1  8D 23 9F        sta VERA_data0
000B80  1  A9 00           lda #>UFO_Y                  ; byte 5: Y hi
000B82  1  8D 23 9F        sta VERA_data0
000B85  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000B87  1  8D 23 9F        sta VERA_data0
000B8A  1  A9 50           lda #SPR_16x16_PAL0          ; byte 7: 16x16, palette 0
000B8C  1  8D 23 9F        sta VERA_data0
000B8F  1               
000B8F  1  60              rts
000B90  1               
000B90  1               ;******************************************************************
000B90  1               ; init_invaders — upload invader pixel data, init grid state, place sprites
000B90  1               ;******************************************************************
000B90  1               init_invaders:
000B90  1  9C 25 9F        stz VERA_ctrl
000B93  1               
000B93  1                  ; --- upload Type A frame 0 → VRAM $00100 ---
000B93  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F0, 1
000B97  1  9F A9 01 8D  
000B9B  1  21 9F A9 00  
000BA2  1  A2 80           ldx #128
000BA4  1  BD 63 1E     @up_af0: lda inv_a_spr_f0-128,x
000BA7  1  8D 23 9F        sta VERA_data0
000BAA  1  E8              inx
000BAB  1  D0 F7           bne @up_af0
000BAD  1               
000BAD  1                  ; --- upload Type A frame 1 → VRAM $00180 ---
000BAD  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F1, 1
000BB1  1  9F A9 01 8D  
000BB5  1  21 9F A9 80  
000BBC  1  A2 80           ldx #128
000BBE  1  BD E3 1E     @up_af1: lda inv_a_spr_f1-128,x
000BC1  1  8D 23 9F        sta VERA_data0
000BC4  1  E8              inx
000BC5  1  D0 F7           bne @up_af1
000BC7  1               
000BC7  1                  ; --- upload Type B frame 0 → VRAM $00200 ---
000BC7  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F0, 1
000BCB  1  9F A9 02 8D  
000BCF  1  21 9F A9 00  
000BD6  1  A2 80           ldx #128
000BD8  1  BD 63 1F     @up_bf0: lda inv_b_spr_f0-128,x
000BDB  1  8D 23 9F        sta VERA_data0
000BDE  1  E8              inx
000BDF  1  D0 F7           bne @up_bf0
000BE1  1               
000BE1  1                  ; --- upload Type B frame 1 → VRAM $00280 ---
000BE1  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F1, 1
000BE5  1  9F A9 02 8D  
000BE9  1  21 9F A9 80  
000BF0  1  A2 80           ldx #128
000BF2  1  BD E3 1F     @up_bf1: lda inv_b_spr_f1-128,x
000BF5  1  8D 23 9F        sta VERA_data0
000BF8  1  E8              inx
000BF9  1  D0 F7           bne @up_bf1
000BFB  1               
000BFB  1                  ; --- upload Type C frame 0 → VRAM $00300 ---
000BFB  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F0, 1
000BFF  1  9F A9 03 8D  
000C03  1  21 9F A9 00  
000C0A  1  A2 80           ldx #128
000C0C  1  BD 63 20     @up_cf0: lda inv_c_spr_f0-128,x
000C0F  1  8D 23 9F        sta VERA_data0
000C12  1  E8              inx
000C13  1  D0 F7           bne @up_cf0
000C15  1               
000C15  1                  ; --- upload Type C frame 1 → VRAM $00380 ---
000C15  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F1, 1
000C19  1  9F A9 03 8D  
000C1D  1  21 9F A9 80  
000C24  1  A2 80           ldx #128
000C26  1  BD E3 20     @up_cf1: lda inv_c_spr_f1-128,x
000C29  1  8D 23 9F        sta VERA_data0
000C2C  1  E8              inx
000C2D  1  D0 F7           bne @up_cf1
000C2F  1               
000C2F  1                  ; --- initialize zero-page grid variables ---
000C2F  1  A9 70           lda #<INV_GRID_X_INIT
000C31  1  85 rr           sta inv_grid_x_lo
000C33  1  A9 00           lda #>INV_GRID_X_INIT
000C35  1  85 rr           sta inv_grid_x_hi
000C37  1  64 rr           stz inv_offset_y
000C39  1  64 rr           stz inv_direction
000C3B  1  64 rr           stz inv_anim_frame
000C3D  1  64 rr           stz inv_drop_flag
000C3F  1               
000C3F  1                  ; all 55 invaders alive: bytes 0-5 = $FF, byte 6 = $7F (55 bits)
000C3F  1  A9 FF           lda #$FF
000C41  1  85 rr           sta inv_alive+0
000C43  1  85 rr           sta inv_alive+1
000C45  1  85 rr           sta inv_alive+2
000C47  1  85 rr           sta inv_alive+3
000C49  1  85 rr           sta inv_alive+4
000C4B  1  85 rr           sta inv_alive+5
000C4D  1  A9 7F           lda #$7F
000C4F  1  85 rr           sta inv_alive+6
000C51  1               
000C51  1  A9 37           lda #INV_COUNT_INIT
000C53  1  85 rr           sta inv_count
000C55  1  A5 rr           lda wave_init_speed
000C57  1  85 rr           sta inv_move_speed
000C59  1  85 rr           sta inv_move_timer
000C5B  1               
000C5B  1                  ; --- write initial sprite attributes for all 55 invaders ---
000C5B  1  20 C7 0C        jsr update_invader_sprites
000C5E  1  60              rts
000C5F  1               
000C5F  1               ;******************************************************************
000C5F  1               ; step_invaders — one march step: move or drop grid, toggle anim frame
000C5F  1               ;   Called when inv_move_timer reaches 0.
000C5F  1               ;   Updates inv_grid_x / inv_offset_y, sets inv_drop_flag as needed,
000C5F  1               ;   then refreshes all VERA sprite positions.
000C5F  1               ;******************************************************************
000C5F  1               step_invaders:
000C5F  1                  ; toggle animation frame
000C5F  1  A5 rr           lda inv_anim_frame
000C61  1  49 01           eor #1
000C63  1  85 rr           sta inv_anim_frame
000C65  1               
000C65  1                  ; if drop flag is set: drop grid this step, skip march
000C65  1  A5 rr           lda inv_drop_flag
000C67  1  F0 0B           beq @do_march
000C69  1  64 rr           stz inv_drop_flag
000C6B  1  A5 rr           lda inv_offset_y
000C6D  1  18              clc
000C6E  1  69 10           adc #INV_DROP_Y
000C70  1  85 rr           sta inv_offset_y
000C72  1  80 4C           bra @sprites_done
000C74  1               
000C74  1               @do_march:
000C74  1  A5 rr           lda inv_direction
000C76  1  D0 25           bne @march_left
000C78  1               
000C78  1                  ; --- march right ---
000C78  1  A5 rr           lda inv_grid_x_lo
000C7A  1  18              clc
000C7B  1  69 04           adc #INV_STEP_X
000C7D  1  85 rr           sta inv_grid_x_lo
000C7F  1  90 02           bcc @chk_right
000C81  1  E6 rr           inc inv_grid_x_hi
000C83  1               @chk_right:
000C83  1                  ; hit right if grid_x > INV_X_RIGHT_LIM (208, fits in 1 byte, hi always 0)
000C83  1  A5 rr           lda inv_grid_x_hi
000C85  1  D0 06           bne @clamp_right          ; hi > 0 → definitely over limit
000C87  1  A5 rr           lda inv_grid_x_lo
000C89  1  C9 D1           cmp #INV_X_RIGHT_LIM + 1  ; C set if lo > limit
000C8B  1  90 33           bcc @sprites_done
000C8D  1               @clamp_right:
000C8D  1  A9 D0           lda #<INV_X_RIGHT_LIM
000C8F  1  85 rr           sta inv_grid_x_lo
000C91  1  A9 00           lda #>INV_X_RIGHT_LIM
000C93  1  85 rr           sta inv_grid_x_hi
000C95  1  A9 01           lda #1
000C97  1  85 rr           sta inv_direction
000C99  1  85 rr           sta inv_drop_flag
000C9B  1  80 23           bra @sprites_done
000C9D  1               
000C9D  1                  ; --- march left ---
000C9D  1               @march_left:
000C9D  1  A5 rr           lda inv_grid_x_lo
000C9F  1  38              sec
000CA0  1  E9 04           sbc #INV_STEP_X
000CA2  1  85 rr           sta inv_grid_x_lo
000CA4  1  B0 02           bcs @chk_left             ; no borrow
000CA6  1  C6 rr           dec inv_grid_x_hi
000CA8  1               @chk_left:
000CA8  1                  ; hit left if hi went negative OR lo < INV_X_LEFT_LIM
000CA8  1  A5 rr           lda inv_grid_x_hi
000CAA  1  30 06           bmi @clamp_left
000CAC  1  A5 rr           lda inv_grid_x_lo
000CAE  1  C9 10           cmp #INV_X_LEFT_LIM
000CB0  1  B0 0E           bcs @sprites_done         ; lo >= left limit → ok
000CB2  1               @clamp_left:
000CB2  1  A9 10           lda #<INV_X_LEFT_LIM
000CB4  1  85 rr           sta inv_grid_x_lo
000CB6  1  A9 00           lda #>INV_X_LEFT_LIM
000CB8  1  85 rr           sta inv_grid_x_hi
000CBA  1  64 rr           stz inv_direction
000CBC  1  A9 01           lda #1
000CBE  1  85 rr           sta inv_drop_flag
000CC0  1               
000CC0  1               @sprites_done:
000CC0  1  20 BF 1A        jsr snd_march_step
000CC3  1  20 C7 0C        jsr update_invader_sprites
000CC6  1  60              rts
000CC7  1               
000CC7  1               ;******************************************************************
000CC7  1               ; update_invader_sprites — write all 55 invader sprite attributes to VERA
000CC7  1               ;
000CC7  1               ;   VERA sprite slots 11-65 hold the 55 invaders.
000CC7  1               ;   Attributes base: $1FC58 ($1FC00 + 11*8).
000CC7  1               ;   With stride=1 the VERA address auto-increments, so we set it
000CC7  1               ;   once and write all 440 bytes sequentially.
000CC7  1               ;
000CC7  1               ;   Byte layout per sprite:
000CC7  1               ;     0: data addr[12:5]   (encodes VRAM pixel data address + frame)
000CC7  1               ;     1: $00               (4bpp, addr[16:13]=0)
000CC7  1               ;     2: X[7:0]
000CC7  1               ;     3: X[9:8]
000CC7  1               ;     4: Y[7:0]
000CC7  1               ;     5: Y[9:8]
000CC7  1               ;     6: z-depth/collision
000CC7  1               ;     7: palette / size
000CC7  1               ;
000CC7  1               ;   Invader index i = row*11 + col; alive bit i in inv_alive bitmap.
000CC7  1               ;   For Phase 3 all invaders are alive; alive check will be added Phase 4.
000CC7  1               ;******************************************************************
000CC7  1               update_invader_sprites:
000CC7  1  9C 25 9F        stz VERA_ctrl
000CCA  1  A9 11           lda #$11              ; stride=1, VRAM bank bit=1 (addr $1Fxxxx)
000CCC  1  8D 22 9F        sta VERA_addr_bank
000CCF  1  A9 FC           lda #$FC
000CD1  1  8D 21 9F        sta VERA_addr_high
000CD4  1  A9 58           lda #$58
000CD6  1  8D 20 9F        sta VERA_addr_low     ; VERA now at $1FC58, auto-increments by 1
000CD9  1               
000CD9  1                  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000CD9  1  A9 50           lda #<INV_GRID_Y_BASE
000CDB  1  18              clc
000CDC  1  65 rr           adc inv_offset_y
000CDE  1  85 rr           sta zp_y_base_lo
000CE0  1  A9 00           lda #>INV_GRID_Y_BASE
000CE2  1  69 00           adc #0
000CE4  1  85 rr           sta zp_y_base_hi
000CE6  1               
000CE6  1  64 rr           stz zp_row
000CE8  1               @row_loop:
000CE8  1                  ; compute row Y: zp_row_y = zp_y_base + row_y_offsets[row]
000CE8  1  A4 rr           ldy zp_row
000CEA  1  B9 49 1D        lda row_y_offsets,y
000CED  1  18              clc
000CEE  1  65 rr           adc zp_y_base_lo
000CF0  1  85 rr           sta zp_row_y_lo
000CF2  1  A9 00           lda #0
000CF4  1  65 rr           adc zp_y_base_hi
000CF6  1  85 rr           sta zp_row_y_hi
000CF8  1               
000CF8  1                  ; select addr byte0 based on row type and animation frame
000CF8  1  A4 rr           ldy zp_row
000CFA  1  A5 rr           lda inv_anim_frame
000CFC  1  F0 05           beq @use_f0
000CFE  1  B9 2E 1D        lda inv_addr_b0_f1,y
000D01  1  80 03           bra @got_b0
000D03  1               @use_f0:
000D03  1  B9 29 1D        lda inv_addr_b0_f0,y
000D06  1               @got_b0:
000D06  1  85 rr           sta zp_addr_b0
000D08  1               
000D08  1  20 14 0D        jsr update_invader_row
000D0B  1               
000D0B  1  E6 rr           inc zp_row
000D0D  1  A5 rr           lda zp_row
000D0F  1  C9 05           cmp #5
000D11  1  D0 D5           bne @row_loop
000D13  1               
000D13  1  60              rts
000D14  1               
000D14  1               ;******************************************************************
000D14  1               ; update_invader_row — write 11 sprite attribute blocks for one row
000D14  1               ;
000D14  1               ;   Inputs (ZP): zp_row, zp_addr_b0, zp_row_y_lo/hi, inv_grid_x_lo/hi
000D14  1               ;   VERA address register must already be set to the first sprite slot
000D14  1               ;   for this row on entry (maintained by the sequential write stream).
000D14  1               ;******************************************************************
000D14  1               update_invader_row:
000D14  1  64 rr           stz zp_col
000D16  1               @col_loop:
000D16  1                  ; --- determine z-depth from alive bitmap ---
000D16  1                  ; index = inv_row_base[row] + col; byte = index>>3; bit = index&7
000D16  1  A4 rr           ldy zp_row
000D18  1  B9 4E 1D        lda inv_row_base,y
000D1B  1  18              clc
000D1C  1  65 rr           adc zp_col
000D1E  1  A8              tay                   ; Y = invader index
000D1F  1  29 07           and #$07
000D21  1  AA              tax                   ; X = bit index
000D22  1  BD 53 1D        lda bit_masks,x
000D25  1  48              pha                   ; save bit mask
000D26  1  98              tya
000D27  1  4A              lsr
000D28  1  4A              lsr
000D29  1  4A              lsr
000D2A  1  A8              tay                   ; Y = byte index into inv_alive
000D2B  1  68              pla                   ; A = bit mask
000D2C  1  39 rr rr        and inv_alive,y
000D2F  1  F0 04           beq @zdepth_off
000D31  1  A9 0C           lda #SPR_Z_FRONT
000D33  1  80 02           bra @zdepth_done
000D35  1               @zdepth_off:
000D35  1  A9 00           lda #0
000D37  1               @zdepth_done:
000D37  1  85 rr           sta zp_scratch_lo     ; save z-depth before VERA stream starts
000D39  1               
000D39  1                  ; --- compute sprite X = inv_grid_x + col_x_offsets[col] ---
000D39  1  A4 rr           ldy zp_col
000D3B  1  B9 33 1D        lda col_x_lo,y
000D3E  1  18              clc
000D3F  1  65 rr           adc inv_grid_x_lo
000D41  1  85 rr           sta zp_x_lo
000D43  1  B9 3E 1D        lda col_x_hi,y
000D46  1  65 rr           adc inv_grid_x_hi
000D48  1  85 rr           sta zp_x_hi
000D4A  1               
000D4A  1                  ; --- write 8 attribute bytes (VERA auto-increments) ---
000D4A  1  A5 rr           lda zp_addr_b0
000D4C  1  8D 23 9F        sta VERA_data0        ; byte 0: data addr[12:5]
000D4F  1  9C 23 9F        stz VERA_data0        ; byte 1: 4bpp, addr[16:13]=0
000D52  1  A5 rr           lda zp_x_lo
000D54  1  8D 23 9F        sta VERA_data0        ; byte 2: X[7:0]
000D57  1  A5 rr           lda zp_x_hi
000D59  1  29 03           and #$03
000D5B  1  8D 23 9F        sta VERA_data0        ; byte 3: X[9:8]
000D5E  1  A5 rr           lda zp_row_y_lo
000D60  1  8D 23 9F        sta VERA_data0        ; byte 4: Y[7:0]
000D63  1  A5 rr           lda zp_row_y_hi
000D65  1  29 03           and #$03
000D67  1  8D 23 9F        sta VERA_data0        ; byte 5: Y[9:8]
000D6A  1  A5 rr           lda zp_scratch_lo
000D6C  1  8D 23 9F        sta VERA_data0        ; byte 6: z-depth (SPR_Z_FRONT if alive, 0 if dead)
000D6F  1  A9 50           lda #SPR_16x16_PAL0
000D71  1  8D 23 9F        sta VERA_data0        ; byte 7: 16x16, palette offset 0
000D74  1               
000D74  1  E6 rr           inc zp_col
000D76  1  A5 rr           lda zp_col
000D78  1  C9 0B           cmp #11
000D7A  1  D0 9A           bne @col_loop
000D7C  1               
000D7C  1  60              rts
000D7D  1               
000D7D  1               ;******************************************************************
000D7D  1               ; move_player — apply key_flags movement and clamp to screen edges
000D7D  1               ;******************************************************************
000D7D  1               move_player:
000D7D  1  A5 rr           lda key_flags
000D7F  1               
000D7F  1                  ; --- move left ---
000D7F  1  29 01           and #KEY_LEFT
000D81  1  F0 1F           beq @check_right
000D83  1  A5 rr           lda player_x_lo
000D85  1  38              sec
000D86  1  E9 04           sbc #PLAYER_SPEED
000D88  1  85 rr           sta player_x_lo
000D8A  1  B0 02           bcs @clamp_left              ; no borrow → hi unchanged
000D8C  1  C6 rr           dec player_x_hi
000D8E  1               @clamp_left:
000D8E  1                  ; Clamp: if hi went negative ($FF) or (hi=0 AND lo < min) → set to min
000D8E  1  A5 rr           lda player_x_hi
000D90  1  30 08           bmi @set_min                 ; $80–$FF = underflowed
000D92  1  D0 0E           bne @check_right             ; hi > 0 → still above minimum
000D94  1  A5 rr           lda player_x_lo
000D96  1  C9 08           cmp #PLAYER_X_MIN
000D98  1  B0 08           bcs @check_right             ; lo >= min → ok
000D9A  1               @set_min:
000D9A  1  A9 08           lda #<PLAYER_X_MIN
000D9C  1  85 rr           sta player_x_lo
000D9E  1  A9 00           lda #>PLAYER_X_MIN
000DA0  1  85 rr           sta player_x_hi
000DA2  1               
000DA2  1                  ; --- move right ---
000DA2  1               @check_right:
000DA2  1  A5 rr           lda key_flags
000DA4  1  29 02           and #KEY_RIGHT
000DA6  1  F0 23           beq @move_done
000DA8  1  A5 rr           lda player_x_lo
000DAA  1  18              clc
000DAB  1  69 04           adc #PLAYER_SPEED
000DAD  1  85 rr           sta player_x_lo
000DAF  1  90 02           bcc @clamp_right             ; no carry → hi unchanged
000DB1  1  E6 rr           inc player_x_hi
000DB3  1               @clamp_right:
000DB3  1                  ; Clamp: if hi > max_hi, OR (hi == max_hi AND lo > max_lo) → set to max
000DB3  1  A5 rr           lda player_x_hi
000DB5  1  C9 02           cmp #>PLAYER_X_MAX
000DB7  1  90 12           bcc @move_done               ; hi < max_hi → definitely ok
000DB9  1  D0 08           bne @set_max                 ; hi > max_hi → over limit
000DBB  1  A5 rr           lda player_x_lo
000DBD  1  C9 68           cmp #<PLAYER_X_MAX
000DBF  1  90 0A           bcc @move_done               ; lo < max_lo when hi == max_hi → ok
000DC1  1  F0 08           beq @move_done               ; lo == max_lo → exactly at max, ok
000DC3  1               @set_max:
000DC3  1  A9 68           lda #<PLAYER_X_MAX
000DC5  1  85 rr           sta player_x_lo
000DC7  1  A9 02           lda #>PLAYER_X_MAX
000DC9  1  85 rr           sta player_x_hi
000DCB  1               
000DCB  1               @move_done:
000DCB  1  60              rts
000DCC  1               
000DCC  1               ;******************************************************************
000DCC  1               ; update_player_sprite — write current X position to sprite 1 in VERA
000DCC  1               ;   Only X needs updating (Y is fixed)
000DCC  1               ;******************************************************************
000DCC  1               update_player_sprite:
000DCC  1  9C 25 9F        stz VERA_ctrl
000DCF  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 2), 1
000DD3  1  9F A9 FC 8D  
000DD7  1  21 9F A9 0A  
000DDE  1  A5 rr           lda player_x_lo
000DE0  1  8D 23 9F        sta VERA_data0               ; sprite byte 2: X[7:0]
000DE3  1  A5 rr           lda player_x_hi
000DE5  1  29 03           and #$03
000DE7  1  8D 23 9F        sta VERA_data0               ; sprite byte 3: X[9:8]
000DEA  1                  ; update z-depth based on inv_hit_timer:
000DEA  1                  ;   timer = 0        → show solid (not hit)
000DEA  1                  ;   timer = 61-120   → hidden solid (1-second respawn delay)
000DEA  1                  ;   timer = 1-60     → flashing (invincible, visible warning)
000DEA  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 6), 1
000DEE  1  9F A9 FC 8D  
000DF2  1  21 9F A9 0E  
000DF9  1  A5 rr           lda inv_hit_timer
000DFB  1  F0 08           beq @show                    ; timer=0 → show solid
000DFD  1  C9 3D           cmp #61
000DFF  1  B0 08           bcs @hide                    ; timer>=61 → first second: fully hidden
000E01  1  29 08           and #$08                     ; timer 1-60: bit 3 flips every 8 frames → ~4 Hz flash
000E03  1  D0 04           bne @hide
000E05  1               @show:
000E05  1  A9 0C           lda #SPR_Z_FRONT
000E07  1  80 02           bra @write_z
000E09  1               @hide:
000E09  1  A9 00           lda #0
000E0B  1               @write_z:
000E0B  1  8D 23 9F        sta VERA_data0               ; sprite byte 6: z-depth
000E0E  1  60              rts
000E0F  1               
000E0F  1               ;******************************************************************
000E0F  1               ; fire_bullet — activate player bullet at cannon tip, update sprite
000E0F  1               ;   Bullet X centers the 8-px bullet over the 16-px player ship:
000E0F  1               ;     bullet_x = player_x + 4
000E0F  1               ;   Bullet Y starts 8 VERA pixels above the player sprite top.
000E0F  1               ;   Caller must check bullet_active == 0 before calling.
000E0F  1               ;******************************************************************
000E0F  1               fire_bullet:
000E0F  1  A5 rr           lda player_x_lo
000E11  1  18              clc
000E12  1  69 04           adc #4
000E14  1  85 rr           sta bullet_x_lo
000E16  1  A5 rr           lda player_x_hi
000E18  1  69 00           adc #0
000E1A  1  85 rr           sta bullet_x_hi
000E1C  1               
000E1C  1  A9 9C           lda #<BULLET_Y_INIT
000E1E  1  85 rr           sta bullet_y_lo
000E20  1  A9 01           lda #>BULLET_Y_INIT
000E22  1  85 rr           sta bullet_y_hi
000E24  1               
000E24  1  A9 01           lda #1
000E26  1  85 rr           sta bullet_active
000E28  1  E6 rr           inc shot_count
000E2A  1  20 47 0E        jsr update_bullet_sprite
000E2D  1  60              rts
000E2E  1               
000E2E  1               ;******************************************************************
000E2E  1               ; move_bullet — move bullet upward by BULLET_SPEED each frame;
000E2E  1               ;   deactivate when it reaches the top of the screen (Y underflows 0)
000E2E  1               ;******************************************************************
000E2E  1               move_bullet:
000E2E  1  A5 rr           lda bullet_y_lo
000E30  1  38              sec
000E31  1  E9 0C           sbc #BULLET_SPEED
000E33  1  85 rr           sta bullet_y_lo
000E35  1  A5 rr           lda bullet_y_hi
000E37  1  E9 00           sbc #0
000E39  1  85 rr           sta bullet_y_hi
000E3B  1  30 04           bmi @deactivate              ; 16-bit underflow past 0 → off screen
000E3D  1               
000E3D  1  20 47 0E        jsr update_bullet_sprite
000E40  1  60              rts
000E41  1               
000E41  1               @deactivate:
000E41  1  64 rr           stz bullet_active
000E43  1  20 47 0E        jsr update_bullet_sprite     ; disables sprite (z-depth=0)
000E46  1  60              rts
000E47  1               
000E47  1               ;******************************************************************
000E47  1               ; update_bullet_sprite — write bullet position and enable/disable
000E47  1               ;   to VERA sprite 2 (bytes 2-6); byte 7 set once at init.
000E47  1               ;   z-depth = SPR_Z_FRONT when active, 0 when inactive.
000E47  1               ;******************************************************************
000E47  1               update_bullet_sprite:
000E47  1  9C 25 9F        stz VERA_ctrl
000E4A  1  A9 11 8D 22     VERA_SET_ADDR (BULLET_SPRITE_ATTR + 2), 1
000E4E  1  9F A9 FC 8D  
000E52  1  21 9F A9 12  
000E59  1  A5 rr           lda bullet_x_lo
000E5B  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000E5E  1  A5 rr           lda bullet_x_hi
000E60  1  29 03           and #$03
000E62  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000E65  1  A5 rr           lda bullet_y_lo
000E67  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000E6A  1  A5 rr           lda bullet_y_hi
000E6C  1  29 03           and #$03
000E6E  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000E71  1  A5 rr           lda bullet_active
000E73  1  F0 04           beq @z_off
000E75  1  A9 0C           lda #SPR_Z_FRONT
000E77  1  80 02           bra @write_z
000E79  1               @z_off:
000E79  1  A9 00           lda #$00
000E7B  1               @write_z:
000E7B  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
000E7E  1  60              rts
000E7F  1               
000E7F  1               ;******************************************************************
000E7F  1               ; check_bullet_invader — scan all 55 invaders for a hit with the player bullet
000E7F  1               ;
000E7F  1               ;   Iterates rows 0-4, columns 0-10.  Skips dead invaders.
000E7F  1               ;   For each live invader checks 16-bit AABB overlap:
000E7F  1               ;     X: bullet_x+8 > inv_x  AND  bullet_x < inv_x+16
000E7F  1               ;     Y: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000E7F  1               ;   On hit: calls kill_invader_hit and returns immediately.
000E7F  1               ;
000E7F  1               ;   Scratch used: zp_y_base_lo/hi, zp_row_y_lo/hi, zp_x_lo/hi,
000E7F  1               ;                 zp_scratch_lo/hi, zp_row, zp_col
000E7F  1               ;******************************************************************
000E7F  1               check_bullet_invader:
000E7F  1  A5 rr           lda bullet_active
000E81  1  D0 01           bne :+
000E83  1  60              rts
000E84  1               :  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000E84  1  A9 50           lda #<INV_GRID_Y_BASE
000E86  1  18              clc
000E87  1  65 rr           adc inv_offset_y
000E89  1  85 rr           sta zp_y_base_lo
000E8B  1  A9 00           lda #>INV_GRID_Y_BASE
000E8D  1  69 00           adc #0
000E8F  1  85 rr           sta zp_y_base_hi
000E91  1               
000E91  1  64 rr           stz zp_row
000E93  1               @row_loop:
000E93  1                  ; row Y = y_base + row_y_offsets[row]
000E93  1  A4 rr           ldy zp_row
000E95  1  B9 49 1D        lda row_y_offsets,y
000E98  1  18              clc
000E99  1  65 rr           adc zp_y_base_lo
000E9B  1  85 rr           sta zp_row_y_lo
000E9D  1  A9 00           lda #0
000E9F  1  65 rr           adc zp_y_base_hi
000EA1  1  85 rr           sta zp_row_y_hi
000EA3  1               
000EA3  1                  ; --- Quick Y range check for whole row ---
000EA3  1                  ; Need: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000EA3  1               
000EA3  1                  ; (1) bullet_y+8 > inv_y  →  (bullet_y+8) - inv_y > 0
000EA3  1                  ;     result negative (bmi) means bullet above this row
000EA3  1  A5 rr           lda bullet_y_lo
000EA5  1  18              clc
000EA6  1  69 08           adc #8
000EA8  1  85 rr           sta zp_scratch_lo
000EAA  1  A5 rr           lda bullet_y_hi
000EAC  1  69 00           adc #0
000EAE  1  85 rr           sta zp_scratch_hi
000EB0  1  A5 rr           lda zp_scratch_lo
000EB2  1  38              sec
000EB3  1  E5 rr           sbc zp_row_y_lo
000EB5  1  A5 rr           lda zp_scratch_hi
000EB7  1  E5 rr           sbc zp_row_y_hi
000EB9  1  30 1D           bmi @next_row         ; bullet bottom above invader top → no hit in this row
000EBB  1               
000EBB  1                  ; (2) bullet_y < inv_y+16  →  bullet_y - (inv_y+16) < 0
000EBB  1                  ;     result >= 0 (bpl) means bullet below this row
000EBB  1  A5 rr           lda zp_row_y_lo
000EBD  1  18              clc
000EBE  1  69 10           adc #16
000EC0  1  85 rr           sta zp_scratch_lo
000EC2  1  A5 rr           lda zp_row_y_hi
000EC4  1  69 00           adc #0
000EC6  1  85 rr           sta zp_scratch_hi
000EC8  1  A5 rr           lda bullet_y_lo
000ECA  1  38              sec
000ECB  1  E5 rr           sbc zp_scratch_lo
000ECD  1  A5 rr           lda bullet_y_hi
000ECF  1  E5 rr           sbc zp_scratch_hi
000ED1  1  10 05           bpl @next_row         ; bullet top at or below invader bottom → no hit
000ED3  1               
000ED3  1                  ; Y overlaps this row — check each column
000ED3  1  20 E1 0E        jsr cbi_check_cols
000ED6  1  B0 08           bcs @done             ; hit found; bullet already handled
000ED8  1               
000ED8  1               @next_row:
000ED8  1  E6 rr           inc zp_row
000EDA  1  A5 rr           lda zp_row
000EDC  1  C9 05           cmp #5
000EDE  1  D0 B3           bne @row_loop
000EE0  1               
000EE0  1               @done:
000EE0  1  60              rts
000EE1  1               
000EE1  1               ;******************************************************************
000EE1  1               ; cbi_check_cols — column scan for check_bullet_invader
000EE1  1               ;
000EE1  1               ;   Scans all 11 columns of zp_row for an X overlap with the bullet.
000EE1  1               ;   Assumes Y overlap for this row has already been confirmed.
000EE1  1               ;   Returns: C set if hit (kill_invader_hit already called),
000EE1  1               ;            C clear if no hit.
000EE1  1               ;   Scratch used: zp_col, zp_x_lo/hi, zp_scratch_lo/hi
000EE1  1               ;******************************************************************
000EE1  1               cbi_check_cols:
000EE1  1  64 rr           stz zp_col
000EE3  1               @col_loop:
000EE3  1                  ; skip if invader is dead
000EE3  1  A4 rr           ldy zp_row
000EE5  1  B9 4E 1D        lda inv_row_base,y
000EE8  1  18              clc
000EE9  1  65 rr           adc zp_col
000EEB  1  A8              tay                   ; Y = invader index
000EEC  1  29 07           and #$07
000EEE  1  AA              tax
000EEF  1  BD 53 1D        lda bit_masks,x
000EF2  1  48              pha
000EF3  1  98              tya
000EF4  1  4A              lsr
000EF5  1  4A              lsr
000EF6  1  4A              lsr
000EF7  1  A8              tay                   ; Y = byte index into inv_alive
000EF8  1  68              pla
000EF9  1  39 rr rr        and inv_alive,y
000EFC  1  F0 46           beq @next_col         ; dead
000EFE  1               
000EFE  1                  ; compute inv_x = inv_grid_x + col_x_offsets[col]
000EFE  1  A4 rr           ldy zp_col
000F00  1  B9 33 1D        lda col_x_lo,y
000F03  1  18              clc
000F04  1  65 rr           adc inv_grid_x_lo
000F06  1  85 rr           sta zp_x_lo
000F08  1  B9 3E 1D        lda col_x_hi,y
000F0B  1  65 rr           adc inv_grid_x_hi
000F0D  1  85 rr           sta zp_x_hi
000F0F  1               
000F0F  1                  ; X check (1): bullet_x+8 > inv_x
000F0F  1  A5 rr           lda bullet_x_lo
000F11  1  18              clc
000F12  1  69 08           adc #8
000F14  1  85 rr           sta zp_scratch_lo
000F16  1  A5 rr           lda bullet_x_hi
000F18  1  69 00           adc #0
000F1A  1  85 rr           sta zp_scratch_hi
000F1C  1  A5 rr           lda zp_scratch_lo
000F1E  1  38              sec
000F1F  1  E5 rr           sbc zp_x_lo
000F21  1  A5 rr           lda zp_scratch_hi
000F23  1  E5 rr           sbc zp_x_hi
000F25  1  30 1D           bmi @next_col         ; bullet right edge left of invader → no hit
000F27  1               
000F27  1                  ; X check (2): bullet_x < inv_x+16
000F27  1  A5 rr           lda zp_x_lo
000F29  1  18              clc
000F2A  1  69 10           adc #16
000F2C  1  85 rr           sta zp_scratch_lo
000F2E  1  A5 rr           lda zp_x_hi
000F30  1  69 00           adc #0
000F32  1  85 rr           sta zp_scratch_hi
000F34  1  A5 rr           lda bullet_x_lo
000F36  1  38              sec
000F37  1  E5 rr           sbc zp_scratch_lo
000F39  1  A5 rr           lda bullet_x_hi
000F3B  1  E5 rr           sbc zp_scratch_hi
000F3D  1  10 05           bpl @next_col         ; bullet left edge at or right of invader → no hit
000F3F  1               
000F3F  1                  ; --- HIT ---
000F3F  1  20 4E 0F        jsr kill_invader_hit
000F42  1  38              sec                   ; signal hit to caller
000F43  1  60              rts
000F44  1               
000F44  1               @next_col:
000F44  1  E6 rr           inc zp_col
000F46  1  A5 rr           lda zp_col
000F48  1  C9 0B           cmp #11
000F4A  1  D0 97           bne @col_loop
000F4C  1               
000F4C  1  18              clc                   ; no hit
000F4D  1  60              rts
000F4E  1               
000F4E  1               ;******************************************************************
000F4E  1               ; kill_invader_hit — clear alive bit, deactivate bullet, update score & speed
000F4E  1               ;   Expects zp_row, zp_col to identify the hit invader.
000F4E  1               ;******************************************************************
000F4E  1               kill_invader_hit:
000F4E  1                  ; --- clear alive bit ---
000F4E  1  A4 rr           ldy zp_row
000F50  1  B9 4E 1D        lda inv_row_base,y
000F53  1  18              clc
000F54  1  65 rr           adc zp_col
000F56  1  A8              tay                   ; Y = invader index
000F57  1  29 07           and #$07
000F59  1  AA              tax
000F5A  1  BD 53 1D        lda bit_masks,x       ; bit mask for this invader
000F5D  1  48              pha
000F5E  1  98              tya
000F5F  1  4A              lsr
000F60  1  4A              lsr
000F61  1  4A              lsr
000F62  1  A8              tay                   ; Y = byte index into inv_alive
000F63  1  68              pla
000F64  1  49 FF           eor #$FF              ; invert → clear mask
000F66  1  39 rr rr        and inv_alive,y
000F69  1  99 rr rr        sta inv_alive,y
000F6C  1               
000F6C  1                  ; --- start explosion at the hit invader's position ---
000F6C  1                  ; zp_x_lo/hi and zp_row_y_lo/hi still hold the invader coords from collision detection
000F6C  1  20 9A 0F        jsr start_explosion
000F6F  1               
000F6F  1                  ; --- deactivate bullet ---
000F6F  1  64 rr           stz bullet_active
000F71  1  20 47 0E        jsr update_bullet_sprite
000F74  1               
000F74  1                  ; --- decrement inv_count ---
000F74  1  C6 rr           dec inv_count
000F76  1               
000F76  1                  ; --- update inv_move_speed: proportional to remaining count ---
000F76  1  A6 rr           ldx inv_count
000F78  1  BD 60 1D        lda inv_speed_table,x
000F7B  1  85 rr           sta inv_move_speed
000F7D  1               
000F7D  1                  ; --- add score for this row's invader type ---
000F7D  1  A4 rr           ldy zp_row
000F7F  1  B9 5B 1D        lda score_by_row_bcd,y
000F82  1  20 86 0F        jsr add_score
000F85  1  60              rts
000F86  1               
000F86  1               ;******************************************************************
000F86  1               ; add_score — add BCD value in A to score_lo/mid/hi
000F86  1               ;******************************************************************
000F86  1               add_score:
000F86  1  F8              sed
000F87  1  18              clc
000F88  1  65 rr           adc score_lo
000F8A  1  85 rr           sta score_lo
000F8C  1  A5 rr           lda score_mid
000F8E  1  69 00           adc #0
000F90  1  85 rr           sta score_mid
000F92  1  A5 rr           lda score_hi
000F94  1  69 00           adc #0
000F96  1  85 rr           sta score_hi
000F98  1  D8              cld
000F99  1  60              rts
000F9A  1               
000F9A  1               ;******************************************************************
000F9A  1               ; start_explosion — position sprite 4 at the hit invader and start timer
000F9A  1               ;
000F9A  1               ;   Inputs: zp_x_lo/hi     — invader X (VERA coords)
000F9A  1               ;           zp_row_y_lo/hi — invader Y (VERA coords)
000F9A  1               ;   Sets exp_timer = EXPLODE_FRAMES and enables sprite 4.
000F9A  1               ;******************************************************************
000F9A  1               start_explosion:
000F9A  1  9C 25 9F        stz VERA_ctrl
000F9D  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 2), 1  ; start at byte 2 (X lo)
000FA1  1  9F A9 FC 8D  
000FA5  1  21 9F A9 22  
000FAC  1  A5 rr           lda zp_x_lo
000FAE  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000FB1  1  A5 rr           lda zp_x_hi
000FB3  1  29 03           and #$03
000FB5  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000FB8  1  A5 rr           lda zp_row_y_lo
000FBA  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000FBD  1  A5 rr           lda zp_row_y_hi
000FBF  1  29 03           and #$03
000FC1  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000FC4  1  A9 0C           lda #SPR_Z_FRONT
000FC6  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3 → enabled, in front
000FC9  1  A9 1E           lda #EXPLODE_FRAMES
000FCB  1  85 rr           sta exp_timer
000FCD  1  60              rts
000FCE  1               
000FCE  1               ;******************************************************************
000FCE  1               ; update_explosion — decrement exp_timer; disable sprite when it hits 0
000FCE  1               ;******************************************************************
000FCE  1               update_explosion:
000FCE  1  A5 rr           lda exp_timer
000FD0  1  F0 1B           beq @inactive
000FD2  1  C6 rr           dec exp_timer
000FD4  1  D0 17           bne @inactive
000FD6  1                  ; timer just expired — disable sprite 4
000FD6  1  9C 25 9F        stz VERA_ctrl
000FD9  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1  ; byte 6 = z-depth
000FDD  1  9F A9 FC 8D  
000FE1  1  21 9F A9 26  
000FE8  1  A9 00           lda #$00
000FEA  1  8D 23 9F        sta VERA_data0               ; z-depth=0 → disabled
000FED  1               @inactive:
000FED  1  60              rts
000FEE  1               
000FEE  1               ;******************************************************************
000FEE  1               ; prng — 16-bit Galois LFSR, feedback polynomial $B400
000FEE  1               ;   Updates rand_seed_lo/hi; returns pseudo-random byte in A.
000FEE  1               ;******************************************************************
000FEE  1               prng:
000FEE  1  46 rr           lsr rand_seed_hi          ; shift 16-bit state right; carry = old hi[0]
000FF0  1  66 rr           ror rand_seed_lo          ; lo[7] = old hi[0]; carry = old lo[0] (feedback bit)
000FF2  1  90 06           bcc @done                 ; feedback bit=0: no XOR
000FF4  1  A5 rr           lda rand_seed_hi
000FF6  1  49 B4           eor #$B4                  ; XOR hi byte with feedback poly ($B400 >> 8)
000FF8  1  85 rr           sta rand_seed_hi
000FFA  1               @done:
000FFA  1  A5 rr           lda rand_seed_lo
000FFC  1  60              rts
000FFD  1               
000FFD  1               ;******************************************************************
000FFD  1               ; update_inv_bullets — fire timer, move active bullets, boundary check,
000FFD  1               ;   update VERA sprites for all 3 invader bullet slots.
000FFD  1               ;******************************************************************
000FFD  1               update_inv_bullets:
000FFD  1                  ; --- fire timer ---
000FFD  1  C6 rr           dec inv_fire_timer
000FFF  1  D0 0D           bne @move_loop
001001  1                  ; reset timer = max(inv_move_speed, INV_FIRE_TIMER_MIN)
001001  1  A5 rr           lda inv_move_speed
001003  1  C9 0A           cmp #INV_FIRE_TIMER_MIN
001005  1  B0 02           bcs @set_timer
001007  1  A9 0A           lda #INV_FIRE_TIMER_MIN
001009  1               @set_timer:
001009  1  85 rr           sta inv_fire_timer
00100B  1  20 78 10        jsr try_fire_inv_bullet
00100E  1               
00100E  1               @move_loop:
00100E  1  A2 00           ldx #0
001010  1               @slot_loop:
001010  1  B5 rr           lda ibul_active,x
001012  1  F0 1B           beq @update_spr           ; inactive: just hide sprite
001014  1               
001014  1                  ; move bullet down by INV_BULLET_SPEED
001014  1  B5 rr           lda ibul_y_lo,x
001016  1  18              clc
001017  1  69 06           adc #INV_BULLET_SPEED
001019  1  95 rr           sta ibul_y_lo,x
00101B  1  B5 rr           lda ibul_y_hi,x
00101D  1  69 00           adc #0
00101F  1  95 rr           sta ibul_y_hi,x
001021  1               
001021  1                  ; boundary: deactivate if Y >= 480 ($01E0)
001021  1  C9 01           cmp #>480                 ; A = new hi byte; compare with 1
001023  1  90 0A           bcc @update_spr           ; hi < 1: still on screen
001025  1  D0 06           bne @deactivate           ; hi > 1: off screen
001027  1  B5 rr           lda ibul_y_lo,x
001029  1  C9 E0           cmp #<480                 ; compare lo with $E0
00102B  1  90 02           bcc @update_spr           ; lo < $E0: still on screen
00102D  1               @deactivate:
00102D  1  74 rr           stz ibul_active,x
00102F  1               
00102F  1               @update_spr:
00102F  1  20 38 10        jsr update_inv_bullet_sprite   ; preserves X
001032  1  E8              inx
001033  1  E0 03           cpx #3
001035  1  D0 D9           bne @slot_loop
001037  1  60              rts
001038  1               
001038  1               ;******************************************************************
001038  1               ; update_inv_bullet_sprite — write VERA sprite attrs bytes 2-6 for slot X
001038  1               ;   X = slot index (0-2).  Preserves X.
001038  1               ;******************************************************************
001038  1               update_inv_bullet_sprite:
001038  1  86 rr           stx zp_scratch_lo              ; preserve slot index
00103A  1  9C 25 9F        stz VERA_ctrl
00103D  1  A9 11           lda #$11                       ; stride=1, bank bit=1
00103F  1  8D 22 9F        sta VERA_addr_bank
001042  1  A9 FC           lda #$FC
001044  1  8D 21 9F        sta VERA_addr_high
001047  1  BD 98 1D        lda ibul_spr_lo,x
00104A  1  18              clc
00104B  1  69 02           adc #2                         ; point to byte 2 (X position)
00104D  1  8D 20 9F        sta VERA_addr_low
001050  1  B5 rr           lda ibul_x_lo,x
001052  1  8D 23 9F        sta VERA_data0                 ; byte 2: X lo
001055  1  B5 rr           lda ibul_x_hi,x
001057  1  29 03           and #$03
001059  1  8D 23 9F        sta VERA_data0                 ; byte 3: X hi
00105C  1  B5 rr           lda ibul_y_lo,x
00105E  1  8D 23 9F        sta VERA_data0                 ; byte 4: Y lo
001061  1  B5 rr           lda ibul_y_hi,x
001063  1  29 03           and #$03
001065  1  8D 23 9F        sta VERA_data0                 ; byte 5: Y hi
001068  1  B5 rr           lda ibul_active,x
00106A  1  F0 04           beq @disabled
00106C  1  A9 0C           lda #SPR_Z_FRONT
00106E  1  80 02           bra @write_z
001070  1               @disabled:
001070  1  A9 00           lda #0
001072  1               @write_z:
001072  1  8D 23 9F        sta VERA_data0                 ; byte 6: z-depth
001075  1  A6 rr           ldx zp_scratch_lo
001077  1  60              rts
001078  1               
001078  1               ;******************************************************************
001078  1               ; try_fire_inv_bullet — find a free slot and spawn a bullet from the
001078  1               ;   bottommost live invader in a randomly chosen column.
001078  1               ;   Returns immediately if all slots busy or chosen column is empty.
001078  1               ;   Scratch used: zp_row, zp_col, zp_scratch_lo (slot index)
001078  1               ;******************************************************************
001078  1               try_fire_inv_bullet:
001078  1                  ; find a free bullet slot
001078  1  A2 00           ldx #0
00107A  1               @find_slot:
00107A  1  B5 rr           lda ibul_active,x
00107C  1  F0 06           beq @slot_found
00107E  1  E8              inx
00107F  1  E0 03           cpx #3
001081  1  D0 F7           bne @find_slot
001083  1  60              rts                            ; all slots busy
001084  1               
001084  1               @slot_found:
001084  1  86 rr           stx zp_scratch_lo              ; save free slot index
001086  1               
001086  1                  ; pick a random column 0-10
001086  1  20 EE 0F        jsr prng
001089  1  29 0F           and #$0F                       ; 0-15
00108B  1  C9 0B           cmp #11
00108D  1  90 03           bcc @col_ok
00108F  1  38              sec
001090  1  E9 0B           sbc #11                        ; wrap 11-15 → 0-4 (slight bias, acceptable)
001092  1               @col_ok:
001092  1  85 rr           sta zp_col
001094  1               
001094  1                  ; scan rows 4 down to 0 for bottommost live invader in this column
001094  1  A9 04           lda #4
001096  1  85 rr           sta zp_row
001098  1               @row_scan:
001098  1  A4 rr           ldy zp_row
00109A  1  B9 4E 1D        lda inv_row_base,y
00109D  1  18              clc
00109E  1  65 rr           adc zp_col
0010A0  1  A8              tay                            ; Y = invader index
0010A1  1  29 07           and #$07
0010A3  1  AA              tax                            ; X = bit position
0010A4  1  BD 53 1D        lda bit_masks,x
0010A7  1  48              pha
0010A8  1  98              tya
0010A9  1  4A              lsr
0010AA  1  4A              lsr
0010AB  1  4A              lsr
0010AC  1  A8              tay                            ; Y = byte index into inv_alive
0010AD  1  68              pla
0010AE  1  39 rr rr        and inv_alive,y
0010B1  1  D0 09           bne @found_invader
0010B3  1  A5 rr           lda zp_row
0010B5  1  F0 04           beq @no_invader                ; checked row 0, nothing alive
0010B7  1  C6 rr           dec zp_row
0010B9  1  80 DD           bra @row_scan
0010BB  1               
0010BB  1               @no_invader:
0010BB  1  60              rts                            ; column empty, skip fire
0010BC  1               
0010BC  1               @found_invader:
0010BC  1  A6 rr           ldx zp_scratch_lo              ; restore free slot index
0010BE  1  A9 01           lda #1
0010C0  1  95 rr           sta ibul_active,x
0010C2  1               
0010C2  1                  ; spawn X = inv_grid_x + col_x_offsets[col]  (16-bit, matching update_invader_sprites)
0010C2  1  A4 rr           ldy zp_col
0010C4  1  B9 33 1D        lda col_x_lo,y
0010C7  1  18              clc
0010C8  1  65 rr           adc inv_grid_x_lo
0010CA  1  95 rr           sta ibul_x_lo,x
0010CC  1  B9 3E 1D        lda col_x_hi,y
0010CF  1  65 rr           adc inv_grid_x_hi
0010D1  1  95 rr           sta ibul_x_hi,x
0010D3  1                  ; add +4 as a separate 16-bit step to centre the 8px bullet in the 16px invader
0010D3  1  B5 rr           lda ibul_x_lo,x
0010D5  1  18              clc
0010D6  1  69 04           adc #4
0010D8  1  95 rr           sta ibul_x_lo,x
0010DA  1  B5 rr           lda ibul_x_hi,x
0010DC  1  69 00           adc #0
0010DE  1  95 rr           sta ibul_x_hi,x
0010E0  1               
0010E0  1                  ; spawn Y: compute y_base first (same two-step pattern as update_invader_sprites)
0010E0  1                  ; step 1: y_base = INV_GRID_Y_BASE + inv_offset_y  (16-bit)
0010E0  1  A9 50           lda #<INV_GRID_Y_BASE
0010E2  1  18              clc
0010E3  1  65 rr           adc inv_offset_y
0010E5  1  85 rr           sta zp_y_base_lo
0010E7  1  A9 00           lda #>INV_GRID_Y_BASE
0010E9  1  69 00           adc #0
0010EB  1  85 rr           sta zp_y_base_hi
0010ED  1                  ; step 2: spawn_y = y_base + row_y_offsets[row]
0010ED  1  A4 rr           ldy zp_row
0010EF  1  B9 49 1D        lda row_y_offsets,y
0010F2  1  18              clc
0010F3  1  65 rr           adc zp_y_base_lo
0010F5  1  95 rr           sta ibul_y_lo,x
0010F7  1  A9 00           lda #0
0010F9  1  65 rr           adc zp_y_base_hi
0010FB  1  95 rr           sta ibul_y_hi,x
0010FD  1                  ; step 3: +16 to place bullet at the bottom edge of the 16px invader
0010FD  1  B5 rr           lda ibul_y_lo,x
0010FF  1  18              clc
001100  1  69 10           adc #16
001102  1  95 rr           sta ibul_y_lo,x
001104  1  B5 rr           lda ibul_y_hi,x
001106  1  69 00           adc #0
001108  1  95 rr           sta ibul_y_hi,x
00110A  1               
00110A  1  60              rts
00110B  1               
00110B  1               ;******************************************************************
00110B  1               ; check_inv_bullet_player — AABB test each active invader bullet vs. player
00110B  1               ;
00110B  1               ;   Player rect: (player_x, PLAYER_Y) to (player_x+15, PLAYER_Y+15), 16x16
00110B  1               ;   Bullet rect: (ibul_x,   ibul_y)   to (ibul_x+7,   ibul_y+7),     8x8
00110B  1               ;
00110B  1               ;   On hit: bullet deactivated, jsr player_hit called, loop continues
00110B  1               ;   (remaining bullets checked — at most one hit landing per frame).
00110B  1               ;   Scratch: zp_scratch_lo/hi, X (slot index)
00110B  1               ;******************************************************************
00110B  1               check_inv_bullet_player:
00110B  1  A2 00           ldx #0
00110D  1               @slot_loop:
00110D  1  B5 rr           lda ibul_active,x
00110F  1  F0 5B           beq @next_slot
001111  1               
001111  1                  ; --- Y check 1: (bullet_y + 8) > PLAYER_Y  →  bullet_y + 8 - PLAYER_Y > 0 ---
001111  1  B5 rr           lda ibul_y_lo,x
001113  1  18              clc
001114  1  69 08           adc #8
001116  1  85 rr           sta zp_scratch_lo
001118  1  B5 rr           lda ibul_y_hi,x
00111A  1  69 00           adc #0
00111C  1  85 rr           sta zp_scratch_hi
00111E  1  A5 rr           lda zp_scratch_lo
001120  1  38              sec
001121  1  E9 A4           sbc #<PLAYER_Y
001123  1  A5 rr           lda zp_scratch_hi
001125  1  E9 01           sbc #>PLAYER_Y
001127  1  30 43           bmi @next_slot            ; bullet bottom above player top → no hit
001129  1               
001129  1                  ; --- Y check 2: bullet_y < PLAYER_Y + 16 → bullet_y - (PLAYER_Y+16) < 0 ---
001129  1  B5 rr           lda ibul_y_lo,x
00112B  1  38              sec
00112C  1  E9 B4           sbc #<(PLAYER_Y+16)
00112E  1  B5 rr           lda ibul_y_hi,x
001130  1  E9 01           sbc #>(PLAYER_Y+16)
001132  1  10 38           bpl @next_slot            ; bullet top at or below player bottom → no hit
001134  1               
001134  1                  ; --- X check 1: (bullet_x + 8) > player_x ---
001134  1  B5 rr           lda ibul_x_lo,x
001136  1  18              clc
001137  1  69 08           adc #8
001139  1  85 rr           sta zp_scratch_lo
00113B  1  B5 rr           lda ibul_x_hi,x
00113D  1  69 00           adc #0
00113F  1  85 rr           sta zp_scratch_hi
001141  1  A5 rr           lda zp_scratch_lo
001143  1  38              sec
001144  1  E5 rr           sbc player_x_lo
001146  1  A5 rr           lda zp_scratch_hi
001148  1  E5 rr           sbc player_x_hi
00114A  1  30 20           bmi @next_slot            ; bullet right edge left of player → no hit
00114C  1               
00114C  1                  ; --- X check 2: bullet_x < player_x + 16 ---
00114C  1  A5 rr           lda player_x_lo
00114E  1  18              clc
00114F  1  69 10           adc #16
001151  1  85 rr           sta zp_scratch_lo
001153  1  A5 rr           lda player_x_hi
001155  1  69 00           adc #0
001157  1  85 rr           sta zp_scratch_hi
001159  1  B5 rr           lda ibul_x_lo,x
00115B  1  38              sec
00115C  1  E5 rr           sbc zp_scratch_lo
00115E  1  B5 rr           lda ibul_x_hi,x
001160  1  E5 rr           sbc zp_scratch_hi
001162  1  10 08           bpl @next_slot            ; bullet left edge at or right of player → no hit
001164  1               
001164  1                  ; --- HIT ---
001164  1  74 rr           stz ibul_active,x         ; deactivate this bullet
001166  1  20 38 10        jsr update_inv_bullet_sprite
001169  1  20 72 11        jsr player_hit
00116C  1               
00116C  1               @next_slot:
00116C  1  E8              inx
00116D  1  E0 03           cpx #3
00116F  1  D0 9C           bne @slot_loop
001171  1  60              rts
001172  1               
001172  1               ;******************************************************************
001172  1               ; player_hit — handle a bullet-player collision:
001172  1               ;   explosion at player position, decrement lives, respawn, invincibility
001172  1               ;******************************************************************
001172  1               player_hit:
001172  1                  ; start explosion at player position
001172  1  A5 rr           lda player_x_lo
001174  1  85 rr           sta zp_x_lo
001176  1  A5 rr           lda player_x_hi
001178  1  85 rr           sta zp_x_hi
00117A  1  A9 A4           lda #<PLAYER_Y
00117C  1  85 rr           sta zp_row_y_lo
00117E  1  A9 01           lda #>PLAYER_Y
001180  1  85 rr           sta zp_row_y_hi
001182  1  20 9A 0F        jsr start_explosion
001185  1               
001185  1                  ; decrement lives
001185  1  C6 rr           dec lives
001187  1  F0 0D           beq @game_over            ; lives hit 0 → end game (Phase 6 will handle this properly)
001189  1               
001189  1                  ; grant invincibility and re-centre the ship
001189  1  A9 78           lda #INV_HIT_FRAMES
00118B  1  85 rr           sta inv_hit_timer
00118D  1  A9 38           lda #<PLAYER_X_INIT
00118F  1  85 rr           sta player_x_lo
001191  1  A9 01           lda #>PLAYER_X_INIT
001193  1  85 rr           sta player_x_hi
001195  1  60              rts
001196  1               
001196  1               @game_over:
