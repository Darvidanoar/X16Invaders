0012D4  1               ; hide_all_inv_sprites — set z-depth=0 for all 55 invader sprites
0012D4  1               ;   Uses VERA stride=8 to write only byte 6 (z-depth) of each block.
0012D4  1               ;   First invader sprite byte 6: $1FC00 + 11*8 + 6 = $1FC5E
0012D4  1               ;******************************************************************
0012D4  1               hide_all_inv_sprites:
0012D4  1  9C 25 9F        stz VERA_ctrl
0012D7  1  A9 41           lda #$41               ; stride=8 (code $4 in high nibble), bank=1
0012D9  1  8D 22 9F        sta VERA_addr_bank
0012DC  1  A9 FC           lda #$FC
0012DE  1  8D 21 9F        sta VERA_addr_high
0012E1  1  A9 5E           lda #$5E               ; low byte of $1FC5E  ($1FC58+6)
0012E3  1  8D 20 9F        sta VERA_addr_low
0012E6  1  A9 00           lda #0                 ; z-depth=0 → disabled
0012E8  1  A2 37           ldx #55
0012EA  1               @loop:
0012EA  1  8D 23 9F        sta VERA_data0         ; writes byte 6; addr auto-advances by 8
0012ED  1  CA              dex
0012EE  1  D0 FA           bne @loop
0012F0  1  60              rts
