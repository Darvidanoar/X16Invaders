0015DE  1               ; hide_all_inv_sprites — set z-depth=0 for all 55 invader sprites
0015DE  1               ;   Uses VERA stride=8 to write only byte 6 (z-depth) of each block.
0015DE  1               ;   First invader sprite byte 6: $1FC00 + 11*8 + 6 = $1FC5E
0015DE  1               ;******************************************************************
0015DE  1               hide_all_inv_sprites:
0015DE  1  9C 25 9F        stz VERA_ctrl
0015E1  1  A9 41           lda #$41               ; stride=8 (code $4 in high nibble), bank=1
0015E3  1  8D 22 9F        sta VERA_addr_bank
0015E6  1  A9 FC           lda #$FC
0015E8  1  8D 21 9F        sta VERA_addr_high
0015EB  1  A9 5E           lda #$5E               ; low byte of $1FC5E  ($1FC58+6)
0015ED  1  8D 20 9F        sta VERA_addr_low
0015F0  1  A9 00           lda #0                 ; z-depth=0 → disabled
0015F2  1  A2 37           ldx #55
0015F4  1               @loop:
0015F4  1  8D 23 9F        sta VERA_data0         ; writes byte 6; addr auto-advances by 8
0015F7  1  CA              dex
0015F8  1  D0 FA           bne @loop
0015FA  1  60              rts
