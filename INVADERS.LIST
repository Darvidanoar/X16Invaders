001261  1               ;******************************************************************
001261  1               ; update_hi_score — copy score → hi_score when score > hi_score
001261  1               ;   BCD compare: check hi byte, then mid, then lo.
001261  1               ;******************************************************************
001261  1               update_hi_score:
001261  1  A5 rr           lda score_hi
001263  1  C5 rr           cmp hi_score_hi
001265  1  90 1E           bcc @no_update
001267  1  D0 10           bne @do_update
001269  1  A5 rr           lda score_mid
00126B  1  C5 rr           cmp hi_score_mid
00126D  1  90 16           bcc @no_update
00126F  1  D0 08           bne @do_update
001271  1  A5 rr           lda score_lo
001273  1  C5 rr           cmp hi_score_lo
001275  1  90 0E           bcc @no_update
001277  1  F0 0C           beq @no_update            ; equal → no change
001279  1               @do_update:
001279  1  A5 rr           lda score_lo
00127B  1  85 rr           sta hi_score_lo
00127D  1  A5 rr           lda score_mid
00127F  1  85 rr           sta hi_score_mid
001281  1  A5 rr           lda score_hi
001283  1  85 rr           sta hi_score_hi
001285  1               @no_update:
001285  1  60              rts
001286  1               
001286  1               ;******************************************************************
001286  1               ; restart_game — reset all gameplay state; reuse VRAM data; jump to main_loop
001286  1               ;   Does NOT reset hi-score.
001286  1               ;******************************************************************
001286  1               restart_game:
001286  1  64 rr           stz score_lo
001288  1  64 rr           stz score_mid
00128A  1  64 rr           stz score_hi
00128C  1  A9 01           lda #1
00128E  1  85 rr           sta wave
001290  1  A9 32           lda #INV_MOVE_SPEED_INIT
001292  1  85 rr           sta wave_init_speed
001294  1               
001294  1  20 7B 09        jsr init_player           ; resets player_x, lives=3, inv_hit_timer=0
001297  1               
001297  1                  ; hide + deactivate player bullet
001297  1  64 rr           stz bullet_active
001299  1  20 3D 0E        jsr update_bullet_sprite
00129C  1               
00129C  1                  ; reset explosion timer and hide sprite 4
00129C  1  64 rr           stz exp_timer
00129E  1  9C 25 9F        stz VERA_ctrl
0012A1  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1
0012A5  1  9F A9 FC 8D  
0012A9  1  21 9F A9 26  
0012B0  1  A9 00           lda #$00
0012B2  1  8D 23 9F        sta VERA_data0
0012B5  1               
0012B5  1                  ; deactivate all invader bullets and hide their sprites
0012B5  1  64 rr           stz ibul_active+0
0012B7  1  64 rr           stz ibul_active+1
0012B9  1  64 rr           stz ibul_active+2
0012BB  1  A2 00           ldx #0
0012BD  1               @rst_ibul:
