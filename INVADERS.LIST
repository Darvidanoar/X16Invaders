00185E  1               ;******************************************************************
00185E  1               ; update_shield_sprite — write new data-addr byte to shield sprite N
00185E  1               ;   Input:  X = shield index (0–3)
00185E  1               ;           shield_damage[X] = current damage level (1–7)
00185E  1               ;   Writes sprite byte 0 (addr[12:5]) using shield_addr_b0 lookup.
00185E  1               ;   VERA addr for byte 0 of sprite N: $1FE10 + N*8
00185E  1               ;******************************************************************
00185E  1               update_shield_sprite:
00185E  1  9C 25 9F        stz VERA_ctrl
001861  1  A9 11           lda #$11               ; stride=1, bank=1
001863  1  8D 22 9F        sta VERA_addr_bank
001866  1  A9 FE           lda #$FE
001868  1  8D 21 9F        sta VERA_addr_high
00186B  1  8A              txa                    ; A = shield index
00186C  1  0A              asl                    ; ×2
00186D  1  0A              asl                    ; ×4
00186E  1  0A              asl                    ; ×8
00186F  1  18              clc
001870  1  69 10           adc #$10               ; + low byte of $1FE10
001872  1  8D 20 9F        sta VERA_addr_low
001875  1  B4 rr           ldy shield_damage, x   ; Y = damage level (1-3)
001877  1  B9 44 1F        lda shield_addr_b0, y  ; addr[12:5] for this tile
00187A  1  8D 23 9F        sta VERA_data0
00187D  1  60              rts
00187E  1               
00187E  1               ;******************************************************************
00187E  1               ; hide_shield_sprite — disable sprite for shield N (z-depth=0)
00187E  1               ;   Input: X = shield index (0–3)
00187E  1               ;   Writes sprite byte 6 at $1FE10 + N*8 + 6 = $1FE16 + N*8
00187E  1               ;******************************************************************
00187E  1               hide_shield_sprite:
00187E  1  9C 25 9F        stz VERA_ctrl
001881  1  A9 11           lda #$11
001883  1  8D 22 9F        sta VERA_addr_bank
001886  1  A9 FE           lda #$FE
001888  1  8D 21 9F        sta VERA_addr_high
00188B  1  8A              txa
00188C  1  0A              asl
00188D  1  0A              asl
00188E  1  0A              asl
00188F  1  18              clc
001890  1  69 16           adc #$16               ; low($1FE10) + 6 = $16, + N*8
001892  1  8D 20 9F        sta VERA_addr_low
001895  1  A9 00           lda #0                 ; z-depth=0 → sprite disabled
001897  1  8D 23 9F        sta VERA_data0
00189A  1  60              rts
00189B  1               
00189B  1               ;******************************************************************
00189B  1               ; damage_shield — increment damage counter for shield X and update
00189B  1               ;   sprite (or disable it when counter reaches 8 = destroyed).
00189B  1               ;   Input:  X = shield index (0–3)
00189B  1               ;   Clobbers: A, Y, VERA registers.  Preserves X.
00189B  1               ;******************************************************************
00189B  1               damage_shield:
00189B  1  F6 rr           inc shield_damage, x
00189D  1  B5 rr           lda shield_damage, x
00189F  1  C9 08           cmp #8
0018A1  1  F0 06           beq @destroy
0018A3  1  B0 07           bcs @done              ; already at 8 (safety guard)
0018A5  1  20 5E 18        jsr update_shield_sprite
0018A8  1  60              rts
0018A9  1               @destroy:
0018A9  1  20 7E 18        jsr hide_shield_sprite
0018AC  1               @done:
0018AC  1  60              rts
0018AD  1               
0018AD  1               ;******************************************************************
0018AD  1               ; check_bullet_shields — test active player bullet vs all 4 shields
0018AD  1               ;
0018AD  1               ;   Overlap condition (AABB, all values VERA 16-bit):
0018AD  1               ;     X: bullet_x+8 > shield_x  AND  bullet_x < shield_x+16
0018AD  1               ;     Y: bullet_y+8 > SHIELD_Y  AND  bullet_y < SHIELD_Y+16
0018AD  1               ;
0018AD  1               ;   On hit: calls damage_shield, deactivates bullet, returns.
0018AD  1               ;   Scratch used: zp_scratch_lo/hi.  Preserves nothing.
0018AD  1               ;******************************************************************
0018AD  1               check_bullet_shields:
0018AD  1  A5 rr           lda bullet_active
0018AF  1  F0 6D           beq @done
0018B1  1               
0018B1  1                  ; --- Y quick check (same band for all shields) ---
0018B1  1                  ; (1) bullet_y+8 > SHIELD_Y
0018B1  1  A5 rr           lda bullet_y_lo
0018B3  1  18              clc
0018B4  1  69 08           adc #8
0018B6  1  85 rr           sta zp_scratch_lo
0018B8  1  A5 rr           lda bullet_y_hi
0018BA  1  69 00           adc #0
0018BC  1  85 rr           sta zp_scratch_hi
0018BE  1  A5 rr           lda zp_scratch_lo
0018C0  1  38              sec
0018C1  1  E9 60           sbc #<SHIELD_Y
0018C3  1  A5 rr           lda zp_scratch_hi
0018C5  1  E9 01           sbc #>SHIELD_Y
0018C7  1  30 55           bmi @done              ; bullet bottom above shield top
0018C9  1               
0018C9  1                  ; (2) bullet_y < SHIELD_Y+32
0018C9  1  A5 rr           lda bullet_y_lo
0018CB  1  38              sec
0018CC  1  E9 80           sbc #<(SHIELD_Y + 32)
0018CE  1  A5 rr           lda bullet_y_hi
0018D0  1  E9 01           sbc #>(SHIELD_Y + 32)
0018D2  1  10 4A           bpl @done              ; bullet top at or below shield bottom
0018D4  1               
0018D4  1                  ; --- Y overlaps: scan each shield ---
0018D4  1  A2 00           ldx #0
0018D6  1               @sld_loop:
0018D6  1  B5 rr           lda shield_damage, x
0018D8  1  C9 08           cmp #8
0018DA  1  B0 3D           bcs @next_sld          ; destroyed, skip
0018DC  1               
0018DC  1                  ; X check (1): bullet_x+8 > shield_x[x]
0018DC  1  A5 rr           lda bullet_x_lo
0018DE  1  18              clc
0018DF  1  69 08           adc #8
0018E1  1  85 rr           sta zp_scratch_lo
0018E3  1  A5 rr           lda bullet_x_hi
0018E5  1  69 00           adc #0
0018E7  1  85 rr           sta zp_scratch_hi
0018E9  1  A5 rr           lda zp_scratch_lo
0018EB  1  38              sec
0018EC  1  FD 3C 1F        sbc shield_x_lo, x
0018EF  1  A5 rr           lda zp_scratch_hi
0018F1  1  FD 40 1F        sbc shield_x_hi, x
0018F4  1  30 23           bmi @next_sld
0018F6  1               
0018F6  1                  ; X check (2): bullet_x < shield_x[x]+32
0018F6  1  BD 3C 1F        lda shield_x_lo, x
0018F9  1  18              clc
0018FA  1  69 20           adc #32
0018FC  1  85 rr           sta zp_scratch_lo
0018FE  1  BD 40 1F        lda shield_x_hi, x
001901  1  69 00           adc #0
001903  1  85 rr           sta zp_scratch_hi
001905  1  A5 rr           lda bullet_x_lo
001907  1  38              sec
001908  1  E5 rr           sbc zp_scratch_lo
00190A  1  A5 rr           lda bullet_x_hi
00190C  1  E5 rr           sbc zp_scratch_hi
00190E  1  10 09           bpl @next_sld
001910  1               
001910  1                  ; --- HIT ---
001910  1  20 9B 18        jsr damage_shield      ; X = shield index
001913  1  64 rr           stz bullet_active
001915  1  20 66 0E        jsr update_bullet_sprite
001918  1  60              rts
001919  1               
001919  1               @next_sld:
001919  1  E8              inx
00191A  1  E0 04           cpx #4
00191C  1  D0 B8           bne @sld_loop
00191E  1               @done:
00191E  1  60              rts
00191F  1               
00191F  1               ;******************************************************************
00191F  1               ; check_invbullet_shields — test each active invader bullet vs all
00191F  1               ;   4 shields.  Same AABB logic as check_bullet_shields but loops
00191F  1               ;   over 3 bullet slots (ibul_active / ibul_x / ibul_y arrays).
00191F  1               ;
00191F  1               ;   Scratch: zp_scratch_lo/hi, zp_row (bullet slot index),
00191F  1               ;            zp_col (shield index during inner scan).
00191F  1               ;******************************************************************
00191F  1               check_invbullet_shields:
00191F  1  A2 00           ldx #0                 ; outer loop: invader bullet slot
001921  1               @ibul_loop:
001921  1  86 rr           stx zp_row             ; save slot before any branch
001923  1  B5 rr           lda ibul_active, x
001925  1  F0 7B           beq @next_ibul
001927  1               
001927  1                  ; --- Y quick check ---
001927  1                  ; (1) ibul_y+8 > SHIELD_Y
001927  1  B5 rr           lda ibul_y_lo, x
001929  1  18              clc
00192A  1  69 08           adc #8
00192C  1  85 rr           sta zp_scratch_lo
00192E  1  B5 rr           lda ibul_y_hi, x
001930  1  69 00           adc #0
001932  1  85 rr           sta zp_scratch_hi
001934  1  A5 rr           lda zp_scratch_lo
001936  1  38              sec
001937  1  E9 60           sbc #<SHIELD_Y
001939  1  A5 rr           lda zp_scratch_hi
00193B  1  E9 01           sbc #>SHIELD_Y
00193D  1  30 63           bmi @next_ibul
00193F  1               
00193F  1                  ; (2) ibul_y < SHIELD_Y+32
00193F  1  A6 rr           ldx zp_row
001941  1  B5 rr           lda ibul_y_lo, x
001943  1  38              sec
001944  1  E9 80           sbc #<(SHIELD_Y + 32)
001946  1  B5 rr           lda ibul_y_hi, x
001948  1  E9 01           sbc #>(SHIELD_Y + 32)
00194A  1  10 56           bpl @next_ibul
00194C  1               
00194C  1                  ; --- Y overlaps: scan shields with Y register ---
00194C  1  A0 00           ldy #0
00194E  1               @sld_scan:
00194E  1  B9 rr rr        lda shield_damage, y
001951  1  C9 08           cmp #8
001953  1  B0 48           bcs @next_sld_y        ; destroyed
001955  1               
001955  1                  ; X check (1): ibul_x+8 > shield_x[y]
001955  1  A6 rr           ldx zp_row
001957  1  B5 rr           lda ibul_x_lo, x
001959  1  18              clc
00195A  1  69 08           adc #8
00195C  1  85 rr           sta zp_scratch_lo
00195E  1  B5 rr           lda ibul_x_hi, x
001960  1  69 00           adc #0
001962  1  85 rr           sta zp_scratch_hi
001964  1  A5 rr           lda zp_scratch_lo
001966  1  38              sec
001967  1  F9 3C 1F        sbc shield_x_lo, y
00196A  1  A5 rr           lda zp_scratch_hi
00196C  1  F9 40 1F        sbc shield_x_hi, y
00196F  1  30 2C           bmi @next_sld_y
001971  1               
001971  1                  ; X check (2): ibul_x < shield_x[y]+32
001971  1  B9 3C 1F        lda shield_x_lo, y
001974  1  18              clc
001975  1  69 20           adc #32
001977  1  85 rr           sta zp_scratch_lo
001979  1  B9 40 1F        lda shield_x_hi, y
00197C  1  69 00           adc #0
00197E  1  85 rr           sta zp_scratch_hi
001980  1  A6 rr           ldx zp_row
001982  1  B5 rr           lda ibul_x_lo, x
001984  1  38              sec
001985  1  E5 rr           sbc zp_scratch_lo
001987  1  B5 rr           lda ibul_x_hi, x
001989  1  E5 rr           sbc zp_scratch_hi
00198B  1  10 10           bpl @next_sld_y
00198D  1               
00198D  1                  ; --- HIT ---
00198D  1  98              tya                    ; shield index → A → X for damage_shield
00198E  1  AA              tax
00198F  1  20 9B 18        jsr damage_shield
001992  1  A6 rr           ldx zp_row             ; restore bullet slot
001994  1  74 rr           stz ibul_active, x
001996  1  20 5A 10        jsr update_inv_bullet_sprite
001999  1  A6 rr           ldx zp_row
00199B  1  80 05           bra @next_ibul         ; done with this bullet
00199D  1               
00199D  1               @next_sld_y:
00199D  1  C8              iny
00199E  1  C0 04           cpy #4
0019A0  1  D0 AC           bne @sld_scan
0019A2  1               
0019A2  1               @next_ibul:
0019A2  1  A6 rr           ldx zp_row
0019A4  1  E8              inx
0019A5  1  E0 03           cpx #3
0019A7  1  F0 03           beq @cis_done
0019A9  1  4C 21 19        jmp @ibul_loop
0019AC  1               @cis_done:
0019AC  1  60              rts
