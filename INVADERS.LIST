0015A0  1                  ; --- sprite 44 (Type A, crab/green): attr $1FC00+44*8=$1FD60 ---
0015A0  1                  ; addr[12:5] = VRAM_INV_A_F0>>5 = $00100>>5 = $08
0015A0  1  A9 11           lda #$11
0015A2  1  8D 22 9F        sta VERA_addr_bank
0015A5  1  A9 FD           lda #$FD               ; high byte of $1FD60
0015A7  1  8D 21 9F        sta VERA_addr_high
0015AA  1  A9 60           lda #$60               ; low byte of $1FD60
0015AC  1  8D 20 9F        sta VERA_addr_low
0015AF  1  A9 08           lda #$08               ; byte 0: addr[12:5]
0015B1  1  8D 23 9F        sta VERA_data0
0015B4  1  A9 00           lda #$00
0015B6  1  8D 23 9F        sta VERA_data0
0015B9  1  A9 60           lda #96                ; X
0015BB  1  8D 23 9F        sta VERA_data0
0015BE  1  A9 00           lda #0
0015C0  1  8D 23 9F        sta VERA_data0
0015C3  1  A9 D0           lda #208               ; Y (row 13: 13*16=208)
0015C5  1  8D 23 9F        sta VERA_data0
0015C8  1  A9 00           lda #0
0015CA  1  8D 23 9F        sta VERA_data0
0015CD  1  A9 0C           lda #SPR_Z_FRONT
