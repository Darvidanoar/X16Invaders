0011D6  1  F0 06           beq @go_ctr_done
0011D8  1  20 D2 FF        jsr CHROUT
0011DB  1  E8              inx
0011DC  1  80 F5           bra @go_ctr_lp
0011DE  1               @go_ctr_done:
0011DE  1               
0011DE  1                  ; wait 300 frames (≈ 5 seconds at 60 Hz) using 16-bit countdown in scratch
0011DE  1  A9 2C           lda #<300
0011E0  1  85 rr           sta zp_scratch_lo
0011E2  1  A9 01           lda #>300
0011E4  1  85 rr           sta zp_scratch_hi
