001384  1  29 04           and #KEY_FIRE
001386  1  D0 04           bne @wc_advance
001388  1               
001388  1  C6 rr           dec zp_scratch_lo
00138A  1  D0 EA           bne wave_clear_loop       ; timer not yet zero
00138C  1                  ; fall through when timer expires
00138C  1               
00138C  1               @wc_advance:
00138C  1  4C 97 13        jmp next_wave
00138F  1               
00138F  1               @wc_quit:
