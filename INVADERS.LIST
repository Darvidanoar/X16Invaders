0015FE  1               
0015FE  1                  ; --- palette entry 7 → dark green (R=0, G=$A, B=0) ---
0015FE  1                  ; Palette byte 0: G[3:0] B[3:0] = $A0;  byte 1: R[3:0] = $00
0015FE  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_palette + 14), 1   ; entry 7 = offset 14 bytes
001602  1  9F A9 FA 8D  
001606  1  21 9F A9 0E  
