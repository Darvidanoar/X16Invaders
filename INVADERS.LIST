0018F9  1               ;******************************************************************
0018F9  1               ; check_invbullet_shields — test each active invader bullet vs all
0018F9  1               ;   4 shields.  Same AABB logic as check_bullet_shields but loops
0018F9  1               ;   over 3 bullet slots (ibul_active / ibul_x / ibul_y arrays).
0018F9  1               ;
0018F9  1               ;   Scratch: zp_scratch_lo/hi, zp_row (bullet slot index),
0018F9  1               ;            zp_col (shield index during inner scan).
0018F9  1               ;******************************************************************
0018F9  1               check_invbullet_shields:
0018F9  1  A2 00           ldx #0                 ; outer loop: invader bullet slot
0018FB  1               @ibul_loop:
0018FB  1  86 rr           stx zp_row             ; save slot before any branch
0018FD  1  B5 rr           lda ibul_active, x
0018FF  1  F0 7B           beq @next_ibul
001901  1               
001901  1                  ; --- Y quick check ---
001901  1                  ; (1) ibul_y+8 > SHIELD_Y
001901  1  B5 rr           lda ibul_y_lo, x
001903  1  18              clc
001904  1  69 08           adc #8
001906  1  85 rr           sta zp_scratch_lo
001908  1  B5 rr           lda ibul_y_hi, x
00190A  1  69 00           adc #0
00190C  1  85 rr           sta zp_scratch_hi
00190E  1  A5 rr           lda zp_scratch_lo
001910  1  38              sec
001911  1  E9 60           sbc #<SHIELD_Y
001913  1  A5 rr           lda zp_scratch_hi
001915  1  E9 01           sbc #>SHIELD_Y
001917  1  30 63           bmi @next_ibul
001919  1               
001919  1                  ; (2) ibul_y < SHIELD_Y+32
001919  1  A6 rr           ldx zp_row
00191B  1  B5 rr           lda ibul_y_lo, x
00191D  1  38              sec
00191E  1  E9 80           sbc #<(SHIELD_Y + 32)
001920  1  B5 rr           lda ibul_y_hi, x
001922  1  E9 01           sbc #>(SHIELD_Y + 32)
001924  1  10 56           bpl @next_ibul
001926  1               
001926  1                  ; --- Y overlaps: scan shields with Y register ---
001926  1  A0 00           ldy #0
001928  1               @sld_scan:
001928  1  B9 rr rr        lda shield_damage, y
00192B  1  C9 08           cmp #8
00192D  1  B0 48           bcs @next_sld_y        ; destroyed
00192F  1               
00192F  1                  ; X check (1): ibul_x+8 > shield_x[y]
00192F  1  A6 rr           ldx zp_row
001931  1  B5 rr           lda ibul_x_lo, x
001933  1  18              clc
001934  1  69 08           adc #8
001936  1  85 rr           sta zp_scratch_lo
001938  1  B5 rr           lda ibul_x_hi, x
00193A  1  69 00           adc #0
00193C  1  85 rr           sta zp_scratch_hi
00193E  1  A5 rr           lda zp_scratch_lo
001940  1  38              sec
001941  1  F9 16 1F        sbc shield_x_lo, y
001944  1  A5 rr           lda zp_scratch_hi
001946  1  F9 1A 1F        sbc shield_x_hi, y
001949  1  30 2C           bmi @next_sld_y
00194B  1               
00194B  1                  ; X check (2): ibul_x < shield_x[y]+32
00194B  1  B9 16 1F        lda shield_x_lo, y
00194E  1  18              clc
00194F  1  69 20           adc #32
001951  1  85 rr           sta zp_scratch_lo
001953  1  B9 1A 1F        lda shield_x_hi, y
001956  1  69 00           adc #0
001958  1  85 rr           sta zp_scratch_hi
00195A  1  A6 rr           ldx zp_row
00195C  1  B5 rr           lda ibul_x_lo, x
00195E  1  38              sec
00195F  1  E5 rr           sbc zp_scratch_lo
001961  1  B5 rr           lda ibul_x_hi, x
001963  1  E5 rr           sbc zp_scratch_hi
001965  1  10 10           bpl @next_sld_y
001967  1               
001967  1                  ; --- HIT ---
001967  1  98              tya                    ; shield index → A → X for damage_shield
001968  1  AA              tax
001969  1  20 75 18        jsr damage_shield
00196C  1  A6 rr           ldx zp_row             ; restore bullet slot
00196E  1  74 rr           stz ibul_active, x
001970  1  20 57 10        jsr update_inv_bullet_sprite
001973  1  A6 rr           ldx zp_row
001975  1  80 05           bra @next_ibul         ; done with this bullet
001977  1               
