0011C9  1  A2 1E           ldx #30
0011CB  1  A0 23           ldy #35
0011CD  1  18              clc
0011CE  1  20 F0 FF        jsr PLOT
0011D1  1  A2 00           ldx #0
0011D3  1               @go_ctr_lp:
