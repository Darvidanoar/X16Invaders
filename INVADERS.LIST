00135A  1  20 EE 13        jsr print_dec_byte
00135D  1               
00135D  1  A9 0E           lda #14
00135F  1  A0 08           ldy #8
001361  1  18              clc
001362  1  20 F0 FF        jsr PLOT
001365  1  A2 00           ldx #0
001367  1  BD 44 1D     @wc3: lda str_wave_continue, x
