00126B  1  4C 93 12        jmp restart_game
00126E  1               
00126E  1               ;******************************************************************
00126E  1               ; update_hi_score — copy score → hi_score when score > hi_score
00126E  1               ;   BCD compare: check hi byte, then mid, then lo.
00126E  1               ;******************************************************************
00126E  1               update_hi_score:
00126E  1  A5 rr           lda score_hi
001270  1  C5 rr           cmp hi_score_hi
001272  1  90 1E           bcc @no_update
001274  1  D0 10           bne @do_update
001276  1  A5 rr           lda score_mid
001278  1  C5 rr           cmp hi_score_mid
00127A  1  90 16           bcc @no_update
00127C  1  D0 08           bne @do_update
00127E  1  A5 rr           lda score_lo
001280  1  C5 rr           cmp hi_score_lo
001282  1  90 0E           bcc @no_update
001284  1  F0 0C           beq @no_update            ; equal → no change
001286  1               @do_update:
001286  1  A5 rr           lda score_lo
001288  1  85 rr           sta hi_score_lo
00128A  1  A5 rr           lda score_mid
00128C  1  85 rr           sta hi_score_mid
00128E  1  A5 rr           lda score_hi
001290  1  85 rr           sta hi_score_hi
001292  1               @no_update:
001292  1  60              rts
001293  1               
001293  1               ;******************************************************************
001293  1               ; restart_game — reset all gameplay state; reuse VRAM data; jump to main_loop
001293  1               ;   Does NOT reset hi-score.
001293  1               ;******************************************************************
001293  1               restart_game:
001293  1  64 rr           stz score_lo
001295  1  64 rr           stz score_mid
001297  1  64 rr           stz score_hi
001299  1  A9 01           lda #1
00129B  1  85 rr           sta wave
00129D  1  A9 32           lda #INV_MOVE_SPEED_INIT
00129F  1  85 rr           sta wave_init_speed
0012A1  1               
0012A1  1  20 82 09        jsr init_player           ; resets player_x, lives=3, inv_hit_timer=0
0012A4  1               
0012A4  1                  ; hide + deactivate player bullet
0012A4  1  64 rr           stz bullet_active
0012A6  1  20 47 0E        jsr update_bullet_sprite
0012A9  1               
0012A9  1                  ; reset explosion timer and hide sprite 4
0012A9  1  64 rr           stz exp_timer
0012AB  1  9C 25 9F        stz VERA_ctrl
0012AE  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1
0012B2  1  9F A9 FC 8D  
0012B6  1  21 9F A9 26  
0012BD  1  A9 00           lda #$00
0012BF  1  8D 23 9F        sta VERA_data0
0012C2  1               
0012C2  1                  ; deactivate all invader bullets and hide their sprites
0012C2  1  64 rr           stz ibul_active+0
0012C4  1  64 rr           stz ibul_active+1
0012C6  1  64 rr           stz ibul_active+2
0012C8  1  A2 00           ldx #0
0012CA  1               @rst_ibul:
0012CA  1  20 38 10        jsr update_inv_bullet_sprite
0012CD  1  E8              inx
0012CE  1  E0 03           cpx #3
0012D0  1  D0 F8           bne @rst_ibul
0012D2  1  A9 5A           lda #INV_FIRE_TIMER_INIT
0012D4  1  85 rr           sta inv_fire_timer
0012D6  1               
0012D6  1                  ; reset UFO state and silence all sounds
0012D6  1  64 rr           stz ufo_active
0012D8  1  20 71 1A        jsr snd_stop_ufo_drone
0012DB  1  20 15 1B        jsr snd_stop_march
0012DE  1  20 88 19        jsr update_ufo_sprite
0012E1  1  A9 58           lda #<UFO_TIMER_INIT
0012E3  1  85 rr           sta ufo_timer_lo
0012E5  1  A9 02           lda #>UFO_TIMER_INIT
0012E7  1  85 rr           sta ufo_timer_hi
0012E9  1  64 rr           stz shot_count
0012EB  1               
0012EB  1                  ; reset invader grid (alive bits, position, speed, sprites)
0012EB  1  20 90 0B        jsr init_invaders
0012EE  1                  ; reset shields (damage counters, sprite tiles)
0012EE  1  20 86 15        jsr init_shields
0012F1  1               
