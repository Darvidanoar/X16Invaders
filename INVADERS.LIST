0011FD  1               ;------------------------------------------------------------------
0011FD  1               ; game_over_loop — blink "SPACE = PLAY AGAIN"; wait for input
0011FD  1               ;------------------------------------------------------------------
0011FD  1               game_over_loop:
0011FD  1  20 1C 09        jsr wait_vsync
001200  1  E6 rr           inc frame_count
001202  1  20 1E 09        jsr update_input
001205  1               
001205  1  A5 rr           lda key_last
001207  1  C9 03           cmp #KEY_RUN_STOP
001209  1  F0 39           beq @go_quit
00120B  1               
00120B  1  A5 rr           lda key_flags
00120D  1  29 04           and #KEY_FIRE
00120F  1  D0 3B           bne @go_restart
001211  1               
001211  1  A5 rr           lda frame_count
001213  1  29 20           and #$20                  ; bit 5: flips every 32 frames ≈ 2 Hz blink
001215  1  D0 15           bne @go_show
001217  1               @go_hide:
001217  1  A9 0F           lda #15
001219  1  A0 0B           ldy #11
00121B  1  18              clc
00121C  1  20 F0 FF        jsr PLOT
00121F  1  A2 12           ldx #18
001221  1  A9 20        @go_erase: lda #' '
001223  1  20 D2 FF        jsr CHROUT
001226  1  CA              dex
001227  1  D0 F8           bne @go_erase
001229  1  4C FD 11        jmp game_over_loop
00122C  1               @go_show:
00122C  1  A9 0F           lda #15
00122E  1  A0 0B           ldy #11
001230  1  18              clc
001231  1  20 F0 FF        jsr PLOT
001234  1  A2 00           ldx #0
001236  1  BD 48 1A     @go_print: lda str_play_again, x
001239  1  F0 06           beq @go_pd
00123B  1  20 D2 FF        jsr CHROUT
00123E  1  E8              inx
00123F  1  80 F5           bra @go_print
001241  1               @go_pd:
001241  1  4C FD 11        jmp game_over_loop
001244  1               
001244  1               @go_quit:
001244  1  A9 93           lda #PETSCII_CLR
001246  1  20 D2 FF        jsr CHROUT
001249  1  4C 47 FF        jmp ENTER_BASIC
00124C  1               
00124C  1               @go_restart:
00124C  1  4C 74 12        jmp restart_game
00124F  1               
00124F  1               ;******************************************************************
00124F  1               ; update_hi_score — copy score → hi_score when score > hi_score
00124F  1               ;   BCD compare: check hi byte, then mid, then lo.
00124F  1               ;******************************************************************
00124F  1               update_hi_score:
00124F  1  A5 rr           lda score_hi
001251  1  C5 rr           cmp hi_score_hi
001253  1  90 1E           bcc @no_update
001255  1  D0 10           bne @do_update
001257  1  A5 rr           lda score_mid
001259  1  C5 rr           cmp hi_score_mid
00125B  1  90 16           bcc @no_update
00125D  1  D0 08           bne @do_update
00125F  1  A5 rr           lda score_lo
001261  1  C5 rr           cmp hi_score_lo
001263  1  90 0E           bcc @no_update
001265  1  F0 0C           beq @no_update            ; equal → no change
001267  1               @do_update:
001267  1  A5 rr           lda score_lo
001269  1  85 rr           sta hi_score_lo
00126B  1  A5 rr           lda score_mid
00126D  1  85 rr           sta hi_score_mid
00126F  1  A5 rr           lda score_hi
001271  1  85 rr           sta hi_score_hi
001273  1               @no_update:
001273  1  60              rts
001274  1               
001274  1               ;******************************************************************
001274  1               ; restart_game — reset all gameplay state; reuse VRAM data; jump to main_loop
001274  1               ;   Does NOT reset hi-score.
001274  1               ;******************************************************************
001274  1               restart_game:
001274  1  64 rr           stz score_lo
001276  1  64 rr           stz score_mid
001278  1  64 rr           stz score_hi
00127A  1               
00127A  1  20 69 09        jsr init_player           ; resets player_x, lives=3, inv_hit_timer=0
00127D  1               
00127D  1                  ; hide + deactivate player bullet
00127D  1  64 rr           stz bullet_active
00127F  1  20 2B 0E        jsr update_bullet_sprite
001282  1               
001282  1                  ; reset explosion timer and hide sprite 4
001282  1  64 rr           stz exp_timer
001284  1  9C 25 9F        stz VERA_ctrl
001287  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1
00128B  1  9F A9 FC 8D  
00128F  1  21 9F A9 26  
001296  1  A9 00           lda #$00
001298  1  8D 23 9F        sta VERA_data0
00129B  1               
00129B  1                  ; deactivate all invader bullets and hide their sprites
00129B  1  64 rr           stz ibul_active+0
00129D  1  64 rr           stz ibul_active+1
00129F  1  64 rr           stz ibul_active+2
0012A1  1  A2 00           ldx #0
0012A3  1               @rst_ibul:
0012A3  1  20 1C 10        jsr update_inv_bullet_sprite
0012A6  1  E8              inx
0012A7  1  E0 03           cpx #3
0012A9  1  D0 F8           bne @rst_ibul
0012AB  1  A9 5A           lda #INV_FIRE_TIMER_INIT
0012AD  1  85 rr           sta inv_fire_timer
0012AF  1               
0012AF  1                  ; reset UFO state and silence drone
0012AF  1  64 rr           stz ufo_active
0012B1  1  20 2E 19        jsr snd_stop_ufo_drone
0012B4  1  20 45 18        jsr update_ufo_sprite
0012B7  1  A9 58           lda #<UFO_TIMER_INIT
0012B9  1  85 rr           sta ufo_timer_lo
0012BB  1  A9 02           lda #>UFO_TIMER_INIT
0012BD  1  85 rr           sta ufo_timer_hi
0012BF  1  64 rr           stz shot_count
