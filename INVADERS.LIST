0011EE  1  85 rr           sta zp_scratch_lo
0011F0  1  A5 rr           lda zp_scratch_hi
0011F2  1  E9 00           sbc #0
0011F4  1  85 rr           sta zp_scratch_hi
0011F6  1  05 rr           ora zp_scratch_lo
0011F8  1  D0 EC           bne @go_pause
0011FA  1               
