001987  1               ;******************************************************************
001987  1               ; add_score_bcd — add a 2-byte BCD pair to the score
001987  1               ;   A = BCD low byte (units/tens), Y = BCD mid byte (hundreds/thousands)
001987  1               ;******************************************************************
001987  1               add_score_bcd:
001987  1  F8              sed
001988  1  18              clc
001989  1  65 rr           adc score_lo
00198B  1  85 rr           sta score_lo
00198D  1  98              tya
00198E  1  65 rr           adc score_mid
001990  1  85 rr           sta score_mid
001992  1  A5 rr           lda score_hi
001994  1  69 00           adc #0
001996  1  85 rr           sta score_hi
001998  1  D8              cld
001999  1  60              rts
