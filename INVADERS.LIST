0014A3  1  F0 06           beq @lp1_done
0014A5  1  20 D2 FF        jsr CHROUT
0014A8  1  E8              inx
0014A9  1  80 F5           bra @lp1
0014AB  1               @lp1_done:
0014AB  1               
0014AB  1                  ; Row 3, col 16: "HI-SCORE"
0014AB  1  A2 01           ldx #1
0014AD  1  A0 3F           ldy #63
0014AF  1  18              clc
0014B0  1  20 F0 FF        jsr PLOT
0014B3  1  A2 00           ldx #0
0014B5  1  BD 65 1D     @lp2: lda str_hi_score_lbl, x
0014B8  1  F0 06           beq @lp2_done
0014BA  1  20 D2 FF        jsr CHROUT
0014BD  1  E8              inx
0014BE  1  80 F5           bra @lp2
0014C0  1               @lp2_done:
0014C0  1               
0014C0  1                  ; Row 4, col 17: hi-score 6 BCD digits (000000 at start)
0014C0  1  A2 01           ldx #1
0014C2  1  A0 49           ldy #73
0014C4  1  18              clc
0014C5  1  20 F0 FF        jsr PLOT
0014C8  1  A5 rr           lda hi_score_hi
0014CA  1  20 33 1D        jsr print_hex_byte
0014CD  1  A5 rr           lda hi_score_mid
0014CF  1  20 33 1D        jsr print_hex_byte
0014D2  1  A5 rr           lda hi_score_lo
0014D4  1  20 33 1D        jsr print_hex_byte
0014D7  1               
0014D7  1                  ; Row 5, col 5: "?UFO? = ??? PTS"
0014D7  1  A2 09           ldx #9
0014D9  1  A0 09           ldy #9
0014DB  1  18              clc
0014DC  1  20 F0 FF        jsr PLOT
0014DF  1  A2 00           ldx #0
0014E1  1  BD 6D 1D     @lp3: lda str_ufo_score, x
0014E4  1  F0 06           beq @lp3_done
0014E6  1  20 D2 FF        jsr CHROUT
0014E9  1  E8              inx
0014EA  1  80 F5           bra @lp3
0014EC  1               @lp3_done:
0014EC  1               
0014EC  1                  ; Sample invader sprites (Types C, B, A) + score labels
0014EC  1  20 05 15        jsr show_title_sprites
0014EF  1               
0014EF  1                  ; Row 19, col 12: "Q TO QUIT"  (Plot: Set X to Row, Set Y to Col)
0014EF  1  A2 25           ldx #37
0014F1  1  A0 23           ldy #35
0014F3  1  18              clc
0014F4  1  20 F0 FF        jsr PLOT
0014F7  1  A2 00           ldx #0
0014F9  1  BD 06 1E     @lp4: lda str_run_stop_hint, x
0014FC  1  F0 06           beq @lp4_done
0014FE  1  20 D2 FF        jsr CHROUT
001501  1  E8              inx
001502  1  80 F5           bra @lp4
001504  1               @lp4_done:
