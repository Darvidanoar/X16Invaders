001C13  1  10 00 00 00  
001C17  1                  ; row 2
001C17  1  00 00 00 01     .byte $00,$00,$00,$01,$10,$00,$00,$00
001C1B  1  10 00 00 00  
001C1F  1                  ; row 3
001C1F  1  00 00 00 01     .byte $00,$00,$00,$01,$10,$00,$00,$00
001C23  1  10 00 00 00  
001C27  1                  ; row 4
001C27  1  00 00 01 11     .byte $00,$00,$01,$11,$11,$10,$00,$00
001C2B  1  11 10 00 00  
001C2F  1                  ; row 5
001C2F  1  00 00 11 11     .byte $00,$00,$11,$11,$11,$11,$00,$00
001C33  1  11 11 00 00  
001C37  1                  ; row 6
001C37  1  00 01 11 11     .byte $00,$01,$11,$11,$11,$11,$10,$00
001C3B  1  11 11 10 00  
001C3F  1                  ; row 7
001C3F  1  00 01 11 11     .byte $00,$01,$11,$11,$11,$11,$10,$00
001C43  1  11 11 10 00  
