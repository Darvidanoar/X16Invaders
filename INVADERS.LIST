0016E6  1               ;******************************************************************
0016E6  1               ; player_spr_data — 16x16 4bpp sprite, 128 bytes
0016E6  1               ;
0016E6  1               ;   Color 0 = transparent, Color 1 = white (default palette index 1)
0016E6  1               ;   Design: classic upward-pointing triangular ship with engine notches
0016E6  1               ;
0016E6  1               ;   Each byte encodes 2 pixels: high nibble = left, low nibble = right
0016E6  1               ;   Columns: 0123456789ABCDEF
0016E6  1               ;
0016E6  1               ;   Row  0:  .......1........   cannon tip
0016E6  1               ;   Row  1:  .......11.......
0016E6  1               ;   Row  2:  ......111.......
0016E6  1               ;   Row  3:  ......111.......
0016E6  1               ;   Row  4:  .....11111......
0016E6  1               ;   Row  5:  .....1111111....
0016E6  1               ;   Row  6:  ...111111111....
0016E6  1               ;   Row  7:  ..11111111111...
0016E6  1               ;   Row  8:  .1111111111111..
0016E6  1               ;   Row  9:  1111111111111111   full base
0016E6  1               ;   Row 10:  1111111111111111
0016E6  1               ;   Row 11:  1111111111111111
0016E6  1               ;   Row 12:  11..11111111..11   engine notches
0016E6  1               ;   Row 13:  11..11111111..11
0016E6  1               ;   Row 14:  ................
0016E6  1               ;   Row 15:  ................
0016E6  1               ;******************************************************************
0016E6  1               player_spr_data:
0016E6  1                  ; row 0
0016E6  1  00 00 00 00     .byte $00,$00,$00,$00,$00,$00,$00,$00
0016EA  1  00 00 00 00  
0016EE  1                  ; row 1
0016EE  1  00 00 00 01     .byte $00,$00,$00,$01,$10,$00,$00,$00
0016F2  1  10 00 00 00  
0016F6  1                  ; row 2
0016F6  1  00 00 00 01     .byte $00,$00,$00,$01,$10,$00,$00,$00
0016FA  1  10 00 00 00  
0016FE  1                  ; row 3
0016FE  1  00 00 00 01     .byte $00,$00,$00,$01,$10,$00,$00,$00
001702  1  10 00 00 00  
001706  1                  ; row 4
001706  1  00 00 01 11     .byte $00,$00,$01,$11,$11,$10,$00,$00
00170A  1  11 10 00 00  
00170E  1                  ; row 5
00170E  1  00 00 11 11     .byte $00,$00,$11,$11,$11,$11,$00,$00
001712  1  11 11 00 00  
001716  1                  ; row 6
001716  1  00 01 11 11     .byte $00,$01,$11,$11,$11,$11,$10,$00
00171A  1  11 11 10 00  
00171E  1                  ; row 7
00171E  1  00 01 11 11     .byte $00,$01,$11,$11,$11,$11,$10,$00
001722  1  11 11 10 00  
001726  1                  ; row 8
001726  1  01 11 11 11     .byte $01,$11,$11,$11,$11,$11,$11,$10
00172A  1  11 11 11 10  
00172E  1                  ; row 9
00172E  1  11 11 11 11     .byte $11,$11,$11,$11,$11,$11,$11,$11
001732  1  11 11 11 11  
001736  1                  ; row 10
001736  1  11 11 11 11     .byte $11,$11,$11,$11,$11,$11,$11,$11
00173A  1  11 11 11 11  
00173E  1                  ; row 11
00173E  1  11 11 11 11     .byte $11,$11,$11,$11,$11,$11,$11,$11
001742  1  11 11 11 11  
001746  1                  ; row 12  (engine notches: cols 2-3 and 12-13 transparent)
001746  1  11 00 11 11     .byte $11,$00,$11,$11,$11,$11,$00,$11
00174A  1  11 11 00 11  
00174E  1                  ; row 13
00174E  1  11 00 11 11     .byte $11,$00,$11,$11,$11,$11,$00,$11
001752  1  11 11 00 11  
001756  1                  ; row 14
001756  1  00 00 00 00     .byte $00,$00,$00,$00,$00,$00,$00,$00
00175A  1  00 00 00 00  
00175E  1                  ; row 15
