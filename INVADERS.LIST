000A66  1  A9 11 8D 22     VERA_SET_ADDR BULLET_SPRITE_ATTR, 1
000A6A  1  9F A9 FC 8D  
000A6E  1  21 9F A9 10  
000A75  1  A9 20           lda #$20                     ; byte 0: addr[12:5] = $00400>>5 = $20
000A77  1  8D 23 9F        sta VERA_data0
000A7A  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000A7C  1  8D 23 9F        sta VERA_data0
000A7F  1  A9 00           lda #$00                     ; byte 2: X lo (arbitrary; sprite disabled)
000A81  1  8D 23 9F        sta VERA_data0
000A84  1  A9 00           lda #$00                     ; byte 3: X hi
000A86  1  8D 23 9F        sta VERA_data0
000A89  1  A9 00           lda #$00                     ; byte 4: Y lo
000A8B  1  8D 23 9F        sta VERA_data0
000A8E  1  A9 00           lda #$00                     ; byte 5: Y hi
000A90  1  8D 23 9F        sta VERA_data0
000A93  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000A95  1  8D 23 9F        sta VERA_data0
000A98  1  A9 00           lda #SPR_8x8_PAL0            ; byte 7: 8x8, palette 0
000A9A  1  8D 23 9F        sta VERA_data0
000A9D  1               
