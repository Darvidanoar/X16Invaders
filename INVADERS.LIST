0015E9  1  A2 80           ldx #128
0015EB  1  BD 4F 23     @up_s0c: lda shield_tile_full + 128, x
0015EE  1  8D 23 9F        sta VERA_data0
0015F1  1  E8              inx
0015F2  1  D0 F7           bne @up_s0c
0015F4  1  A2 80           ldx #128
0015F6  1  BD CF 23     @up_s0d: lda shield_tile_full + 256, x
0015F9  1  8D 23 9F        sta VERA_data0
0015FC  1  E8              inx
