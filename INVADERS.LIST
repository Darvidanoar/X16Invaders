0011A9  1               ;******************************************************************
0011A9  1               ; game_over_screen — update hi-score, draw GAME OVER, wait for input
0011A9  1               ;   SPACE     → restart_game (full state reset + main_loop)
0011A9  1               ;   RUN/STOP  → exit to BASIC
0011A9  1               ;
0011A9  1               ;   Layout (40-col text):
0011A9  1               ;     Row  9, col 15: "GAME OVER"
0011A9  1               ;     Row 11, col 13: "SCORE: " + 6 BCD digits
0011A9  1               ;     Row 12, col 12: "HI-SCORE: " + 6 BCD digits
0011A9  1               ;     Row 15, col 11: "SPACE = PLAY AGAIN"  (blinks)
0011A9  1               ;     Row 17, col 12: "RUN/STOP TO QUIT"
0011A9  1               ;******************************************************************
0011A9  1               game_over_screen:
0011A9  1  20 93 1A        jsr snd_stop_ufo_drone    ; silence drone if UFO was active
0011AC  1  20 37 1B        jsr snd_stop_march        ; silence march beat
0011AF  1  20 9C 1B        jsr snd_stop_fire         ; silence fire tone
0011B2  1  20 01 1C        jsr snd_stop_exp          ; silence explosion noise
0011B5  1               
0011B5  1  20 84 12        jsr update_hi_score       ; copy score → hi_score if score is higher
0011B8  1               
0011B8  1  20 8B 15        jsr hide_all_inv_sprites  ; clear play field sprites
0011BB  1               
0011BB  1  A9 93           lda #PETSCII_CLR
0011BD  1  20 D2 FF        jsr CHROUT
0011C0  1               
