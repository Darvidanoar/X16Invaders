001766  1               ;******************************************************************
001766  1               ; bullet_spr_data — 8x8 4bpp, 32 bytes
001766  1               ;
001766  1               ;   Color 0 = transparent, Color 1 = white
001766  1               ;   Design: 2-pixel-wide vertical bar, centered in 8px columns 3-4
001766  1               ;
001766  1               ;   Each byte encodes 2 pixels: high nibble = left, low nibble = right
001766  1               ;   Columns:  0 1 | 2 3 | 4 5 | 6 7
001766  1               ;   Pattern:  . . | . 1 | 1 . | . .   → $00 $01 $10 $00
001766  1               ;   All 8 rows identical.
001766  1               ;******************************************************************
001766  1               bullet_spr_data:
001766  1  00 01 10 00     .byte $00,$01,$10,$00  ; row 0
00176A  1  00 01 10 00     .byte $00,$01,$10,$00  ; row 1
00176E  1  00 01 10 00     .byte $00,$01,$10,$00  ; row 2
001772  1  00 01 10 00     .byte $00,$01,$10,$00  ; row 3
001776  1  00 01 10 00     .byte $00,$01,$10,$00  ; row 4
00177A  1  00 01 10 00     .byte $00,$01,$10,$00  ; row 5
00177E  1  00 01 10 00     .byte $00,$01,$10,$00  ; row 6
001782  1  00 01 10 00     .byte $00,$01,$10,$00  ; row 7
