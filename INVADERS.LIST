000810  1               ;******************************************************************
000810  1               ; Constants
000810  1               ;******************************************************************
000810  1               
000810  1               ; VERA display control
000810  1               VERA_SPRITE_EN  = %01000000      ; VERA_dc_video bit 6: enable sprites
000810  1               
000810  1               ; PETSCII control codes
000810  1               PETSCII_WHITE   = $05            ; set text color to white
000810  1               PETSCII_CLR     = $93            ; clear screen and home cursor
000810  1               PETSCII_HOME    = $13            ; home cursor (no clear)
000810  1               PETSCII_RETURN  = $0D            ; carriage return
000810  1               
000810  1               ; SCREEN_SET_CHARSET font numbers (call address $FF62)
000810  1               CHARSET_UPPER   = 1              ; Commodore upper/graphics: $41-$5A = A-Z
000810  1               CHARSET_LOWER   = 2              ; Commodore lower/upper:    $41-$5A = a-z (lowercase)
000810  1               
000810  1               ; Key codes (PETSCII)
000810  1               KEY_RUN_STOP    = $03            ; RUN/STOP — exit game
000810  1               
000810  1               ; Input flag bits (key_flags)
000810  1               KEY_LEFT        = %00000001
000810  1               KEY_RIGHT       = %00000010
000810  1               KEY_FIRE        = %00000100
000810  1               
000810  1               ; JOYSTICK_GET .A return: {B,Y,Sel,Sta,Up,Dn,Left,Right} active low
000810  1               JOY_RIGHT       = %00000001     ; bit 0
000810  1               JOY_LEFT        = %00000010     ; bit 1
000810  1               
000810  1               ; Player ship — all positions in VERA 640x480 coordinate space
000810  1               PLAYER_Y        = 420            ; fixed Y, near bottom (479 = bottom edge)
000810  1               PLAYER_X_INIT   = 312            ; starting X, centred  ((640-16)/2)
000810  1               PLAYER_X_MIN    = 8              ; left  boundary (sprite left edge)
000810  1               PLAYER_X_MAX    = 616            ; right boundary (640 - 16px sprite - 8px margin)
000810  1               PLAYER_SPEED    = 4              ; pixels per frame
000810  1               
000810  1               ; Sprite attribute encoding helpers
000810  1               SPRITE1_ATTR    = $1FC08 ; sprite 1 attribute base ($1FC00=sprite 0, reserved for KERNAL mouse)
000810  1               SPR_Z_FRONT     = %00001100     ; byte 6: z-depth = %11 in bits 3-2 (in front of all layers)
000810  1               SPR_16x16_PAL0  = %01010000     ; byte 7: width=1(16px), height=1(16px), palette_off=0
000810  1               SPR_32x16_PAL0  = %10010000     ; byte 7: width=2(32px), height=1(16px), palette_off=0
000810  1               SPR_32x32_PAL0  = %10100000     ; byte 7: width=2(32px), height=2(32px), palette_off=0
000810  1               SPR_8x8_PAL0    = %00000000     ; byte 7: width=0(8px),  height=0(8px),  palette_off=0
000810  1               
000810  1               ; Explosion sprite (slot 4)
000810  1               VRAM_EXPLOSION     = $00440     ; explosion pixel data (128 bytes, 16x16 4bpp)
000810  1               EXPLODE_SPRITE_ATTR = $1FC20    ; sprite 4 attribute base (explosion)
000810  1               EXPLODE_FRAMES     = 30         ; display duration in frames (~0.5 sec at 60 Hz)
000810  1               
000810  1               ; Invader bullets (sprite slots 5-7)
000810  1               VRAM_INV_BULLET    = $00420     ; invader bullet pixel data (32 bytes, 8x8 4bpp)
000810  1               INV_BULLET_SPR_BASE = $1FC28    ; sprite 5 attribute base (first invader bullet)
000810  1               INV_BULLET_SPEED   = 6          ; VERA pixels per frame downward (=3 game pixels)
000810  1               INV_FIRE_TIMER_MIN = 10         ; minimum frames between fire attempts
000810  1               INV_FIRE_TIMER_INIT = 90        ; frames before first shot
000810  1               
000810  1               ; Player lives
000810  1               LIVES_INIT         = 3          ; starting lives
000810  1               INV_HIT_FRAMES     = 120        ; invincibility duration after being hit (2 sec at 60 Hz)
000810  1               
000810  1               ; Shields
000810  1               SHIELD_Y           = 352        ; VERA Y coordinate for all 4 shields (176 display pixels)
000810  1               SHIELD_SPR_BASE    = $1FE10     ; sprite slot 66 attr ($1FC00 + 66*8); slots 8-65 in use
000810  1               VRAM_SHIELD_FULL   = $00500     ; 512-byte 32x32 4bpp tile: intact
000810  1               VRAM_SHIELD_DMG1   = $00700     ; 12% damaged
000810  1               VRAM_SHIELD_DMG2   = $00900     ; 25% damaged
000810  1               VRAM_SHIELD_DMG3   = $00B00     ; 37% damaged
000810  1               VRAM_SHIELD_DMG4   = $00D00     ; 50% damaged
000810  1               VRAM_SHIELD_DMG5   = $00F00     ; 62% damaged
000810  1               VRAM_SHIELD_DMG6   = $01100     ; 75% damaged
000810  1               VRAM_SHIELD_DMG7   = $01300     ; nearly destroyed
000810  1               
000810  1               ; Player bullet
000810  1               BULLET_SPRITE_ATTR = $1FC10     ; sprite 2 attribute base (player bullet)
000810  1               VRAM_BULLET     = $00400        ; player bullet pixel data (32 bytes, 8x8 4bpp)
000810  1               BULLET_SPEED    = 12            ; VERA pixels per frame upward (= 6 game pixels)
000810  1               BULLET_Y_INIT   = PLAYER_Y - 8 ; bullet starts just above player ship top
000810  1               
000810  1               ; Invader grid geometry (VERA 640x480 coordinate space)
000810  1               INV_GRID_X_INIT   = 112         ; left-column X at start (centered: (640 - 10*40 - 16) / 2 = 112)
000810  1               INV_GRID_Y_BASE   = 80          ; top-row Y, fixed base (drops added via inv_offset_y)
000810  1               INV_SPACING_X     = 40          ; VERA pixels between invader column origins
000810  1               INV_SPACING_Y     = 48          ; VERA pixels between invader row origins
000810  1               INV_STEP_X        = 4           ; VERA pixels per march step
000810  1               INV_DROP_Y        = 16          ; VERA pixels per grid drop
000810  1               INV_MOVE_SPEED_INIT = 50        ; frames between march steps (initial)
000810  1               INV_COUNT_INIT    = 55
000810  1               INV_MOVE_SPEED_MIN = 5           ; minimum frames per march step
000810  1               
000810  1               ; Grid boundary: when grid_x reaches these values, reverse and drop
000810  1               ; Rightmost invader base X = grid_x + 10*INV_SPACING_X (=400). Right wall = 624 (640-16px).
000810  1               ; So right limit = 624 - 400 - 16 = 208
000810  1               INV_X_RIGHT_LIM   = 208
000810  1               INV_X_LEFT_LIM    = 16          ; leftmost sprite at x=grid_x must stay >= 16
000810  1               
000810  1               ; VRAM addresses for invader sprite pixel data (128 bytes each, 16x16 4bpp)
000810  1               VRAM_INV_A_F0   = $00100        ; Type A (crab,   bottom rows 3-4), frame 0
000810  1               VRAM_INV_A_F1   = $00180        ; Type A frame 1
000810  1               VRAM_INV_B_F0   = $00200        ; Type B (octopus, middle rows 1-2), frame 0
000810  1               VRAM_INV_B_F1   = $00280        ; Type B frame 1
000810  1               VRAM_INV_C_F0   = $00300        ; Type C (squid,   top row 0), frame 0
000810  1               VRAM_INV_C_F1   = $00380        ; Type C frame 1
000810  1               
000810  1               ; Sprite addr[12:5] byte values for each type/frame (= VRAM_addr >> 5)
000810  1               ;   VRAM $00100>>5=$08  $00180>>5=$0C  $00200>>5=$10  $00280>>5=$14  $00300>>5=$18  $00380>>5=$1C
000810  1               INV_ATTR_BASE   = $1FC58        ; sprite slot 11 = first invader ($1FC00 + 11*8)
000810  1               INV_SPRITE_SLOT = 11            ; first invader sprite slot index
000810  1               
000810  1               ;******************************************************************
000810  1               ; start — main program entry point
000810  1               ;******************************************************************
000810  1               start:
000810  1  78              sei                           ; disable interrupts during init
000811  1               
000811  1                  ; Switch to 40-column text mode (mode 0)
000811  1                  ; Carry clear = SET mode (carry set = READ mode)
000811  1  18              clc
000812  1  A9 00           lda #$00
000814  1  20 5F FF        jsr SCREEN_MODE
000817  1               
000817  1                  ; Seed PRNG with hardware entropy
000817  1  20 CF FE        jsr ENTROPY_GET
00081A  1  85 rr           sta rand_seed_lo
00081C  1  86 rr           stx rand_seed_hi
00081E  1               
00081E  1                  ; Enable sprites in VERA display controller
00081E  1  9C 25 9F        stz VERA_ctrl                 ; DCSEL=0, ADDRSEL=0
000821  1  AD 29 9F        lda VERA_dc_video
000824  1  09 40           ora #VERA_SPRITE_EN
000826  1  8D 29 9F        sta VERA_dc_video
000829  1               
000829  1               
000829  1                  ; Clear game variables
000829  1  64 rr           stz key_last
00082B  1  64 rr           stz key_flags
00082D  1  64 rr           stz frame_count
00082F  1  64 rr           stz bullet_active
000831  1  64 rr           stz score_lo
000833  1  64 rr           stz score_mid
000835  1  64 rr           stz score_hi
000837  1  64 rr           stz hi_score_lo
000839  1  64 rr           stz hi_score_mid
00083B  1  64 rr           stz hi_score_hi
00083D  1               
00083D  1                  ; Set initial player position before sprite init reads it
00083D  1  20 57 09        jsr init_player
000840  1               
000840  1  58              cli                           ; re-enable interrupts
000841  1               
000841  1                  ; Switch to Commodore uppercase/graphics charset: $41-$5A = A-Z
000841  1                  ; Must be called AFTER SCREEN_MODE (which resets to lowercase by default)
000841  1  A9 01           lda #CHARSET_UPPER
000843  1  20 62 FF        jsr SCREEN_SET_CHARSET
000846  1               
000846  1                  ; Clear screen and set text color
000846  1  A9 05           lda #PETSCII_WHITE
000848  1  20 D2 FF        jsr CHROUT
00084B  1  A9 93           lda #PETSCII_CLR
00084D  1  20 D2 FF        jsr CHROUT
000850  1               
000850  1                  ; Upload sprite pixel data and configure sprite 1 attributes
000850  1  20 66 09        jsr init_sprites
000853  1               
000853  1                  ; Upload invader sprite data, set palette, init grid state, place sprites
000853  1  20 0A 0B        jsr init_invaders
000856  1  20 65 12        jsr hide_all_inv_sprites     ; hide all 55 during title screen
000859  1               
000859  1  20 0E 11        jsr draw_title_screen
00085C  1               
00085C  1               ;------------------------------------------------------------------
00085C  1               ; title_loop — wait for SPACE; blink "PRESS SPACE TO START"
00085C  1               ;------------------------------------------------------------------
00085C  1               title_loop:
00085C  1  20 0A 09        jsr wait_vsync
00085F  1  E6 rr           inc frame_count
000861  1  20 0C 09        jsr update_input
000864  1               
000864  1  A5 rr           lda key_last
000866  1  C9 03           cmp #KEY_RUN_STOP
000868  1  D0 03           bne @tl_no_exit
00086A  1  4C 02 09        jmp exit_game
00086D  1               @tl_no_exit:
00086D  1               
00086D  1  A5 rr           lda key_flags
00086F  1  29 04           and #KEY_FIRE
000871  1  D0 33           bne start_game
000873  1               
000873  1                  ; blink using frame_count bit 5 (~2 Hz)
000873  1  A5 rr           lda frame_count
000875  1  29 20           and #$20
000877  1  D0 15           bne @tl_on
000879  1               @tl_off:
000879  1  A9 11           lda #17
00087B  1  A0 0A           ldy #10
00087D  1  18              clc
00087E  1  20 F0 FF        jsr PLOT
000881  1  A2 14           ldx #20                      ; erase 20 chars of "PRESS SPACE TO START"
000883  1  A9 20        @tl_erase: lda #' '
000885  1  20 D2 FF        jsr CHROUT
000888  1  CA              dex
000889  1  D0 F8           bne @tl_erase
00088B  1  4C 5C 08        jmp title_loop
00088E  1               @tl_on:
00088E  1  A9 11           lda #17
000890  1  A0 0A           ldy #10
000892  1  18              clc
000893  1  20 F0 FF        jsr PLOT
000896  1  A2 00           ldx #0
000898  1  BD A8 16     @tl_print: lda str_press_space, x
00089B  1  F0 06           beq @tl_print_done
00089D  1  20 D2 FF        jsr CHROUT
0008A0  1  E8              inx
0008A1  1  80 F5           bra @tl_print
0008A3  1               @tl_print_done:
0008A3  1  4C 5C 08        jmp title_loop
0008A6  1               
0008A6  1               start_game:
0008A6  1  20 3E 0C        jsr update_invader_sprites   ; re-enable all 55 invaders at grid positions
0008A9  1  20 82 12        jsr init_shields             ; upload shield tiles, init damage counters, place sprites
0008AC  1  A9 93           lda #PETSCII_CLR
0008AE  1  20 D2 FF        jsr CHROUT                   ; clear title text, leave sprites visible
0008B1  1               
0008B1  1               ;******************************************************************
0008B1  1               ; main_loop — one iteration per video frame (60 Hz)
0008B1  1               ;******************************************************************
0008B1  1               main_loop:
0008B1  1  20 0A 09        jsr wait_vsync
0008B4  1               
0008B4  1  E6 rr           inc frame_count
0008B6  1               
0008B6  1  20 0C 09        jsr update_input              ; fills key_flags (joystick) + key_last (GETIN)
0008B9  1               
0008B9  1  A5 rr           lda key_last
0008BB  1  C9 03           cmp #KEY_RUN_STOP
0008BD  1  F0 43           beq exit_game
0008BF  1               
0008BF  1                  ; --- invincibility timer ---
0008BF  1  A5 rr           lda inv_hit_timer
0008C1  1  F0 02           beq @no_inv_dec
0008C3  1  C6 rr           dec inv_hit_timer
0008C5  1               @no_inv_dec:
0008C5  1               
0008C5  1  20 F4 0C        jsr move_player               ; apply movement, clamp to boundaries
0008C8  1  20 43 0D        jsr update_player_sprite      ; write new X to VERA sprite 1
0008CB  1               
0008CB  1                  ; --- fire player bullet (SPACE pressed and bullet not already active) ---
0008CB  1  A5 rr           lda key_flags
0008CD  1  29 04           and #KEY_FIRE
0008CF  1  F0 07           beq @skip_fire
0008D1  1  A5 rr           lda bullet_active
0008D3  1  D0 03           bne @skip_fire
0008D5  1  20 86 0D        jsr fire_bullet
0008D8  1               @skip_fire:
0008D8  1               
0008D8  1                  ; --- move bullet if active ---
0008D8  1  A5 rr           lda bullet_active
0008DA  1  F0 03           beq @skip_bullet_move
0008DC  1  20 A3 0D        jsr move_bullet
0008DF  1               @skip_bullet_move:
0008DF  1               
0008DF  1                  ; --- check player bullet vs invader collision ---
0008DF  1  20 F4 0D        jsr check_bullet_invader
0008E2  1               
0008E2  1                  ; --- check player bullet vs shield collision ---
0008E2  1  20 0E 15        jsr check_bullet_shields
0008E5  1               
0008E5  1                  ; --- explosion timer ---
0008E5  1  20 43 0F        jsr update_explosion
0008E8  1               
0008E8  1                  ; --- invader bullets: move, spawn, boundary check ---
0008E8  1  20 72 0F        jsr update_inv_bullets
0008EB  1               
0008EB  1                  ; --- invader bullet vs player collision ---
0008EB  1  20 80 10        jsr check_inv_bullet_player
0008EE  1               
0008EE  1                  ; --- invader bullet vs shield collision ---
0008EE  1  20 80 15        jsr check_invbullet_shields
0008F1  1               
0008F1  1                  ; --- Invader march timer ---
0008F1  1  C6 rr           dec inv_move_timer
0008F3  1  D0 07           bne @skip_inv_step
0008F5  1  20 D9 0B        jsr step_invaders             ; move grid, check bounds, update sprites
0008F8  1  A5 rr           lda inv_move_speed
0008FA  1  85 rr           sta inv_move_timer
0008FC  1               @skip_inv_step:
0008FC  1               
0008FC  1  20 0E 16        jsr update_hud                ; refresh text readouts
0008FF  1               
0008FF  1  4C B1 08        jmp main_loop
000902  1               
000902  1               ;------------------------------------------------------------------
000902  1               exit_game:
000902  1  A9 93           lda #PETSCII_CLR
000904  1  20 D2 FF        jsr CHROUT
000907  1  4C 47 FF        jmp ENTER_BASIC
00090A  1               
00090A  1               ;******************************************************************
00090A  1               ; wait_vsync — busy-poll VERA_isr until VSYNC, then clear flag
00090A  1               ;******************************************************************
00090A  1               wait_vsync:
00090A  1                  ; WAI sleeps the CPU until any IRQ fires.  The KERNAL's VSYNC IRQ
00090A  1                  ; handler (60 Hz) wakes us up and has already cleared VERA_isr bit 0
00090A  1                  ; by the time execution returns here, so polling VERA_isr would loop
00090A  1                  ; forever.  Just return — one WAI ≈ one frame.
00090A  1  CB              wai
00090B  1  60              rts
00090C  1               
00090C  1               ;******************************************************************
00090C  1               ; update_input — joystick + GETIN keyboard input each frame
00090C  1               ;
00090C  1               ;   key_flags bits set this frame:
00090C  1               ;     KEY_LEFT  — left arrow held
00090C  1               ;     KEY_RIGHT — right arrow held
00090C  1               ;     KEY_FIRE  — space bar pressed
00090C  1               ;   key_last   — raw PETSCII from GETIN (RUN/STOP etc.)
00090C  1               ;
00090C  1               ;   JOYSTICK_GET(0) = keyboard-as-joystick; gives smooth held-key
00090C  1               ;   movement with no repeat delay.  GETIN handles space and RUN/STOP.
00090C  1               ;******************************************************************
00090C  1               update_input:
00090C  1  64 rr           stz key_flags
00090E  1  64 rr           stz key_last
000910  1               
000910  1                  ; --- joystick 0 = keyboard d-pad (active low: 0 = pressed) ---
000910  1                  ; Byte returned: {B,Y,Sel,Sta,Up,Dn,Left,Right} bits 7–0
000910  1  A9 00           lda #0
000912  1  20 56 FF        jsr JOYSTICK_GET
000915  1  48              pha                           ; save — AND destroys .A
000916  1               
000916  1  29 01           and #JOY_RIGHT                ; bit 0: right arrow
000918  1  D0 06           bne @not_right
00091A  1  A5 rr           lda key_flags
00091C  1  09 02           ora #KEY_RIGHT
00091E  1  85 rr           sta key_flags
000920  1               @not_right:
000920  1  68              pla
000921  1  29 02           and #JOY_LEFT                 ; bit 1: left arrow
000923  1  D0 06           bne @not_left
000925  1  A5 rr           lda key_flags
000927  1  09 01           ora #KEY_LEFT
000929  1  85 rr           sta key_flags
00092B  1               @not_left:
00092B  1               
00092B  1                  ; --- GETIN — discrete events: fire, RUN/STOP, arrow fallback ---
00092B  1               @getin_drain:
00092B  1  20 E4 FF        jsr GETIN
00092E  1  F0 26           beq @getin_done               ; buffer empty
000930  1  85 rr           sta key_last
000932  1  C9 9D           cmp #$9D                      ; cursor left (PETSCII)
000934  1  D0 08           bne @chk_right_getin
000936  1  A5 rr           lda key_flags
000938  1  09 01           ora #KEY_LEFT
00093A  1  85 rr           sta key_flags
00093C  1  80 ED           bra @getin_drain
00093E  1               @chk_right_getin:
00093E  1  C9 1D           cmp #$1D                      ; cursor right (PETSCII)
000940  1  D0 08           bne @chk_fire_getin
000942  1  A5 rr           lda key_flags
000944  1  09 02           ora #KEY_RIGHT
000946  1  85 rr           sta key_flags
000948  1  80 E1           bra @getin_drain
00094A  1               @chk_fire_getin:
00094A  1  C9 20           cmp #$20                      ; space = fire
00094C  1  D0 DD           bne @getin_drain
00094E  1  A5 rr           lda key_flags
000950  1  09 04           ora #KEY_FIRE
000952  1  85 rr           sta key_flags
000954  1  80 D5           bra @getin_drain
000956  1               @getin_done:
000956  1  60              rts
000957  1               
000957  1               ;******************************************************************
000957  1               ; init_player — set player_x to starting position
000957  1               ;******************************************************************
000957  1               init_player:
000957  1  A9 38           lda #<PLAYER_X_INIT
000959  1  85 rr           sta player_x_lo
00095B  1  A9 01           lda #>PLAYER_X_INIT
00095D  1  85 rr           sta player_x_hi
00095F  1  A9 03           lda #LIVES_INIT
000961  1  85 rr           sta lives
000963  1  64 rr           stz inv_hit_timer
000965  1  60              rts
000966  1               
000966  1               ;******************************************************************
000966  1               ; init_sprites — upload pixel data + write sprite 1 attributes
000966  1               ;
000966  1               ;   Sprite 0 ($1FC00) is reserved by the KERNAL mouse cursor —
000966  1               ;   we disable it and keep clear of $1FC00.
000966  1               ;
000966  1               ;   Sprite 1 ($1FC08) = player ship
000966  1               ;   Pixel data at VRAM $00080 (128 bytes, 16x16 4bpp)
000966  1               ;   Address encoding:  addr[12:5] = $00080>>5 = $04  → byte 0 = $04
000966  1               ;                      4bpp, addr[16:13] = 0          → byte 1 = $00
000966  1               ;******************************************************************
000966  1               init_sprites:
000966  1  9C 25 9F        stz VERA_ctrl
000969  1               
000969  1                  ; --- set palette entries 1-4 ---
000969  1                  ; VERA palette entry N is 2 bytes at VRAM_palette + N*2
000969  1                  ; Byte 0: [7:4]=Green [3:0]=Blue   Byte 1: [3:0]=Red (bits 7-4 unused)
000969  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_palette + 2), 1   ; entry 1 (player white); stride=1 auto-advances
00096D  1  9F A9 FA 8D  
000971  1  21 9F A9 02  
000978  1  A9 FF           lda #$FF                               ; G=$F, B=$F
00097A  1  8D 23 9F        sta VERA_data0
00097D  1  A9 0F           lda #$0F                               ; R=$F  → white
00097F  1  8D 23 9F        sta VERA_data0
000982  1                  ; entry 2 = cyan  (R=0, G=$F, B=$F)
000982  1  A9 FF           lda #$FF                               ; G=$F, B=$F
000984  1  8D 23 9F        sta VERA_data0
000987  1  A9 00           lda #$00                               ; R=$0
000989  1  8D 23 9F        sta VERA_data0
00098C  1                  ; entry 3 = magenta (R=$F, G=0, B=$F)
00098C  1  A9 0F           lda #$0F                               ; G=$0, B=$F
00098E  1  8D 23 9F        sta VERA_data0
000991  1  A9 0F           lda #$0F                               ; R=$F
000993  1  8D 23 9F        sta VERA_data0
000996  1                  ; entry 4 = green  (R=0, G=$F, B=0)
000996  1  A9 F0           lda #$F0                               ; G=$F, B=$0
000998  1  8D 23 9F        sta VERA_data0
00099B  1  A9 00           lda #$00                               ; R=$0
00099D  1  8D 23 9F        sta VERA_data0
0009A0  1                  ; --- disable sprite 0 (KERNAL mouse cursor) ---
0009A0  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_sprattr + 6), 1   ; sprite 0 byte 6 = z-depth
0009A4  1  9F A9 FC 8D  
0009A8  1  21 9F A9 06  
0009AF  1  A9 00           lda #$00                               ; z-depth=0 → disabled
0009B1  1  8D 23 9F        sta VERA_data0
0009B4  1               
0009B4  1                  ; --- upload player sprite pixel data to VRAM $00080 ---
0009B4  1  A9 10 8D 22     VERA_SET_ADDR $00080, 1
0009B8  1  9F A9 00 8D  
0009BC  1  21 9F A9 80  
0009C3  1  A2 00           ldx #0
0009C5  1               @upload:
0009C5  1  BD E6 16        lda player_spr_data,x
0009C8  1  8D 23 9F        sta VERA_data0
0009CB  1  E8              inx
0009CC  1  E0 80           cpx #128
0009CE  1  D0 F5           bne @upload
0009D0  1               
0009D0  1                  ; --- write sprite 1 attribute bytes ---
0009D0  1  A9 11 8D 22     VERA_SET_ADDR SPRITE1_ATTR, 1
0009D4  1  9F A9 FC 8D  
0009D8  1  21 9F A9 08  
0009DF  1  A9 04           lda #$04
0009E1  1  8D 23 9F        sta VERA_data0               ; byte 0: addr[12:5] = $00080>>5 = $04
0009E4  1  A9 00           lda #$00
0009E6  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, addr[16:13] = 0
0009E9  1  A5 rr           lda player_x_lo
0009EB  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
0009EE  1  A5 rr           lda player_x_hi
0009F0  1  29 03           and #$03
0009F2  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
0009F5  1  A9 A4           lda #<PLAYER_Y
0009F7  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
0009FA  1  A9 01           lda #>PLAYER_Y
0009FC  1  29 03           and #$03
0009FE  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000A01  1  A9 0C           lda #SPR_Z_FRONT
000A03  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3, no collision, no flip
000A06  1  A9 50           lda #SPR_16x16_PAL0
000A08  1  8D 23 9F        sta VERA_data0               ; byte 7: palette 0, 16x16
000A0B  1               
000A0B  1                  ; --- upload player bullet pixel data to VRAM $00400 ---
000A0B  1  A9 10 8D 22     VERA_SET_ADDR VRAM_BULLET, 1
000A0F  1  9F A9 04 8D  
000A13  1  21 9F A9 00  
000A1A  1  A2 00           ldx #0
000A1C  1               @up_bullet:
000A1C  1  BD 66 17        lda bullet_spr_data,x
000A1F  1  8D 23 9F        sta VERA_data0
000A22  1  E8              inx
000A23  1  E0 20           cpx #32
000A25  1  D0 F5           bne @up_bullet
000A27  1               
000A27  1                  ; --- write sprite 2 attributes (initially disabled, z-depth=0) ---
000A27  1  A9 11 8D 22     VERA_SET_ADDR BULLET_SPRITE_ATTR, 1
000A2B  1  9F A9 FC 8D  
000A2F  1  21 9F A9 10  
000A36  1  A9 20           lda #$20                     ; byte 0: addr[12:5] = $00400>>5 = $20
000A38  1  8D 23 9F        sta VERA_data0
000A3B  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000A3D  1  8D 23 9F        sta VERA_data0
000A40  1  A9 00           lda #$00                     ; byte 2: X lo (arbitrary; sprite disabled)
000A42  1  8D 23 9F        sta VERA_data0
000A45  1  A9 00           lda #$00                     ; byte 3: X hi
000A47  1  8D 23 9F        sta VERA_data0
000A4A  1  A9 00           lda #$00                     ; byte 4: Y lo
000A4C  1  8D 23 9F        sta VERA_data0
000A4F  1  A9 00           lda #$00                     ; byte 5: Y hi
000A51  1  8D 23 9F        sta VERA_data0
000A54  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000A56  1  8D 23 9F        sta VERA_data0
000A59  1  A9 00           lda #SPR_8x8_PAL0            ; byte 7: 8x8, palette 0
000A5B  1  8D 23 9F        sta VERA_data0
000A5E  1               
000A5E  1                  ; --- upload explosion pixel data to VRAM $00440 ---
000A5E  1  A9 10 8D 22     VERA_SET_ADDR VRAM_EXPLOSION, 1
000A62  1  9F A9 04 8D  
000A66  1  21 9F A9 40  
000A6D  1  A2 00           ldx #0
000A6F  1               @up_exp:
000A6F  1  BD 28 18        lda explosion_pixels,x
000A72  1  8D 23 9F        sta VERA_data0
000A75  1  E8              inx
000A76  1  E0 80           cpx #128
000A78  1  D0 F5           bne @up_exp
000A7A  1               
000A7A  1                  ; --- write sprite 4 attributes (initially disabled) ---
000A7A  1                  ; addr[12:5] = VRAM_EXPLOSION>>5 = $00440>>5 = $22
000A7A  1  A9 11 8D 22     VERA_SET_ADDR EXPLODE_SPRITE_ATTR, 1
000A7E  1  9F A9 FC 8D  
000A82  1  21 9F A9 20  
000A89  1  A9 22           lda #$22                     ; byte 0: addr[12:5]
000A8B  1  8D 23 9F        sta VERA_data0
000A8E  1  A9 00           lda #$00                     ; byte 1: 4bpp, addr[16:13]=0
000A90  1  8D 23 9F        sta VERA_data0
000A93  1  A9 00           lda #$00                     ; byte 2: X lo (placeholder)
000A95  1  8D 23 9F        sta VERA_data0
000A98  1  A9 00           lda #$00                     ; byte 3: X hi
000A9A  1  8D 23 9F        sta VERA_data0
000A9D  1  A9 00           lda #$00                     ; byte 4: Y lo (placeholder)
000A9F  1  8D 23 9F        sta VERA_data0
000AA2  1  A9 00           lda #$00                     ; byte 5: Y hi
000AA4  1  8D 23 9F        sta VERA_data0
000AA7  1  A9 00           lda #$00                     ; byte 6: z-depth=0 → disabled
000AA9  1  8D 23 9F        sta VERA_data0
000AAC  1  A9 50           lda #SPR_16x16_PAL0          ; byte 7: 16x16, palette 0
000AAE  1  8D 23 9F        sta VERA_data0
000AB1  1               
000AB1  1  64 rr           stz exp_timer
000AB3  1               
000AB3  1                  ; --- upload invader bullet pixel data to VRAM $00420 ---
000AB3  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_BULLET, 1
000AB7  1  9F A9 04 8D  
000ABB  1  21 9F A9 20  
000AC2  1  A2 00           ldx #0
000AC4  1               @up_ibul:
000AC4  1  BD 08 18        lda inv_bullet_spr_data,x
000AC7  1  8D 23 9F        sta VERA_data0
000ACA  1  E8              inx
000ACB  1  E0 20           cpx #32
000ACD  1  D0 F5           bne @up_ibul
000ACF  1               
000ACF  1                  ; --- init 3 invader bullet sprites (slots 5-7, base $1FC28), all disabled ---
000ACF  1                  ; addr[12:5] = VRAM_INV_BULLET>>5 = $00420>>5 = $21
000ACF  1  A9 11 8D 22     VERA_SET_ADDR INV_BULLET_SPR_BASE, 1
000AD3  1  9F A9 FC 8D  
000AD7  1  21 9F A9 28  
000ADE  1  A2 03           ldx #3                       ; 3 sprites
000AE0  1               @init_ibspr:
000AE0  1  A9 21           lda #$21                     ; byte 0: addr[12:5] = $21
000AE2  1  8D 23 9F        sta VERA_data0
000AE5  1  A9 00           lda #$00
000AE7  1  8D 23 9F        sta VERA_data0               ; byte 1: 4bpp, bank 0
000AEA  1  8D 23 9F        sta VERA_data0               ; byte 2: X lo
000AED  1  8D 23 9F        sta VERA_data0               ; byte 3: X hi
000AF0  1  8D 23 9F        sta VERA_data0               ; byte 4: Y lo
000AF3  1  8D 23 9F        sta VERA_data0               ; byte 5: Y hi
000AF6  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=0 → disabled
000AF9  1  8D 23 9F        sta VERA_data0               ; byte 7: 8x8, palette 0
000AFC  1  CA              dex
000AFD  1  D0 E1           bne @init_ibspr
000AFF  1               
000AFF  1                  ; --- clear invader bullet state ---
000AFF  1  64 rr           stz ibul_active+0
000B01  1  64 rr           stz ibul_active+1
000B03  1  64 rr           stz ibul_active+2
000B05  1  A9 5A           lda #INV_FIRE_TIMER_INIT
000B07  1  85 rr           sta inv_fire_timer
000B09  1               
000B09  1  60              rts
000B0A  1               
000B0A  1               ;******************************************************************
000B0A  1               ; init_invaders — upload invader pixel data, init grid state, place sprites
000B0A  1               ;******************************************************************
000B0A  1               init_invaders:
000B0A  1  9C 25 9F        stz VERA_ctrl
000B0D  1               
000B0D  1                  ; --- upload Type A frame 0 → VRAM $00100 ---
000B0D  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F0, 1
000B11  1  9F A9 01 8D  
000B15  1  21 9F A9 00  
000B1C  1  A2 80           ldx #128
000B1E  1  BD 28 18     @up_af0: lda inv_a_spr_f0-128,x
000B21  1  8D 23 9F        sta VERA_data0
000B24  1  E8              inx
000B25  1  D0 F7           bne @up_af0
000B27  1               
000B27  1                  ; --- upload Type A frame 1 → VRAM $00180 ---
000B27  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_A_F1, 1
000B2B  1  9F A9 01 8D  
000B2F  1  21 9F A9 80  
000B36  1  A2 80           ldx #128
000B38  1  BD A8 18     @up_af1: lda inv_a_spr_f1-128,x
000B3B  1  8D 23 9F        sta VERA_data0
000B3E  1  E8              inx
000B3F  1  D0 F7           bne @up_af1
000B41  1               
000B41  1                  ; --- upload Type B frame 0 → VRAM $00200 ---
000B41  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F0, 1
000B45  1  9F A9 02 8D  
000B49  1  21 9F A9 00  
000B50  1  A2 80           ldx #128
000B52  1  BD 28 19     @up_bf0: lda inv_b_spr_f0-128,x
000B55  1  8D 23 9F        sta VERA_data0
000B58  1  E8              inx
000B59  1  D0 F7           bne @up_bf0
000B5B  1               
000B5B  1                  ; --- upload Type B frame 1 → VRAM $00280 ---
000B5B  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_B_F1, 1
000B5F  1  9F A9 02 8D  
000B63  1  21 9F A9 80  
000B6A  1  A2 80           ldx #128
000B6C  1  BD A8 19     @up_bf1: lda inv_b_spr_f1-128,x
000B6F  1  8D 23 9F        sta VERA_data0
000B72  1  E8              inx
000B73  1  D0 F7           bne @up_bf1
000B75  1               
000B75  1                  ; --- upload Type C frame 0 → VRAM $00300 ---
000B75  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F0, 1
000B79  1  9F A9 03 8D  
000B7D  1  21 9F A9 00  
000B84  1  A2 80           ldx #128
000B86  1  BD 28 1A     @up_cf0: lda inv_c_spr_f0-128,x
000B89  1  8D 23 9F        sta VERA_data0
000B8C  1  E8              inx
000B8D  1  D0 F7           bne @up_cf0
000B8F  1               
000B8F  1                  ; --- upload Type C frame 1 → VRAM $00380 ---
000B8F  1  A9 10 8D 22     VERA_SET_ADDR VRAM_INV_C_F1, 1
000B93  1  9F A9 03 8D  
000B97  1  21 9F A9 80  
000B9E  1  A2 80           ldx #128
000BA0  1  BD A8 1A     @up_cf1: lda inv_c_spr_f1-128,x
000BA3  1  8D 23 9F        sta VERA_data0
000BA6  1  E8              inx
000BA7  1  D0 F7           bne @up_cf1
000BA9  1               
000BA9  1                  ; --- initialize zero-page grid variables ---
000BA9  1  A9 70           lda #<INV_GRID_X_INIT
000BAB  1  85 rr           sta inv_grid_x_lo
000BAD  1  A9 00           lda #>INV_GRID_X_INIT
000BAF  1  85 rr           sta inv_grid_x_hi
000BB1  1  64 rr           stz inv_offset_y
000BB3  1  64 rr           stz inv_direction
000BB5  1  64 rr           stz inv_anim_frame
000BB7  1  64 rr           stz inv_drop_flag
000BB9  1               
000BB9  1                  ; all 55 invaders alive: bytes 0-5 = $FF, byte 6 = $7F (55 bits)
000BB9  1  A9 FF           lda #$FF
000BBB  1  85 rr           sta inv_alive+0
000BBD  1  85 rr           sta inv_alive+1
000BBF  1  85 rr           sta inv_alive+2
000BC1  1  85 rr           sta inv_alive+3
000BC3  1  85 rr           sta inv_alive+4
000BC5  1  85 rr           sta inv_alive+5
000BC7  1  A9 7F           lda #$7F
000BC9  1  85 rr           sta inv_alive+6
000BCB  1               
000BCB  1  A9 37           lda #INV_COUNT_INIT
000BCD  1  85 rr           sta inv_count
000BCF  1  A9 32           lda #INV_MOVE_SPEED_INIT
000BD1  1  85 rr           sta inv_move_speed
000BD3  1  85 rr           sta inv_move_timer
000BD5  1               
000BD5  1                  ; --- write initial sprite attributes for all 55 invaders ---
000BD5  1  20 3E 0C        jsr update_invader_sprites
000BD8  1  60              rts
000BD9  1               
000BD9  1               ;******************************************************************
000BD9  1               ; step_invaders — one march step: move or drop grid, toggle anim frame
000BD9  1               ;   Called when inv_move_timer reaches 0.
000BD9  1               ;   Updates inv_grid_x / inv_offset_y, sets inv_drop_flag as needed,
000BD9  1               ;   then refreshes all VERA sprite positions.
000BD9  1               ;******************************************************************
000BD9  1               step_invaders:
000BD9  1                  ; toggle animation frame
000BD9  1  A5 rr           lda inv_anim_frame
000BDB  1  49 01           eor #1
000BDD  1  85 rr           sta inv_anim_frame
000BDF  1               
000BDF  1                  ; if drop flag is set: drop grid this step, skip march
000BDF  1  A5 rr           lda inv_drop_flag
000BE1  1  F0 0B           beq @do_march
000BE3  1  64 rr           stz inv_drop_flag
000BE5  1  A5 rr           lda inv_offset_y
000BE7  1  18              clc
000BE8  1  69 10           adc #INV_DROP_Y
000BEA  1  85 rr           sta inv_offset_y
000BEC  1  80 4C           bra @sprites_done
000BEE  1               
000BEE  1               @do_march:
000BEE  1  A5 rr           lda inv_direction
000BF0  1  D0 25           bne @march_left
000BF2  1               
000BF2  1                  ; --- march right ---
000BF2  1  A5 rr           lda inv_grid_x_lo
000BF4  1  18              clc
000BF5  1  69 04           adc #INV_STEP_X
000BF7  1  85 rr           sta inv_grid_x_lo
000BF9  1  90 02           bcc @chk_right
000BFB  1  E6 rr           inc inv_grid_x_hi
000BFD  1               @chk_right:
000BFD  1                  ; hit right if grid_x > INV_X_RIGHT_LIM (208, fits in 1 byte, hi always 0)
000BFD  1  A5 rr           lda inv_grid_x_hi
000BFF  1  D0 06           bne @clamp_right          ; hi > 0 → definitely over limit
000C01  1  A5 rr           lda inv_grid_x_lo
000C03  1  C9 D1           cmp #INV_X_RIGHT_LIM + 1  ; C set if lo > limit
000C05  1  90 33           bcc @sprites_done
000C07  1               @clamp_right:
000C07  1  A9 D0           lda #<INV_X_RIGHT_LIM
000C09  1  85 rr           sta inv_grid_x_lo
000C0B  1  A9 00           lda #>INV_X_RIGHT_LIM
000C0D  1  85 rr           sta inv_grid_x_hi
000C0F  1  A9 01           lda #1
000C11  1  85 rr           sta inv_direction
000C13  1  85 rr           sta inv_drop_flag
000C15  1  80 23           bra @sprites_done
000C17  1               
000C17  1                  ; --- march left ---
000C17  1               @march_left:
000C17  1  A5 rr           lda inv_grid_x_lo
000C19  1  38              sec
000C1A  1  E9 04           sbc #INV_STEP_X
000C1C  1  85 rr           sta inv_grid_x_lo
000C1E  1  B0 02           bcs @chk_left             ; no borrow
000C20  1  C6 rr           dec inv_grid_x_hi
000C22  1               @chk_left:
000C22  1                  ; hit left if hi went negative OR lo < INV_X_LEFT_LIM
000C22  1  A5 rr           lda inv_grid_x_hi
000C24  1  30 06           bmi @clamp_left
000C26  1  A5 rr           lda inv_grid_x_lo
000C28  1  C9 10           cmp #INV_X_LEFT_LIM
000C2A  1  B0 0E           bcs @sprites_done         ; lo >= left limit → ok
000C2C  1               @clamp_left:
000C2C  1  A9 10           lda #<INV_X_LEFT_LIM
000C2E  1  85 rr           sta inv_grid_x_lo
000C30  1  A9 00           lda #>INV_X_LEFT_LIM
000C32  1  85 rr           sta inv_grid_x_hi
000C34  1  64 rr           stz inv_direction
000C36  1  A9 01           lda #1
000C38  1  85 rr           sta inv_drop_flag
000C3A  1               
000C3A  1               @sprites_done:
000C3A  1  20 3E 0C        jsr update_invader_sprites
000C3D  1  60              rts
000C3E  1               
000C3E  1               ;******************************************************************
000C3E  1               ; update_invader_sprites — write all 55 invader sprite attributes to VERA
000C3E  1               ;
000C3E  1               ;   VERA sprite slots 11-65 hold the 55 invaders.
000C3E  1               ;   Attributes base: $1FC58 ($1FC00 + 11*8).
000C3E  1               ;   With stride=1 the VERA address auto-increments, so we set it
000C3E  1               ;   once and write all 440 bytes sequentially.
000C3E  1               ;
000C3E  1               ;   Byte layout per sprite:
000C3E  1               ;     0: data addr[12:5]   (encodes VRAM pixel data address + frame)
000C3E  1               ;     1: $00               (4bpp, addr[16:13]=0)
000C3E  1               ;     2: X[7:0]
000C3E  1               ;     3: X[9:8]
000C3E  1               ;     4: Y[7:0]
000C3E  1               ;     5: Y[9:8]
000C3E  1               ;     6: z-depth/collision
000C3E  1               ;     7: palette / size
000C3E  1               ;
000C3E  1               ;   Invader index i = row*11 + col; alive bit i in inv_alive bitmap.
000C3E  1               ;   For Phase 3 all invaders are alive; alive check will be added Phase 4.
000C3E  1               ;******************************************************************
000C3E  1               update_invader_sprites:
000C3E  1  9C 25 9F        stz VERA_ctrl
000C41  1  A9 11           lda #$11              ; stride=1, VRAM bank bit=1 (addr $1Fxxxx)
000C43  1  8D 22 9F        sta VERA_addr_bank
000C46  1  A9 FC           lda #$FC
000C48  1  8D 21 9F        sta VERA_addr_high
000C4B  1  A9 58           lda #$58
000C4D  1  8D 20 9F        sta VERA_addr_low     ; VERA now at $1FC58, auto-increments by 1
000C50  1               
000C50  1                  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000C50  1  A9 50           lda #<INV_GRID_Y_BASE
000C52  1  18              clc
000C53  1  65 rr           adc inv_offset_y
000C55  1  85 rr           sta zp_y_base_lo
000C57  1  A9 00           lda #>INV_GRID_Y_BASE
000C59  1  69 00           adc #0
000C5B  1  85 rr           sta zp_y_base_hi
000C5D  1               
000C5D  1  64 rr           stz zp_row
000C5F  1               @row_loop:
000C5F  1                  ; compute row Y: zp_row_y = zp_y_base + row_y_offsets[row]
000C5F  1  A4 rr           ldy zp_row
000C61  1  B9 A6 17        lda row_y_offsets,y
000C64  1  18              clc
000C65  1  65 rr           adc zp_y_base_lo
000C67  1  85 rr           sta zp_row_y_lo
000C69  1  A9 00           lda #0
000C6B  1  65 rr           adc zp_y_base_hi
000C6D  1  85 rr           sta zp_row_y_hi
000C6F  1               
000C6F  1                  ; select addr byte0 based on row type and animation frame
000C6F  1  A4 rr           ldy zp_row
000C71  1  A5 rr           lda inv_anim_frame
000C73  1  F0 05           beq @use_f0
000C75  1  B9 8B 17        lda inv_addr_b0_f1,y
000C78  1  80 03           bra @got_b0
000C7A  1               @use_f0:
000C7A  1  B9 86 17        lda inv_addr_b0_f0,y
000C7D  1               @got_b0:
000C7D  1  85 rr           sta zp_addr_b0
000C7F  1               
000C7F  1  20 8B 0C        jsr update_invader_row
000C82  1               
000C82  1  E6 rr           inc zp_row
000C84  1  A5 rr           lda zp_row
000C86  1  C9 05           cmp #5
000C88  1  D0 D5           bne @row_loop
000C8A  1               
000C8A  1  60              rts
000C8B  1               
000C8B  1               ;******************************************************************
000C8B  1               ; update_invader_row — write 11 sprite attribute blocks for one row
000C8B  1               ;
000C8B  1               ;   Inputs (ZP): zp_row, zp_addr_b0, zp_row_y_lo/hi, inv_grid_x_lo/hi
000C8B  1               ;   VERA address register must already be set to the first sprite slot
000C8B  1               ;   for this row on entry (maintained by the sequential write stream).
000C8B  1               ;******************************************************************
000C8B  1               update_invader_row:
000C8B  1  64 rr           stz zp_col
000C8D  1               @col_loop:
000C8D  1                  ; --- determine z-depth from alive bitmap ---
000C8D  1                  ; index = inv_row_base[row] + col; byte = index>>3; bit = index&7
000C8D  1  A4 rr           ldy zp_row
000C8F  1  B9 AB 17        lda inv_row_base,y
000C92  1  18              clc
000C93  1  65 rr           adc zp_col
000C95  1  A8              tay                   ; Y = invader index
000C96  1  29 07           and #$07
000C98  1  AA              tax                   ; X = bit index
000C99  1  BD B0 17        lda bit_masks,x
000C9C  1  48              pha                   ; save bit mask
000C9D  1  98              tya
000C9E  1  4A              lsr
000C9F  1  4A              lsr
000CA0  1  4A              lsr
000CA1  1  A8              tay                   ; Y = byte index into inv_alive
000CA2  1  68              pla                   ; A = bit mask
000CA3  1  39 rr rr        and inv_alive,y
000CA6  1  F0 04           beq @zdepth_off
000CA8  1  A9 0C           lda #SPR_Z_FRONT
000CAA  1  80 02           bra @zdepth_done
000CAC  1               @zdepth_off:
000CAC  1  A9 00           lda #0
000CAE  1               @zdepth_done:
000CAE  1  85 rr           sta zp_scratch_lo     ; save z-depth before VERA stream starts
000CB0  1               
000CB0  1                  ; --- compute sprite X = inv_grid_x + col_x_offsets[col] ---
000CB0  1  A4 rr           ldy zp_col
000CB2  1  B9 90 17        lda col_x_lo,y
000CB5  1  18              clc
000CB6  1  65 rr           adc inv_grid_x_lo
000CB8  1  85 rr           sta zp_x_lo
000CBA  1  B9 9B 17        lda col_x_hi,y
000CBD  1  65 rr           adc inv_grid_x_hi
000CBF  1  85 rr           sta zp_x_hi
000CC1  1               
000CC1  1                  ; --- write 8 attribute bytes (VERA auto-increments) ---
000CC1  1  A5 rr           lda zp_addr_b0
000CC3  1  8D 23 9F        sta VERA_data0        ; byte 0: data addr[12:5]
000CC6  1  9C 23 9F        stz VERA_data0        ; byte 1: 4bpp, addr[16:13]=0
000CC9  1  A5 rr           lda zp_x_lo
000CCB  1  8D 23 9F        sta VERA_data0        ; byte 2: X[7:0]
000CCE  1  A5 rr           lda zp_x_hi
000CD0  1  29 03           and #$03
000CD2  1  8D 23 9F        sta VERA_data0        ; byte 3: X[9:8]
000CD5  1  A5 rr           lda zp_row_y_lo
000CD7  1  8D 23 9F        sta VERA_data0        ; byte 4: Y[7:0]
000CDA  1  A5 rr           lda zp_row_y_hi
000CDC  1  29 03           and #$03
000CDE  1  8D 23 9F        sta VERA_data0        ; byte 5: Y[9:8]
000CE1  1  A5 rr           lda zp_scratch_lo
000CE3  1  8D 23 9F        sta VERA_data0        ; byte 6: z-depth (SPR_Z_FRONT if alive, 0 if dead)
000CE6  1  A9 50           lda #SPR_16x16_PAL0
000CE8  1  8D 23 9F        sta VERA_data0        ; byte 7: 16x16, palette offset 0
000CEB  1               
000CEB  1  E6 rr           inc zp_col
000CED  1  A5 rr           lda zp_col
000CEF  1  C9 0B           cmp #11
000CF1  1  D0 9A           bne @col_loop
000CF3  1               
000CF3  1  60              rts
000CF4  1               
000CF4  1               ;******************************************************************
000CF4  1               ; move_player — apply key_flags movement and clamp to screen edges
000CF4  1               ;******************************************************************
000CF4  1               move_player:
000CF4  1  A5 rr           lda key_flags
000CF6  1               
000CF6  1                  ; --- move left ---
000CF6  1  29 01           and #KEY_LEFT
000CF8  1  F0 1F           beq @check_right
000CFA  1  A5 rr           lda player_x_lo
000CFC  1  38              sec
000CFD  1  E9 04           sbc #PLAYER_SPEED
000CFF  1  85 rr           sta player_x_lo
000D01  1  B0 02           bcs @clamp_left              ; no borrow → hi unchanged
000D03  1  C6 rr           dec player_x_hi
000D05  1               @clamp_left:
000D05  1                  ; Clamp: if hi went negative ($FF) or (hi=0 AND lo < min) → set to min
000D05  1  A5 rr           lda player_x_hi
000D07  1  30 08           bmi @set_min                 ; $80–$FF = underflowed
000D09  1  D0 0E           bne @check_right             ; hi > 0 → still above minimum
000D0B  1  A5 rr           lda player_x_lo
000D0D  1  C9 08           cmp #PLAYER_X_MIN
000D0F  1  B0 08           bcs @check_right             ; lo >= min → ok
000D11  1               @set_min:
000D11  1  A9 08           lda #<PLAYER_X_MIN
000D13  1  85 rr           sta player_x_lo
000D15  1  A9 00           lda #>PLAYER_X_MIN
000D17  1  85 rr           sta player_x_hi
000D19  1               
000D19  1                  ; --- move right ---
000D19  1               @check_right:
000D19  1  A5 rr           lda key_flags
000D1B  1  29 02           and #KEY_RIGHT
000D1D  1  F0 23           beq @move_done
000D1F  1  A5 rr           lda player_x_lo
000D21  1  18              clc
000D22  1  69 04           adc #PLAYER_SPEED
000D24  1  85 rr           sta player_x_lo
000D26  1  90 02           bcc @clamp_right             ; no carry → hi unchanged
000D28  1  E6 rr           inc player_x_hi
000D2A  1               @clamp_right:
000D2A  1                  ; Clamp: if hi > max_hi, OR (hi == max_hi AND lo > max_lo) → set to max
000D2A  1  A5 rr           lda player_x_hi
000D2C  1  C9 02           cmp #>PLAYER_X_MAX
000D2E  1  90 12           bcc @move_done               ; hi < max_hi → definitely ok
000D30  1  D0 08           bne @set_max                 ; hi > max_hi → over limit
000D32  1  A5 rr           lda player_x_lo
000D34  1  C9 68           cmp #<PLAYER_X_MAX
000D36  1  90 0A           bcc @move_done               ; lo < max_lo when hi == max_hi → ok
000D38  1  F0 08           beq @move_done               ; lo == max_lo → exactly at max, ok
000D3A  1               @set_max:
000D3A  1  A9 68           lda #<PLAYER_X_MAX
000D3C  1  85 rr           sta player_x_lo
000D3E  1  A9 02           lda #>PLAYER_X_MAX
000D40  1  85 rr           sta player_x_hi
000D42  1               
000D42  1               @move_done:
000D42  1  60              rts
000D43  1               
000D43  1               ;******************************************************************
000D43  1               ; update_player_sprite — write current X position to sprite 1 in VERA
000D43  1               ;   Only X needs updating (Y is fixed)
000D43  1               ;******************************************************************
000D43  1               update_player_sprite:
000D43  1  9C 25 9F        stz VERA_ctrl
000D46  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 2), 1
000D4A  1  9F A9 FC 8D  
000D4E  1  21 9F A9 0A  
000D55  1  A5 rr           lda player_x_lo
000D57  1  8D 23 9F        sta VERA_data0               ; sprite byte 2: X[7:0]
000D5A  1  A5 rr           lda player_x_hi
000D5C  1  29 03           and #$03
000D5E  1  8D 23 9F        sta VERA_data0               ; sprite byte 3: X[9:8]
000D61  1                  ; update z-depth based on inv_hit_timer:
000D61  1                  ;   timer = 0        → show solid (not hit)
000D61  1                  ;   timer = 61-120   → hidden solid (1-second respawn delay)
000D61  1                  ;   timer = 1-60     → flashing (invincible, visible warning)
000D61  1  A9 11 8D 22     VERA_SET_ADDR (SPRITE1_ATTR + 6), 1
000D65  1  9F A9 FC 8D  
000D69  1  21 9F A9 0E  
000D70  1  A5 rr           lda inv_hit_timer
000D72  1  F0 08           beq @show                    ; timer=0 → show solid
000D74  1  C9 3D           cmp #61
000D76  1  B0 08           bcs @hide                    ; timer>=61 → first second: fully hidden
000D78  1  29 08           and #$08                     ; timer 1-60: bit 3 flips every 8 frames → ~4 Hz flash
000D7A  1  D0 04           bne @hide
000D7C  1               @show:
000D7C  1  A9 0C           lda #SPR_Z_FRONT
000D7E  1  80 02           bra @write_z
000D80  1               @hide:
000D80  1  A9 00           lda #0
000D82  1               @write_z:
000D82  1  8D 23 9F        sta VERA_data0               ; sprite byte 6: z-depth
000D85  1  60              rts
000D86  1               
000D86  1               ;******************************************************************
000D86  1               ; fire_bullet — activate player bullet at cannon tip, update sprite
000D86  1               ;   Bullet X centers the 8-px bullet over the 16-px player ship:
000D86  1               ;     bullet_x = player_x + 4
000D86  1               ;   Bullet Y starts 8 VERA pixels above the player sprite top.
000D86  1               ;   Caller must check bullet_active == 0 before calling.
000D86  1               ;******************************************************************
000D86  1               fire_bullet:
000D86  1  A5 rr           lda player_x_lo
000D88  1  18              clc
000D89  1  69 04           adc #4
000D8B  1  85 rr           sta bullet_x_lo
000D8D  1  A5 rr           lda player_x_hi
000D8F  1  69 00           adc #0
000D91  1  85 rr           sta bullet_x_hi
000D93  1               
000D93  1  A9 9C           lda #<BULLET_Y_INIT
000D95  1  85 rr           sta bullet_y_lo
000D97  1  A9 01           lda #>BULLET_Y_INIT
000D99  1  85 rr           sta bullet_y_hi
000D9B  1               
000D9B  1  A9 01           lda #1
000D9D  1  85 rr           sta bullet_active
000D9F  1  20 BC 0D        jsr update_bullet_sprite
000DA2  1  60              rts
000DA3  1               
000DA3  1               ;******************************************************************
000DA3  1               ; move_bullet — move bullet upward by BULLET_SPEED each frame;
000DA3  1               ;   deactivate when it reaches the top of the screen (Y underflows 0)
000DA3  1               ;******************************************************************
000DA3  1               move_bullet:
000DA3  1  A5 rr           lda bullet_y_lo
000DA5  1  38              sec
000DA6  1  E9 0C           sbc #BULLET_SPEED
000DA8  1  85 rr           sta bullet_y_lo
000DAA  1  A5 rr           lda bullet_y_hi
000DAC  1  E9 00           sbc #0
000DAE  1  85 rr           sta bullet_y_hi
000DB0  1  30 04           bmi @deactivate              ; 16-bit underflow past 0 → off screen
000DB2  1               
000DB2  1  20 BC 0D        jsr update_bullet_sprite
000DB5  1  60              rts
000DB6  1               
000DB6  1               @deactivate:
000DB6  1  64 rr           stz bullet_active
000DB8  1  20 BC 0D        jsr update_bullet_sprite     ; disables sprite (z-depth=0)
000DBB  1  60              rts
000DBC  1               
000DBC  1               ;******************************************************************
000DBC  1               ; update_bullet_sprite — write bullet position and enable/disable
000DBC  1               ;   to VERA sprite 2 (bytes 2-6); byte 7 set once at init.
000DBC  1               ;   z-depth = SPR_Z_FRONT when active, 0 when inactive.
000DBC  1               ;******************************************************************
000DBC  1               update_bullet_sprite:
000DBC  1  9C 25 9F        stz VERA_ctrl
000DBF  1  A9 11 8D 22     VERA_SET_ADDR (BULLET_SPRITE_ATTR + 2), 1
000DC3  1  9F A9 FC 8D  
000DC7  1  21 9F A9 12  
000DCE  1  A5 rr           lda bullet_x_lo
000DD0  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000DD3  1  A5 rr           lda bullet_x_hi
000DD5  1  29 03           and #$03
000DD7  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000DDA  1  A5 rr           lda bullet_y_lo
000DDC  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000DDF  1  A5 rr           lda bullet_y_hi
000DE1  1  29 03           and #$03
000DE3  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000DE6  1  A5 rr           lda bullet_active
000DE8  1  F0 04           beq @z_off
000DEA  1  A9 0C           lda #SPR_Z_FRONT
000DEC  1  80 02           bra @write_z
000DEE  1               @z_off:
000DEE  1  A9 00           lda #$00
000DF0  1               @write_z:
000DF0  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
000DF3  1  60              rts
000DF4  1               
000DF4  1               ;******************************************************************
000DF4  1               ; check_bullet_invader — scan all 55 invaders for a hit with the player bullet
000DF4  1               ;
000DF4  1               ;   Iterates rows 0-4, columns 0-10.  Skips dead invaders.
000DF4  1               ;   For each live invader checks 16-bit AABB overlap:
000DF4  1               ;     X: bullet_x+8 > inv_x  AND  bullet_x < inv_x+16
000DF4  1               ;     Y: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000DF4  1               ;   On hit: calls kill_invader_hit and returns immediately.
000DF4  1               ;
000DF4  1               ;   Scratch used: zp_y_base_lo/hi, zp_row_y_lo/hi, zp_x_lo/hi,
000DF4  1               ;                 zp_scratch_lo/hi, zp_row, zp_col
000DF4  1               ;******************************************************************
000DF4  1               check_bullet_invader:
000DF4  1  A5 rr           lda bullet_active
000DF6  1  D0 01           bne :+
000DF8  1  60              rts
000DF9  1               :  ; precompute grid Y base = INV_GRID_Y_BASE + inv_offset_y
000DF9  1  A9 50           lda #<INV_GRID_Y_BASE
000DFB  1  18              clc
000DFC  1  65 rr           adc inv_offset_y
000DFE  1  85 rr           sta zp_y_base_lo
000E00  1  A9 00           lda #>INV_GRID_Y_BASE
000E02  1  69 00           adc #0
000E04  1  85 rr           sta zp_y_base_hi
000E06  1               
000E06  1  64 rr           stz zp_row
000E08  1               @row_loop:
000E08  1                  ; row Y = y_base + row_y_offsets[row]
000E08  1  A4 rr           ldy zp_row
000E0A  1  B9 A6 17        lda row_y_offsets,y
000E0D  1  18              clc
000E0E  1  65 rr           adc zp_y_base_lo
000E10  1  85 rr           sta zp_row_y_lo
000E12  1  A9 00           lda #0
000E14  1  65 rr           adc zp_y_base_hi
000E16  1  85 rr           sta zp_row_y_hi
000E18  1               
000E18  1                  ; --- Quick Y range check for whole row ---
000E18  1                  ; Need: bullet_y+8 > inv_y  AND  bullet_y < inv_y+16
000E18  1               
000E18  1                  ; (1) bullet_y+8 > inv_y  →  (bullet_y+8) - inv_y > 0
000E18  1                  ;     result negative (bmi) means bullet above this row
000E18  1  A5 rr           lda bullet_y_lo
000E1A  1  18              clc
000E1B  1  69 08           adc #8
000E1D  1  85 rr           sta zp_scratch_lo
000E1F  1  A5 rr           lda bullet_y_hi
000E21  1  69 00           adc #0
000E23  1  85 rr           sta zp_scratch_hi
000E25  1  A5 rr           lda zp_scratch_lo
000E27  1  38              sec
000E28  1  E5 rr           sbc zp_row_y_lo
000E2A  1  A5 rr           lda zp_scratch_hi
000E2C  1  E5 rr           sbc zp_row_y_hi
000E2E  1  30 1D           bmi @next_row         ; bullet bottom above invader top → no hit in this row
000E30  1               
000E30  1                  ; (2) bullet_y < inv_y+16  →  bullet_y - (inv_y+16) < 0
000E30  1                  ;     result >= 0 (bpl) means bullet below this row
000E30  1  A5 rr           lda zp_row_y_lo
000E32  1  18              clc
000E33  1  69 10           adc #16
000E35  1  85 rr           sta zp_scratch_lo
000E37  1  A5 rr           lda zp_row_y_hi
000E39  1  69 00           adc #0
000E3B  1  85 rr           sta zp_scratch_hi
000E3D  1  A5 rr           lda bullet_y_lo
000E3F  1  38              sec
000E40  1  E5 rr           sbc zp_scratch_lo
000E42  1  A5 rr           lda bullet_y_hi
000E44  1  E5 rr           sbc zp_scratch_hi
000E46  1  10 05           bpl @next_row         ; bullet top at or below invader bottom → no hit
000E48  1               
000E48  1                  ; Y overlaps this row — check each column
000E48  1  20 56 0E        jsr cbi_check_cols
000E4B  1  B0 08           bcs @done             ; hit found; bullet already handled
000E4D  1               
000E4D  1               @next_row:
000E4D  1  E6 rr           inc zp_row
000E4F  1  A5 rr           lda zp_row
000E51  1  C9 05           cmp #5
000E53  1  D0 B3           bne @row_loop
000E55  1               
000E55  1               @done:
000E55  1  60              rts
000E56  1               
000E56  1               ;******************************************************************
000E56  1               ; cbi_check_cols — column scan for check_bullet_invader
000E56  1               ;
000E56  1               ;   Scans all 11 columns of zp_row for an X overlap with the bullet.
000E56  1               ;   Assumes Y overlap for this row has already been confirmed.
000E56  1               ;   Returns: C set if hit (kill_invader_hit already called),
000E56  1               ;            C clear if no hit.
000E56  1               ;   Scratch used: zp_col, zp_x_lo/hi, zp_scratch_lo/hi
000E56  1               ;******************************************************************
000E56  1               cbi_check_cols:
000E56  1  64 rr           stz zp_col
000E58  1               @col_loop:
000E58  1                  ; skip if invader is dead
000E58  1  A4 rr           ldy zp_row
000E5A  1  B9 AB 17        lda inv_row_base,y
000E5D  1  18              clc
000E5E  1  65 rr           adc zp_col
000E60  1  A8              tay                   ; Y = invader index
000E61  1  29 07           and #$07
000E63  1  AA              tax
000E64  1  BD B0 17        lda bit_masks,x
000E67  1  48              pha
000E68  1  98              tya
000E69  1  4A              lsr
000E6A  1  4A              lsr
000E6B  1  4A              lsr
000E6C  1  A8              tay                   ; Y = byte index into inv_alive
000E6D  1  68              pla
000E6E  1  39 rr rr        and inv_alive,y
000E71  1  F0 46           beq @next_col         ; dead
000E73  1               
000E73  1                  ; compute inv_x = inv_grid_x + col_x_offsets[col]
000E73  1  A4 rr           ldy zp_col
000E75  1  B9 90 17        lda col_x_lo,y
000E78  1  18              clc
000E79  1  65 rr           adc inv_grid_x_lo
000E7B  1  85 rr           sta zp_x_lo
000E7D  1  B9 9B 17        lda col_x_hi,y
000E80  1  65 rr           adc inv_grid_x_hi
000E82  1  85 rr           sta zp_x_hi
000E84  1               
000E84  1                  ; X check (1): bullet_x+8 > inv_x
000E84  1  A5 rr           lda bullet_x_lo
000E86  1  18              clc
000E87  1  69 08           adc #8
000E89  1  85 rr           sta zp_scratch_lo
000E8B  1  A5 rr           lda bullet_x_hi
000E8D  1  69 00           adc #0
000E8F  1  85 rr           sta zp_scratch_hi
000E91  1  A5 rr           lda zp_scratch_lo
000E93  1  38              sec
000E94  1  E5 rr           sbc zp_x_lo
000E96  1  A5 rr           lda zp_scratch_hi
000E98  1  E5 rr           sbc zp_x_hi
000E9A  1  30 1D           bmi @next_col         ; bullet right edge left of invader → no hit
000E9C  1               
000E9C  1                  ; X check (2): bullet_x < inv_x+16
000E9C  1  A5 rr           lda zp_x_lo
000E9E  1  18              clc
000E9F  1  69 10           adc #16
000EA1  1  85 rr           sta zp_scratch_lo
000EA3  1  A5 rr           lda zp_x_hi
000EA5  1  69 00           adc #0
000EA7  1  85 rr           sta zp_scratch_hi
000EA9  1  A5 rr           lda bullet_x_lo
000EAB  1  38              sec
000EAC  1  E5 rr           sbc zp_scratch_lo
000EAE  1  A5 rr           lda bullet_x_hi
000EB0  1  E5 rr           sbc zp_scratch_hi
000EB2  1  10 05           bpl @next_col         ; bullet left edge at or right of invader → no hit
000EB4  1               
000EB4  1                  ; --- HIT ---
000EB4  1  20 C3 0E        jsr kill_invader_hit
000EB7  1  38              sec                   ; signal hit to caller
000EB8  1  60              rts
000EB9  1               
000EB9  1               @next_col:
000EB9  1  E6 rr           inc zp_col
000EBB  1  A5 rr           lda zp_col
000EBD  1  C9 0B           cmp #11
000EBF  1  D0 97           bne @col_loop
000EC1  1               
000EC1  1  18              clc                   ; no hit
000EC2  1  60              rts
000EC3  1               
000EC3  1               ;******************************************************************
000EC3  1               ; kill_invader_hit — clear alive bit, deactivate bullet, update score & speed
000EC3  1               ;   Expects zp_row, zp_col to identify the hit invader.
000EC3  1               ;******************************************************************
000EC3  1               kill_invader_hit:
000EC3  1                  ; --- clear alive bit ---
000EC3  1  A4 rr           ldy zp_row
000EC5  1  B9 AB 17        lda inv_row_base,y
000EC8  1  18              clc
000EC9  1  65 rr           adc zp_col
000ECB  1  A8              tay                   ; Y = invader index
000ECC  1  29 07           and #$07
000ECE  1  AA              tax
000ECF  1  BD B0 17        lda bit_masks,x       ; bit mask for this invader
000ED2  1  48              pha
000ED3  1  98              tya
000ED4  1  4A              lsr
000ED5  1  4A              lsr
000ED6  1  4A              lsr
000ED7  1  A8              tay                   ; Y = byte index into inv_alive
000ED8  1  68              pla
000ED9  1  49 FF           eor #$FF              ; invert → clear mask
000EDB  1  39 rr rr        and inv_alive,y
000EDE  1  99 rr rr        sta inv_alive,y
000EE1  1               
000EE1  1                  ; --- start explosion at the hit invader's position ---
000EE1  1                  ; zp_x_lo/hi and zp_row_y_lo/hi still hold the invader coords from collision detection
000EE1  1  20 0F 0F        jsr start_explosion
000EE4  1               
000EE4  1                  ; --- deactivate bullet ---
000EE4  1  64 rr           stz bullet_active
000EE6  1  20 BC 0D        jsr update_bullet_sprite
000EE9  1               
000EE9  1                  ; --- decrement inv_count ---
000EE9  1  C6 rr           dec inv_count
000EEB  1               
000EEB  1                  ; --- update inv_move_speed: proportional to remaining count ---
000EEB  1  A6 rr           ldx inv_count
000EED  1  BD BD 17        lda inv_speed_table,x
000EF0  1  85 rr           sta inv_move_speed
000EF2  1               
000EF2  1                  ; --- add score for this row's invader type ---
000EF2  1  A4 rr           ldy zp_row
000EF4  1  B9 B8 17        lda score_by_row_bcd,y
000EF7  1  20 FB 0E        jsr add_score
000EFA  1  60              rts
000EFB  1               
000EFB  1               ;******************************************************************
000EFB  1               ; add_score — add BCD value in A to score_lo/mid/hi
000EFB  1               ;******************************************************************
000EFB  1               add_score:
000EFB  1  F8              sed
000EFC  1  18              clc
000EFD  1  65 rr           adc score_lo
000EFF  1  85 rr           sta score_lo
000F01  1  A5 rr           lda score_mid
000F03  1  69 00           adc #0
000F05  1  85 rr           sta score_mid
000F07  1  A5 rr           lda score_hi
000F09  1  69 00           adc #0
000F0B  1  85 rr           sta score_hi
000F0D  1  D8              cld
000F0E  1  60              rts
000F0F  1               
000F0F  1               ;******************************************************************
000F0F  1               ; start_explosion — position sprite 4 at the hit invader and start timer
000F0F  1               ;
000F0F  1               ;   Inputs: zp_x_lo/hi     — invader X (VERA coords)
000F0F  1               ;           zp_row_y_lo/hi — invader Y (VERA coords)
000F0F  1               ;   Sets exp_timer = EXPLODE_FRAMES and enables sprite 4.
000F0F  1               ;******************************************************************
000F0F  1               start_explosion:
000F0F  1  9C 25 9F        stz VERA_ctrl
000F12  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 2), 1  ; start at byte 2 (X lo)
000F16  1  9F A9 FC 8D  
000F1A  1  21 9F A9 22  
000F21  1  A5 rr           lda zp_x_lo
000F23  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
000F26  1  A5 rr           lda zp_x_hi
000F28  1  29 03           and #$03
000F2A  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
000F2D  1  A5 rr           lda zp_row_y_lo
000F2F  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
000F32  1  A5 rr           lda zp_row_y_hi
000F34  1  29 03           and #$03
000F36  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
000F39  1  A9 0C           lda #SPR_Z_FRONT
000F3B  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth=3 → enabled, in front
000F3E  1  A9 1E           lda #EXPLODE_FRAMES
000F40  1  85 rr           sta exp_timer
000F42  1  60              rts
000F43  1               
000F43  1               ;******************************************************************
000F43  1               ; update_explosion — decrement exp_timer; disable sprite when it hits 0
000F43  1               ;******************************************************************
000F43  1               update_explosion:
000F43  1  A5 rr           lda exp_timer
000F45  1  F0 1B           beq @inactive
000F47  1  C6 rr           dec exp_timer
000F49  1  D0 17           bne @inactive
000F4B  1                  ; timer just expired — disable sprite 4
000F4B  1  9C 25 9F        stz VERA_ctrl
000F4E  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1  ; byte 6 = z-depth
000F52  1  9F A9 FC 8D  
000F56  1  21 9F A9 26  
000F5D  1  A9 00           lda #$00
000F5F  1  8D 23 9F        sta VERA_data0               ; z-depth=0 → disabled
000F62  1               @inactive:
000F62  1  60              rts
000F63  1               
000F63  1               ;******************************************************************
000F63  1               ; prng — 16-bit Galois LFSR, feedback polynomial $B400
000F63  1               ;   Updates rand_seed_lo/hi; returns pseudo-random byte in A.
000F63  1               ;******************************************************************
000F63  1               prng:
000F63  1  46 rr           lsr rand_seed_hi          ; shift 16-bit state right; carry = old hi[0]
000F65  1  66 rr           ror rand_seed_lo          ; lo[7] = old hi[0]; carry = old lo[0] (feedback bit)
000F67  1  90 06           bcc @done                 ; feedback bit=0: no XOR
000F69  1  A5 rr           lda rand_seed_hi
000F6B  1  49 B4           eor #$B4                  ; XOR hi byte with feedback poly ($B400 >> 8)
000F6D  1  85 rr           sta rand_seed_hi
000F6F  1               @done:
000F6F  1  A5 rr           lda rand_seed_lo
000F71  1  60              rts
000F72  1               
000F72  1               ;******************************************************************
000F72  1               ; update_inv_bullets — fire timer, move active bullets, boundary check,
000F72  1               ;   update VERA sprites for all 3 invader bullet slots.
000F72  1               ;******************************************************************
000F72  1               update_inv_bullets:
000F72  1                  ; --- fire timer ---
000F72  1  C6 rr           dec inv_fire_timer
000F74  1  D0 0D           bne @move_loop
000F76  1                  ; reset timer = max(inv_move_speed, INV_FIRE_TIMER_MIN)
000F76  1  A5 rr           lda inv_move_speed
000F78  1  C9 0A           cmp #INV_FIRE_TIMER_MIN
000F7A  1  B0 02           bcs @set_timer
000F7C  1  A9 0A           lda #INV_FIRE_TIMER_MIN
000F7E  1               @set_timer:
000F7E  1  85 rr           sta inv_fire_timer
000F80  1  20 ED 0F        jsr try_fire_inv_bullet
000F83  1               
000F83  1               @move_loop:
000F83  1  A2 00           ldx #0
000F85  1               @slot_loop:
000F85  1  B5 rr           lda ibul_active,x
000F87  1  F0 1B           beq @update_spr           ; inactive: just hide sprite
000F89  1               
000F89  1                  ; move bullet down by INV_BULLET_SPEED
000F89  1  B5 rr           lda ibul_y_lo,x
000F8B  1  18              clc
000F8C  1  69 06           adc #INV_BULLET_SPEED
000F8E  1  95 rr           sta ibul_y_lo,x
000F90  1  B5 rr           lda ibul_y_hi,x
000F92  1  69 00           adc #0
000F94  1  95 rr           sta ibul_y_hi,x
000F96  1               
000F96  1                  ; boundary: deactivate if Y >= 480 ($01E0)
000F96  1  C9 01           cmp #>480                 ; A = new hi byte; compare with 1
000F98  1  90 0A           bcc @update_spr           ; hi < 1: still on screen
000F9A  1  D0 06           bne @deactivate           ; hi > 1: off screen
000F9C  1  B5 rr           lda ibul_y_lo,x
000F9E  1  C9 E0           cmp #<480                 ; compare lo with $E0
000FA0  1  90 02           bcc @update_spr           ; lo < $E0: still on screen
000FA2  1               @deactivate:
000FA2  1  74 rr           stz ibul_active,x
000FA4  1               
000FA4  1               @update_spr:
000FA4  1  20 AD 0F        jsr update_inv_bullet_sprite   ; preserves X
000FA7  1  E8              inx
000FA8  1  E0 03           cpx #3
000FAA  1  D0 D9           bne @slot_loop
000FAC  1  60              rts
000FAD  1               
000FAD  1               ;******************************************************************
000FAD  1               ; update_inv_bullet_sprite — write VERA sprite attrs bytes 2-6 for slot X
000FAD  1               ;   X = slot index (0-2).  Preserves X.
000FAD  1               ;******************************************************************
000FAD  1               update_inv_bullet_sprite:
000FAD  1  86 rr           stx zp_scratch_lo              ; preserve slot index
000FAF  1  9C 25 9F        stz VERA_ctrl
000FB2  1  A9 11           lda #$11                       ; stride=1, bank bit=1
000FB4  1  8D 22 9F        sta VERA_addr_bank
000FB7  1  A9 FC           lda #$FC
000FB9  1  8D 21 9F        sta VERA_addr_high
000FBC  1  BD F5 17        lda ibul_spr_lo,x
000FBF  1  18              clc
000FC0  1  69 02           adc #2                         ; point to byte 2 (X position)
000FC2  1  8D 20 9F        sta VERA_addr_low
000FC5  1  B5 rr           lda ibul_x_lo,x
000FC7  1  8D 23 9F        sta VERA_data0                 ; byte 2: X lo
000FCA  1  B5 rr           lda ibul_x_hi,x
000FCC  1  29 03           and #$03
000FCE  1  8D 23 9F        sta VERA_data0                 ; byte 3: X hi
000FD1  1  B5 rr           lda ibul_y_lo,x
000FD3  1  8D 23 9F        sta VERA_data0                 ; byte 4: Y lo
000FD6  1  B5 rr           lda ibul_y_hi,x
000FD8  1  29 03           and #$03
000FDA  1  8D 23 9F        sta VERA_data0                 ; byte 5: Y hi
000FDD  1  B5 rr           lda ibul_active,x
000FDF  1  F0 04           beq @disabled
000FE1  1  A9 0C           lda #SPR_Z_FRONT
000FE3  1  80 02           bra @write_z
000FE5  1               @disabled:
000FE5  1  A9 00           lda #0
000FE7  1               @write_z:
000FE7  1  8D 23 9F        sta VERA_data0                 ; byte 6: z-depth
000FEA  1  A6 rr           ldx zp_scratch_lo
000FEC  1  60              rts
000FED  1               
000FED  1               ;******************************************************************
000FED  1               ; try_fire_inv_bullet — find a free slot and spawn a bullet from the
000FED  1               ;   bottommost live invader in a randomly chosen column.
000FED  1               ;   Returns immediately if all slots busy or chosen column is empty.
000FED  1               ;   Scratch used: zp_row, zp_col, zp_scratch_lo (slot index)
000FED  1               ;******************************************************************
000FED  1               try_fire_inv_bullet:
000FED  1                  ; find a free bullet slot
000FED  1  A2 00           ldx #0
000FEF  1               @find_slot:
000FEF  1  B5 rr           lda ibul_active,x
000FF1  1  F0 06           beq @slot_found
000FF3  1  E8              inx
000FF4  1  E0 03           cpx #3
000FF6  1  D0 F7           bne @find_slot
000FF8  1  60              rts                            ; all slots busy
000FF9  1               
000FF9  1               @slot_found:
000FF9  1  86 rr           stx zp_scratch_lo              ; save free slot index
000FFB  1               
000FFB  1                  ; pick a random column 0-10
000FFB  1  20 63 0F        jsr prng
000FFE  1  29 0F           and #$0F                       ; 0-15
001000  1  C9 0B           cmp #11
001002  1  90 03           bcc @col_ok
001004  1  38              sec
001005  1  E9 0B           sbc #11                        ; wrap 11-15 → 0-4 (slight bias, acceptable)
001007  1               @col_ok:
001007  1  85 rr           sta zp_col
001009  1               
001009  1                  ; scan rows 4 down to 0 for bottommost live invader in this column
001009  1  A9 04           lda #4
00100B  1  85 rr           sta zp_row
00100D  1               @row_scan:
00100D  1  A4 rr           ldy zp_row
00100F  1  B9 AB 17        lda inv_row_base,y
001012  1  18              clc
001013  1  65 rr           adc zp_col
001015  1  A8              tay                            ; Y = invader index
001016  1  29 07           and #$07
001018  1  AA              tax                            ; X = bit position
001019  1  BD B0 17        lda bit_masks,x
00101C  1  48              pha
00101D  1  98              tya
00101E  1  4A              lsr
00101F  1  4A              lsr
001020  1  4A              lsr
001021  1  A8              tay                            ; Y = byte index into inv_alive
001022  1  68              pla
001023  1  39 rr rr        and inv_alive,y
001026  1  D0 09           bne @found_invader
001028  1  A5 rr           lda zp_row
00102A  1  F0 04           beq @no_invader                ; checked row 0, nothing alive
00102C  1  C6 rr           dec zp_row
00102E  1  80 DD           bra @row_scan
001030  1               
001030  1               @no_invader:
001030  1  60              rts                            ; column empty, skip fire
001031  1               
001031  1               @found_invader:
001031  1  A6 rr           ldx zp_scratch_lo              ; restore free slot index
001033  1  A9 01           lda #1
001035  1  95 rr           sta ibul_active,x
001037  1               
001037  1                  ; spawn X = inv_grid_x + col_x_offsets[col]  (16-bit, matching update_invader_sprites)
001037  1  A4 rr           ldy zp_col
001039  1  B9 90 17        lda col_x_lo,y
00103C  1  18              clc
00103D  1  65 rr           adc inv_grid_x_lo
00103F  1  95 rr           sta ibul_x_lo,x
001041  1  B9 9B 17        lda col_x_hi,y
001044  1  65 rr           adc inv_grid_x_hi
001046  1  95 rr           sta ibul_x_hi,x
001048  1                  ; add +4 as a separate 16-bit step to centre the 8px bullet in the 16px invader
001048  1  B5 rr           lda ibul_x_lo,x
00104A  1  18              clc
00104B  1  69 04           adc #4
00104D  1  95 rr           sta ibul_x_lo,x
00104F  1  B5 rr           lda ibul_x_hi,x
001051  1  69 00           adc #0
001053  1  95 rr           sta ibul_x_hi,x
001055  1               
001055  1                  ; spawn Y: compute y_base first (same two-step pattern as update_invader_sprites)
001055  1                  ; step 1: y_base = INV_GRID_Y_BASE + inv_offset_y  (16-bit)
001055  1  A9 50           lda #<INV_GRID_Y_BASE
001057  1  18              clc
001058  1  65 rr           adc inv_offset_y
00105A  1  85 rr           sta zp_y_base_lo
00105C  1  A9 00           lda #>INV_GRID_Y_BASE
00105E  1  69 00           adc #0
001060  1  85 rr           sta zp_y_base_hi
001062  1                  ; step 2: spawn_y = y_base + row_y_offsets[row]
001062  1  A4 rr           ldy zp_row
001064  1  B9 A6 17        lda row_y_offsets,y
001067  1  18              clc
001068  1  65 rr           adc zp_y_base_lo
00106A  1  95 rr           sta ibul_y_lo,x
00106C  1  A9 00           lda #0
00106E  1  65 rr           adc zp_y_base_hi
001070  1  95 rr           sta ibul_y_hi,x
001072  1                  ; step 3: +16 to place bullet at the bottom edge of the 16px invader
001072  1  B5 rr           lda ibul_y_lo,x
001074  1  18              clc
001075  1  69 10           adc #16
001077  1  95 rr           sta ibul_y_lo,x
001079  1  B5 rr           lda ibul_y_hi,x
00107B  1  69 00           adc #0
00107D  1  95 rr           sta ibul_y_hi,x
00107F  1               
00107F  1  60              rts
001080  1               
001080  1               ;******************************************************************
001080  1               ; check_inv_bullet_player — AABB test each active invader bullet vs. player
001080  1               ;
001080  1               ;   Player rect: (player_x, PLAYER_Y) to (player_x+15, PLAYER_Y+15), 16x16
001080  1               ;   Bullet rect: (ibul_x,   ibul_y)   to (ibul_x+7,   ibul_y+7),     8x8
001080  1               ;
001080  1               ;   On hit: bullet deactivated, jsr player_hit called, loop continues
001080  1               ;   (remaining bullets checked — at most one hit landing per frame).
001080  1               ;   Scratch: zp_scratch_lo/hi, X (slot index)
001080  1               ;******************************************************************
001080  1               check_inv_bullet_player:
001080  1  A2 00           ldx #0
001082  1               @slot_loop:
001082  1  B5 rr           lda ibul_active,x
001084  1  F0 5B           beq @next_slot
001086  1               
001086  1                  ; --- Y check 1: (bullet_y + 8) > PLAYER_Y  →  bullet_y + 8 - PLAYER_Y > 0 ---
001086  1  B5 rr           lda ibul_y_lo,x
001088  1  18              clc
001089  1  69 08           adc #8
00108B  1  85 rr           sta zp_scratch_lo
00108D  1  B5 rr           lda ibul_y_hi,x
00108F  1  69 00           adc #0
001091  1  85 rr           sta zp_scratch_hi
001093  1  A5 rr           lda zp_scratch_lo
001095  1  38              sec
001096  1  E9 A4           sbc #<PLAYER_Y
001098  1  A5 rr           lda zp_scratch_hi
00109A  1  E9 01           sbc #>PLAYER_Y
00109C  1  30 43           bmi @next_slot            ; bullet bottom above player top → no hit
00109E  1               
00109E  1                  ; --- Y check 2: bullet_y < PLAYER_Y + 16 → bullet_y - (PLAYER_Y+16) < 0 ---
00109E  1  B5 rr           lda ibul_y_lo,x
0010A0  1  38              sec
0010A1  1  E9 B4           sbc #<(PLAYER_Y+16)
0010A3  1  B5 rr           lda ibul_y_hi,x
0010A5  1  E9 01           sbc #>(PLAYER_Y+16)
0010A7  1  10 38           bpl @next_slot            ; bullet top at or below player bottom → no hit
0010A9  1               
0010A9  1                  ; --- X check 1: (bullet_x + 8) > player_x ---
0010A9  1  B5 rr           lda ibul_x_lo,x
0010AB  1  18              clc
0010AC  1  69 08           adc #8
0010AE  1  85 rr           sta zp_scratch_lo
0010B0  1  B5 rr           lda ibul_x_hi,x
0010B2  1  69 00           adc #0
0010B4  1  85 rr           sta zp_scratch_hi
0010B6  1  A5 rr           lda zp_scratch_lo
0010B8  1  38              sec
0010B9  1  E5 rr           sbc player_x_lo
0010BB  1  A5 rr           lda zp_scratch_hi
0010BD  1  E5 rr           sbc player_x_hi
0010BF  1  30 20           bmi @next_slot            ; bullet right edge left of player → no hit
0010C1  1               
0010C1  1                  ; --- X check 2: bullet_x < player_x + 16 ---
0010C1  1  A5 rr           lda player_x_lo
0010C3  1  18              clc
0010C4  1  69 10           adc #16
0010C6  1  85 rr           sta zp_scratch_lo
0010C8  1  A5 rr           lda player_x_hi
0010CA  1  69 00           adc #0
0010CC  1  85 rr           sta zp_scratch_hi
0010CE  1  B5 rr           lda ibul_x_lo,x
0010D0  1  38              sec
0010D1  1  E5 rr           sbc zp_scratch_lo
0010D3  1  B5 rr           lda ibul_x_hi,x
0010D5  1  E5 rr           sbc zp_scratch_hi
0010D7  1  10 08           bpl @next_slot            ; bullet left edge at or right of player → no hit
0010D9  1               
0010D9  1                  ; --- HIT ---
0010D9  1  74 rr           stz ibul_active,x         ; deactivate this bullet
0010DB  1  20 AD 0F        jsr update_inv_bullet_sprite
0010DE  1  20 E7 10        jsr player_hit
0010E1  1               
0010E1  1               @next_slot:
0010E1  1  E8              inx
0010E2  1  E0 03           cpx #3
0010E4  1  D0 9C           bne @slot_loop
0010E6  1  60              rts
0010E7  1               
0010E7  1               ;******************************************************************
0010E7  1               ; player_hit — handle a bullet-player collision:
0010E7  1               ;   explosion at player position, decrement lives, respawn, invincibility
0010E7  1               ;******************************************************************
0010E7  1               player_hit:
0010E7  1                  ; start explosion at player position
0010E7  1  A5 rr           lda player_x_lo
0010E9  1  85 rr           sta zp_x_lo
0010EB  1  A5 rr           lda player_x_hi
0010ED  1  85 rr           sta zp_x_hi
0010EF  1  A9 A4           lda #<PLAYER_Y
0010F1  1  85 rr           sta zp_row_y_lo
0010F3  1  A9 01           lda #>PLAYER_Y
0010F5  1  85 rr           sta zp_row_y_hi
0010F7  1  20 0F 0F        jsr start_explosion
0010FA  1               
0010FA  1                  ; decrement lives
0010FA  1  C6 rr           dec lives
0010FC  1  F0 0D           beq @game_over            ; lives hit 0 → end game (Phase 6 will handle this properly)
0010FE  1               
0010FE  1                  ; grant invincibility and re-centre the ship
0010FE  1  A9 78           lda #INV_HIT_FRAMES
001100  1  85 rr           sta inv_hit_timer
001102  1  A9 38           lda #<PLAYER_X_INIT
001104  1  85 rr           sta player_x_lo
001106  1  A9 01           lda #>PLAYER_X_INIT
001108  1  85 rr           sta player_x_hi
00110A  1  60              rts
00110B  1               
00110B  1               @game_over:
00110B  1  4C 02 09        jmp exit_game             ; placeholder: Phase 6 will show a game-over screen
00110E  1               
00110E  1               ;******************************************************************
00110E  1               ; draw_title_screen — paint the title screen; called once before title_loop
00110E  1               ;
00110E  1               ;   Layout (40-col text, VERA Y=row*16):
00110E  1               ;     Row  1, col 14: "X16 INVADERS"      (12 chars, centred)
00110E  1               ;     Row  3, col 16: "HI-SCORE"          (8 chars, centred)
00110E  1               ;     Row  4, col 17: 000000              (6-digit BCD hi-score)
00110E  1               ;     Row  5, col  5: "?UFO? = ??? PTS"
00110E  1               ;     Row  7, col  9: "= 30 PTS"          + Type C sprite at X=96,Y=112
00110E  1               ;     Row 10, col  9: "= 20 PTS"          + Type B sprite at X=96,Y=160
00110E  1               ;     Row 13, col  9: "= 10 PTS"          + Type A sprite at X=96,Y=208
00110E  1               ;     Row 17, col 10: (PRESS SPACE TO START — blinked by title_loop)
00110E  1               ;     Row 19, col 12: "RUN/STOP TO QUIT"
00110E  1               ;******************************************************************
00110E  1               draw_title_screen:
00110E  1                  ; Row 1, col 14: "X16 INVADERS"
00110E  1  A9 01           lda #1
001110  1  A0 0E           ldy #14
001112  1  18              clc
001113  1  20 F0 FF        jsr PLOT
001116  1  A2 00           ldx #0
001118  1  BD 67 16     @lp1: lda str_title_main, x
00111B  1  F0 06           beq @lp1_done
00111D  1  20 D2 FF        jsr CHROUT
001120  1  E8              inx
001121  1  80 F5           bra @lp1
001123  1               @lp1_done:
001123  1               
001123  1                  ; Row 3, col 16: "HI-SCORE"
001123  1  A9 03           lda #3
001125  1  A0 10           ldy #16
001127  1  18              clc
001128  1  20 F0 FF        jsr PLOT
00112B  1  A2 00           ldx #0
00112D  1  BD 74 16     @lp2: lda str_hi_score_lbl, x
001130  1  F0 06           beq @lp2_done
001132  1  20 D2 FF        jsr CHROUT
001135  1  E8              inx
001136  1  80 F5           bra @lp2
001138  1               @lp2_done:
001138  1               
001138  1                  ; Row 4, col 17: hi-score 6 BCD digits (000000 at start)
001138  1  A9 04           lda #4
00113A  1  A0 11           ldy #17
00113C  1  18              clc
00113D  1  20 F0 FF        jsr PLOT
001140  1  A5 rr           lda hi_score_hi
001142  1  20 48 16        jsr print_hex_byte
001145  1  A5 rr           lda hi_score_mid
001147  1  20 48 16        jsr print_hex_byte
00114A  1  A5 rr           lda hi_score_lo
00114C  1  20 48 16        jsr print_hex_byte
00114F  1               
00114F  1                  ; Row 5, col 5: "?UFO? = ??? PTS"
00114F  1  A9 05           lda #5
001151  1  A0 05           ldy #5
001153  1  18              clc
001154  1  20 F0 FF        jsr PLOT
001157  1  A2 00           ldx #0
001159  1  BD 7D 16     @lp3: lda str_ufo_score, x
00115C  1  F0 06           beq @lp3_done
00115E  1  20 D2 FF        jsr CHROUT
001161  1  E8              inx
001162  1  80 F5           bra @lp3
001164  1               @lp3_done:
001164  1               
001164  1                  ; Sample invader sprites (Types C, B, A) + score labels
001164  1  20 7D 11        jsr show_title_sprites
001167  1               
001167  1                  ; Row 19, col 12: "RUN/STOP TO QUIT"
001167  1  A9 13           lda #19
001169  1  A0 0C           ldy #12
00116B  1  18              clc
00116C  1  20 F0 FF        jsr PLOT
00116F  1  A2 00           ldx #0
001171  1  BD BD 16     @lp4: lda str_run_stop_hint, x
001174  1  F0 06           beq @lp4_done
001176  1  20 D2 FF        jsr CHROUT
001179  1  E8              inx
00117A  1  80 F5           bra @lp4
00117C  1               @lp4_done:
00117C  1               
00117C  1  60              rts
00117D  1               
00117D  1               ;******************************************************************
00117D  1               ; show_title_sprites — enable one sprite of each type at fixed
00117D  1               ;   title-screen positions and print score labels beside them.
00117D  1               ;
00117D  1               ;   In VERA 640x480 space, 1 text row/col = 16 VERA pixels.
00117D  1               ;   Sprites: X=96 (col 6), score labels at col 9.
00117D  1               ;   Sprite 11 (Type C): Y=112 → text row 7,  "= 30 PTS"
00117D  1               ;   Sprite 22 (Type B): Y=160 → text row 10, "= 20 PTS"
00117D  1               ;   Sprite 44 (Type A): Y=208 → text row 13, "= 10 PTS"
00117D  1               ;******************************************************************
00117D  1               show_title_sprites:
00117D  1  9C 25 9F        stz VERA_ctrl
001180  1                  ; --- sprite 11 (Type C, squid/cyan): attr $1FC00+11*8=$1FC58 ---
001180  1                  ; addr[12:5] = VRAM_INV_C_F0>>5 = $00300>>5 = $18
001180  1  A9 11           lda #$11               ; stride=1, bank=1
001182  1  8D 22 9F        sta VERA_addr_bank
001185  1  A9 FC           lda #$FC
001187  1  8D 21 9F        sta VERA_addr_high
00118A  1  A9 58           lda #$58               ; low byte of $1FC58
00118C  1  8D 20 9F        sta VERA_addr_low
00118F  1  A9 18           lda #$18               ; byte 0: data addr[12:5]
001191  1  8D 23 9F        sta VERA_data0
001194  1  A9 00           lda #$00               ; byte 1: 4bpp, addr[16:13]=0
001196  1  8D 23 9F        sta VERA_data0
001199  1  A9 60           lda #96                ; byte 2: X lo
00119B  1  8D 23 9F        sta VERA_data0
00119E  1  A9 00           lda #0                 ; byte 3: X hi
0011A0  1  8D 23 9F        sta VERA_data0
0011A3  1  A9 70           lda #112               ; byte 4: Y lo (row 7: 7*16=112)
0011A5  1  8D 23 9F        sta VERA_data0
0011A8  1  A9 00           lda #0                 ; byte 5: Y hi
0011AA  1  8D 23 9F        sta VERA_data0
0011AD  1  A9 0C           lda #SPR_Z_FRONT       ; byte 6: z-depth=3
0011AF  1  8D 23 9F        sta VERA_data0
0011B2  1  A9 50           lda #SPR_16x16_PAL0    ; byte 7: 16x16, palette 0
0011B4  1  8D 23 9F        sta VERA_data0
0011B7  1               
0011B7  1  A9 07           lda #7
0011B9  1  A0 09           ldy #9
0011BB  1  18              clc
0011BC  1  20 F0 FF        jsr PLOT
0011BF  1  A2 00           ldx #0
0011C1  1  BD 8D 16     @lp_c: lda str_score_c, x
0011C4  1  F0 06           beq @lp_c_done
0011C6  1  20 D2 FF        jsr CHROUT
0011C9  1  E8              inx
0011CA  1  80 F5           bra @lp_c
0011CC  1               @lp_c_done:
0011CC  1               
0011CC  1                  ; --- sprite 22 (Type B, octopus/magenta): attr $1FC00+22*8=$1FCB0 ---
0011CC  1                  ; addr[12:5] = VRAM_INV_B_F0>>5 = $00200>>5 = $10
