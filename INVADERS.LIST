001863  1               ;******************************************************************
001863  1               ; update_shield_sprite — write new data-addr byte to shield sprite N
001863  1               ;   Input:  X = shield index (0–3)
001863  1               ;           shield_damage[X] = current damage level (1–7)
001863  1               ;   Writes sprite byte 0 (addr[12:5]) using shield_addr_b0 lookup.
001863  1               ;   VERA addr for byte 0 of sprite N: $1FE10 + N*8
001863  1               ;******************************************************************
001863  1               update_shield_sprite:
001863  1  9C 25 9F        stz VERA_ctrl
001866  1  A9 11           lda #$11               ; stride=1, bank=1
001868  1  8D 22 9F        sta VERA_addr_bank
00186B  1  A9 FE           lda #$FE
00186D  1  8D 21 9F        sta VERA_addr_high
001870  1  8A              txa                    ; A = shield index
001871  1  0A              asl                    ; ×2
001872  1  0A              asl                    ; ×4
001873  1  0A              asl                    ; ×8
001874  1  18              clc
001875  1  69 10           adc #$10               ; + low byte of $1FE10
001877  1  8D 20 9F        sta VERA_addr_low
00187A  1  B4 rr           ldy shield_damage, x   ; Y = damage level (1-3)
00187C  1  B9 49 1F        lda shield_addr_b0, y  ; addr[12:5] for this tile
00187F  1  8D 23 9F        sta VERA_data0
001882  1  60              rts
001883  1               
001883  1               ;******************************************************************
001883  1               ; hide_shield_sprite — disable sprite for shield N (z-depth=0)
001883  1               ;   Input: X = shield index (0–3)
001883  1               ;   Writes sprite byte 6 at $1FE10 + N*8 + 6 = $1FE16 + N*8
001883  1               ;******************************************************************
001883  1               hide_shield_sprite:
001883  1  9C 25 9F        stz VERA_ctrl
001886  1  A9 11           lda #$11
001888  1  8D 22 9F        sta VERA_addr_bank
00188B  1  A9 FE           lda #$FE
00188D  1  8D 21 9F        sta VERA_addr_high
001890  1  8A              txa
001891  1  0A              asl
001892  1  0A              asl
001893  1  0A              asl
001894  1  18              clc
001895  1  69 16           adc #$16               ; low($1FE10) + 6 = $16, + N*8
001897  1  8D 20 9F        sta VERA_addr_low
00189A  1  A9 00           lda #0                 ; z-depth=0 → sprite disabled
00189C  1  8D 23 9F        sta VERA_data0
00189F  1  60              rts
0018A0  1               
0018A0  1               ;******************************************************************
0018A0  1               ; damage_shield — increment damage counter for shield X and update
0018A0  1               ;   sprite (or disable it when counter reaches 8 = destroyed).
0018A0  1               ;   Input:  X = shield index (0–3)
0018A0  1               ;   Clobbers: A, Y, VERA registers.  Preserves X.
0018A0  1               ;******************************************************************
0018A0  1               damage_shield:
0018A0  1  F6 rr           inc shield_damage, x
0018A2  1  B5 rr           lda shield_damage, x
0018A4  1  C9 08           cmp #8
0018A6  1  F0 06           beq @destroy
0018A8  1  B0 07           bcs @done              ; already at 8 (safety guard)
0018AA  1  20 63 18        jsr update_shield_sprite
0018AD  1  60              rts
0018AE  1               @destroy:
0018AE  1  20 83 18        jsr hide_shield_sprite
0018B1  1               @done:
0018B1  1  60              rts
0018B2  1               
0018B2  1               ;******************************************************************
0018B2  1               ; check_bullet_shields — test active player bullet vs all 4 shields
0018B2  1               ;
0018B2  1               ;   Overlap condition (AABB, all values VERA 16-bit):
0018B2  1               ;     X: bullet_x+8 > shield_x  AND  bullet_x < shield_x+16
0018B2  1               ;     Y: bullet_y+8 > SHIELD_Y  AND  bullet_y < SHIELD_Y+16
0018B2  1               ;
0018B2  1               ;   On hit: calls damage_shield, deactivates bullet, returns.
0018B2  1               ;   Scratch used: zp_scratch_lo/hi.  Preserves nothing.
0018B2  1               ;******************************************************************
0018B2  1               check_bullet_shields:
0018B2  1  A5 rr           lda bullet_active
0018B4  1  F0 6D           beq @done
0018B6  1               
0018B6  1                  ; --- Y quick check (same band for all shields) ---
0018B6  1                  ; (1) bullet_y+8 > SHIELD_Y
0018B6  1  A5 rr           lda bullet_y_lo
0018B8  1  18              clc
0018B9  1  69 08           adc #8
0018BB  1  85 rr           sta zp_scratch_lo
0018BD  1  A5 rr           lda bullet_y_hi
0018BF  1  69 00           adc #0
0018C1  1  85 rr           sta zp_scratch_hi
0018C3  1  A5 rr           lda zp_scratch_lo
0018C5  1  38              sec
0018C6  1  E9 60           sbc #<SHIELD_Y
0018C8  1  A5 rr           lda zp_scratch_hi
0018CA  1  E9 01           sbc #>SHIELD_Y
0018CC  1  30 55           bmi @done              ; bullet bottom above shield top
0018CE  1               
0018CE  1                  ; (2) bullet_y < SHIELD_Y+32
0018CE  1  A5 rr           lda bullet_y_lo
0018D0  1  38              sec
0018D1  1  E9 80           sbc #<(SHIELD_Y + 32)
0018D3  1  A5 rr           lda bullet_y_hi
0018D5  1  E9 01           sbc #>(SHIELD_Y + 32)
0018D7  1  10 4A           bpl @done              ; bullet top at or below shield bottom
0018D9  1               
0018D9  1                  ; --- Y overlaps: scan each shield ---
0018D9  1  A2 00           ldx #0
0018DB  1               @sld_loop:
0018DB  1  B5 rr           lda shield_damage, x
0018DD  1  C9 08           cmp #8
0018DF  1  B0 3D           bcs @next_sld          ; destroyed, skip
0018E1  1               
0018E1  1                  ; X check (1): bullet_x+8 > shield_x[x]
0018E1  1  A5 rr           lda bullet_x_lo
0018E3  1  18              clc
0018E4  1  69 08           adc #8
0018E6  1  85 rr           sta zp_scratch_lo
0018E8  1  A5 rr           lda bullet_x_hi
0018EA  1  69 00           adc #0
0018EC  1  85 rr           sta zp_scratch_hi
0018EE  1  A5 rr           lda zp_scratch_lo
0018F0  1  38              sec
0018F1  1  FD 41 1F        sbc shield_x_lo, x
0018F4  1  A5 rr           lda zp_scratch_hi
0018F6  1  FD 45 1F        sbc shield_x_hi, x
0018F9  1  30 23           bmi @next_sld
0018FB  1               
0018FB  1                  ; X check (2): bullet_x < shield_x[x]+32
0018FB  1  BD 41 1F        lda shield_x_lo, x
0018FE  1  18              clc
0018FF  1  69 20           adc #32
001901  1  85 rr           sta zp_scratch_lo
001903  1  BD 45 1F        lda shield_x_hi, x
001906  1  69 00           adc #0
001908  1  85 rr           sta zp_scratch_hi
00190A  1  A5 rr           lda bullet_x_lo
00190C  1  38              sec
00190D  1  E5 rr           sbc zp_scratch_lo
00190F  1  A5 rr           lda bullet_x_hi
001911  1  E5 rr           sbc zp_scratch_hi
001913  1  10 09           bpl @next_sld
001915  1               
001915  1                  ; --- HIT ---
001915  1  20 A0 18        jsr damage_shield      ; X = shield index
001918  1  64 rr           stz bullet_active
00191A  1  20 6B 0E        jsr update_bullet_sprite
00191D  1  60              rts
00191E  1               
00191E  1               @next_sld:
00191E  1  E8              inx
00191F  1  E0 04           cpx #4
001921  1  D0 B8           bne @sld_loop
001923  1               @done:
001923  1  60              rts
