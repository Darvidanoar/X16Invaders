00092E  1               ;******************************************************************
00092E  1               ; print_hex_byte — print .A as two uppercase hex digits via CHROUT
00092E  1               ;******************************************************************
00092E  1               print_hex_byte:
00092E  1  48              pha
00092F  1  4A              lsr                           ; shift high nibble down
000930  1  4A              lsr
000931  1  4A              lsr
000932  1  4A              lsr
000933  1  20 3D 09        jsr print_hex_nybble
000936  1  68              pla
000937  1  29 0F           and #$0F                      ; isolate low nibble
000939  1  20 3D 09        jsr print_hex_nybble
00093C  1  60              rts
00093D  1               
00093D  1               ; print_hex_nybble — print lower 4 bits of .A as one hex digit
00093D  1               ;   Relies on carry state from CMP to select digit vs. letter range
00093D  1               print_hex_nybble:
00093D  1  C9 0A           cmp #10
00093F  1  90 06           bcc @digit                    ; carry clear → 0-9
000941  1  69 36           adc #($41 - 10 - 1)          ; A-F: 'A'=65; carry set adds 1
000943  1  20 D2 FF        jsr CHROUT
000946  1  60              rts
000947  1               @digit:
000947  1  69 30           adc #$30                      ; 0-9: '0'=48; carry clear adds 0
000949  1  20 D2 FF        jsr CHROUT
00094C  1  60              rts
00094D  1               
