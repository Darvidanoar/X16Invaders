000D14  1               ;******************************************************************
000D14  1               ; player_spr_data — 16x16 4bpp sprite, 128 bytes
000D14  1               ;
000D14  1               ;   Color 0 = transparent, Color 1 = white (default palette index 1)
000D14  1               ;   Design: classic upward-pointing triangular ship with engine notches
000D14  1               ;
000D14  1               ;   Each byte encodes 2 pixels: high nibble = left, low nibble = right
000D14  1               ;   Columns: 0123456789ABCDEF
000D14  1               ;
000D14  1               ;   Row  0:  .......1........   cannon tip
000D14  1               ;   Row  1:  .......11.......
000D14  1               ;   Row  2:  ......111.......
000D14  1               ;   Row  3:  ......111.......
000D14  1               ;   Row  4:  .....11111......
000D14  1               ;   Row  5:  .....1111111....
000D14  1               ;   Row  6:  ...111111111....
000D14  1               ;   Row  7:  ..11111111111...
000D14  1               ;   Row  8:  .1111111111111..
000D14  1               ;   Row  9:  1111111111111111   full base
000D14  1               ;   Row 10:  1111111111111111
000D14  1               ;   Row 11:  1111111111111111
000D14  1               ;   Row 12:  11..11111111..11   engine notches
000D14  1               ;   Row 13:  11..11111111..11
000D14  1               ;   Row 14:  ................
000D14  1               ;   Row 15:  ................
000D14  1               ;******************************************************************
000D14  1               player_spr_data:
000D14  1                  ; row 0
000D14  1  00 00 00 00     .byte $00,$00,$00,$00,$00,$00,$00,$00
000D18  1  00 00 00 00  
000D1C  1                  ; row 1
000D1C  1  00 00 00 01     .byte $00,$00,$00,$01,$10,$00,$00,$00
000D20  1  10 00 00 00  
000D24  1                  ; row 2
000D24  1  00 00 00 01     .byte $00,$00,$00,$01,$10,$00,$00,$00
000D28  1  10 00 00 00  
000D2C  1                  ; row 3
000D2C  1  00 00 00 01     .byte $00,$00,$00,$01,$10,$00,$00,$00
000D30  1  10 00 00 00  
000D34  1                  ; row 4
000D34  1  00 00 01 11     .byte $00,$00,$01,$11,$11,$10,$00,$00
000D38  1  11 10 00 00  
000D3C  1                  ; row 5
000D3C  1  00 00 11 11     .byte $00,$00,$11,$11,$11,$11,$00,$00
000D40  1  11 11 00 00  
000D44  1                  ; row 6
000D44  1  00 01 11 11     .byte $00,$01,$11,$11,$11,$11,$10,$00
000D48  1  11 11 10 00  
000D4C  1                  ; row 7
000D4C  1  00 01 11 11     .byte $00,$01,$11,$11,$11,$11,$10,$00
000D50  1  11 11 10 00  
000D54  1                  ; row 8
000D54  1  01 11 11 11     .byte $01,$11,$11,$11,$11,$11,$11,$10
000D58  1  11 11 11 10  
000D5C  1                  ; row 9
000D5C  1  11 11 11 11     .byte $11,$11,$11,$11,$11,$11,$11,$11
000D60  1  11 11 11 11  
000D64  1                  ; row 10
000D64  1  11 11 11 11     .byte $11,$11,$11,$11,$11,$11,$11,$11
000D68  1  11 11 11 11  
000D6C  1                  ; row 11
000D6C  1  11 11 11 11     .byte $11,$11,$11,$11,$11,$11,$11,$11
000D70  1  11 11 11 11  
000D74  1                  ; row 12  (engine notches: cols 2-3 and 12-13 transparent)
000D74  1  11 00 11 11     .byte $11,$00,$11,$11,$11,$11,$00,$11
000D78  1  11 11 00 11  
000D7C  1                  ; row 13
000D7C  1  11 00 11 11     .byte $11,$00,$11,$11,$11,$11,$00,$11
000D80  1  11 11 00 11  
000D84  1                  ; row 14
000D84  1  00 00 00 00     .byte $00,$00,$00,$00,$00,$00,$00,$00
000D88  1  00 00 00 00  
000D8C  1                  ; row 15
000D8C  1  00 00 00 00     .byte $00,$00,$00,$00,$00,$00,$00,$00
000D90  1  00 00 00 00  
