0012CF  1               ;******************************************************************
0012CF  1               ; draw_title_screen — paint the title screen; called once before title_loop
0012CF  1               ;
0012CF  1               ;   Layout (40-col text, VERA Y=row*16):
0012CF  1               ;     Row  1, col 14: "X16 INVADERS"      (12 chars, centred)
0012CF  1               ;     Row  3, col 16: "HI-SCORE"          (8 chars, centred)
0012CF  1               ;     Row  4, col 17: 000000              (6-digit BCD hi-score)
0012CF  1               ;     Row  5, col  5: "?UFO? = ??? PTS"
0012CF  1               ;     Row  7, col  9: "= 30 PTS"          + Type C sprite at X=96,Y=112
0012CF  1               ;     Row 10, col  9: "= 20 PTS"          + Type B sprite at X=96,Y=160
0012CF  1               ;     Row 13, col  9: "= 10 PTS"          + Type A sprite at X=96,Y=208
0012CF  1               ;     Row 17, col 10: (PRESS SPACE TO START — blinked by title_loop)
0012CF  1               ;     Row 19, col 12: "RUN/STOP TO QUIT"
0012CF  1               ;******************************************************************
0012CF  1               draw_title_screen:
0012CF  1                  ; Row 1, col 14: "X16 INVADERS"
0012CF  1  A9 01           lda #1
0012D1  1  A0 0E           ldy #14
0012D3  1  18              clc
0012D4  1  20 F0 FF        jsr PLOT
0012D7  1  A2 00           ldx #0
0012D9  1  BD D5 19     @lp1: lda str_title_main, x
0012DC  1  F0 06           beq @lp1_done
0012DE  1  20 D2 FF        jsr CHROUT
0012E1  1  E8              inx
0012E2  1  80 F5           bra @lp1
0012E4  1               @lp1_done:
0012E4  1               
0012E4  1                  ; Row 3, col 16: "HI-SCORE"
0012E4  1  A9 03           lda #3
0012E6  1  A0 10           ldy #16
0012E8  1  18              clc
0012E9  1  20 F0 FF        jsr PLOT
0012EC  1  A2 00           ldx #0
0012EE  1  BD E2 19     @lp2: lda str_hi_score_lbl, x
0012F1  1  F0 06           beq @lp2_done
0012F3  1  20 D2 FF        jsr CHROUT
0012F6  1  E8              inx
0012F7  1  80 F5           bra @lp2
0012F9  1               @lp2_done:
0012F9  1               
0012F9  1                  ; Row 4, col 17: hi-score 6 BCD digits (000000 at start)
0012F9  1  A9 04           lda #4
0012FB  1  A0 11           ldy #17
0012FD  1  18              clc
0012FE  1  20 F0 FF        jsr PLOT
001301  1  A5 rr           lda hi_score_hi
001303  1  20 B6 19        jsr print_hex_byte
001306  1  A5 rr           lda hi_score_mid
001308  1  20 B6 19        jsr print_hex_byte
00130B  1  A5 rr           lda hi_score_lo
00130D  1  20 B6 19        jsr print_hex_byte
001310  1               
001310  1                  ; Row 5, col 5: "?UFO? = ??? PTS"
001310  1  A9 05           lda #5
001312  1  A0 05           ldy #5
001314  1  18              clc
001315  1  20 F0 FF        jsr PLOT
001318  1  A2 00           ldx #0
00131A  1  BD EB 19     @lp3: lda str_ufo_score, x
00131D  1  F0 06           beq @lp3_done
00131F  1  20 D2 FF        jsr CHROUT
001322  1  E8              inx
001323  1  80 F5           bra @lp3
001325  1               @lp3_done:
