001EB7  1               ; Lookup tables for update_invader_sprites
001EB7  1               ;
001EB7  1               ;   inv_addr_b0_f0/f1 — sprite data addr[12:5] for row 0-4, each frame
001EB7  1               ;     Row 0 = Type C (squid),   VRAM $00300/$00380 → $18/$1C
001EB7  1               ;     Rows 1-2 = Type B (octo), VRAM $00200/$00280 → $10/$14
001EB7  1               ;     Rows 3-4 = Type A (crab), VRAM $00100/$00180 → $08/$0C
001EB7  1               ;
001EB7  1               ;   col_x_lo/hi — column X offset = col * INV_SPACING_X (=40), columns 0-10
001EB7  1               ;   row_y_offsets — row Y offset = row * INV_SPACING_Y (=48), rows 0-4
001EB7  1               ;******************************************************************
001EB7  1  18 10 10 08  inv_addr_b0_f0: .byte $18, $10, $10, $08, $08   ; rows 0-4, frame 0
001EBB  1  08           
