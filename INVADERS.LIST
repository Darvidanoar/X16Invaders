0012C1  1  20 77 0B        jsr init_invaders
0012C4  1                  ; reset shields (damage counters, sprite tiles)
0012C4  1  20 43 14        jsr init_shields
0012C7  1               
0012C7  1  A9 93           lda #PETSCII_CLR
0012C9  1  20 D2 FF        jsr CHROUT
