0019AD  1               ;******************************************************************
0019AD  1               ; add_score_bcd — add a 2-byte BCD pair to the score
0019AD  1               ;   A = BCD low byte (units/tens), Y = BCD mid byte (hundreds/thousands)
0019AD  1               ;******************************************************************
0019AD  1               add_score_bcd:
0019AD  1  F8              sed
0019AE  1  18              clc
0019AF  1  65 rr           adc score_lo
0019B1  1  85 rr           sta score_lo
0019B3  1  98              tya
0019B4  1  65 rr           adc score_mid
0019B6  1  85 rr           sta score_mid
0019B8  1  A5 rr           lda score_hi
0019BA  1  69 00           adc #0
0019BC  1  85 rr           sta score_hi
0019BE  1  D8              cld
0019BF  1  60              rts
0019C0  1               
0019C0  1               ;******************************************************************
0019C0  1               ; update_ufo — per-frame UFO logic: spawn timer + movement
0019C0  1               ;
0019C0  1               ;   Inactive: 16-bit ufo_timer counts down each frame.
0019C0  1               ;   On zero: UFO spawns at left edge (X=0), timer reset to
0019C0  1               ;             UFO_TIMER_INIT + (prng() & $7F) for next cycle.
0019C0  1               ;   Active: move right UFO_SPEED VERA pixels/frame.
0019C0  1               ;           Deactivate when X >= 640 (off right edge).
0019C0  1               ;   Updates VERA sprite 3 after any state change.
0019C0  1               ;******************************************************************
0019C0  1               update_ufo:
0019C0  1  A5 rr           lda ufo_active
0019C2  1  D0 36           bne @move_ufo
0019C4  1               
0019C4  1                  ; --- timer countdown (16-bit decrement) ---
0019C4  1  A5 rr           lda ufo_timer_lo
0019C6  1  D0 0B           bne @dec_lo
0019C8  1  A5 rr           lda ufo_timer_hi
0019CA  1  F0 0F           beq @spawn                   ; both zero → spawn (guard against stuck state)
0019CC  1  C6 rr           dec ufo_timer_hi
0019CE  1  A9 FF           lda #$FF
0019D0  1  85 rr           sta ufo_timer_lo
0019D2  1  60              rts
0019D3  1               @dec_lo:
0019D3  1  C6 rr           dec ufo_timer_lo
0019D5  1  A5 rr           lda ufo_timer_lo
0019D7  1  05 rr           ora ufo_timer_hi
0019D9  1  D0 47           bne @ufo_done                ; timer not yet zero
0019DB  1               
0019DB  1               @spawn:
0019DB  1  A9 01           lda #1
0019DD  1  85 rr           sta ufo_active
0019DF  1  64 rr           stz ufo_x_lo
0019E1  1  64 rr           stz ufo_x_hi
0019E3  1                  ; next timer = UFO_TIMER_INIT + (prng() & $7F) so interval varies by 0-127 frames
0019E3  1  20 10 10        jsr prng
0019E6  1  29 7F           and #$7F
0019E8  1  18              clc
0019E9  1  69 58           adc #<UFO_TIMER_INIT
0019EB  1  85 rr           sta ufo_timer_lo
0019ED  1  A9 02           lda #>UFO_TIMER_INIT
0019EF  1  69 00           adc #0
0019F1  1  85 rr           sta ufo_timer_hi
0019F3  1  20 23 1A        jsr update_ufo_sprite
0019F6  1  20 E5 1A        jsr snd_start_ufo_drone
0019F9  1  60              rts
0019FA  1               
0019FA  1                  ; --- move UFO right ---
0019FA  1               @move_ufo:
0019FA  1  A5 rr           lda ufo_x_lo
0019FC  1  18              clc
0019FD  1  69 02           adc #UFO_SPEED
0019FF  1  85 rr           sta ufo_x_lo
001A01  1  A5 rr           lda ufo_x_hi
001A03  1  69 00           adc #0
001A05  1  85 rr           sta ufo_x_hi
001A07  1                  ; deactivate if X high byte >= 3 (≥ 768, safely off the 640-wide screen)
001A07  1                  ; simpler guard: X hi > 0 means X >= 256; combined with lo check
001A07  1  C9 02           cmp #>640                    ; A = new hi; >640 = 2
001A09  1  90 11           bcc @ufo_on_screen           ; hi < 2 → still visible
001A0B  1  D0 06           bne @ufo_off_screen          ; hi > 2 → gone
001A0D  1  A5 rr           lda ufo_x_lo
001A0F  1  C9 80           cmp #<640
001A11  1  90 09           bcc @ufo_on_screen           ; hi=2, lo < 128 → past edge but close; still off
001A13  1               @ufo_off_screen:
001A13  1  64 rr           stz ufo_active
001A15  1  20 23 1A        jsr update_ufo_sprite
001A18  1  20 18 1B        jsr snd_stop_ufo_drone
001A1B  1  60              rts
001A1C  1               @ufo_on_screen:
001A1C  1  20 23 1A        jsr update_ufo_sprite
001A1F  1  20 30 1B        jsr snd_update_ufo_drone
001A22  1               @ufo_done:
001A22  1  60              rts
001A23  1               
001A23  1               ;******************************************************************
001A23  1               ; update_ufo_sprite — write sprite 3 (UFO) position + enable/disable
001A23  1               ;   addr[12:5] = VRAM_UFO>>5 = $01500>>5 = $A8
001A23  1               ;   Writes bytes 2-6; bytes 0-1 and 7 set once at init.
001A23  1               ;******************************************************************
001A23  1               update_ufo_sprite:
001A23  1  9C 25 9F        stz VERA_ctrl
001A26  1  A9 11 8D 22     VERA_SET_ADDR (UFO_SPRITE_ATTR + 2), 1
001A2A  1  9F A9 FC 8D  
001A2E  1  21 9F A9 1A  
001A35  1  A5 rr           lda ufo_x_lo
001A37  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
001A3A  1  A5 rr           lda ufo_x_hi
001A3C  1  29 03           and #$03
001A3E  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
001A41  1  A9 20           lda #<UFO_Y
001A43  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
001A46  1  A9 00           lda #>UFO_Y
001A48  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
001A4B  1  A5 rr           lda ufo_active
001A4D  1  F0 04           beq @z_off
001A4F  1  A9 0C           lda #SPR_Z_FRONT
001A51  1  80 02           bra @write_z
001A53  1               @z_off:
001A53  1  A9 00           lda #0
001A55  1               @write_z:
001A55  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
001A58  1  60              rts
001A59  1               
001A59  1               ;******************************************************************
001A59  1               ; check_bullet_ufo — AABB test: player bullet vs. UFO sprite (16x16)
001A59  1               ;   Bullet rect: (bullet_x, bullet_y)+(7,7);  UFO rect: (ufo_x, UFO_Y)+(15,15)
001A59  1               ;   On hit: bullet deactivated, UFO killed, score added, explosion started.
001A59  1               ;   Scratch: zp_scratch_lo/hi, zp_x_lo/hi, zp_row_y_lo/hi
001A59  1               ;******************************************************************
001A59  1               check_bullet_ufo:
001A59  1  A5 rr           lda bullet_active
001A5B  1  D0 01           bne :+
001A5D  1  60              rts
001A5E  1  A5 rr        :  lda ufo_active
001A60  1  D0 01           bne :+
001A62  1  60              rts
001A63  1               :
001A63  1               
001A63  1                  ; --- Y check 1: bullet_y+8 > UFO_Y ---
001A63  1  A5 rr           lda bullet_y_lo
001A65  1  18              clc
001A66  1  69 08           adc #8
001A68  1  85 rr           sta zp_scratch_lo
001A6A  1  A5 rr           lda bullet_y_hi
001A6C  1  69 00           adc #0
001A6E  1  85 rr           sta zp_scratch_hi
001A70  1  A5 rr           lda zp_scratch_lo
001A72  1  38              sec
001A73  1  E9 20           sbc #<UFO_Y
001A75  1  A5 rr           lda zp_scratch_hi
001A77  1  E9 00           sbc #>UFO_Y
001A79  1  30 69           bmi @done                    ; bullet bottom above UFO top → no hit
001A7B  1               
001A7B  1                  ; --- Y check 2: bullet_y < UFO_Y+16 ---
001A7B  1  A5 rr           lda bullet_y_lo
001A7D  1  38              sec
001A7E  1  E9 30           sbc #<(UFO_Y + 16)
001A80  1  A5 rr           lda bullet_y_hi
001A82  1  E9 00           sbc #>(UFO_Y + 16)
001A84  1  10 5E           bpl @done                    ; bullet top at or below UFO bottom → no hit
001A86  1               
001A86  1                  ; --- X check 1: bullet_x+8 > ufo_x ---
001A86  1  A5 rr           lda bullet_x_lo
001A88  1  18              clc
001A89  1  69 08           adc #8
001A8B  1  85 rr           sta zp_scratch_lo
001A8D  1  A5 rr           lda bullet_x_hi
001A8F  1  69 00           adc #0
001A91  1  85 rr           sta zp_scratch_hi
001A93  1  A5 rr           lda zp_scratch_lo
001A95  1  38              sec
001A96  1  E5 rr           sbc ufo_x_lo
001A98  1  A5 rr           lda zp_scratch_hi
001A9A  1  E5 rr           sbc ufo_x_hi
001A9C  1  30 46           bmi @done                    ; bullet right edge left of UFO left edge → no hit
001A9E  1               
001A9E  1                  ; --- X check 2: bullet_x < ufo_x+16 ---
001A9E  1  A5 rr           lda ufo_x_lo
001AA0  1  18              clc
001AA1  1  69 10           adc #16
001AA3  1  85 rr           sta zp_scratch_lo
001AA5  1  A5 rr           lda ufo_x_hi
001AA7  1  69 00           adc #0
001AA9  1  85 rr           sta zp_scratch_hi
001AAB  1  A5 rr           lda bullet_x_lo
001AAD  1  38              sec
001AAE  1  E5 rr           sbc zp_scratch_lo
001AB0  1  A5 rr           lda bullet_x_hi
001AB2  1  E5 rr           sbc zp_scratch_hi
001AB4  1  10 2E           bpl @done                    ; bullet left edge at or right of UFO right edge → no hit
001AB6  1               
001AB6  1                  ; --- HIT ---
001AB6  1  A5 rr           lda ufo_x_lo
001AB8  1  85 rr           sta zp_x_lo
001ABA  1  A5 rr           lda ufo_x_hi
001ABC  1  85 rr           sta zp_x_hi
001ABE  1  A9 20           lda #<UFO_Y
001AC0  1  85 rr           sta zp_row_y_lo
001AC2  1  A9 00           lda #>UFO_Y
001AC4  1  85 rr           sta zp_row_y_hi
001AC6  1  20 B9 0F        jsr start_explosion
001AC9  1               
001AC9  1  64 rr           stz bullet_active
001ACB  1  20 66 0E        jsr update_bullet_sprite
001ACE  1               
001ACE  1  64 rr           stz ufo_active
001AD0  1  20 23 1A        jsr update_ufo_sprite
001AD3  1  20 18 1B        jsr snd_stop_ufo_drone
001AD6  1               
001AD6  1                  ; score: ufo_score table indexed by shot_count & 7
001AD6  1  A5 rr           lda shot_count
001AD8  1  29 07           and #$07
001ADA  1  AA              tax
001ADB  1  BD 2C 1F        lda ufo_score_lo, x
001ADE  1  BC 34 1F        ldy ufo_score_hi, x
001AE1  1  20 AD 19        jsr add_score_bcd
001AE4  1               
001AE4  1               @done:
001AE4  1  60              rts
001AE5  1               
001AE5  1               ;******************************************************************
001AE5  1               ; snd_start_ufo_drone — enable VERA PSG voice 3 (sawtooth, full vol, freq1)
001AE5  1               ;   Called once when UFO spawns.
001AE5  1               ;******************************************************************
001AE5  1               snd_start_ufo_drone:
001AE5  1                  ; set starting UFO_DRONE_FREQ
001AE5  1  A9 00           lda #<UFO_DRONE_FREQ1
001AE7  1  85 rr           sta UFO_DRONE_FREQ
001AE9  1  A9 04           lda #>UFO_DRONE_FREQ1
001AEB  1  85 rr           sta UFO_DRONE_FREQ + 1
001AED  1  A9 FF           lda #$ff
001AEF  1  85 rr           sta UFO_FREQ_DIR
001AF1  1                  ; set VERA
001AF1  1  9C 25 9F        stz VERA_ctrl
001AF4  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
001AF8  1  9F A9 F9 8D  
001AFC  1  21 9F A9 CC  
001B03  1  A5 rr           lda UFO_DRONE_FREQ
001B05  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L
001B08  1  A5 rr           lda UFO_DRONE_FREQ + 1
001B0A  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
001B0D  1  A9 DF           lda #PSG_VOL_HALF
001B0F  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001B12  1  A9 40           lda #PSG_WAVE_SAW
001B14  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
001B17  1  60              rts
001B18  1               
001B18  1               ;******************************************************************
001B18  1               ; snd_stop_ufo_drone — silence VERA PSG voice 3
001B18  1               ;   Called when UFO leaves screen or is destroyed.
001B18  1               ;******************************************************************
001B18  1               snd_stop_ufo_drone:
001B18  1  9C 25 9F        stz VERA_ctrl
001B1B  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE3 + 2), 1   ; byte 2 = volume/enable
001B1F  1  9F A9 F9 8D  
001B23  1  21 9F A9 CE  
001B2A  1  A9 00           lda #$00
001B2C  1  8D 23 9F        sta VERA_data0               ; zero volume → silent
001B2F  1  60              rts
001B30  1               
001B30  1               ;******************************************************************
001B30  1               ; snd_update_ufo_drone — warble between freq1/freq2 using frame_count
001B30  1               ;   bit 3 (flips every 8 frames ≈ 3.75 Hz wobble rate).
001B30  1               ;   Call every frame while UFO is active.
001B30  1               ;   Rewrites all 4 voice bytes (keeps volume/waveform stable).
001B30  1               ;******************************************************************
001B30  1               snd_update_ufo_drone:
001B30  1  9C 25 9F        stz VERA_ctrl
001B33  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
001B37  1  9F A9 F9 8D  
001B3B  1  21 9F A9 CC  
001B42  1  A5 rr           lda UFO_DRONE_FREQ
001B44  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L
001B47  1  A5 rr           lda UFO_DRONE_FREQ + 1
001B49  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
001B4C  1  A9 DF           lda #PSG_VOL_HALF
001B4E  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001B51  1  A9 40           lda #PSG_WAVE_SAW
001B53  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
001B56  1                  ; change the frequency
001B56  1  A5 rr           lda UFO_FREQ_DIR
001B58  1  F0 16           beq @ufo_tone_down
001B5A  1  A9 10           lda #$10
001B5C  1  18              clc
001B5D  1  65 rr           adc UFO_DRONE_FREQ
001B5F  1  85 rr           sta UFO_DRONE_FREQ
001B61  1  A9 00           lda #$00
001B63  1  65 rr           adc UFO_DRONE_FREQ + 1
001B65  1  85 rr           sta UFO_DRONE_FREQ + 1
001B67  1  C9 06           cmp #>UFO_DRONE_FREQ2
001B69  1  D0 1A           bne @ufo_update_done
001B6B  1  64 rr           stz UFO_FREQ_DIR
001B6D  1  4C 85 1B        jmp @ufo_update_done
001B70  1               @ufo_tone_down:
001B70  1  A5 rr           lda UFO_DRONE_FREQ
001B72  1  38              sec
001B73  1  E9 10           sbc #$10
001B75  1  85 rr           sta UFO_DRONE_FREQ
001B77  1  A5 rr           lda UFO_DRONE_FREQ + 1
001B79  1  E9 00           sbc #$00
001B7B  1  85 rr           sta UFO_DRONE_FREQ + 1
001B7D  1  C9 04           cmp #>UFO_DRONE_FREQ1
001B7F  1  D0 04           bne @ufo_update_done
001B81  1  A9 FF           lda #$ff
001B83  1  85 rr           sta UFO_FREQ_DIR
001B85  1               @ufo_update_done:
001B85  1  60              rts
001B86  1               
001B86  1               ;******************************************************************
001B86  1               ; snd_march_step — advance march_beat and play next note on PSG voice 0
001B86  1               ;   Called once per invader march step (from step_invaders).
001B86  1               ;   Increments beat index mod 4, writes freq/vol/wave to voice 0,
001B86  1               ;   and arms march_snd_timer so snd_tick_march will silence it.
001B86  1               ;******************************************************************
001B86  1               snd_march_step:
001B86  1  E6 rr           inc march_beat
001B88  1  A5 rr           lda march_beat
001B8A  1  29 03           and #$03
001B8C  1  85 rr           sta march_beat
001B8E  1  AA              tax                            ; X = note index 0-3
001B8F  1  9C 25 9F        stz VERA_ctrl
001B92  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE0, 1
001B96  1  9F A9 F9 8D  
001B9A  1  21 9F A9 C0  
001BA1  1  BD 24 1F        lda march_freq_lo, x
001BA4  1  8D 23 9F        sta VERA_data0                 ; byte 0: FREQ_L
001BA7  1  BD 28 1F        lda march_freq_hi, x
001BAA  1  8D 23 9F        sta VERA_data0                 ; byte 1: FREQ_H
001BAD  1  A9 FF           lda #PSG_MARCH_VOL
001BAF  1  8D 23 9F        sta VERA_data0                 ; byte 2: volume (stereo, full)
001BB2  1  A9 C0           lda #PSG_WAVE_PULSE
001BB4  1  8D 23 9F        sta VERA_data0                 ; byte 3: pulse waveform
001BB7  1  A9 06           lda #MARCH_NOTE_FRAMES
001BB9  1  85 rr           sta march_snd_timer
001BBB  1  60              rts
001BBC  1               
001BBC  1               ;******************************************************************
001BBC  1               ; snd_tick_march — decrement march note timer; silence voice 0 when it expires
001BBC  1               ;   Call once per frame from main_loop.
001BBC  1               ;******************************************************************
001BBC  1               snd_tick_march:
001BBC  1  A5 rr           lda march_snd_timer
001BBE  1  F0 1B           beq @done
001BC0  1  C6 rr           dec march_snd_timer
001BC2  1  D0 17           bne @done
001BC4  1  9C 25 9F        stz VERA_ctrl
001BC7  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE0 + 2), 1
001BCB  1  9F A9 F9 8D  
001BCF  1  21 9F A9 C2  
001BD6  1  A9 00           lda #$00
001BD8  1  8D 23 9F        sta VERA_data0                 ; zero volume → silent
001BDB  1               @done:
001BDB  1  60              rts
001BDC  1               
001BDC  1               ;******************************************************************
001BDC  1               ; snd_stop_march — immediately silence PSG voice 0 and clear timer
001BDC  1               ;   Call when leaving gameplay (game over, wave clear, restart).
001BDC  1               ;******************************************************************
001BDC  1               snd_stop_march:
001BDC  1  64 rr           stz march_snd_timer
001BDE  1  9C 25 9F        stz VERA_ctrl
001BE1  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE0 + 2), 1
001BE5  1  9F A9 F9 8D  
001BE9  1  21 9F A9 C2  
001BF0  1  A9 00           lda #$00
001BF2  1  8D 23 9F        sta VERA_data0
001BF5  1  60              rts
001BF6  1               
001BF6  1               ;******************************************************************
001BF6  1               ; snd_fire — play short high-pitched pulse on PSG voice 1 (~800 Hz, 5 frames)
001BF6  1               ;   Called from fire_bullet.
001BF6  1               ;******************************************************************
001BF6  1               snd_fire:
001BF6  1  9C 25 9F        stz VERA_ctrl
001BF9  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE1, 1
001BFD  1  9F A9 F9 8D  
001C01  1  21 9F A9 C4  
001C08  1  A9 63           lda #PSG_FIRE_FREQ_L
001C0A  1  8D 23 9F        sta VERA_data0                 ; byte 0: FREQ_L
001C0D  1  A9 7F           lda #PSG_FIRE_FREQ_H
001C0F  1  8D 23 9F        sta VERA_data0                 ; byte 1: FREQ_H
001C12  1  A9 FF           lda #PSG_MARCH_VOL             ; reuse full-volume constant
001C14  1  8D 23 9F        sta VERA_data0                 ; byte 2: volume
001C17  1  A9 C0           lda #PSG_WAVE_PULSE
001C19  1  8D 23 9F        sta VERA_data0                 ; byte 3: pulse waveform
001C1C  1  A9 05           lda #FIRE_NOTE_FRAMES
001C1E  1  85 rr           sta fire_snd_timer
001C20  1  60              rts
001C21  1               
001C21  1               ;******************************************************************
001C21  1               ; snd_tick_fire — decrement fire timer; silence voice 1 when it expires
001C21  1               ;   Call once per frame from main_loop.
001C21  1               ;******************************************************************
001C21  1               snd_tick_fire:
001C21  1  A5 rr           lda fire_snd_timer
001C23  1  F0 1B           beq @done
001C25  1  C6 rr           dec fire_snd_timer
001C27  1  D0 17           bne @done
001C29  1  9C 25 9F        stz VERA_ctrl
001C2C  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE1 + 2), 1
001C30  1  9F A9 F9 8D  
001C34  1  21 9F A9 C6  
001C3B  1  A9 00           lda #$00
001C3D  1  8D 23 9F        sta VERA_data0
001C40  1               @done:
001C40  1  60              rts
001C41  1               
001C41  1               ;******************************************************************
001C41  1               ; snd_stop_fire — immediately silence PSG voice 1 and clear timer
001C41  1               ;******************************************************************
001C41  1               snd_stop_fire:
001C41  1  64 rr           stz fire_snd_timer
001C43  1  9C 25 9F        stz VERA_ctrl
001C46  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE1 + 2), 1
001C4A  1  9F A9 F9 8D  
001C4E  1  21 9F A9 C6  
001C55  1  A9 00           lda #$00
001C57  1  8D 23 9F        sta VERA_data0
001C5A  1  60              rts
001C5B  1               
001C5B  1               ;******************************************************************
001C5B  1               ; snd_explosion — play low-frequency noise burst on PSG voice 2 (20 frames)
001C5B  1               ;   Called from start_explosion (covers invader kills, UFO, player hit).
001C5B  1               ;******************************************************************
001C5B  1               snd_explosion:
001C5B  1  9C 25 9F        stz VERA_ctrl
001C5E  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE2, 1
001C62  1  9F A9 F9 8D  
001C66  1  21 9F A9 C8  
001C6D  1  A9 40           lda #PSG_EXP_FREQ_L
001C6F  1  8D 23 9F        sta VERA_data0                 ; byte 0: FREQ_L (slow noise clock → deep rumble)
001C72  1  A9 00           lda #PSG_EXP_FREQ_H
001C74  1  8D 23 9F        sta VERA_data0                 ; byte 1: FREQ_H
001C77  1  A9 FF           lda #PSG_MARCH_VOL             ; reuse full-volume constant
001C79  1  8D 23 9F        sta VERA_data0                 ; byte 2: volume
001C7C  1  A9 C0           lda #PSG_WAVE_NOISE
001C7E  1  8D 23 9F        sta VERA_data0                 ; byte 3: noise waveform
001C81  1  A9 14           lda #EXP_NOTE_FRAMES
001C83  1  85 rr           sta exp_snd_timer
001C85  1  60              rts
001C86  1               
001C86  1               ;******************************************************************
001C86  1               ; snd_tick_exp — decrement explosion timer; silence voice 2 when it expires
001C86  1               ;   Call once per frame from main_loop.
001C86  1               ;******************************************************************
001C86  1               snd_tick_exp:
001C86  1  A5 rr           lda exp_snd_timer
001C88  1  F0 1B           beq @done
001C8A  1  C6 rr           dec exp_snd_timer
001C8C  1  D0 17           bne @done
001C8E  1  9C 25 9F        stz VERA_ctrl
001C91  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE2 + 2), 1
001C95  1  9F A9 F9 8D  
001C99  1  21 9F A9 CA  
001CA0  1  A9 00           lda #$00
001CA2  1  8D 23 9F        sta VERA_data0
001CA5  1               @done:
001CA5  1  60              rts
001CA6  1               
001CA6  1               ;******************************************************************
001CA6  1               ; snd_stop_exp — immediately silence PSG voice 2 and clear timer
001CA6  1               ;******************************************************************
001CA6  1               snd_stop_exp:
001CA6  1  64 rr           stz exp_snd_timer
001CA8  1  9C 25 9F        stz VERA_ctrl
001CAB  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE2 + 2), 1
001CAF  1  9F A9 F9 8D  
001CB3  1  21 9F A9 CA  
001CBA  1  A9 00           lda #$00
001CBC  1  8D 23 9F        sta VERA_data0
001CBF  1  60              rts
001CC0  1               
001CC0  1               ;******************************************************************
001CC0  1               ; update_hud — rewrite dynamic HUD values each frame
001CC0  1               ;   Row  1, col  0: 6-digit BCD score
001CC0  1               ;   Row  1, col 16: 6-digit BCD hi-score
001CC0  1               ;   Row 29, col  1: LIVES: N
001CC0  1               ;   Row 29, col 20: WAVE: N
001CC0  1               ;   Overwrites fixed positions; no full redraw needed.
001CC0  1               ;   Note: KERNAL PLOT convention for X16: A = row, Y = col, CLC.
001CC0  1               ;******************************************************************
001CC0  1               update_hud:
001CC0  1                  ; --- score: row 1, col 0 (Plot: Set X to Row, Set Y to Col) ---
001CC0  1  A2 01           ldx #1
001CC2  1  A0 0A           ldy #10
001CC4  1  18              clc
001CC5  1  20 F0 FF        jsr PLOT
001CC8  1  A5 rr           lda score_hi
001CCA  1  20 2D 1D        jsr print_hex_byte
001CCD  1  A5 rr           lda score_mid
001CCF  1  20 2D 1D        jsr print_hex_byte
001CD2  1  A5 rr           lda score_lo
001CD4  1  20 2D 1D        jsr print_hex_byte
001CD7  1               
001CD7  1                  ; --- hi-score: row 1, col 16  (Plot: Set X to Row, Set Y to Col) ---
001CD7  1  A2 01           ldx #1
001CD9  1  A0 49           ldy #73
001CDB  1  18              clc
001CDC  1  20 F0 FF        jsr PLOT
001CDF  1  A5 rr           lda hi_score_hi
001CE1  1  20 2D 1D        jsr print_hex_byte
001CE4  1  A5 rr           lda hi_score_mid
001CE6  1  20 2D 1D        jsr print_hex_byte
001CE9  1  A5 rr           lda hi_score_lo
001CEB  1  20 2D 1D        jsr print_hex_byte
001CEE  1               
001CEE  1                  ; --- lives count: row 58, col 1  (Plot: Set X to Row, Set Y to Col) ---
001CEE  1  A2 3A           ldx #58
001CF0  1  A0 01           ldy #1
001CF2  1  18              clc
001CF3  1  20 F0 FF        jsr PLOT
001CF6  1  A2 00           ldx #0
001CF8  1  BD 0A 1E     @lv_lbl: lda str_lives_lbl,x
001CFB  1  F0 06           beq @lv_val
001CFD  1  20 D2 FF        jsr CHROUT
001D00  1  E8              inx
001D01  1  80 F5           bra @lv_lbl
001D03  1               @lv_val:
001D03  1  A5 rr           lda lives
001D05  1  20 4A 14        jsr print_dec_byte
001D08  1  A9 20           lda #' '
001D0A  1  20 D2 FF        jsr CHROUT                    ; erase any stale digit
001D0D  1               
001D0D  1                  ; --- wave number: row 58, col 20  (Plot: Set X to Row, Set Y to Col) ---
001D0D  1  A2 3A           ldx #58
001D0F  1  A0 14           ldy #20
001D11  1  18              clc
001D12  1  20 F0 FF        jsr PLOT
001D15  1  A2 00           ldx #0
001D17  1  BD E1 1D     @wv_lbl: lda str_wave_lbl,x
001D1A  1  F0 06           beq @wv_val
001D1C  1  20 D2 FF        jsr CHROUT
001D1F  1  E8              inx
001D20  1  80 F5           bra @wv_lbl
001D22  1               @wv_val:
001D22  1  A5 rr           lda wave
001D24  1  20 4A 14        jsr print_dec_byte
001D27  1  A9 20           lda #' '
001D29  1  20 D2 FF        jsr CHROUT                    ; erase any stale digit
001D2C  1               
001D2C  1  60              rts
001D2D  1               
001D2D  1               ;******************************************************************
001D2D  1               ; print_hex_byte — print .A as two uppercase hex digits via CHROUT
001D2D  1               ;******************************************************************
001D2D  1               print_hex_byte:
001D2D  1  48              pha
001D2E  1  4A              lsr                           ; shift high nibble down
001D2F  1  4A              lsr
001D30  1  4A              lsr
001D31  1  4A              lsr
001D32  1  20 3C 1D        jsr print_hex_nybble
001D35  1  68              pla
001D36  1  29 0F           and #$0F                      ; isolate low nibble
001D38  1  20 3C 1D        jsr print_hex_nybble
001D3B  1  60              rts
001D3C  1               
001D3C  1               ; print_hex_nybble — print lower 4 bits of .A as one hex digit
001D3C  1               ;   Relies on carry state from CMP to select digit vs. letter range
001D3C  1               print_hex_nybble:
001D3C  1  C9 0A           cmp #10
001D3E  1  90 06           bcc @digit                    ; carry clear → 0-9
001D40  1  69 36           adc #($41 - 10 - 1)          ; A-F: 'A'=65; carry set adds 1
001D42  1  20 D2 FF        jsr CHROUT
001D45  1  60              rts
001D46  1               @digit:
001D46  1  69 30           adc #$30                      ; 0-9: '0'=48; carry clear adds 0
001D48  1  20 D2 FF        jsr CHROUT
001D4B  1  60              rts
001D4C  1               
