0019B2  1               ;******************************************************************
0019B2  1               ; add_score_bcd — add a 2-byte BCD pair to the score
0019B2  1               ;   A = BCD low byte (units/tens), Y = BCD mid byte (hundreds/thousands)
0019B2  1               ;******************************************************************
0019B2  1               add_score_bcd:
0019B2  1  F8              sed
0019B3  1  18              clc
0019B4  1  65 rr           adc score_lo
0019B6  1  85 rr           sta score_lo
0019B8  1  98              tya
0019B9  1  65 rr           adc score_mid
0019BB  1  85 rr           sta score_mid
0019BD  1  A5 rr           lda score_hi
0019BF  1  69 00           adc #0
0019C1  1  85 rr           sta score_hi
0019C3  1  D8              cld
0019C4  1  60              rts
0019C5  1               
0019C5  1               ;******************************************************************
0019C5  1               ; update_ufo — per-frame UFO logic: spawn timer + movement
0019C5  1               ;
0019C5  1               ;   Inactive: 16-bit ufo_timer counts down each frame.
0019C5  1               ;   On zero: UFO spawns at left edge (X=0), timer reset to
0019C5  1               ;             UFO_TIMER_INIT + (prng() & $7F) for next cycle.
0019C5  1               ;   Active: move right UFO_SPEED VERA pixels/frame.
0019C5  1               ;           Deactivate when X >= 640 (off right edge).
0019C5  1               ;   Updates VERA sprite 3 after any state change.
0019C5  1               ;******************************************************************
0019C5  1               update_ufo:
0019C5  1  A5 rr           lda ufo_active
0019C7  1  D0 36           bne @move_ufo
0019C9  1               
0019C9  1                  ; --- timer countdown (16-bit decrement) ---
0019C9  1  A5 rr           lda ufo_timer_lo
0019CB  1  D0 0B           bne @dec_lo
0019CD  1  A5 rr           lda ufo_timer_hi
0019CF  1  F0 0F           beq @spawn                   ; both zero → spawn (guard against stuck state)
0019D1  1  C6 rr           dec ufo_timer_hi
0019D3  1  A9 FF           lda #$FF
0019D5  1  85 rr           sta ufo_timer_lo
0019D7  1  60              rts
0019D8  1               @dec_lo:
0019D8  1  C6 rr           dec ufo_timer_lo
0019DA  1  A5 rr           lda ufo_timer_lo
0019DC  1  05 rr           ora ufo_timer_hi
0019DE  1  D0 47           bne @ufo_done                ; timer not yet zero
0019E0  1               
0019E0  1               @spawn:
0019E0  1  A9 01           lda #1
0019E2  1  85 rr           sta ufo_active
0019E4  1  64 rr           stz ufo_x_lo
0019E6  1  64 rr           stz ufo_x_hi
0019E8  1                  ; next timer = UFO_TIMER_INIT + (prng() & $7F) so interval varies by 0-127 frames
0019E8  1  20 15 10        jsr prng
0019EB  1  29 7F           and #$7F
0019ED  1  18              clc
0019EE  1  69 58           adc #<UFO_TIMER_INIT
0019F0  1  85 rr           sta ufo_timer_lo
0019F2  1  A9 02           lda #>UFO_TIMER_INIT
0019F4  1  69 00           adc #0
0019F6  1  85 rr           sta ufo_timer_hi
0019F8  1  20 28 1A        jsr update_ufo_sprite
0019FB  1  20 EA 1A        jsr snd_start_ufo_drone
0019FE  1  60              rts
0019FF  1               
0019FF  1                  ; --- move UFO right ---
0019FF  1               @move_ufo:
0019FF  1  A5 rr           lda ufo_x_lo
001A01  1  18              clc
001A02  1  69 02           adc #UFO_SPEED
001A04  1  85 rr           sta ufo_x_lo
001A06  1  A5 rr           lda ufo_x_hi
001A08  1  69 00           adc #0
001A0A  1  85 rr           sta ufo_x_hi
001A0C  1                  ; deactivate if X high byte >= 3 (≥ 768, safely off the 640-wide screen)
001A0C  1                  ; simpler guard: X hi > 0 means X >= 256; combined with lo check
001A0C  1  C9 02           cmp #>640                    ; A = new hi; >640 = 2
001A0E  1  90 11           bcc @ufo_on_screen           ; hi < 2 → still visible
001A10  1  D0 06           bne @ufo_off_screen          ; hi > 2 → gone
001A12  1  A5 rr           lda ufo_x_lo
001A14  1  C9 80           cmp #<640
001A16  1  90 09           bcc @ufo_on_screen           ; hi=2, lo < 128 → past edge but close; still off
001A18  1               @ufo_off_screen:
001A18  1  64 rr           stz ufo_active
001A1A  1  20 28 1A        jsr update_ufo_sprite
001A1D  1  20 1D 1B        jsr snd_stop_ufo_drone
001A20  1  60              rts
001A21  1               @ufo_on_screen:
001A21  1  20 28 1A        jsr update_ufo_sprite
001A24  1  20 35 1B        jsr snd_update_ufo_drone
001A27  1               @ufo_done:
001A27  1  60              rts
001A28  1               
001A28  1               ;******************************************************************
001A28  1               ; update_ufo_sprite — write sprite 3 (UFO) position + enable/disable
001A28  1               ;   addr[12:5] = VRAM_UFO>>5 = $01500>>5 = $A8
001A28  1               ;   Writes bytes 2-6; bytes 0-1 and 7 set once at init.
001A28  1               ;******************************************************************
001A28  1               update_ufo_sprite:
001A28  1  9C 25 9F        stz VERA_ctrl
001A2B  1  A9 11 8D 22     VERA_SET_ADDR (UFO_SPRITE_ATTR + 2), 1
001A2F  1  9F A9 FC 8D  
001A33  1  21 9F A9 1A  
001A3A  1  A5 rr           lda ufo_x_lo
001A3C  1  8D 23 9F        sta VERA_data0               ; byte 2: X[7:0]
001A3F  1  A5 rr           lda ufo_x_hi
001A41  1  29 03           and #$03
001A43  1  8D 23 9F        sta VERA_data0               ; byte 3: X[9:8]
001A46  1  A9 20           lda #<UFO_Y
001A48  1  8D 23 9F        sta VERA_data0               ; byte 4: Y[7:0]
001A4B  1  A9 00           lda #>UFO_Y
001A4D  1  8D 23 9F        sta VERA_data0               ; byte 5: Y[9:8]
001A50  1  A5 rr           lda ufo_active
001A52  1  F0 04           beq @z_off
001A54  1  A9 0C           lda #SPR_Z_FRONT
001A56  1  80 02           bra @write_z
001A58  1               @z_off:
001A58  1  A9 00           lda #0
001A5A  1               @write_z:
001A5A  1  8D 23 9F        sta VERA_data0               ; byte 6: z-depth
001A5D  1  60              rts
001A5E  1               
001A5E  1               ;******************************************************************
001A5E  1               ; check_bullet_ufo — AABB test: player bullet vs. UFO sprite (16x16)
001A5E  1               ;   Bullet rect: (bullet_x, bullet_y)+(7,7);  UFO rect: (ufo_x, UFO_Y)+(15,15)
001A5E  1               ;   On hit: bullet deactivated, UFO killed, score added, explosion started.
001A5E  1               ;   Scratch: zp_scratch_lo/hi, zp_x_lo/hi, zp_row_y_lo/hi
001A5E  1               ;******************************************************************
001A5E  1               check_bullet_ufo:
001A5E  1  A5 rr           lda bullet_active
001A60  1  D0 01           bne :+
001A62  1  60              rts
001A63  1  A5 rr        :  lda ufo_active
001A65  1  D0 01           bne :+
001A67  1  60              rts
001A68  1               :
001A68  1               
001A68  1                  ; --- Y check 1: bullet_y+8 > UFO_Y ---
001A68  1  A5 rr           lda bullet_y_lo
001A6A  1  18              clc
001A6B  1  69 08           adc #8
001A6D  1  85 rr           sta zp_scratch_lo
001A6F  1  A5 rr           lda bullet_y_hi
001A71  1  69 00           adc #0
001A73  1  85 rr           sta zp_scratch_hi
001A75  1  A5 rr           lda zp_scratch_lo
001A77  1  38              sec
001A78  1  E9 20           sbc #<UFO_Y
001A7A  1  A5 rr           lda zp_scratch_hi
001A7C  1  E9 00           sbc #>UFO_Y
001A7E  1  30 69           bmi @done                    ; bullet bottom above UFO top → no hit
001A80  1               
001A80  1                  ; --- Y check 2: bullet_y < UFO_Y+16 ---
001A80  1  A5 rr           lda bullet_y_lo
001A82  1  38              sec
001A83  1  E9 30           sbc #<(UFO_Y + 16)
001A85  1  A5 rr           lda bullet_y_hi
001A87  1  E9 00           sbc #>(UFO_Y + 16)
001A89  1  10 5E           bpl @done                    ; bullet top at or below UFO bottom → no hit
001A8B  1               
001A8B  1                  ; --- X check 1: bullet_x+8 > ufo_x ---
001A8B  1  A5 rr           lda bullet_x_lo
001A8D  1  18              clc
001A8E  1  69 08           adc #8
001A90  1  85 rr           sta zp_scratch_lo
001A92  1  A5 rr           lda bullet_x_hi
001A94  1  69 00           adc #0
001A96  1  85 rr           sta zp_scratch_hi
001A98  1  A5 rr           lda zp_scratch_lo
001A9A  1  38              sec
001A9B  1  E5 rr           sbc ufo_x_lo
001A9D  1  A5 rr           lda zp_scratch_hi
001A9F  1  E5 rr           sbc ufo_x_hi
001AA1  1  30 46           bmi @done                    ; bullet right edge left of UFO left edge → no hit
001AA3  1               
001AA3  1                  ; --- X check 2: bullet_x < ufo_x+16 ---
001AA3  1  A5 rr           lda ufo_x_lo
001AA5  1  18              clc
001AA6  1  69 10           adc #16
001AA8  1  85 rr           sta zp_scratch_lo
001AAA  1  A5 rr           lda ufo_x_hi
001AAC  1  69 00           adc #0
001AAE  1  85 rr           sta zp_scratch_hi
001AB0  1  A5 rr           lda bullet_x_lo
001AB2  1  38              sec
001AB3  1  E5 rr           sbc zp_scratch_lo
001AB5  1  A5 rr           lda bullet_x_hi
001AB7  1  E5 rr           sbc zp_scratch_hi
001AB9  1  10 2E           bpl @done                    ; bullet left edge at or right of UFO right edge → no hit
001ABB  1               
001ABB  1                  ; --- HIT ---
001ABB  1  A5 rr           lda ufo_x_lo
001ABD  1  85 rr           sta zp_x_lo
001ABF  1  A5 rr           lda ufo_x_hi
001AC1  1  85 rr           sta zp_x_hi
001AC3  1  A9 20           lda #<UFO_Y
001AC5  1  85 rr           sta zp_row_y_lo
001AC7  1  A9 00           lda #>UFO_Y
001AC9  1  85 rr           sta zp_row_y_hi
001ACB  1  20 BE 0F        jsr start_explosion
001ACE  1               
001ACE  1  64 rr           stz bullet_active
001AD0  1  20 6B 0E        jsr update_bullet_sprite
001AD3  1               
001AD3  1  64 rr           stz ufo_active
001AD5  1  20 28 1A        jsr update_ufo_sprite
001AD8  1  20 1D 1B        jsr snd_stop_ufo_drone
001ADB  1               
001ADB  1                  ; score: ufo_score table indexed by shot_count & 7
001ADB  1  A5 rr           lda shot_count
001ADD  1  29 07           and #$07
001ADF  1  AA              tax
001AE0  1  BD 31 1F        lda ufo_score_lo, x
001AE3  1  BC 39 1F        ldy ufo_score_hi, x
001AE6  1  20 B2 19        jsr add_score_bcd
001AE9  1               
001AE9  1               @done:
001AE9  1  60              rts
001AEA  1               
001AEA  1               ;******************************************************************
001AEA  1               ; snd_start_ufo_drone — enable VERA PSG voice 3 (sawtooth, full vol, freq1)
001AEA  1               ;   Called once when UFO spawns.
001AEA  1               ;******************************************************************
001AEA  1               snd_start_ufo_drone:
001AEA  1                  ; set starting UFO_DRONE_FREQ
001AEA  1  A9 00           lda #<UFO_DRONE_FREQ1
001AEC  1  85 rr           sta UFO_DRONE_FREQ
001AEE  1  A9 04           lda #>UFO_DRONE_FREQ1
001AF0  1  85 rr           sta UFO_DRONE_FREQ + 1
001AF2  1  A9 FF           lda #$ff
001AF4  1  85 rr           sta UFO_FREQ_DIR
001AF6  1                  ; set VERA
001AF6  1  9C 25 9F        stz VERA_ctrl
001AF9  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
001AFD  1  9F A9 F9 8D  
001B01  1  21 9F A9 CC  
001B08  1  A5 rr           lda UFO_DRONE_FREQ
001B0A  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L
001B0D  1  A5 rr           lda UFO_DRONE_FREQ + 1
001B0F  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
001B12  1  A9 DF           lda #PSG_VOL_HALF
001B14  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001B17  1  A9 40           lda #PSG_WAVE_SAW
001B19  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
001B1C  1  60              rts
001B1D  1               
001B1D  1               ;******************************************************************
001B1D  1               ; snd_stop_ufo_drone — silence VERA PSG voice 3
001B1D  1               ;   Called when UFO leaves screen or is destroyed.
001B1D  1               ;******************************************************************
001B1D  1               snd_stop_ufo_drone:
001B1D  1  9C 25 9F        stz VERA_ctrl
001B20  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE3 + 2), 1   ; byte 2 = volume/enable
001B24  1  9F A9 F9 8D  
001B28  1  21 9F A9 CE  
001B2F  1  A9 00           lda #$00
001B31  1  8D 23 9F        sta VERA_data0               ; zero volume → silent
001B34  1  60              rts
001B35  1               
001B35  1               ;******************************************************************
001B35  1               ; snd_update_ufo_drone — warble between freq1/freq2 using frame_count
001B35  1               ;   bit 3 (flips every 8 frames ≈ 3.75 Hz wobble rate).
001B35  1               ;   Call every frame while UFO is active.
001B35  1               ;   Rewrites all 4 voice bytes (keeps volume/waveform stable).
001B35  1               ;******************************************************************
001B35  1               snd_update_ufo_drone:
001B35  1  9C 25 9F        stz VERA_ctrl
001B38  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE3, 1
001B3C  1  9F A9 F9 8D  
001B40  1  21 9F A9 CC  
001B47  1  A5 rr           lda UFO_DRONE_FREQ
001B49  1  8D 23 9F        sta VERA_data0               ; byte 0: FREQ_L
001B4C  1  A5 rr           lda UFO_DRONE_FREQ + 1
001B4E  1  8D 23 9F        sta VERA_data0               ; byte 1: FREQ_H
001B51  1  A9 DF           lda #PSG_VOL_HALF
001B53  1  8D 23 9F        sta VERA_data0               ; byte 2: volume
001B56  1  A9 40           lda #PSG_WAVE_SAW
001B58  1  8D 23 9F        sta VERA_data0               ; byte 3: waveform
001B5B  1                  ; change the frequency
001B5B  1  A5 rr           lda UFO_FREQ_DIR
001B5D  1  F0 16           beq @ufo_tone_down
001B5F  1  A9 10           lda #$10
001B61  1  18              clc
001B62  1  65 rr           adc UFO_DRONE_FREQ
001B64  1  85 rr           sta UFO_DRONE_FREQ
001B66  1  A9 00           lda #$00
001B68  1  65 rr           adc UFO_DRONE_FREQ + 1
001B6A  1  85 rr           sta UFO_DRONE_FREQ + 1
001B6C  1  C9 06           cmp #>UFO_DRONE_FREQ2
001B6E  1  D0 1A           bne @ufo_update_done
001B70  1  64 rr           stz UFO_FREQ_DIR
001B72  1  4C 8A 1B        jmp @ufo_update_done
001B75  1               @ufo_tone_down:
001B75  1  A5 rr           lda UFO_DRONE_FREQ
001B77  1  38              sec
001B78  1  E9 10           sbc #$10
001B7A  1  85 rr           sta UFO_DRONE_FREQ
001B7C  1  A5 rr           lda UFO_DRONE_FREQ + 1
001B7E  1  E9 00           sbc #$00
001B80  1  85 rr           sta UFO_DRONE_FREQ + 1
001B82  1  C9 04           cmp #>UFO_DRONE_FREQ1
001B84  1  D0 04           bne @ufo_update_done
001B86  1  A9 FF           lda #$ff
001B88  1  85 rr           sta UFO_FREQ_DIR
001B8A  1               @ufo_update_done:
001B8A  1  60              rts
001B8B  1               
001B8B  1               ;******************************************************************
001B8B  1               ; snd_march_step — advance march_beat and play next note on PSG voice 0
001B8B  1               ;   Called once per invader march step (from step_invaders).
001B8B  1               ;   Increments beat index mod 4, writes freq/vol/wave to voice 0,
001B8B  1               ;   and arms march_snd_timer so snd_tick_march will silence it.
001B8B  1               ;******************************************************************
001B8B  1               snd_march_step:
001B8B  1  E6 rr           inc march_beat
001B8D  1  A5 rr           lda march_beat
001B8F  1  29 03           and #$03
001B91  1  85 rr           sta march_beat
001B93  1  AA              tax                            ; X = note index 0-3
001B94  1  9C 25 9F        stz VERA_ctrl
001B97  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE0, 1
001B9B  1  9F A9 F9 8D  
001B9F  1  21 9F A9 C0  
001BA6  1  BD 29 1F        lda march_freq_lo, x
001BA9  1  8D 23 9F        sta VERA_data0                 ; byte 0: FREQ_L
001BAC  1  BD 2D 1F        lda march_freq_hi, x
001BAF  1  8D 23 9F        sta VERA_data0                 ; byte 1: FREQ_H
001BB2  1  A9 FF           lda #PSG_MARCH_VOL
001BB4  1  8D 23 9F        sta VERA_data0                 ; byte 2: volume (stereo, full)
001BB7  1  A9 C0           lda #PSG_WAVE_PULSE
001BB9  1  8D 23 9F        sta VERA_data0                 ; byte 3: pulse waveform
001BBC  1  A9 06           lda #MARCH_NOTE_FRAMES
001BBE  1  85 rr           sta march_snd_timer
001BC0  1  60              rts
001BC1  1               
001BC1  1               ;******************************************************************
001BC1  1               ; snd_tick_march — decrement march note timer; silence voice 0 when it expires
001BC1  1               ;   Call once per frame from main_loop.
001BC1  1               ;******************************************************************
001BC1  1               snd_tick_march:
001BC1  1  A5 rr           lda march_snd_timer
001BC3  1  F0 1B           beq @done
001BC5  1  C6 rr           dec march_snd_timer
001BC7  1  D0 17           bne @done
001BC9  1  9C 25 9F        stz VERA_ctrl
001BCC  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE0 + 2), 1
001BD0  1  9F A9 F9 8D  
001BD4  1  21 9F A9 C2  
001BDB  1  A9 00           lda #$00
001BDD  1  8D 23 9F        sta VERA_data0                 ; zero volume → silent
001BE0  1               @done:
001BE0  1  60              rts
001BE1  1               
001BE1  1               ;******************************************************************
001BE1  1               ; snd_stop_march — immediately silence PSG voice 0 and clear timer
001BE1  1               ;   Call when leaving gameplay (game over, wave clear, restart).
001BE1  1               ;******************************************************************
001BE1  1               snd_stop_march:
001BE1  1  64 rr           stz march_snd_timer
001BE3  1  9C 25 9F        stz VERA_ctrl
001BE6  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE0 + 2), 1
001BEA  1  9F A9 F9 8D  
001BEE  1  21 9F A9 C2  
001BF5  1  A9 00           lda #$00
001BF7  1  8D 23 9F        sta VERA_data0
001BFA  1  60              rts
001BFB  1               
001BFB  1               ;******************************************************************
001BFB  1               ; snd_fire — play short high-pitched pulse on PSG voice 1 (~800 Hz, 5 frames)
001BFB  1               ;   Called from fire_bullet.
001BFB  1               ;******************************************************************
001BFB  1               snd_fire:
001BFB  1  9C 25 9F        stz VERA_ctrl
001BFE  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE1, 1
001C02  1  9F A9 F9 8D  
001C06  1  21 9F A9 C4  
001C0D  1  A9 63           lda #PSG_FIRE_FREQ_L
001C0F  1  8D 23 9F        sta VERA_data0                 ; byte 0: FREQ_L
001C12  1  A9 7F           lda #PSG_FIRE_FREQ_H
001C14  1  8D 23 9F        sta VERA_data0                 ; byte 1: FREQ_H
001C17  1  A9 FF           lda #PSG_MARCH_VOL             ; reuse full-volume constant
001C19  1  8D 23 9F        sta VERA_data0                 ; byte 2: volume
001C1C  1  A9 C0           lda #PSG_WAVE_PULSE
001C1E  1  8D 23 9F        sta VERA_data0                 ; byte 3: pulse waveform
001C21  1  A9 05           lda #FIRE_NOTE_FRAMES
001C23  1  85 rr           sta fire_snd_timer
001C25  1  60              rts
001C26  1               
001C26  1               ;******************************************************************
001C26  1               ; snd_tick_fire — decrement fire timer; silence voice 1 when it expires
001C26  1               ;   Call once per frame from main_loop.
001C26  1               ;******************************************************************
001C26  1               snd_tick_fire:
001C26  1  A5 rr           lda fire_snd_timer
001C28  1  F0 1B           beq @done
001C2A  1  C6 rr           dec fire_snd_timer
001C2C  1  D0 17           bne @done
001C2E  1  9C 25 9F        stz VERA_ctrl
001C31  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE1 + 2), 1
001C35  1  9F A9 F9 8D  
001C39  1  21 9F A9 C6  
001C40  1  A9 00           lda #$00
001C42  1  8D 23 9F        sta VERA_data0
001C45  1               @done:
001C45  1  60              rts
001C46  1               
001C46  1               ;******************************************************************
001C46  1               ; snd_stop_fire — immediately silence PSG voice 1 and clear timer
001C46  1               ;******************************************************************
001C46  1               snd_stop_fire:
001C46  1  64 rr           stz fire_snd_timer
001C48  1  9C 25 9F        stz VERA_ctrl
001C4B  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE1 + 2), 1
001C4F  1  9F A9 F9 8D  
001C53  1  21 9F A9 C6  
001C5A  1  A9 00           lda #$00
001C5C  1  8D 23 9F        sta VERA_data0
001C5F  1  60              rts
001C60  1               
001C60  1               ;******************************************************************
001C60  1               ; snd_explosion — play low-frequency noise burst on PSG voice 2 (20 frames)
001C60  1               ;   Called from start_explosion (covers invader kills, UFO, player hit).
001C60  1               ;******************************************************************
001C60  1               snd_explosion:
001C60  1  9C 25 9F        stz VERA_ctrl
001C63  1  A9 11 8D 22     VERA_SET_ADDR VRAM_PSG_VOICE2, 1
001C67  1  9F A9 F9 8D  
001C6B  1  21 9F A9 C8  
001C72  1  A9 40           lda #PSG_EXP_FREQ_L
001C74  1  8D 23 9F        sta VERA_data0                 ; byte 0: FREQ_L (slow noise clock → deep rumble)
001C77  1  A9 00           lda #PSG_EXP_FREQ_H
001C79  1  8D 23 9F        sta VERA_data0                 ; byte 1: FREQ_H
001C7C  1  A9 FF           lda #PSG_MARCH_VOL             ; reuse full-volume constant
001C7E  1  8D 23 9F        sta VERA_data0                 ; byte 2: volume
001C81  1  A9 C0           lda #PSG_WAVE_NOISE
001C83  1  8D 23 9F        sta VERA_data0                 ; byte 3: noise waveform
001C86  1  A9 14           lda #EXP_NOTE_FRAMES
001C88  1  85 rr           sta exp_snd_timer
001C8A  1  60              rts
001C8B  1               
001C8B  1               ;******************************************************************
001C8B  1               ; snd_tick_exp — decrement explosion timer; silence voice 2 when it expires
001C8B  1               ;   Call once per frame from main_loop.
001C8B  1               ;******************************************************************
001C8B  1               snd_tick_exp:
001C8B  1  A5 rr           lda exp_snd_timer
001C8D  1  F0 1B           beq @done
001C8F  1  C6 rr           dec exp_snd_timer
001C91  1  D0 17           bne @done
001C93  1  9C 25 9F        stz VERA_ctrl
001C96  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE2 + 2), 1
001C9A  1  9F A9 F9 8D  
001C9E  1  21 9F A9 CA  
001CA5  1  A9 00           lda #$00
001CA7  1  8D 23 9F        sta VERA_data0
001CAA  1               @done:
001CAA  1  60              rts
001CAB  1               
001CAB  1               ;******************************************************************
001CAB  1               ; snd_stop_exp — immediately silence PSG voice 2 and clear timer
001CAB  1               ;******************************************************************
001CAB  1               snd_stop_exp:
001CAB  1  64 rr           stz exp_snd_timer
001CAD  1  9C 25 9F        stz VERA_ctrl
001CB0  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_PSG_VOICE2 + 2), 1
001CB4  1  9F A9 F9 8D  
001CB8  1  21 9F A9 CA  
001CBF  1  A9 00           lda #$00
001CC1  1  8D 23 9F        sta VERA_data0
001CC4  1  60              rts
001CC5  1               
001CC5  1               ;******************************************************************
001CC5  1               ; update_hud — rewrite dynamic HUD values each frame
001CC5  1               ;   Row  1, col  0: 6-digit BCD score
001CC5  1               ;   Row  1, col 16: 6-digit BCD hi-score
001CC5  1               ;   Row 29, col  1: LIVES: N
001CC5  1               ;   Row 29, col 20: WAVE: N
001CC5  1               ;   Overwrites fixed positions; no full redraw needed.
001CC5  1               ;   Note: KERNAL PLOT convention for X16: A = row, Y = col, CLC.
001CC5  1               ;******************************************************************
001CC5  1               update_hud:
001CC5  1                  ; --- score: row 1, col 0 (Plot: Set X to Row, Set Y to Col) ---
001CC5  1  A2 01           ldx #1
001CC7  1  A0 0A           ldy #10
001CC9  1  18              clc
001CCA  1  20 F0 FF        jsr PLOT
001CCD  1  A5 rr           lda score_hi
001CCF  1  20 32 1D        jsr print_hex_byte
001CD2  1  A5 rr           lda score_mid
001CD4  1  20 32 1D        jsr print_hex_byte
001CD7  1  A5 rr           lda score_lo
001CD9  1  20 32 1D        jsr print_hex_byte
001CDC  1               
001CDC  1                  ; --- hi-score: row 1, col 16  (Plot: Set X to Row, Set Y to Col) ---
001CDC  1  A2 01           ldx #1
001CDE  1  A0 49           ldy #73
001CE0  1  18              clc
001CE1  1  20 F0 FF        jsr PLOT
001CE4  1  A5 rr           lda hi_score_hi
001CE6  1  20 32 1D        jsr print_hex_byte
001CE9  1  A5 rr           lda hi_score_mid
001CEB  1  20 32 1D        jsr print_hex_byte
001CEE  1  A5 rr           lda hi_score_lo
001CF0  1  20 32 1D        jsr print_hex_byte
001CF3  1               
001CF3  1                  ; --- lives count: row 58, col 1  (Plot: Set X to Row, Set Y to Col) ---
001CF3  1  A2 3A           ldx #58
001CF5  1  A0 01           ldy #1
001CF7  1  18              clc
001CF8  1  20 F0 FF        jsr PLOT
001CFB  1  A2 00           ldx #0
001CFD  1  BD 0F 1E     @lv_lbl: lda str_lives_lbl,x
001D00  1  F0 06           beq @lv_val
001D02  1  20 D2 FF        jsr CHROUT
001D05  1  E8              inx
001D06  1  80 F5           bra @lv_lbl
001D08  1               @lv_val:
001D08  1  A5 rr           lda lives
001D0A  1  20 4F 14        jsr print_dec_byte
001D0D  1  A9 20           lda #' '
001D0F  1  20 D2 FF        jsr CHROUT                    ; erase any stale digit
001D12  1               
001D12  1                  ; --- wave number: row 58, col 20  (Plot: Set X to Row, Set Y to Col) ---
001D12  1  A2 3A           ldx #58
001D14  1  A0 14           ldy #20
001D16  1  18              clc
001D17  1  20 F0 FF        jsr PLOT
001D1A  1  A2 00           ldx #0
001D1C  1  BD E6 1D     @wv_lbl: lda str_wave_lbl,x
001D1F  1  F0 06           beq @wv_val
001D21  1  20 D2 FF        jsr CHROUT
001D24  1  E8              inx
001D25  1  80 F5           bra @wv_lbl
001D27  1               @wv_val:
001D27  1  A5 rr           lda wave
001D29  1  20 4F 14        jsr print_dec_byte
001D2C  1  A9 20           lda #' '
001D2E  1  20 D2 FF        jsr CHROUT                    ; erase any stale digit
001D31  1               
001D31  1  60              rts
001D32  1               
001D32  1               ;******************************************************************
001D32  1               ; print_hex_byte — print .A as two uppercase hex digits via CHROUT
001D32  1               ;******************************************************************
001D32  1               print_hex_byte:
001D32  1  48              pha
001D33  1  4A              lsr                           ; shift high nibble down
001D34  1  4A              lsr
001D35  1  4A              lsr
001D36  1  4A              lsr
001D37  1  20 41 1D        jsr print_hex_nybble
001D3A  1  68              pla
001D3B  1  29 0F           and #$0F                      ; isolate low nibble
001D3D  1  20 41 1D        jsr print_hex_nybble
001D40  1  60              rts
001D41  1               
001D41  1               ; print_hex_nybble — print lower 4 bits of .A as one hex digit
001D41  1               ;   Relies on carry state from CMP to select digit vs. letter range
001D41  1               print_hex_nybble:
001D41  1  C9 0A           cmp #10
001D43  1  90 06           bcc @digit                    ; carry clear → 0-9
001D45  1  69 36           adc #($41 - 10 - 1)          ; A-F: 'A'=65; carry set adds 1
001D47  1  20 D2 FF        jsr CHROUT
001D4A  1  60              rts
001D4B  1               @digit:
001D4B  1  69 30           adc #$30                      ; 0-9: '0'=48; carry clear adds 0
001D4D  1  20 D2 FF        jsr CHROUT
001D50  1  60              rts
