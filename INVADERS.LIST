000000r 1               .segment "ZEROPAGE"
000000r 1               ; Zero Page variables ($22-$7F available)
000000r 1               
000000r 1  xx           key_last:       .res 1           ; most recent PETSCII key from GETIN ($00 = none)
000001r 1  xx           frame_count:    .res 1           ; wrapping frame counter (increments each VSYNC)
000002r 1  xx           rand_seed_lo:   .res 1           ; PRNG state - low byte
000003r 1  xx           rand_seed_hi:   .res 1           ; PRNG state - high byte
000004r 1  xx           player_x_lo:    .res 1           ; player X position, low byte  (VERA 640x480 space)
000005r 1  xx           player_x_hi:    .res 1           ; player X position, high byte (bits 1-0 only)
000006r 1  xx           key_flags:      .res 1           ; input flags this frame (see KEY_* constants)
000007r 1               
000007r 1               ; --- Invader grid state ---
000007r 1  xx           inv_grid_x_lo:  .res 1           ; invader grid left-column X, low byte (VERA coords)
000008r 1  xx           inv_grid_x_hi:  .res 1           ; invader grid left-column X, high byte
000009r 1  xx           inv_offset_y:   .res 1           ; cumulative Y drop applied to grid (VERA pixels)
00000Ar 1  xx           inv_direction:  .res 1           ; 0 = moving right, 1 = moving left
00000Br 1  xx xx xx xx  inv_alive:      .res 7           ; 55-bit alive bitmap; bit N = invader N alive
00000Fr 1  xx xx xx     
000012r 1  xx           inv_count:      .res 1           ; number of invaders still alive
000013r 1  xx           inv_move_timer: .res 1           ; frames until next march step
000014r 1  xx           inv_move_speed: .res 1           ; frames per march step (decreases as invaders die)
000015r 1  xx           inv_drop_flag:  .res 1           ; 1 = drop grid on next step instead of marching
000016r 1  xx           inv_anim_frame: .res 1           ; animation frame index: 0 or 1
000017r 1               
000017r 1               ; --- Scratch for invader sprite update loop ---
000017r 1  xx           zp_row:         .res 1
000018r 1  xx           zp_col:         .res 1
000019r 1  xx           zp_x_lo:        .res 1
00001Ar 1  xx           zp_x_hi:        .res 1
00001Br 1  xx           zp_y_base_lo:   .res 1           ; grid Y base + cumulative drop
00001Cr 1  xx           zp_y_base_hi:   .res 1
00001Dr 1  xx           zp_row_y_lo:    .res 1           ; row Y = y_base + row spacing offset
00001Er 1  xx           zp_row_y_hi:    .res 1
00001Fr 1  xx           zp_addr_b0:     .res 1           ; VERA sprite data addr[12:5] for current row+frame
000020r 1               
000020r 1               ;******************************************************************
000020r 1               .segment "ONCE"
000000r 1               .segment "CODE"
000000r 1               .org $080D
00080D  1               
00080D  1  4C 10 08        jmp start                     ; jump to main code routine
