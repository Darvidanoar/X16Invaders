0013C9  1  4C CC 08        jmp main_loop
0013CC  1               
0013CC  1               ;******************************************************************
0013CC  1               ; print_dec_byte — print .A as 1 or 2 decimal digits (values 0-99)
0013CC  1               ;   Suppresses leading zero for single-digit numbers.
0013CC  1               ;   Clobbers: A, X.  Carry is cleared on exit.
0013CC  1               ;******************************************************************
0013CC  1               print_dec_byte:
0013CC  1  A2 00           ldx #0
0013CE  1               @pdb_loop:
0013CE  1  C9 0A           cmp #10
0013D0  1  90 05           bcc @pdb_units            ; A < 10 → done dividing
0013D2  1  E8              inx
0013D3  1  E9 0A           sbc #10                   ; carry is set by cmp, so sbc = A - 10
0013D5  1  80 F7           bra @pdb_loop
0013D7  1               @pdb_units:
0013D7  1  48              pha                       ; save units digit
0013D8  1  8A              txa                       ; tens digit count
0013D9  1  F0 05           beq @pdb_skip_tens        ; zero → suppress leading zero
0013DB  1  69 30           adc #$30                  ; carry=0 here (from last bcc), so adc = X + $30
0013DD  1  20 D2 FF        jsr CHROUT
0013E0  1               @pdb_skip_tens:
0013E0  1  68              pla                       ; units digit (0-9; carry=0)
0013E1  1  69 30           adc #$30
0013E3  1  20 D2 FF        jsr CHROUT
0013E6  1  60              rts
0013E7  1               
0013E7  1               ;******************************************************************
0013E7  1               ; draw_score_labels — paint "SCORE" (row 0, col 0) and "HI-SCORE" (row 0, col 16)
0013E7  1               ; Called once after screen clear, before main_loop.
0013E7  1               ;******************************************************************
0013E7  1               draw_score_labels:
0013E7  1  A9 00           lda #0
0013E9  1  A0 00           ldy #0
0013EB  1  18              clc
0013EC  1  20 F0 FF        jsr PLOT
0013EF  1  A2 00           ldx #0
0013F1  1  BD C8 1B     @sl1: lda str_score_title, x
0013F4  1  F0 06           beq @sl1d
0013F6  1  20 D2 FF        jsr CHROUT
0013F9  1  E8              inx
0013FA  1  80 F5           bra @sl1
0013FC  1               @sl1d:
0013FC  1  A9 00           lda #0
0013FE  1  A0 10           ldy #16
001400  1  18              clc
001401  1  20 F0 FF        jsr PLOT
001404  1  A2 00           ldx #0
001406  1  BD CE 1B     @sl2: lda str_hi_score_lbl, x
001409  1  F0 06           beq @sl2d
00140B  1  20 D2 FF        jsr CHROUT
00140E  1  E8              inx
