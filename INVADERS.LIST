001397  1               ;******************************************************************
001397  1               ; next_wave — advance wave counter, reduce speed, reset grid, resume play
001397  1               ;   Keeps: player X, lives, score, shields.
001397  1               ;   Clears: bullets, invaders, explosion, UFO.
001397  1               ;******************************************************************
001397  1               next_wave:
001397  1  E6 rr           inc wave
001399  1               
001399  1                  ; new wave_init_speed = max(current - WAVE_SPEED_STEP, INV_MOVE_SPEED_MIN)
001399  1  A5 rr           lda wave_init_speed
00139B  1  38              sec
00139C  1  E9 05           sbc #WAVE_SPEED_STEP
00139E  1  C9 05           cmp #INV_MOVE_SPEED_MIN
0013A0  1  B0 02           bcs @speed_ok
0013A2  1  A9 05           lda #INV_MOVE_SPEED_MIN
0013A4  1               @speed_ok:
0013A4  1  85 rr           sta wave_init_speed
0013A6  1               
0013A6  1                  ; deactivate player bullet
0013A6  1  64 rr           stz bullet_active
0013A8  1  20 54 0E        jsr update_bullet_sprite
0013AB  1               
0013AB  1                  ; reset explosion
0013AB  1  64 rr           stz exp_timer
0013AD  1  9C 25 9F        stz VERA_ctrl
0013B0  1  A9 11 8D 22     VERA_SET_ADDR (EXPLODE_SPRITE_ATTR + 6), 1
0013B4  1  9F A9 FC 8D  
0013B8  1  21 9F A9 26  
0013BF  1  A9 00           lda #$00
0013C1  1  8D 23 9F        sta VERA_data0
0013C4  1               
0013C4  1                  ; deactivate invader bullets
0013C4  1  64 rr           stz ibul_active+0
0013C6  1  64 rr           stz ibul_active+1
0013C8  1  64 rr           stz ibul_active+2
0013CA  1  A2 00           ldx #0
0013CC  1               @nw_ibul:
