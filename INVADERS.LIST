001487  1               ;******************************************************************
001487  1               ; draw_title_screen — paint the title screen; called once before title_loop
001487  1               ;
001487  1               ;   Layout (40-col text, VERA Y=row*16):
001487  1               ;     Row  1, col 14: "X16 INVADERS"      (12 chars, centred)
001487  1               ;     Row  3, col 16: "HI-SCORE"          (8 chars, centred)
001487  1               ;     Row  4, col 17: 000000              (6-digit BCD hi-score)
001487  1               ;     Row  5, col  5: "?UFO? = ??? PTS"
001487  1               ;     Row  7, col  9: "= 30 PTS"          + Type C sprite at X=96,Y=112
001487  1               ;     Row 10, col  9: "= 20 PTS"          + Type B sprite at X=96,Y=160
001487  1               ;     Row 13, col  9: "= 10 PTS"          + Type A sprite at X=96,Y=208
001487  1               ;     Row 17, col 10: (PRESS SPACE TO START — blinked by title_loop)
001487  1               ;     Row 19, col 12: "Q TO QUIT"
001487  1               ;******************************************************************
001487  1               draw_title_screen:
001487  1                  ; Row 1, col 14: "X16 INVADERS"
001487  1  A2 02           ldx #2
001489  1  A0 22           ldy #34
00148B  1  18              clc
00148C  1  20 F0 FF        jsr PLOT
00148F  1  A2 00           ldx #0
001491  1  BD 26 1D     @lp1: lda str_title_main, x
001494  1  F0 06           beq @lp1_done
001496  1  20 D2 FF        jsr CHROUT
001499  1  E8              inx
00149A  1  80 F5           bra @lp1
00149C  1               @lp1_done:
00149C  1               
00149C  1                  ; Row 3, col 16: "HI-SCORE"
00149C  1  A2 01           ldx #1
00149E  1  A0 3F           ldy #63
0014A0  1  18              clc
0014A1  1  20 F0 FF        jsr PLOT
0014A4  1  A2 00           ldx #0
0014A6  1  BD 39 1D     @lp2: lda str_hi_score_lbl, x
0014A9  1  F0 06           beq @lp2_done
0014AB  1  20 D2 FF        jsr CHROUT
0014AE  1  E8              inx
0014AF  1  80 F5           bra @lp2
0014B1  1               @lp2_done:
0014B1  1               
0014B1  1                  ; Row 4, col 17: hi-score 6 BCD digits (000000 at start)
0014B1  1  A2 01           ldx #1
0014B3  1  A0 49           ldy #73
0014B5  1  18              clc
0014B6  1  20 F0 FF        jsr PLOT
0014B9  1  A5 rr           lda hi_score_hi
0014BB  1  20 07 1D        jsr print_hex_byte
0014BE  1  A5 rr           lda hi_score_mid
0014C0  1  20 07 1D        jsr print_hex_byte
0014C3  1  A5 rr           lda hi_score_lo
0014C5  1  20 07 1D        jsr print_hex_byte
0014C8  1               
0014C8  1                  ; Row 5, col 5: "?UFO? = ??? PTS"
0014C8  1  A2 09           ldx #9
0014CA  1  A0 09           ldy #9
0014CC  1  18              clc
0014CD  1  20 F0 FF        jsr PLOT
0014D0  1  A2 00           ldx #0
0014D2  1  BD 41 1D     @lp3: lda str_ufo_score, x
0014D5  1  F0 06           beq @lp3_done
0014D7  1  20 D2 FF        jsr CHROUT
0014DA  1  E8              inx
0014DB  1  80 F5           bra @lp3
0014DD  1               @lp3_done:
