00133E  1               ;******************************************************************
00133E  1               ; show_title_sprites — enable one sprite of each type at fixed
00133E  1               ;   title-screen positions and print score labels beside them.
00133E  1               ;
00133E  1               ;   In VERA 640x480 space, 1 text row/col = 16 VERA pixels.
00133E  1               ;   Sprites: X=96 (col 6), score labels at col 9.
00133E  1               ;   Sprite 11 (Type C): Y=112 → text row 7,  "= 30 PTS"
00133E  1               ;   Sprite 22 (Type B): Y=160 → text row 10, "= 20 PTS"
00133E  1               ;   Sprite 44 (Type A): Y=208 → text row 13, "= 10 PTS"
00133E  1               ;******************************************************************
00133E  1               show_title_sprites:
00133E  1  9C 25 9F        stz VERA_ctrl
001341  1                  ; --- sprite 11 (Type C, squid/cyan): attr $1FC00+11*8=$1FC58 ---
001341  1                  ; addr[12:5] = VRAM_INV_C_F0>>5 = $00300>>5 = $18
001341  1  A9 11           lda #$11               ; stride=1, bank=1
001343  1  8D 22 9F        sta VERA_addr_bank
001346  1  A9 FC           lda #$FC
001348  1  8D 21 9F        sta VERA_addr_high
00134B  1  A9 58           lda #$58               ; low byte of $1FC58
00134D  1  8D 20 9F        sta VERA_addr_low
001350  1  A9 18           lda #$18               ; byte 0: data addr[12:5]
001352  1  8D 23 9F        sta VERA_data0
001355  1  A9 00           lda #$00               ; byte 1: 4bpp, addr[16:13]=0
001357  1  8D 23 9F        sta VERA_data0
00135A  1  A9 60           lda #96                ; byte 2: X lo
00135C  1  8D 23 9F        sta VERA_data0
00135F  1  A9 00           lda #0                 ; byte 3: X hi
001361  1  8D 23 9F        sta VERA_data0
001364  1  A9 70           lda #112               ; byte 4: Y lo (row 7: 7*16=112)
001366  1  8D 23 9F        sta VERA_data0
001369  1  A9 00           lda #0                 ; byte 5: Y hi
00136B  1  8D 23 9F        sta VERA_data0
00136E  1  A9 0C           lda #SPR_Z_FRONT       ; byte 6: z-depth=3
001370  1  8D 23 9F        sta VERA_data0
001373  1  A9 50           lda #SPR_16x16_PAL0    ; byte 7: 16x16, palette 0
001375  1  8D 23 9F        sta VERA_data0
001378  1               
001378  1  A9 07           lda #7
00137A  1  A0 09           ldy #9
00137C  1  18              clc
00137D  1  20 F0 FF        jsr PLOT
001380  1  A2 00           ldx #0
001382  1  BD FB 19     @lp_c: lda str_score_c, x
001385  1  F0 06           beq @lp_c_done
001387  1  20 D2 FF        jsr CHROUT
00138A  1  E8              inx
00138B  1  80 F5           bra @lp_c
00138D  1               @lp_c_done:
00138D  1               
00138D  1                  ; --- sprite 22 (Type B, octopus/magenta): attr $1FC00+22*8=$1FCB0 ---
00138D  1                  ; addr[12:5] = VRAM_INV_B_F0>>5 = $00200>>5 = $10
00138D  1  A9 11           lda #$11
00138F  1  8D 22 9F        sta VERA_addr_bank
001392  1  A9 FC           lda #$FC
001394  1  8D 21 9F        sta VERA_addr_high
001397  1  A9 B0           lda #$B0               ; low byte of $1FCB0
001399  1  8D 20 9F        sta VERA_addr_low
00139C  1  A9 10           lda #$10               ; byte 0: addr[12:5]
00139E  1  8D 23 9F        sta VERA_data0
0013A1  1  A9 00           lda #$00
0013A3  1  8D 23 9F        sta VERA_data0
0013A6  1  A9 60           lda #96                ; X
0013A8  1  8D 23 9F        sta VERA_data0
0013AB  1  A9 00           lda #0
0013AD  1  8D 23 9F        sta VERA_data0
0013B0  1  A9 A0           lda #160               ; Y (row 10: 10*16=160)
0013B2  1  8D 23 9F        sta VERA_data0
0013B5  1  A9 00           lda #0
0013B7  1  8D 23 9F        sta VERA_data0
0013BA  1  A9 0C           lda #SPR_Z_FRONT
0013BC  1  8D 23 9F        sta VERA_data0
0013BF  1  A9 50           lda #SPR_16x16_PAL0
0013C1  1  8D 23 9F        sta VERA_data0
0013C4  1               
0013C4  1  A9 0A           lda #10
0013C6  1  A0 09           ldy #9
0013C8  1  18              clc
0013C9  1  20 F0 FF        jsr PLOT
0013CC  1  A2 00           ldx #0
0013CE  1  BD 04 1A     @lp_b: lda str_score_b, x
0013D1  1  F0 06           beq @lp_b_done
0013D3  1  20 D2 FF        jsr CHROUT
0013D6  1  E8              inx
0013D7  1  80 F5           bra @lp_b
0013D9  1               @lp_b_done:
0013D9  1               
0013D9  1                  ; --- sprite 44 (Type A, crab/green): attr $1FC00+44*8=$1FD60 ---
0013D9  1                  ; addr[12:5] = VRAM_INV_A_F0>>5 = $00100>>5 = $08
0013D9  1  A9 11           lda #$11
0013DB  1  8D 22 9F        sta VERA_addr_bank
0013DE  1  A9 FD           lda #$FD               ; high byte of $1FD60
0013E0  1  8D 21 9F        sta VERA_addr_high
0013E3  1  A9 60           lda #$60               ; low byte of $1FD60
0013E5  1  8D 20 9F        sta VERA_addr_low
0013E8  1  A9 08           lda #$08               ; byte 0: addr[12:5]
0013EA  1  8D 23 9F        sta VERA_data0
0013ED  1  A9 00           lda #$00
0013EF  1  8D 23 9F        sta VERA_data0
0013F2  1  A9 60           lda #96                ; X
0013F4  1  8D 23 9F        sta VERA_data0
0013F7  1  A9 00           lda #0
0013F9  1  8D 23 9F        sta VERA_data0
0013FC  1  A9 D0           lda #208               ; Y (row 13: 13*16=208)
0013FE  1  8D 23 9F        sta VERA_data0
001401  1  A9 00           lda #0
001403  1  8D 23 9F        sta VERA_data0
001406  1  A9 0C           lda #SPR_Z_FRONT
001408  1  8D 23 9F        sta VERA_data0
00140B  1  A9 50           lda #SPR_16x16_PAL0
00140D  1  8D 23 9F        sta VERA_data0
001410  1               
001410  1  A9 0D           lda #13
001412  1  A0 09           ldy #9
001414  1  18              clc
001415  1  20 F0 FF        jsr PLOT
001418  1  A2 00           ldx #0
00141A  1  BD 0D 1A     @lp_a: lda str_score_a, x
00141D  1  F0 06           beq @lp_a_done
00141F  1  20 D2 FF        jsr CHROUT
001422  1  E8              inx
001423  1  80 F5           bra @lp_a
001425  1               @lp_a_done:
001425  1               
001425  1  60              rts
001426  1               
001426  1               ;******************************************************************
001426  1               ; hide_all_inv_sprites — set z-depth=0 for all 55 invader sprites
001426  1               ;   Uses VERA stride=8 to write only byte 6 (z-depth) of each block.
001426  1               ;   First invader sprite byte 6: $1FC00 + 11*8 + 6 = $1FC5E
001426  1               ;******************************************************************
001426  1               hide_all_inv_sprites:
001426  1  9C 25 9F        stz VERA_ctrl
001429  1  A9 41           lda #$41               ; stride=8 (code $4 in high nibble), bank=1
00142B  1  8D 22 9F        sta VERA_addr_bank
00142E  1  A9 FC           lda #$FC
001430  1  8D 21 9F        sta VERA_addr_high
001433  1  A9 5E           lda #$5E               ; low byte of $1FC5E  ($1FC58+6)
001435  1  8D 20 9F        sta VERA_addr_low
001438  1  A9 00           lda #0                 ; z-depth=0 → disabled
00143A  1  A2 37           ldx #55
00143C  1               @loop:
00143C  1  8D 23 9F        sta VERA_data0         ; writes byte 6; addr auto-advances by 8
00143F  1  CA              dex
001440  1  D0 FA           bne @loop
001442  1  60              rts
001443  1               
001443  1               ;******************************************************************
001443  1               ; init_shields — upload 8 damage tiles, set palette entry 7 to dark
001443  1               ;   green, init shield_damage counters, write sprite attributes for
001443  1               ;   all 4 shields (slots 66–69, base $1FE10).
001443  1               ;
001443  1               ;   Sprite positions: X = shield_x_lo/hi[n], Y = SHIELD_Y (352)
001443  1               ;   Each shield sprite: 32x32, palette 0 (entry 7 = dark green).
001443  1               ;******************************************************************
001443  1               init_shields:
001443  1  9C 25 9F        stz VERA_ctrl
001446  1               
001446  1                  ; --- palette entry 7 → dark green (R=0, G=$A, B=0) ---
001446  1                  ; Palette byte 0: G[3:0] B[3:0] = $A0;  byte 1: R[3:0] = $00
001446  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_palette + 14), 1   ; entry 7 = offset 14 bytes
00144A  1  9F A9 FA 8D  
00144E  1  21 9F A9 0E  
001455  1  A9 A0           lda #$A0
001457  1  8D 23 9F        sta VERA_data0
00145A  1  A9 00           lda #$00
00145C  1  8D 23 9F        sta VERA_data0
00145F  1               
00145F  1                  ; --- upload shield_tile_full → $00500 (512 bytes: four 128-byte passes) ---
00145F  1  A9 10 8D 22     VERA_SET_ADDR VRAM_SHIELD_FULL, 1
001463  1  9F A9 05 8D  
001467  1  21 9F A9 00  
00146E  1  A2 80           ldx #128
001470  1  BD 56 1F     @up_s0a: lda shield_tile_full - 128, x
001473  1  8D 23 9F        sta VERA_data0
001476  1  E8              inx
001477  1  D0 F7           bne @up_s0a
001479  1  A2 80           ldx #128
00147B  1  BD D6 1F     @up_s0b: lda shield_tile_full, x
00147E  1  8D 23 9F        sta VERA_data0
001481  1  E8              inx
001482  1  D0 F7           bne @up_s0b
001484  1  A2 80           ldx #128
001486  1  BD 56 20     @up_s0c: lda shield_tile_full + 128, x
001489  1  8D 23 9F        sta VERA_data0
00148C  1  E8              inx
00148D  1  D0 F7           bne @up_s0c
00148F  1  A2 80           ldx #128
001491  1  BD D6 20     @up_s0d: lda shield_tile_full + 256, x
001494  1  8D 23 9F        sta VERA_data0
001497  1  E8              inx
001498  1  D0 F7           bne @up_s0d
00149A  1               
00149A  1                  ; --- upload shield_tile_dmg1 → $00700 ---
00149A  1  A9 10 8D 22     VERA_SET_ADDR VRAM_SHIELD_DMG1, 1
