0012E0  1               ;******************************************************************
0012E0  1               ; update_hi_score — copy score → hi_score when score > hi_score
0012E0  1               ;   BCD compare: check hi byte, then mid, then lo.
0012E0  1               ;******************************************************************
0012E0  1               update_hi_score:
0012E0  1  A5 rr           lda score_hi
0012E2  1  C5 rr           cmp hi_score_hi
0012E4  1  90 1E           bcc @no_update
0012E6  1  D0 10           bne @do_update
0012E8  1  A5 rr           lda score_mid
0012EA  1  C5 rr           cmp hi_score_mid
0012EC  1  90 16           bcc @no_update
0012EE  1  D0 08           bne @do_update
0012F0  1  A5 rr           lda score_lo
0012F2  1  C5 rr           cmp hi_score_lo
0012F4  1  90 0E           bcc @no_update
0012F6  1  F0 0C           beq @no_update            ; equal → no change
0012F8  1               @do_update:
0012F8  1  A5 rr           lda score_lo
0012FA  1  85 rr           sta hi_score_lo
0012FC  1  A5 rr           lda score_mid
0012FE  1  85 rr           sta hi_score_mid
001300  1  A5 rr           lda score_hi
001302  1  85 rr           sta hi_score_hi
001304  1               @no_update:
001304  1  60              rts
