001505  1               ;******************************************************************
001505  1               ; show_title_sprites — enable one sprite of each type at fixed
001505  1               ;   title-screen positions and print score labels beside them.
001505  1               ;
001505  1               ;   In VERA 640x480 space, 1 text row/col = 16 VERA pixels.
001505  1               ;   Sprites: X=96 (col 6), score labels at col 9.
001505  1               ;   Sprite 11 (Type C): Y=112 → text row 7,  "= 30 PTS"
001505  1               ;   Sprite 22 (Type B): Y=160 → text row 10, "= 20 PTS"
001505  1               ;   Sprite 44 (Type A): Y=208 → text row 13, "= 10 PTS"
001505  1               ;******************************************************************
001505  1               show_title_sprites:
001505  1  9C 25 9F        stz VERA_ctrl
001508  1                  ; --- sprite 11 (Type C, squid/cyan): attr $1FC00+11*8=$1FC58 ---
001508  1                  ; addr[12:5] = VRAM_INV_C_F0>>5 = $00300>>5 = $18
001508  1  A9 11           lda #$11               ; stride=1, bank=1
00150A  1  8D 22 9F        sta VERA_addr_bank
00150D  1  A9 FC           lda #$FC
00150F  1  8D 21 9F        sta VERA_addr_high
001512  1  A9 58           lda #$58               ; low byte of $1FC58
001514  1  8D 20 9F        sta VERA_addr_low
001517  1  A9 18           lda #$18               ; byte 0: data addr[12:5]
001519  1  8D 23 9F        sta VERA_data0
00151C  1  A9 00           lda #$00               ; byte 1: 4bpp, addr[16:13]=0
00151E  1  8D 23 9F        sta VERA_data0
001521  1  A9 60           lda #96                ; byte 2: X lo
001523  1  8D 23 9F        sta VERA_data0
001526  1  A9 00           lda #0                 ; byte 3: X hi
001528  1  8D 23 9F        sta VERA_data0
00152B  1  A9 70           lda #112               ; byte 4: Y lo (row 7: 7*16=112)
00152D  1  8D 23 9F        sta VERA_data0
001530  1  A9 00           lda #0                 ; byte 5: Y hi
001532  1  8D 23 9F        sta VERA_data0
001535  1  A9 0C           lda #SPR_Z_FRONT       ; byte 6: z-depth=3
001537  1  8D 23 9F        sta VERA_data0
00153A  1  A9 50           lda #SPR_16x16_PAL0    ; byte 7: 16x16, palette 0
00153C  1  8D 23 9F        sta VERA_data0
00153F  1               
00153F  1  A2 0F           ldx #15
001541  1  A0 0F           ldy #15
001543  1  18              clc
001544  1  20 F0 FF        jsr PLOT
001547  1  A2 00           ldx #0
001549  1  BD 7D 1D     @lp_c: lda str_score_c, x
