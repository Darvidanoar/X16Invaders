00144A  1               ;******************************************************************
00144A  1               ; print_dec_byte — print .A as 1 or 2 decimal digits (values 0-99)
00144A  1               ;   Suppresses leading zero for single-digit numbers.
00144A  1               ;   Clobbers: A, X.  Carry is cleared on exit.
00144A  1               ;******************************************************************
00144A  1               print_dec_byte:
00144A  1  A2 00           ldx #0
00144C  1               @pdb_loop:
00144C  1  C9 0A           cmp #10
00144E  1  90 05           bcc @pdb_units            ; A < 10 → done dividing
001450  1  E8              inx
001451  1  E9 0A           sbc #10                   ; carry is set by cmp, so sbc = A - 10
001453  1  80 F7           bra @pdb_loop
001455  1               @pdb_units:
001455  1  48              pha                       ; save units digit
001456  1  8A              txa                       ; tens digit count
001457  1  F0 05           beq @pdb_skip_tens        ; zero → suppress leading zero
001459  1  69 30           adc #$30                  ; carry=0 here (from last bcc), so adc = X + $30
00145B  1  20 D2 FF        jsr CHROUT
00145E  1               @pdb_skip_tens:
00145E  1  68              pla                       ; units digit (0-9; carry=0)
00145F  1  69 30           adc #$30
001461  1  20 D2 FF        jsr CHROUT
001464  1  60              rts
001465  1               
