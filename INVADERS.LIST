00139A  1  E8              inx
00139B  1  E0 03           cpx #3
00139D  1  D0 F8           bne @nw_ibul
00139F  1  A9 5A           lda #INV_FIRE_TIMER_INIT
0013A1  1  85 rr           sta inv_fire_timer
0013A3  1               
0013A3  1                  ; reset UFO timer (UFO already inactive from wave_clear_screen)
0013A3  1  A9 58           lda #<UFO_TIMER_INIT
0013A5  1  85 rr           sta ufo_timer_lo
0013A7  1  A9 02           lda #>UFO_TIMER_INIT
