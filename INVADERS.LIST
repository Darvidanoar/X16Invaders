00149E  1               ;******************************************************************
00149E  1               ; update_hud — rewrite dynamic values each frame
00149E  1               ;   Overwrites fixed screen positions; no full redraw needed
00149E  1               ;******************************************************************
00149E  1               update_hud:
00149E  1                  ; Frame counter at row 19, col 2
00149E  1  A9 13           lda #19
0014A0  1  A0 02           ldy #2
0014A2  1  18              clc
0014A3  1  20 F0 FF        jsr PLOT
0014A6  1  A2 00           ldx #0
0014A8  1  BD 5E 15     @fc_lbl: lda str_frame_lbl,x
0014AB  1  F0 06           beq @fc_val
0014AD  1  20 D2 FF        jsr CHROUT
0014B0  1  E8              inx
0014B1  1  80 F5           bra @fc_lbl
0014B3  1               @fc_val:
0014B3  1  A5 rr           lda frame_count
0014B5  1  20 D8 14        jsr print_hex_byte
0014B8  1               
0014B8  1                  ; Last key at row 21, col 2
0014B8  1  A9 15           lda #21
0014BA  1  A0 02           ldy #2
0014BC  1  18              clc
0014BD  1  20 F0 FF        jsr PLOT
0014C0  1  A2 00           ldx #0
0014C2  1  BD 6A 15     @kl_lbl: lda str_key_lbl,x
0014C5  1  F0 06           beq @kl_val
0014C7  1  20 D2 FF        jsr CHROUT
0014CA  1  E8              inx
0014CB  1  80 F5           bra @kl_lbl
0014CD  1               @kl_val:
0014CD  1  A5 rr           lda key_last
0014CF  1  20 D8 14        jsr print_hex_byte
0014D2  1  A9 20           lda #' '
0014D4  1  20 D2 FF        jsr CHROUT                    ; erase stale digit if value shrank
0014D7  1               
0014D7  1  60              rts
0014D8  1               
0014D8  1               ;******************************************************************
0014D8  1               ; print_hex_byte — print .A as two uppercase hex digits via CHROUT
0014D8  1               ;******************************************************************
0014D8  1               print_hex_byte:
0014D8  1  48              pha
0014D9  1  4A              lsr                           ; shift high nibble down
0014DA  1  4A              lsr
0014DB  1  4A              lsr
0014DC  1  4A              lsr
0014DD  1  20 E7 14        jsr print_hex_nybble
0014E0  1  68              pla
0014E1  1  29 0F           and #$0F                      ; isolate low nibble
0014E3  1  20 E7 14        jsr print_hex_nybble
0014E6  1  60              rts
0014E7  1               
0014E7  1               ; print_hex_nybble — print lower 4 bits of .A as one hex digit
0014E7  1               ;   Relies on carry state from CMP to select digit vs. letter range
0014E7  1               print_hex_nybble:
0014E7  1  C9 0A           cmp #10
0014E9  1  90 06           bcc @digit                    ; carry clear → 0-9
0014EB  1  69 36           adc #($41 - 10 - 1)          ; A-F: 'A'=65; carry set adds 1
0014ED  1  20 D2 FF        jsr CHROUT
0014F0  1  60              rts
0014F1  1               @digit:
0014F1  1  69 30           adc #$30                      ; 0-9: '0'=48; carry clear adds 0
0014F3  1  20 D2 FF        jsr CHROUT
0014F6  1  60              rts
