001D07  1               ;******************************************************************
001D07  1               ; print_hex_byte — print .A as two uppercase hex digits via CHROUT
001D07  1               ;******************************************************************
001D07  1               print_hex_byte:
001D07  1  48              pha
001D08  1  4A              lsr                           ; shift high nibble down
001D09  1  4A              lsr
001D0A  1  4A              lsr
001D0B  1  4A              lsr
001D0C  1  20 16 1D        jsr print_hex_nybble
001D0F  1  68              pla
001D10  1  29 0F           and #$0F                      ; isolate low nibble
001D12  1  20 16 1D        jsr print_hex_nybble
001D15  1  60              rts
001D16  1               
001D16  1               ; print_hex_nybble — print lower 4 bits of .A as one hex digit
001D16  1               ;   Relies on carry state from CMP to select digit vs. letter range
001D16  1               print_hex_nybble:
001D16  1  C9 0A           cmp #10
001D18  1  90 06           bcc @digit                    ; carry clear → 0-9
001D1A  1  69 36           adc #($41 - 10 - 1)          ; A-F: 'A'=65; carry set adds 1
001D1C  1  20 D2 FF        jsr CHROUT
001D1F  1  60              rts
001D20  1               @digit:
001D20  1  69 30           adc #$30                      ; 0-9: '0'=48; carry clear adds 0
001D22  1  20 D2 FF        jsr CHROUT
001D25  1  60              rts
