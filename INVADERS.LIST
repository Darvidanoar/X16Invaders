00181F  1  8D 22 9F        sta VERA_addr_bank
001822  1  A9 FE           lda #$FE
001824  1  8D 21 9F        sta VERA_addr_high
001827  1  A9 10           lda #$10               ; low byte of $1FE10
001829  1  8D 20 9F        sta VERA_addr_low
00182C  1               
00182C  1  A2 00           ldx #0
00182E  1               @spr_init:
00182E  1  A9 28           lda #$28               ; byte 0: addr[12:5] = VRAM_SHIELD_FULL>>5 = $00500>>5 = $28
001830  1  8D 23 9F        sta VERA_data0
001833  1  A9 00           lda #$00               ; byte 1: 4bpp, addr[16:13]=0
001835  1  8D 23 9F        sta VERA_data0
001838  1  BD 3C 1F        lda shield_x_lo, x     ; byte 2: X lo
00183B  1  8D 23 9F        sta VERA_data0
