001A5B  1  D2 D5 CE 2F     .byte "RUN/STOP TO QUIT", 0
001A5F  1  D3 D4 CF D0  
001A63  1  20 D4 CF 20  
001A6C  1               str_frame_lbl:
001A6C  1  C6 D2 C1 CD     .byte "FRAME   : $", 0
001A70  1  C5 20 20 20  
001A74  1  3A 20 24 00  
