001C89  1               ;******************************************************************
001C89  1               ; player_spr_data — 16x16 4bpp sprite, 128 bytes
001C89  1               ;
001C89  1               ;   Color 0 = transparent, Color 1 = white (default palette index 1)
001C89  1               ;   Design: classic upward-pointing triangular ship with engine notches
001C89  1               ;
001C89  1               ;   Each byte encodes 2 pixels: high nibble = left, low nibble = right
001C89  1               ;   Columns: 0123456789ABCDEF
001C89  1               ;
001C89  1               ;   Row  0:  .......1........   cannon tip
001C89  1               ;   Row  1:  .......11.......
001C89  1               ;   Row  2:  ......111.......
001C89  1               ;   Row  3:  ......111.......
001C89  1               ;   Row  4:  .....11111......
001C89  1               ;   Row  5:  .....1111111....
001C89  1               ;   Row  6:  ...111111111....
001C89  1               ;   Row  7:  ..11111111111...
001C89  1               ;   Row  8:  .1111111111111..
001C89  1               ;   Row  9:  1111111111111111   full base
001C89  1               ;   Row 10:  1111111111111111
001C89  1               ;   Row 11:  1111111111111111
001C89  1               ;   Row 12:  11..11111111..11   engine notches
001C89  1               ;   Row 13:  11..11111111..11
001C89  1               ;   Row 14:  ................
001C89  1               ;   Row 15:  ................
001C89  1               ;******************************************************************
001C89  1               player_spr_data:
001C89  1                  ; row 0
001C89  1  00 00 00 00     .byte $00,$00,$00,$00,$00,$00,$00,$00
001C8D  1  00 00 00 00  
001C91  1                  ; row 1
001C91  1  00 00 00 01     .byte $00,$00,$00,$01,$10,$00,$00,$00
001C95  1  10 00 00 00  
001C99  1                  ; row 2
001C99  1  00 00 00 01     .byte $00,$00,$00,$01,$10,$00,$00,$00
001C9D  1  10 00 00 00  
001CA1  1                  ; row 3
001CA1  1  00 00 00 01     .byte $00,$00,$00,$01,$10,$00,$00,$00
001CA5  1  10 00 00 00  
001CA9  1                  ; row 4
001CA9  1  00 00 01 11     .byte $00,$00,$01,$11,$11,$10,$00,$00
001CAD  1  11 10 00 00  
001CB1  1                  ; row 5
001CB1  1  00 00 11 11     .byte $00,$00,$11,$11,$11,$11,$00,$00
001CB5  1  11 11 00 00  
001CB9  1                  ; row 6
001CB9  1  00 01 11 11     .byte $00,$01,$11,$11,$11,$11,$10,$00
001CBD  1  11 11 10 00  
001CC1  1                  ; row 7
001CC1  1  00 01 11 11     .byte $00,$01,$11,$11,$11,$11,$10,$00
001CC5  1  11 11 10 00  
001CC9  1                  ; row 8
001CC9  1  01 11 11 11     .byte $01,$11,$11,$11,$11,$11,$11,$10
001CCD  1  11 11 11 10  
001CD1  1                  ; row 9
001CD1  1  11 11 11 11     .byte $11,$11,$11,$11,$11,$11,$11,$11
001CD5  1  11 11 11 11  
001CD9  1                  ; row 10
001CD9  1  11 11 11 11     .byte $11,$11,$11,$11,$11,$11,$11,$11
001CDD  1  11 11 11 11  
001CE1  1                  ; row 11
001CE1  1  11 11 11 11     .byte $11,$11,$11,$11,$11,$11,$11,$11
001CE5  1  11 11 11 11  
001CE9  1                  ; row 12  (engine notches: cols 2-3 and 12-13 transparent)
001CE9  1  11 00 11 11     .byte $11,$00,$11,$11,$11,$11,$00,$11
001CED  1  11 11 00 11  
001CF1  1                  ; row 13
001CF1  1  11 00 11 11     .byte $11,$00,$11,$11,$11,$11,$00,$11
001CF5  1  11 11 00 11  
001CF9  1                  ; row 14
001CF9  1  00 00 00 00     .byte $00,$00,$00,$00,$00,$00,$00,$00
001CFD  1  00 00 00 00  
001D01  1                  ; row 15
001D01  1  00 00 00 00     .byte $00,$00,$00,$00,$00,$00,$00,$00
001D05  1  00 00 00 00  
001D09  1               
001D09  1               ;******************************************************************
001D09  1               ; bullet_spr_data — 8x8 4bpp, 32 bytes
001D09  1               ;
001D09  1               ;   Color 0 = transparent, Color 1 = white
001D09  1               ;   Design: 2-pixel-wide vertical bar, centered in 8px columns 3-4
001D09  1               ;
001D09  1               ;   Each byte encodes 2 pixels: high nibble = left, low nibble = right
001D09  1               ;   Columns:  0 1 | 2 3 | 4 5 | 6 7
001D09  1               ;   Pattern:  . . | . 1 | 1 . | . .   → $00 $01 $10 $00
001D09  1               ;   All 8 rows identical.
001D09  1               ;******************************************************************
001D09  1               bullet_spr_data:
001D09  1  00 01 10 00     .byte $00,$01,$10,$00  ; row 0
001D0D  1  00 01 10 00     .byte $00,$01,$10,$00  ; row 1
001D11  1  00 01 10 00     .byte $00,$01,$10,$00  ; row 2
001D15  1  00 01 10 00     .byte $00,$01,$10,$00  ; row 3
001D19  1  00 01 10 00     .byte $00,$01,$10,$00  ; row 4
