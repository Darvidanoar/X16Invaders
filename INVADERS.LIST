001626  1               ;******************************************************************
001626  1               ; init_shields — upload 8 damage tiles, set palette entry 7 to dark
001626  1               ;   green, init shield_damage counters, write sprite attributes for
001626  1               ;   all 4 shields (slots 66–69, base $1FE10).
001626  1               ;
001626  1               ;   Sprite positions: X = shield_x_lo/hi[n], Y = SHIELD_Y (352)
001626  1               ;   Each shield sprite: 32x32, palette 0 (entry 7 = dark green).
001626  1               ;******************************************************************
001626  1               init_shields:
001626  1  9C 25 9F        stz VERA_ctrl
001629  1               
001629  1                  ; --- palette entry 7 → dark green (R=0, G=$A, B=0) ---
001629  1                  ; Palette byte 0: G[3:0] B[3:0] = $A0;  byte 1: R[3:0] = $00
001629  1  A9 11 8D 22     VERA_SET_ADDR (VRAM_palette + 14), 1   ; entry 7 = offset 14 bytes
00162D  1  9F A9 FA 8D  
001631  1  21 9F A9 0E  
001638  1  A9 A0           lda #$A0
00163A  1  8D 23 9F        sta VERA_data0
00163D  1  A9 00           lda #$00
00163F  1  8D 23 9F        sta VERA_data0
001642  1               
001642  1                  ; --- upload shield_tile_full → $00500 (512 bytes: four 128-byte passes) ---
001642  1  A9 10 8D 22     VERA_SET_ADDR VRAM_SHIELD_FULL, 1
001646  1  9F A9 05 8D  
00164A  1  21 9F A9 00  
001651  1  A2 80           ldx #128
001653  1  BD F1 22     @up_s0a: lda shield_tile_full - 128, x
001656  1  8D 23 9F        sta VERA_data0
001659  1  E8              inx
00165A  1  D0 F7           bne @up_s0a
00165C  1  A2 80           ldx #128
00165E  1  BD 71 23     @up_s0b: lda shield_tile_full, x
001661  1  8D 23 9F        sta VERA_data0
001664  1  E8              inx
001665  1  D0 F7           bne @up_s0b
001667  1  A2 80           ldx #128
001669  1  BD F1 23     @up_s0c: lda shield_tile_full + 128, x
00166C  1  8D 23 9F        sta VERA_data0
00166F  1  E8              inx
001670  1  D0 F7           bne @up_s0c
001672  1  A2 80           ldx #128
001674  1  BD 71 24     @up_s0d: lda shield_tile_full + 256, x
001677  1  8D 23 9F        sta VERA_data0
00167A  1  E8              inx
00167B  1  D0 F7           bne @up_s0d
00167D  1               
00167D  1                  ; --- upload shield_tile_dmg1 → $00700 ---
